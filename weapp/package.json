{
  "name": "ll-miniapp",
  "version": "1.0.0",
  "description": "LocalLife Mini Program",
  "main": "miniprogram/app.ts",
  "scripts": {
    "compile": "tsc",
    "lint": "eslint miniprogram --ext .ts",
    "lint:fix": "eslint miniprogram --ext .ts --fix",
    "lint:all": "eslint miniprogram --ext .ts -f stylish",
    "gate:page-shell": "node scripts/check-page-shell.js",
    "gate:component-policy": "node scripts/check-component-policy.js",
    "gate:request-boundary": "node scripts/check-request-boundary.js",
    "gate:role-contract": "node scripts/check-role-contract.js",
    "gate:business-status-boundary": "node scripts/check-business-status-boundary.js",
    "gate:weapp": "npm run gate:page-shell && npm run gate:component-policy && npm run gate:request-boundary && npm run gate:role-contract && npm run gate:business-status-boundary",
    "quality:check": "npm run lint:all && npm run compile && npm run gate:weapp"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dayjs": "^1.11.10",
    "prettier": "^3.7.4",
    "tdesign-miniprogram": "^1.11.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "miniprogram-api-typings": "^4.1.1",
    "typescript": "~5.3.3"
  }
}
