<view class="custom-navbar" style="height: {{navBarHeight}}px;">
  <!-- Status Bar Spacer -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <!-- Navigation Bar Content -->
  <view class="nav-bar" style="height: {{navBarContentHeight}}px;">
    <!-- Left: Back Button or Location -->
    <view class="nav-left">
      <view wx:if="{{showBack}}" class="back-button" bindtap="onBackTap">
        <image class="back-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{innerShowHome}}" class="home-button" bindtap="onHomeTap">
        <image class="home-icon" src="/assets/icons/home.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{!showBack && !innerShowHome && showLocation}}" class="location-wrapper" bindtap="onLocationTap">
        <text class="location-icon">📍</text>
        <text class="location-text {{displayLocation.length > 6 ? 'scroll' : ''}}">{{displayLocation || '点此获取位置'}}</text>
      </view>
    </view>
    
    <!-- Center: Title -->
    <view class="nav-center">
      <text class="nav-title">{{title}}</text>
    </view>
    
    <!-- Right: Capsule Placeholder -->
    <view class="nav-right" style="width: {{capsuleWidth}}px;"></view>
  </view>
</view>
