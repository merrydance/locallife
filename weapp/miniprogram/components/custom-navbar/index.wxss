/* 自定义导航栏 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: var(--brand-coral-gradient);
  box-shadow: var(--shadow-sm);
}

.status-bar {
  width: 100%;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacer-md);
  gap: var(--spacer-xs);
}

.nav-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

/* 返回按钮 - 使用 flexbox 完美居中 */
.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-round);
  background: rgba(255, 255, 255, 0.35);
  transition: var(--transition-base);
}

.back-button:active {
  background-color: rgba(255, 255, 255, 0.2);
}

/* 返回图标 - 使用图片确保完美居中 */
.back-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 首页按钮 */
.home-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-round);
  background: rgba(255, 255, 255, 0.35);
  transition: var(--transition-base);
}

.home-button:active {
  background-color: rgba(255, 255, 255, 0.2);
}

.home-icon {
  width: 32rpx;
  height: 32rpx;
}

.location-wrapper {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  max-width: 200rpx;
  overflow: hidden;
}

.location-icon {
  display: none;
}

.location-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-anti);
  white-space: nowrap;
}

.location-text.scroll {
  animation: scroll-text 8s linear infinite;
}

@keyframes scroll-text {
  0% { transform: translateX(0); }
  50% { transform: translateX(-50%); }
  100% { transform: translateX(0); }
}

.nav-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-anti);
}

.nav-right {
  flex-shrink: 0;
}
