<view class="cart-bar-placeholder {{dockBottom ? 'dock-bottom' : ''}}" wx:if="{{alwaysShow || totalCount > 0}}"></view>
<view class="cart-bar {{(alwaysShow || totalCount > 0) ? 'show' : ''}} {{dockBottom ? 'dock-bottom' : ''}} {{totalCount > 0 ? 'active' : ''}}">
  <view class="cart-icon-wrapper" bindtap="onCartClick">
    <view class="cart-icon">
      <t-icon name="cart" size="60rpx" color="var(--td-brand-color)" />
    </view>
    <view class="badge {{isBouncing ? 'bounce' : ''}}" wx:if="{{totalCount > 0}}">{{totalCount}}</view>
  </view>
  
  <view class="cart-info" bindtap="onCartClick">
    <view class="price-info">
      <text class="currency">¥</text>
      <text class="total-price">{{computedPriceDisplay}}</text>
    </view>
    <view class="delivery-tip" wx:if="{{feeTip}}">{{feeTip}}</view>
    <view class="delivery-tip" wx:elif="{{!hideFee}}">{{computedDeliveryDisplay ? '预估代取费 ¥' + computedDeliveryDisplay : '结算时计算代取费'}}</view>
    <view class="delivery-tip" wx:elif="{{hideFee}}">点击查看购物车</view>
  </view>
  
  <view class="checkout-btn {{totalCount > 0 ? 'active' : ''}}" hover-class="{{totalCount > 0 ? 'checkout-hover' : ''}}" bindtap="onCheckout">
    去下单
  </view>
</view>
