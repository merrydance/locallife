:host {
  display: block;
}

.promo-center {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 20rpx 0;
}

/* 规则列表 */
.rules-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rule-badge {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-anti);
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: var(--radius-sm);
  text-align: center;
  flex-shrink: 0;
}
.rule-badge.discount { background: var(--td-error-color); }
.rule-badge.delivery { background: var(--td-success-color); }

.rule-text {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
}

/* 优惠券小列 */
.vouchers-section {
  margin-bottom: 24rpx;
}

.v-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.v-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.v-item {
  display: flex;
  align-items: center;
  background: #FFF5F5;
  border: 1rpx solid #FFD1D1;
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  gap: 12rpx;
}

.v-val {
  font-size: 32rpx;
  font-weight: bold;
  color: #E34D59;
}

.v-btn {
  font-size: 22rpx;
  background: #E34D59;
  color: #fff;
  padding: 0 8rpx;
  border-radius: 4rpx;
}

/* 充值区域 */
.recharge-section {
  border-top: 2rpx solid #f5f5f5;
  padding-top: 24rpx;
}

.recharge-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.r-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.recharge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.recharge-box {
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recharge-box.active {
  border-color: #FF6B00;
  background: #FFF9F5;
}

.rb-main {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.rb-sub {
  font-size: 22rpx;
  color: #FF6B00;
}

.pay-btn {
  margin-top: 10rpx;
}
