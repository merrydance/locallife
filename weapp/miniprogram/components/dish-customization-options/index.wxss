.option-editor {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.option-editor__row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.option-editor__input {
  min-width: 0;
}

.option-editor__input--name {
  flex: 1;
}

.option-editor__input--price {
  width: 176rpx;
  flex-shrink: 0;
}

.option-editor__actions {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  flex-shrink: 0;
  padding: 8rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.option-editor__action-button {
  opacity: 0.92;
}

.option-editor__action-button--remove {
  opacity: 0.82;
}