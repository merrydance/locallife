.option-editor {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.option-editor__row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.option-editor__input {
  min-width: 0;
}

.option-editor__input--name {
  flex: 1;
}

.option-editor__input--price {
  width: 176rpx;
  flex-shrink: 0;
}

.option-editor__actions {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  flex-shrink: 0;
}