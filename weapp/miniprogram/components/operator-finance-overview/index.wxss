.finance-section {
  padding: 24rpx 0;
}

.finance-card {
  background: linear-gradient(135deg, #ff6b58 0%, #ff8d7f 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  color: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(255, 107, 88, 0.3);
  position: relative;
  overflow: hidden;
}

.finance-card::after {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 100rpx;
  pointer-events: none;
}

.finance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.balance-title {
  font-size: var(--font-size-sm);
  opacity: 0.9;
}

.region-pill {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 100rpx;
  padding: 6rpx 18rpx;
  max-width: 240rpx;
}

.region-pill--static {
  background: rgba(255, 255, 255, 0.1);
}

.region-pill-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 150rpx;
}

.balance-value {
  font-size: 72rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  font-family: 'DIN Alternate', sans-serif;
}

.income-row {
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  border-radius: 20rpx;
}

.income-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.income-label {
  font-size: var(--font-size-xxs);
  opacity: 0.8;
  margin-bottom: 4rpx;
}

.income-value {
  font-size: var(--font-size-base);
  font-weight: 600;
}

.divider-v {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 32rpx;
}

.finance-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.finance-link-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 24rpx;
}