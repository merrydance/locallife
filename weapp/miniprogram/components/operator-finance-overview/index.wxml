<view class="finance-section">
  <view class="finance-card">
    <view class="finance-header">
      <view class="balance-title">收入概览</view>
      <view wx:if="{{regions.length > 1}}" class="region-pill" bind:tap="onRegionTap">
        <t-icon name="map" size="26rpx" color="var(--td-brand-color)" />
        <text class="region-pill-name">{{regions[selectedRegionIdx].name}}</text>
        <t-icon name="chevron-down" size="22rpx" color="var(--td-brand-color)" />
      </view>
      <view wx:elif="{{regions.length === 1}}" class="region-pill region-pill--static">
        <t-icon name="map" size="26rpx" color="var(--td-text-color-secondary)" />
        <text class="region-pill-name">{{regions[0].name}}</text>
      </view>
    </view>

    <view class="balance-value">{{totalIncomeDisplay}}</view>

    <view class="income-row">
      <view class="income-item">
        <text class="income-label">今日收入</text>
        <text class="income-value">+{{todayIncomeDisplay}}</text>
      </view>
      <view class="divider-v"></view>
      <view class="income-item">
        <text class="income-label">本月收入</text>
        <text class="income-value">{{currentMonthIncomeDisplay}}</text>
      </view>
    </view>

    <view class="finance-actions">
      <view class="finance-link-pill" bind:tap="onFinanceTap">查看财务概览</view>
    </view>
  </view>
</view>
