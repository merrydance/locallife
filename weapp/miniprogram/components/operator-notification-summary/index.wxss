.notification-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-top: 32rpx;
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: #333;
}

.view-all {
  font-size: 24rpx;
  color: var(--td-brand-color);
}

.notification-card {
  background: linear-gradient(135deg, #fff7e6 0%, #ffffff 100%);
  border: 1px solid rgba(237, 108, 2, 0.12);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 32rpx rgba(237, 108, 2, 0.08);
}

.notification-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.notification-card__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(237, 108, 2, 0.12);
  color: #b45309;
  font-size: 24rpx;
  font-weight: 600;
}

.notification-card__time {
  color: #8c8c8c;
  font-size: 24rpx;
}

.notification-card__title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.notification-card__summary {
  margin-top: 12rpx;
  color: #5f6368;
  font-size: 26rpx;
  line-height: 1.6;
}