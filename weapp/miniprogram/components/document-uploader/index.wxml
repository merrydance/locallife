<view class="uploader-container {{disabled ? 'disabled' : ''}} {{feedbackState !== 'idle' ? 'has-feedback' : ''}}" bind:tap="onUpload">
  <!-- Corner Markers (Decoration) -->
  <view class="corner corner-tl"></view>
  <view class="corner corner-tr"></view>
  <view class="corner corner-bl"></view>
  <view class="corner corner-br"></view>

  <!-- Content -->
  <view class="content">
    <!-- 1. Has Image -->
    <block wx:if="{{displayValue}}">
      <image class="preview-image" src="{{displayValue}}" mode="aspectFill" catch:tap="onPreview" binderror="onImageError" />
      <view class="remove-btn" catch:tap="onRemove" wx:if="{{!disabled}}">
        <t-icon name="close" size="32rpx" color="#fff" />
      </view>
    </block>
    
    <!-- 2. Loading -->
    <view class="loading-state" wx:elif="{{uploading}}">
      <t-loading theme="circular" size="48rpx" text="上传中..." />
    </view>

    <!-- 3. Placeholder (Empty) -->
    <view class="placeholder-state" wx:else>
      <!-- ID Front -->
      <view class="icon-wrapper" wx:if="{{type === 'id-front'}}">
        <t-icon name="user" size="80rpx" color="#B5C4D8" />
        <div class="icon-deco-lines"></div>
      </view>

      <!-- ID Back -->
      <view class="icon-wrapper" wx:elif="{{type === 'id-back'}}">
         <t-icon name="certificate" size="80rpx" color="#B5C4D8" />
      </view>

       <!-- License / Permit -->
      <view class="icon-wrapper" wx:elif="{{type === 'license' || type === 'permit'}}">
         <t-icon name="file-certificate" size="80rpx" color="#B5C4D8" />
      </view>

      <!-- Shop -->
      <view class="icon-wrapper" wx:elif="{{type === 'shop'}}">
         <t-icon name="shop" size="80rpx" color="#B5C4D8" />
      </view>

      <!-- Default -->
      <t-icon wx:else name="add" size="64rpx" color="#B5C4D8" />

      <text class="placeholder-text">{{title || '点击上传'}}</text>
    </view>
  </view>

  <view class="feedback-panel feedback-{{feedbackState}}" wx:if="{{feedbackTitle || feedbackDescription}}">
    <view class="feedback-icon">
      <t-loading wx:if="{{feedbackState === 'processing'}}" theme="circular" size="28rpx" />
      <t-icon wx:elif="{{feedbackState === 'success'}}" name="check-circle-filled" size="32rpx" color="#2BA471" />
      <t-icon wx:elif="{{feedbackState === 'error'}}" name="error-circle-filled" size="32rpx" color="#D54941" />
      <t-icon wx:else name="info-circle-filled" size="32rpx" color="#0052D9" />
    </view>
    <view class="feedback-copy">
      <text class="feedback-title feedback-title-{{feedbackState}}">{{feedbackTitle}}</text>
      <text wx:if="{{feedbackDescription}}" class="feedback-desc">{{feedbackDescription}}</text>
    </view>
  </view>
</view>
