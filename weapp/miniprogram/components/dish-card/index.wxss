/* 菜品卡片 - 深度适配 Design System */

.dish-card {
  display: flex;
  gap: var(--spacer-md); /* 24rpx */
  padding: var(--customer-card-padding); /* 24rpx */
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg); /* 16rpx */
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.dish-card:active {
  background: var(--td-bg-color-secondarycontainer);
  transform: scale(0.995);
}

.dish-image {
  width: var(--customer-image-size); /* 180rpx */
  height: var(--customer-image-size);
  border-radius: var(--customer-image-radius); /* 12rpx */
  flex-shrink: 0;
  background-color: var(--td-bg-color-secondarycontainer); /* 图片加载前的占位色 */
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs); /* 8rpx - 紧凑间距 */
  min-width: 0;
  justify-content: space-between;
  padding-bottom: 4rpx; /* 微调对齐 */
}

/* 行布局通用 */
.row-1, .row-2, .row-3, .row-4, .row-5 {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

/* 第1行: 标题 */
.row-1 {
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.shop-dish-name {
  flex: 1;
  font-size: var(--font-size-base); /* 28rpx */
  font-weight: 600; /* 加粗 */
  color: var(--td-text-color-primary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2; /* 允许两行 */
  -webkit-box-orient: vertical;
}

/* 第2行: 价格与销量 */
.row-2 {
  gap: var(--spacer-xs);
  margin-top: 4rpx;
}

.price {
  font-size: var(--font-size-heading); /* 32rpx - 突出价格 */
  font-weight: 700;
  color: var(--td-brand-color);
  line-height: 1;
  display: flex;
  align-items: baseline;
}

/* 价格符号 */
.price::before {
  content: '¥';
  font-size: var(--font-size-xs);
  margin-right: 2rpx;
  font-weight: 500;
}

.separator {
  color: var(--td-text-color-disabled);
  margin: 0 8rpx;
  font-size: 20rpx;
}

.sales {
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs); /* 24rpx */
}

/* 第3行: 距离时间 */
.row-3 {
  gap: var(--spacer-sm);
}

.distance, .delivery-time {
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-xs); /* 24rpx */
}

/* 第4/5行: 标签组 */
.row-4, .row-5 {
  gap: var(--spacer-xs);
  margin-top: 4rpx;
}

/* 加购按钮区域 - Flex贴底 */
.add-btn-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: var(--spacer-xs);
}

/* 调整信息区域 */
.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
  min-width: 0;
  justify-content: space-between;
}
