/* 菜品卡片 - 使用 TDesign 组件，简化自定义样式 */

.dish-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dish-card:active {
  background: #f5f5f5;
}

.dish-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.row-1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.row-2, .row-3, .row-4, .row-5 {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.shop-dish-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price {
  font-size: 28rpx;
  font-weight: bold;
  color: #fa5151;
}

.separator {
  color: #ddd;
  margin: 0 4rpx;
}

.sales {
  color: #666;
  font-size: 24rpx;
}

.distance, .delivery-time {
  color: #999;
  font-size: 22rpx;
}

.add-btn-wrapper {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
}
