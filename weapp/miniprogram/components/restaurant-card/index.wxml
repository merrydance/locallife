<view class="restaurant-card" bindtap="onTap">
  <t-image class="restaurant-image" src="{{restaurant.imageUrl}}" mode="aspectFill" lazy />
  
  <view class="restaurant-info">
    <!-- 第1行: 餐厅名 + 休息中标签 -->
    <view class="row-1">
      <text class="restaurant-name">{{restaurant.name}}</text>
      <t-tag wx:if="{{restaurant.isOpen === false}}" class="merchant-tag" theme="default" size="small" variant="light" shape="round">休息中</t-tag>
    </view>

    
    <!-- 第2行: 菜系 | 人均 | 距离 -->
    <view class="row-2">
      <text class="cuisine">{{restaurant.cuisineType[0] || '美食'}}</text>
      <text class="separator">|</text>
      <text class="avg-price">{{restaurant.avgPriceDisplay || '人均未知'}}</text>
      <text class="separator">|</text>
      <text class="distance">{{restaurant.distance}}</text>
    </view>
    
    <!-- 第3行: 配送费 + 月售 -->
    <view class="row-3">
      <text wx:if="{{restaurant.deliveryFeeDisplay}}" class="delivery-fee">{{restaurant.deliveryFeeDisplay}}</text>
      <text wx:if="{{restaurant.monthlySales > 0}}" class="monthly-sales">月售{{restaurant.monthlySales}}</text>
    </view>

    <!-- 第4行: 促销/运费补贴 -->
    <view class="row-4" wx:if="{{restaurant.promoText || restaurant.subsidyText}}">
      <t-tag wx:if="{{restaurant.promoText}}" class="merchant-tag" size="small" variant="light" theme="default" shape="round">{{restaurant.promoText}}</t-tag>
      <t-tag wx:if="{{restaurant.subsidyText}}" class="merchant-tag" size="small" variant="light" theme="default" shape="round">{{restaurant.subsidyText}}</t-tag>
    </view>

    <!-- 第5行: 标签 + 包间信息（条件显示） -->
    <view class="row-5">
      <t-tag wx:for="{{restaurant.tags}}" wx:key="*this" class="merchant-tag" size="small" variant="light" theme="default" shape="round">{{item}}</t-tag>
      <text wx:if="{{restaurant.availableRoomsBadge}}" class="rooms">🚪 {{restaurant.availableRoomsBadge}}</text>
    </view>
  </view>
</view>
