/* 餐厅卡片 - 深度适配 Design System */

.restaurant-card {
  display: flex;
  gap: var(--spacer-md); /* 24rpx */
  padding: var(--customer-card-padding); /* 24rpx */
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md); /* 12rpx */
  /* 移除 margin-bottom，由列表容器 gap 控制 */
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  overflow: hidden;
}

.restaurant-card:active {
  background: var(--td-bg-color-secondarycontainer);
  transform: scale(0.995);
}

.restaurant-image {
  width: var(--customer-image-size); /* 180rpx */
  height: var(--customer-image-size);
  border-radius: var(--radius-md); /* 12rpx */
  flex-shrink: 0;
  background-color: var(--td-bg-color-secondarycontainer);
}

.restaurant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs); /* 8rpx */
  min-width: 0;
  justify-content: space-between;
}

/* 行布局 */
.row-1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--spacer-sm);
}

.row-2, .row-3 {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  flex-wrap: wrap;
}

/* 标题 */
.restaurant-name {
  flex: 1;
  font-size: var(--font-size-base); /* 28rpx */
  font-weight: 600;
  color: var(--td-text-color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 辅助信息: 菜系 | 人均 | 距离 */
.cuisine, .distance {
  font-size: var(--font-size-xs); /* 24rpx */
  color: var(--td-text-color-secondary);
}

/* 人均价格 */
.avg-price {
  font-size: var(--font-size-base); /* 28rpx */
  font-weight: 700;
  color: var(--td-brand-color); /* 珊瑚色 */
}

.separator {
  color: var(--td-text-color-disabled);
  margin: 0 4rpx;
  font-size: 20rpx;
}

/* 包间信息 */
.rooms {
  font-size: var(--font-size-xs);
  color: var(--td-success-color); /* 深青色 */
  font-weight: 500;
  display: flex;
  align-items: center;
}
