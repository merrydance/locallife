/* 商户 Feed 卡片 - 适配 Design System */
@import '../../styles/customer.wxss';

/* ========== 外层卡片 ========== */

.feed-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* ========== 商户头部（左图右文） ========== */

.merchant-header {
  display: flex;
  gap: var(--spacer-md);
  padding: var(--customer-card-padding);
  align-items: flex-start;
  transition: background 0.15s ease;
}

.merchant-header:active {
  background: var(--td-bg-color-secondarycontainer);
}

/* 4:3 横向图片，门牌/招牌不会被裁成正方形 */
.merchant-image {
  width: 220rpx;
  height: 160rpx;
  --td-image-round-radius: 16rpx;
  flex-shrink: 0;
  background-color: var(--td-bg-color-secondarycontainer);
}

/* ========== 商户文字信息区 ========== */

.merchant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
  min-width: 0;
  justify-content: space-between;
}

.row-1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.merchant-name {
  flex: 1;
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-2 {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--spacer-xs);
}

.meta {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.meta-sep {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.row-3 {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--spacer-xs);
}

/* ========== 菜品预览区 ========== */

.dish-preview-section {
  padding: var(--spacer-sm) var(--spacer-sm) var(--spacer-sm);
  border-top: 1rpx solid var(--td-component-stroke);
}

/* 骨架屏 */

.dish-preview-skeleton {
  display: flex;
  gap: var(--spacer-sm);
  overflow: hidden;
}

.skeleton-item {
  width: 180rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.skeleton-img {
  width: 180rpx;
  height: 130rpx;
  background: var(--td-bg-color-secondarycontainer);
  border-radius: var(--radius-sm);
}

.skeleton-name {
  height: 24rpx;
  width: 130rpx;
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 4rpx;
}

.skeleton-price {
  height: 22rpx;
  width: 80rpx;
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 4rpx;
}

/* 横向滚动容器 */

.dish-scroll {
  width: 100%;
}

.dish-list {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: var(--spacer-sm);
  padding: 4rpx 0 4rpx;
}

/* 单个菜品单元格 */

.dish-item {
  width: 180rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-item:active {
  opacity: 0.8;
}

.dish-img {
  width: 180rpx;
  height: 130rpx;
  --td-image-round-radius: 10rpx;
  background-color: var(--td-bg-color-secondarycontainer);
  flex-shrink: 0;
}

.dish-name {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-primary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 180rpx;
}

.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color);
  line-height: 1;
}

/* 加购按钮通过 size=extra-small 控制 */

/* 自定义加购/规格按钮，避免 Skyline 组件隔离导致尺寸变量失效 */
.add-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--td-brand-color);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-btn:active {
  opacity: 0.7;
}

.add-btn-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1;
  margin-top: -2rpx;
}

.spec-btn {
  height: 40rpx;
  padding: 0 10rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--td-brand-color);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.spec-btn:active {
  opacity: 0.7;
}

.spec-btn-text {
  font-size: 22rpx;
  color: var(--td-brand-color);
  line-height: 1;
}

/* 更多按钮单元格 */

.dish-more {
  width: 72rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding-bottom: 28rpx;
}

.dish-more:active {
  opacity: 0.5;
}

.dish-more-icon {
  font-size: 56rpx;
  color: var(--td-text-color-secondary);
  line-height: 1;
}

.dish-more-text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}
