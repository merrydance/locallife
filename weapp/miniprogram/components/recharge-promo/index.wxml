<!--充值活动促销组件-->
<view class="recharge-promo" wx:if="{{visible}}">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="promo-loading">
    <t-loading theme="circular" size="32rpx" />
  </view>

  <!-- 线上充值暂停提示 -->
  <view wx:else class="promo-simple">
    <view class="simple-row">
      <text class="simple-label">{{pausedMessage}}</text>
      <t-button theme="primary" variant="text" size="small" bind:tap="onCustomRecharge" shape="round">
        我知道了
      </t-button>
    </view>
  </view>
</view>
