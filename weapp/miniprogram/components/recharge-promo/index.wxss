/* 充值活动促销组件样式 */
.recharge-promo {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFAF5 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  border: 1rpx solid rgba(255, 107, 0, 0.15);
}

.promo-loading {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.promo-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.promo-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.promo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.promo-item {
  flex: 1 1 calc(50% - 8rpx);
  min-width: 200rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 2rpx solid #E5E5E5;
  transition: all 0.2s ease;
}

.promo-item.selected {
  border-color: #FF6B00;
  background: linear-gradient(135deg, #FFF5EB 0%, #FFF 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.15);
}

.promo-amount {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.amount-main {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.amount-bonus {
  font-size: 24rpx;
  font-weight: 600;
  color: #FF6B00;
}

.promo-total {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.total-label {
  font-size: 22rpx;
  color: #999;
}

.total-amount {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B00;
}

.insufficient-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FEF0F0;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.insufficient-tip text {
  font-size: 24rpx;
  color: #FA5151;
  flex: 1;
}

.recharge-btn {
  width: 100%;
}

/* 简洁模式 */
.promo-simple {
  background: #F7F7F7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.simple-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.simple-label {
  font-size: 26rpx;
  color: #666;
}
