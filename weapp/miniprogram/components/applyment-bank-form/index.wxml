<view class="bank-form">
  <view class="intro-card">
    <view class="intro-title">填写结算账户</view>
  </view>

  <view class="field-group">
    <view class="field-label">账户类型</view>
    <t-radio-group value="{{form.account_type}}" bindchange="onAccountTypeChange">
      <t-radio value="ACCOUNT_TYPE_BUSINESS" label="对公账户" />
      <t-radio value="ACCOUNT_TYPE_PRIVATE" label="对私账户" />
    </t-radio-group>
  </view>

  <t-input label="开户名称" placeholder="{{form.account_type === 'ACCOUNT_TYPE_BUSINESS' ? '请输入企业或机构全称' : '请输入持卡人姓名'}}" value="{{form.account_name}}" data-field="account_name" bindchange="onTextFieldChange" />

  <view class="account-number-row">
    <view class="account-number-main">
      <t-input label="银行账号" placeholder="{{form.account_type === 'ACCOUNT_TYPE_PRIVATE' ? '输入完成后自动识别开户银行' : '请输入对公银行账户号码'}}" value="{{form.account_number}}" data-field="account_number" bindchange="onTextFieldChange" bindblur="onAccountNumberBlur" />
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view>
        <view class="section-title">开户银行</view>
      </view>
      <view wx:if="{{loadingBanks}}" class="section-meta">加载中...</view>
    </view>

    <view wx:if="{{showSelectedBankCard}}" class="selected-card">
      <view class="selected-row">
        <t-tag theme="primary" variant="light">已选银行</t-tag>
        <view class="selected-name">{{selectedBankLabel}}</view>
      </view>
    </view>

    <view class="picker-group">
      <view class="picker-trigger {{hasSelectedBank ? '' : 'picker-trigger--placeholder'}}" bindtap="onOpenBankPicker">
        <view class="picker-trigger-content">{{hasSelectedBank ? selectedBankLabel : (loadingBanks ? '银行列表加载中...' : '请选择开户银行')}}</view>
        <t-icon class="picker-trigger-arrow" name="chevron-right" size="36rpx" />
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view>
        <view class="section-title">开户地址和支行</view>
      </view>
    </view>

    <view class="picker-group">
      <view class="picker-trigger {{selectedProvinceCode ? '' : 'picker-trigger--placeholder'}}" bindtap="onOpenProvincePicker">
        <view class="picker-trigger-content">{{selectedProvinceCode ? provinces[selectedProvinceIndex].province_name : (loadingProvinces ? '省份加载中...' : '请选择开户省份')}}</view>
        <t-icon class="picker-trigger-arrow" name="chevron-right" size="36rpx" />
      </view>
    </view>

    <view class="picker-group">
      <view class="picker-trigger {{selectedCityCode ? '' : 'picker-trigger--placeholder'}}" bindtap="onOpenCityPicker">
        <view class="picker-trigger-content">{{selectedCityCode ? cities[selectedCityIndex].city_name : (selectedProvinceCode ? (loadingCities ? '城市加载中...' : '请选择开户城市') : '请先选择省份')}}</view>
        <t-icon class="picker-trigger-arrow" name="chevron-right" size="36rpx" />
      </view>
    </view>

    <view class="picker-group">
      <view class="picker-trigger {{form.bank_name ? '' : 'picker-trigger--placeholder'}}" bindtap="onOpenBranchPicker">
        <view class="picker-trigger-content">{{form.bank_name ? form.bank_name : (selectedCityCode ? (loadingBranches ? '支行列表加载中...' : '请选择开户支行') : '请先选择开户城市')}}</view>
        <t-icon class="picker-trigger-arrow" name="chevron-right" size="36rpx" />
      </view>
      <view wx:if="{{loadingBranches}}" class="empty-text">正在加载支行列表...</view>
      <view wx:if="{{!loadingBranches && selectedCityCode && !filteredBranches.length}}" class="empty-text">当前城市下暂无可选支行，请确认开户城市后重试。</view>
    </view>
  </view>
  <view class="form-actions">
    <t-button theme="primary" size="large" shape="round" block loading="{{submitting}}" disabled="{{submitting || !canSubmit}}" bindtap="onSubmit">{{submitLabel}}</t-button>
    <t-button theme="default" variant="outline" size="large" shape="round" block disabled="{{submitting}}" bindtap="onCancel">取消</t-button>
  </view>

  <t-popup wx:if="{{showBankPicker}}" visible="{{showBankPicker}}" placement="bottom" using-custom-navbar="{{true}}" bind:visible-change="onBankPickerVisibleChange">
    <view class="selector-sheet">
      <view class="selector-head">
        <view class="selector-title">选择开户行</view>
        <t-icon name="close" size="44rpx" bindtap="onCloseBankPicker" />
      </view>
      <scroll-view class="selector-list selector-list--bank" scroll-y>
        <view wx:for="{{filteredBanks}}" wx:key="bank_alias_code" class="selector-item {{form.bank_alias_code === item.bank_alias_code && form.account_bank_code === item.account_bank_code ? 'selector-item--active' : ''}}" data-index="{{index}}" bindtap="onSelectBankOption">
          <view class="selector-item-title">{{item.bank_alias}}</view>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <t-popup wx:if="{{showProvincePicker}}" visible="{{showProvincePicker}}" placement="bottom" using-custom-navbar="{{true}}" bind:visible-change="onProvincePickerVisibleChange">
    <view class="selector-sheet">
      <view class="selector-head">
        <view class="selector-title">选择开户省份</view>
        <t-icon name="close" size="44rpx" bindtap="onCloseProvincePicker" />
      </view>
      <scroll-view class="selector-list" scroll-y>
        <view wx:for="{{provinces}}" wx:key="province_code" class="selector-item {{selectedProvinceCode === item.province_code ? 'selector-item--active' : ''}}" data-index="{{index}}" bindtap="onSelectProvinceOption">
          <view class="selector-item-title">{{item.province_name}}</view>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <t-popup wx:if="{{showCityPicker}}" visible="{{showCityPicker}}" placement="bottom" using-custom-navbar="{{true}}" bind:visible-change="onCityPickerVisibleChange">
    <view class="selector-sheet">
      <view class="selector-head">
        <view class="selector-title">选择开户城市</view>
        <t-icon name="close" size="44rpx" bindtap="onCloseCityPicker" />
      </view>
      <scroll-view class="selector-list" scroll-y>
        <view wx:for="{{cities}}" wx:key="city_code" class="selector-item {{selectedCityCode === item.city_code ? 'selector-item--active' : ''}}" data-index="{{index}}" bindtap="onSelectCityOption">
          <view class="selector-item-title">{{item.city_name}}</view>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <t-popup wx:if="{{showBranchPicker}}" visible="{{showBranchPicker}}" placement="bottom" using-custom-navbar="{{true}}" bind:visible-change="onBranchPickerVisibleChange">
    <view class="selector-sheet">
      <view class="selector-head">
        <view class="selector-title">选择开户支行</view>
        <t-icon name="close" size="44rpx" bindtap="onCloseBranchPicker" />
      </view>
      <scroll-view class="selector-list selector-list--branch" scroll-y>
        <view wx:for="{{filteredBranches}}" wx:key="bank_branch_id" class="selector-item {{form.bank_branch_id === item.bank_branch_id ? 'selector-item--active' : ''}}" data-index="{{index}}" bindtap="onSelectBranchOption">
          <view class="selector-item-title">{{item.bank_branch_name}}</view>
        </view>
      </scroll-view>
    </view>
  </t-popup>
</view>