<view class="bank-form {{embedded ? 'bank-form--embedded' : ''}}">
  <t-cell-group theme="{{embedded ? 'default' : 'card'}}">
    <t-cell wx:if="{{showAccountTypeSelector}}" title="账户类型">
      <view slot="note" class="tag-check-list">
        <t-check-tag
          checked="{{form.account_type === 'ACCOUNT_TYPE_BUSINESS'}}"
          content="对公账户"
          shape="round"
          data-value="ACCOUNT_TYPE_BUSINESS"
          bind:change="onAccountTypeSelect"
        />
        <t-check-tag
          checked="{{form.account_type === 'ACCOUNT_TYPE_PRIVATE'}}"
          content="对私账户"
          shape="round"
          data-value="ACCOUNT_TYPE_PRIVATE"
          bind:change="onAccountTypeSelect"
        />
      </view>
    </t-cell>

    <t-input
      label="开户名称"
      t-class-label="{{requireAccountName ? 'form-required-label' : ''}}"
      placeholder="{{requireAccountName ? (form.account_type === 'ACCOUNT_TYPE_BUSINESS' ? '企业或机构全称' : '持卡人姓名') : ''}}"
      value="{{form.account_name}}"
      data-field="account_name"
      align="right"
      bind:change="onTextFieldChange"
    />

    <t-input
      wx:if="{{requireContactEmail}}"
      label="管理邮箱"
      t-class-label="form-required-label"
      placeholder="name@example.com"
      value="{{form.contact_email}}"
      data-field="contact_email"
      align="right"
      bind:change="onTextFieldChange"
    />

    <view wx:if="{{requireContactEmail}}" class="contact-email-tip">用于接收微信支付开户邮件和业务通知，请填写商户自己的邮箱。</view>

    <t-input
      label="银行账号"
      t-class-label="{{!allowSavedAccountNumber ? 'form-required-label' : ''}}"
      placeholder="{{savedAccountNumberMask ? savedAccountNumberMask : (form.account_type === 'ACCOUNT_TYPE_PRIVATE' ? '银行卡号' : '对公账号')}}"
      type="{{showAccountNumber ? 'text' : 'password'}}"
      value="{{form.account_number}}"
      data-field="account_number"
      align="right"
      maxlength="30"
      suffixIcon="{{allowSavedAccountNumber && savedAccountNumberMask && !form.account_number ? '' : (showAccountNumber ? 'browse' : 'browse-off')}}"
      bind:change="onTextFieldChange"
      bind:blur="onAccountNumberBlur"
      bind:click="onToggleAccountNumberVisibility"
    />

    <t-input
      wx:if="{{useManualCatalog}}"
      label="开户银行"
      t-class-label="form-required-label"
      placeholder="例如 招商银行"
      value="{{form.account_bank}}"
      data-field="account_bank"
      align="right"
      bind:change="onManualBankFieldChange"
    />

    <t-input
      wx:if="{{useManualCatalog}}"
      label="开户省份"
      t-class-label="form-required-label"
      placeholder="例如 浙江省"
      value="{{form.bank_address_code}}"
      data-field="bank_address_code"
      align="right"
      bind:change="onManualBankFieldChange"
    />

    <t-input
      wx:if="{{useManualCatalog}}"
      label="开户城市"
      t-class-label="form-required-label"
      placeholder="例如 杭州市"
      value="{{form.manual_bank_city}}"
      data-field="manual_bank_city"
      align="right"
      bind:change="onManualBankFieldChange"
    />

    <t-input
      wx:if="{{useManualCatalog}}"
      label="开户支行"
      t-class-label="form-required-label"
      placeholder="例如 招商银行杭州支行"
      value="{{form.bank_name}}"
      data-field="bank_name"
      align="right"
      bind:change="onManualBankFieldChange"
    />

    <t-cell
      wx:else
      required
      title="开户银行"
      hover
      arrow
      note="{{hasSelectedBank ? selectedBankLabel : (loadingBanks ? '银行列表加载中' : '请选择')}}"
      bind:click="onOpenBankPicker"
    />

    <t-cell
      wx:if="{{form.need_bank_branch || requireBankBranch}}"
      required
      title="开户省份"
      hover
      arrow
      note="{{selectedProvinceLabel || (loadingProvinces ? '省份加载中' : '请选择')}}"
      bind:click="onOpenProvincePicker"
    />

    <t-cell
      wx:if="{{form.need_bank_branch || requireBankBranch}}"
      required
      title="开户城市"
      hover
      arrow
      note="{{selectedCityLabel || (selectedProvinceCode ? (loadingCities ? '城市加载中' : '请选择') : '请先选择省份')}}"
      bind:click="onOpenCityPicker"
    />

    <t-cell
      wx:if="{{form.need_bank_branch || requireBankBranch}}"
      required
      title="开户支行"
      hover
      arrow
      note="{{form.bank_name || (selectedCityCode ? (loadingBranches ? '支行加载中' : '请选择') : '请先选择城市')}}"
      bind:click="onOpenBranchPicker"
    />
  </t-cell-group>

  <view wx:if="{{showContactFields}}" class="section-panel">
    <view class="section-top">
      <text class="section-title">联系人信息</text>
    </view>

    <t-cell-group theme="card">
      <t-cell
        title="默认联系人"
        description="系统会直接复用入驻时保存的法人姓名和身份证号，无需重复填写。"
      />

      <t-cell
        title="联系人不是法人"
        description="仅当微信支付联系人与法人不一致时开启，并补充超级管理员证件。"
      >
        <t-switch slot="note" value="{{form.contact_type === 'SUPER'}}" bind:change="onSuperContactSwitchChange" />
      </t-cell>

      <block wx:if="{{form.contact_type === 'SUPER'}}">
        <t-cell title="证件类型" note="中国大陆居民身份证" />

        <t-input
          label="管理员"
          t-class-label="form-required-label"
          value="{{form.contact_name}}"
          data-field="contact_name"
          align="right"
          bind:change="onTextFieldChange"
        />

        <t-input
          label="管理证件"
          t-class-label="form-required-label"
          placeholder="18位身份证号"
          value="{{form.contact_id_card_number}}"
          data-field="contact_id_card_number"
          align="right"
          bind:change="onTextFieldChange"
        />

        <view class="document-hint">请上传超级管理员身份证人像面与国徽面，确保头像、号码和有效期清晰完整。</view>

        <view class="document-grid">
          <document-uploader
            type="id-front"
            title="上传人像面"
            value="{{form.contact_id_doc_copy_url}}"
            rawUrl="{{form.contact_id_doc_copy_raw_url}}"
            feedbackState="{{contactDocCopyFeedbackState}}"
            feedbackTitle="{{contactDocCopyFeedbackTitle}}"
            feedbackDescription="{{contactDocCopyFeedbackDescription}}"
            bind:change="onContactIDDocCopyChange"
            bind:remove="onContactIDDocCopyRemove"
          />

          <document-uploader
            type="id-back"
            title="上传国徽面"
            value="{{form.contact_id_doc_copy_back_url}}"
            rawUrl="{{form.contact_id_doc_copy_back_raw_url}}"
            feedbackState="{{contactDocCopyBackFeedbackState}}"
            feedbackTitle="{{contactDocCopyBackFeedbackTitle}}"
            feedbackDescription="{{contactDocCopyBackFeedbackDescription}}"
            bind:change="onContactIDDocCopyBackChange"
            bind:remove="onContactIDDocCopyBackRemove"
          />
        </view>

        <t-input
          label="开始日期"
          t-class-label="form-required-label"
          placeholder="例如 2020-01-01"
          value="{{form.contact_id_doc_period_begin}}"
          data-field="contact_id_doc_period_begin"
          align="right"
          bind:change="onTextFieldChange"
        />

        <view class="tag-check-list tag-check-list--subtle">
          <t-check-tag
            checked="{{form.contact_id_doc_period_end === '长期'}}"
            content="长期有效"
            shape="round"
            bind:change="onContactDocLongTermToggle"
          />
        </view>

        <t-cell wx:if="{{form.contact_id_doc_period_end === '长期'}}" title="证件有效期结束" note="长期" />

        <t-input
          wx:else
          label="结束日期"
          t-class-label="form-required-label"
          placeholder="例如 2030-01-01 或填写 长期"
          value="{{form.contact_id_doc_period_end}}"
          data-field="contact_id_doc_period_end"
          align="right"
          bind:change="onTextFieldChange"
        />

        <view class="document-tip">有效期建议按证件原文填写，支持 YYYY-MM-DD 和“长期”两种格式。</view>
      </block>
    </t-cell-group>
  </view>

  <view wx:if="{{showSubmitActions}}" class="form-actions {{submitBlock ? 'form-actions--block' : ''}}">
    <t-button theme="primary" block="{{submitBlock}}" loading="{{submitting}}" disabled="{{submitting}}" bind:tap="onSubmit">{{submitLabel}}</t-button>
    <t-button wx:if="{{showCancelButton}}" theme="default" variant="outline" block="{{submitBlock}}" disabled="{{submitting}}" bind:tap="onCancel">取消</t-button>
  </view>

  <t-popup wx:if="{{showBankPicker}}" visible="{{showBankPicker}}" placement="bottom" using-custom-navbar="{{true}}" bind:visible-change="onBankPickerVisibleChange">
    <view class="popup-panel selector-popup">
      <t-search value="{{bankKeyword}}" placeholder="搜索银行名称" bind:change="onBankKeywordChange" />

      <view wx:if="{{loadingBanks}}" class="popup-state">
        <t-loading theme="circular" size="40rpx" text="加载银行列表中..." vertical />
      </view>

      <t-empty wx:elif="{{!filteredBanks.length}}" description="未找到匹配的开户银行" />

      <scroll-view wx:else class="selector-scroll" scroll-y>
        <t-cell-group theme="card">
          <t-cell
            wx:for="{{filteredBanks}}"
            wx:key="bank_alias_code"
            title="{{item.bank_alias}}"
            hover
            data-index="{{index}}"
            bind:click="onSelectBankOption"
          >
            <view wx:if="{{form.bank_alias_code === item.bank_alias_code && form.account_bank_code === item.account_bank_code}}" slot="note">
              <t-tag theme="primary" variant="light">已选</t-tag>
            </view>
          </t-cell>
        </t-cell-group>
      </scroll-view>

      <view class="popup-actions popup-actions--single">
        <t-button theme="default" bind:tap="onCloseBankPicker">关闭</t-button>
      </view>
    </view>
  </t-popup>

  <t-picker
    visible="{{showProvincePicker}}"
    value="{{provincePickerValue}}"
    title="选择开户省份"
    cancelBtn="取消"
    confirmBtn="确定"
    bind:pick="onProvincePickerPick"
    bind:confirm="onProvincePickerConfirm"
    bind:cancel="onCloseProvincePicker"
    bind:close="onCloseProvincePicker"
  >
    <t-picker-item options="{{provincePickerOptions}}" />
  </t-picker>

  <t-picker
    visible="{{showCityPicker}}"
    value="{{cityPickerValue}}"
    title="选择开户城市"
    cancelBtn="取消"
    confirmBtn="确定"
    bind:pick="onCityPickerPick"
    bind:confirm="onCityPickerConfirm"
    bind:cancel="onCloseCityPicker"
    bind:close="onCloseCityPicker"
  >
    <t-picker-item options="{{cityPickerOptions}}" />
  </t-picker>

  <t-popup wx:if="{{showBranchPicker}}" visible="{{showBranchPicker}}" placement="bottom" using-custom-navbar="{{true}}" bind:visible-change="onBranchPickerVisibleChange">
    <view class="popup-panel selector-popup">
      <t-search value="{{branchKeyword}}" placeholder="搜索支行名称" bind:change="onBranchKeywordChange" />

      <view wx:if="{{loadingBranches}}" class="popup-state">
        <t-loading theme="circular" size="40rpx" text="加载支行列表中..." vertical />
      </view>

      <t-empty wx:elif="{{!filteredBranches.length}}" description="当前条件下暂无可选支行" />

      <scroll-view wx:else class="selector-scroll selector-scroll--branch" scroll-y>
        <t-cell-group theme="card">
          <t-cell
            wx:for="{{filteredBranches}}"
            wx:key="bank_branch_id"
            title="{{item.bank_branch_name}}"
            description="支行编号：{{item.bank_branch_id}}"
            hover
            data-index="{{index}}"
            bind:click="onSelectBranchOption"
          >
            <view wx:if="{{form.bank_branch_id === item.bank_branch_id}}" slot="note">
              <t-tag theme="primary" variant="light">已选</t-tag>
            </view>
          </t-cell>
        </t-cell-group>
      </scroll-view>

      <view class="popup-actions popup-actions--single">
        <t-button theme="default" bind:tap="onCloseBranchPicker">关闭</t-button>
      </view>
    </view>
  </t-popup>
</view>
