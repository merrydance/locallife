.bank-form {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.popup-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.tag-check-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.tag-check-list--subtle {
  padding: 0 var(--spacer-xs);
}

.document-hint,
.document-tip {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.document-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--spacer-sm);
}

@media (max-width: 640rpx) {
  .document-grid {
    grid-template-columns: 1fr;
  }
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}

.submit-block-message {
  margin-top: calc(var(--spacer-xs) * -1);
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
  text-align: right;
}

.popup-panel {
  padding: var(--spacer-md);
  padding-bottom: var(--popup-bottom-padding-md);
}

.selector-popup {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.popup-state {
  min-height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selector-scroll {
  max-height: 56vh;
}

.selector-scroll--branch {
  max-height: 52vh;
}

.popup-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}
