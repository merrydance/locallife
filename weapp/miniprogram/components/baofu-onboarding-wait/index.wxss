.onboarding-wait {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding: var(--spacer-md) 0;
}

.onboarding-wait__loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-sm);
  padding: 64rpx var(--spacer-md);
}

.onboarding-wait__description {
  max-width: 560rpx;
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-sm);
  line-height: 1.6;
  text-align: center;
}

.onboarding-wait__actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}
