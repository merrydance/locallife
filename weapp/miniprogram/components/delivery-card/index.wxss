.delivery-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-card);
  padding: 32rpx;
  box-shadow: var(--shadow-lg);
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--td-border-level-1-color);
}

.header-left {
  display: flex;
  align-items: center;
}

.task-id {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-right: 16rpx;
}

.tag {
  font-size: 24rpx;
  font-weight: 600;
}

.tag.orange { background: var(--td-warning-color-1); color: var(--td-warning-color-7); }
.tag.blue { background: var(--td-brand-color-1); color: var(--td-brand-color-9); }
.tag.green { background: var(--td-success-color-1); color: var(--td-success-color); }
.tag.gray { background: var(--td-bg-color-secondarycontainer); color: var(--td-text-color-secondary); }

.income {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--td-brand-color);
  font-family: 'DIN Alternate', sans-serif;
}

.route-info {
  margin-bottom: 48rpx;
}

.route-node {
  display: flex;
  align-items: flex-start;
}

.node-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: var(--td-text-color-anti);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.node-icon.start { background: var(--td-brand-color-9); }
.node-icon.end { background: var(--td-success-color); }

.node-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.address {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.sub-address {
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
}

.node-action {
  padding: 16rpx;
}

.phone-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.6;
}

.route-line {
  width: 2rpx;
  height: 40rpx;
  background: var(--td-border-level-1-color);
  margin-left: 23rpx; /* Center with icon (48/2 - 1) */
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.action-area {
  margin-top: 24rpx;
}

.big-btn {
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 60rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--td-text-color-anti);
  border: none;
  box-shadow: var(--shadow-md);
}

.btn-blue { background: linear-gradient(135deg, var(--td-brand-color-9), var(--td-brand-color-7)); }
.btn-green { background: linear-gradient(135deg, var(--td-success-color), var(--td-success-color-5)); }

.btn-hover {
  transform: scale(0.98);
  opacity: 0.9;
}
