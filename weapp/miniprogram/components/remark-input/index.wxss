.remark-input-wrapper {
  display: flex;
  flex-direction: column;
}

.native-textarea {
  width: 100%;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 40rpx;
  min-height: 80rpx; /* 40rpx line-height + 20rpx * 2 padding = 80rpx total */
  color: rgba(0, 0, 0, 0.9);
}

.textarea-placeholder {
  color: rgba(0, 0, 0, 0.26);
  line-height: 40rpx;
}

.quick-remarks {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.quick-remark-tag {
  padding: 6rpx 20rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  background: #f0f0f0;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.quick-remark-tag:active {
  background: #e5e5e5;
  opacity: 0.8;
}
