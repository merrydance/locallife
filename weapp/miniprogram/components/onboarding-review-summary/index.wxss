.onboarding-review-summary {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.summary-panel {
  width: 100%;
  box-sizing: border-box;
  padding: var(--spacer-md);
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.summary-head,
.credential-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.summary-title,
.credential-title {
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.summary-title {
  flex: 1;
  font-size: var(--font-size-base);
}

.summary-desc,
.credential-expiry,
.credential-detail {
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.summary-desc {
  margin-top: 16rpx;
  margin-bottom: var(--spacer-sm);
}

.credential-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.credential-row {
  padding: 20rpx 0;
  border-bottom: 1px solid var(--td-component-stroke);
}

.credential-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.credential-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.credential-detail {
  flex-basis: 100%;
}

@media (max-width: 420px) {
  .credential-row {
    flex-wrap: wrap;
  }
}
