.alert-section-note {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.alert-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 24rpx;
}

.alert-item {
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(180deg, #FFF5F3 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(255, 107, 88, 0.18);
  margin-bottom: 20rpx;
}

.alert-item:last-child {
  margin-bottom: 0;
}

.alert-item__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.alert-item__title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.alert-item__title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.alert-item__time {
  flex-shrink: 0;
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.alert-item__message {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.alert-item__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.alert-item__meta-text {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-round);
  background: rgba(255, 107, 88, 0.1);
  font-size: var(--font-size-xxs);
  color: #C75042;
}

.alert-item__footer {
  margin-top: 16rpx;
  font-size: var(--font-size-xxs);
  color: var(--td-brand-color);
}

.ranking-section {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  margin-top: 32rpx;
  padding: 32rpx;
}

.ranking-tabs {
  margin-bottom: 0 !important;
}

.ranking-label {
  font-size: var(--font-size-xxs);
  color: #999;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.ranking-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  color: #999;
  margin-right: 24rpx;
}

.top-1 { color: #FFD700; font-size: 36rpx; }
.top-2 { color: #C0C0C0; font-size: 34rpx; }
.top-3 { color: #CD7F32; font-size: 32rpx; }

.rank-main {
  flex: 1;
}

.rank-name {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: #333;
}

.rank-sub {
  font-size: var(--font-size-xxs);
  color: #999;
}

.rank-val {
  font-weight: bold;
  color: var(--td-brand-color);
  font-family: 'DIN Alternate', sans-serif;
}