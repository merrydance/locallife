.section-state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 80rpx 24rpx;
  border-radius: 20rpx;
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.section-state-block-compact {
  margin-bottom: 0;
  padding: 48rpx 24rpx 24rpx;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.section-error-hint {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: var(--td-error-color-1);
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-error-hint-spaced {
  margin-bottom: 18rpx;
}

.section-error-action {
  flex-shrink: 0;
  color: var(--td-brand-color);
  font-weight: 600;
}
