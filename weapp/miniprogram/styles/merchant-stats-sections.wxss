.meta-strip,
.section-block {
  border-radius: 20rpx;
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.meta-strip {
  margin-bottom: 24rpx;
  padding: 16rpx 24rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  font-size: 25rpx;
}

.meta-row + .meta-row {
  border-top: 1px solid var(--td-component-stroke);
}

.meta-label {
  color: var(--td-text-color-secondary);
}

.meta-value {
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.section-block {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dish-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
}

.dish-card + .dish-card {
  border-top: 1px solid var(--td-component-stroke);
}

.dish-rank {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--td-brand-color-1);
  color: var(--td-brand-color);
  font-size: 26rpx;
  font-weight: 700;
}

.dish-body {
  flex: 1;
  min-width: 0;
}

.dish-head,
.dish-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.dish-head {
  margin-bottom: 8rpx;
}

.dish-name,
.dish-revenue {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.dish-name {
  flex: 1;
  min-width: 0;
  font-weight: 600;
}

.dish-revenue {
  font-weight: 700;
}

.dish-meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.insight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.insight-card-compact {
  gap: 12rpx;
}

.insight-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.insight-title,
.insight-value {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.insight-title {
  flex: 1;
  min-width: 0;
  font-weight: 600;
}

.insight-value {
  font-weight: 700;
}

.insight-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.insight-progress-track {
  overflow: hidden;
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color-light);
}

.insight-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--td-brand-color);
}

.insight-progress-fill-daily {
  background: var(--td-success-color);
}

.insight-progress-fill-accent {
  background: var(--td-brand-color-6);
}

.insight-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.insight-stat-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.accent-soft {
  background: var(--td-bg-color-secondarycontainer);
}

.insight-stat-label,
.insight-stat-meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.insight-stat-value {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.reservation-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.reservation-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.warning-card {
  background: var(--td-warning-color-1);
}

.reservation-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.reservation-value {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--td-text-color-primary);
}