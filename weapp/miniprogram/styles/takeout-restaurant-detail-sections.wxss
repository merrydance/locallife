.action-area {
  align-self: flex-end;
  flex-shrink: 0;
}

.disabled-action {
  min-width: 88rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: var(--td-bg-color-secondarycontainer);
  color: var(--td-text-color-placeholder);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
}

.combos-tab {
  height: 100%;
  padding: var(--spacer-sm);
  box-sizing: border-box;
}

.combo-item {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacer-md);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  gap: var(--spacer-md);
}

.combo-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.combo-image-grid {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--td-bg-color-page);
  display: grid;
  gap: 2rpx;
  flex-shrink: 0;
}

.grid-count-1 {
  grid-template-columns: 1fr;
  grid-template-rows: 1fr;
}

.grid-count-2 {
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: 1fr;
}

.grid-count-3 {
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
}

.grid-count-3 .grid-img:first-child {
  grid-column: span 2;
}

.grid-count-4 {
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
}

.grid-img {
  width: 100% !important;
  height: 100% !important;
  display: block;
}

.combo-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.combo-name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.combo-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  line-height: 1.4;
  margin: 8rpx 0;
}

.combo-price-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.combo-price {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-brand-color);
}

.combo-discount {
  background: var(--td-brand-color-light);
  color: var(--td-brand-color);
  font-size: var(--font-size-xxs);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-xs);
}

.rooms-tab {
  height: 100%;
  padding: var(--spacer-sm);
  box-sizing: border-box;
}

.room-item {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacer-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.room-image {
  width: 100%;
  height: 300rpx;
}

.room-info {
  padding: var(--spacer-md);
}

.room-name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-xs);
}

.room-meta {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  margin-top: var(--spacer-sm);
}

.room-price {
  font-size: var(--font-size-title);
  color: var(--td-brand-color);
  font-weight: bold;
}

.empty-placeholder {
  height: var(--spacer-xl);
}