.cart-modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.cart-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.cart-title {
  font-size: 32rpx;
  font-weight: bold;
}

.cart-items-scroll {
  flex: 1;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.cart-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  box-sizing: border-box;
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
  background: #f5f5f5;
  flex-shrink: 0;
}

.cart-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cart-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #e34d59;
  flex-shrink: 0;
}

.item-spec {
  font-size: 24rpx;
  color: #888;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.item-stepper .qty {
  font-size: 30rpx;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
}

.cart-footer {
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-top: 1rpx solid #eee;
  box-sizing: border-box;
}

.cart-total-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-shrink: 0;
  min-width: 220rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666;
}

.total-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #e34d59;
}

.checkout-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

.custom-drawer {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.drawer-title {
  font-size: 36rpx;
  font-weight: bold;
}

.drawer-content {
  flex: 1;
  overflow-y: auto;
}

.spec-group {
  margin-bottom: 32rpx;
}

.group-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  --td-tag-font-size: 26rpx;
  --td-tag-padding: 12rpx 24rpx;
}

.spec-item.active {
  --td-tag-bg-color: rgba(255, 107, 53, 0.1);
  --td-tag-text-color: #ff6b35;
  --td-tag-border-color: #ff6b35;
}

.dish-detail-popup {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.detail-image {
  width: 100%;
  height: 450rpx;
}

.detail-info {
  padding: 32rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
}

.detail-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 32rpx;
  display: block;
}

.detail-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}