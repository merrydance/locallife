.refund-payment-summary {
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.refund-payment-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.refund-payment-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.refund-payment-no {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  word-break: break-all;
}

.refund-payment-meta {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.refund-summary-strip {
  display: flex;
  margin-top: 20rpx;
  border-top: 1rpx solid var(--td-component-stroke);
  padding-top: 20rpx;
}

.refund-summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.refund-summary-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.refund-summary-label {
  font-size: 22rpx;
  color: var(--td-text-color-secondary);
}

.refund-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.refund-item-card {
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.refund-item-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.refund-item-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.refund-item-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color);
}

.refund-item-time {
  font-size: 22rpx;
  color: var(--td-text-color-secondary);
}

.refund-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.refund-item-row-top {
  align-items: flex-start;
}

.refund-item-label {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.refund-item-value {
  font-size: 24rpx;
  color: var(--td-text-color-primary);
}

.refund-item-value-break {
  flex: 1;
  text-align: right;
  word-break: break-all;
  white-space: pre-wrap;
  line-height: 1.6;
}

.refund-return-section {
  margin-top: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--td-component-stroke);
}

.refund-return-title {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.refund-return-card {
  border-radius: 16rpx;
  background: var(--td-bg-color-container);
  padding: 20rpx;
}

.refund-return-card + .refund-return-card {
  margin-top: 16rpx;
}

.refund-return-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.refund-return-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.print-job-card {
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.print-job-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.print-job-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.print-job-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.print-job-time {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
}

.print-job-summary {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.print-job-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.print-job-row-top {
  align-items: flex-start;
}

.print-job-label {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.print-job-value {
  font-size: 24rpx;
  color: var(--td-text-color-primary);
}

.print-job-value-break {
  flex: 1;
  text-align: right;
  word-break: break-all;
  white-space: pre-wrap;
  line-height: 1.6;
}

.print-job-status-time {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
}

.print-job-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.detail-actions {
  margin-top: 32rpx;
  padding-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-actions__row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.detail-actions__status {
  text-align: center;
  font-size: 28rpx;
  color: var(--td-text-color-placeholder);
}

.loading-state {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}

.loading-state-page {
  min-height: 100vh;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.section-error-hint {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin: 0 32rpx 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-error-color-1);
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-error-action {
  flex-shrink: 0;
  color: var(--td-brand-color);
  font-weight: 600;
}

.popup-sheet {
  background: var(--td-bg-color-container);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  padding: 32rpx 24rpx var(--popup-bottom-padding-md);
}

.popup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.popup-subtitle {
  display: block;
  margin-top: 12rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.popup-block {
  margin-bottom: 24rpx;
}

.popup-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.popup-tip,
.refund-full-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
}

.refund-type-options {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.refund-type-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.popup-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}