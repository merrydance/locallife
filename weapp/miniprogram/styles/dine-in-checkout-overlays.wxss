.voucher-popup {
  background: var(--td-bg-color-container, #fff);
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer, #f0f0f0);
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #333);
}

.voucher-scroll {
  flex: 1;
  padding: 20rpx;
  max-height: 50vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.voucher-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--td-bg-color-container, #fff);
  border: 2rpx solid var(--td-bg-color-secondarycontainer, #f0f0f0);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
  overflow: hidden;
  max-width: 100%;
}

.voucher-item:active {
  opacity: 0.8;
}

.voucher-item.selected {
  border-color: var(--td-brand-color, #0052d9);
  background: rgba(0, 82, 217, 0.04);
}

.voucher-amount {
  width: 120rpx;
  min-width: 120rpx;
  flex-shrink: 0;
  text-align: center;
  color: var(--td-error-color, #e34d59);
}

.voucher-amount .currency {
  font-size: 24rpx;
  font-weight: 600;
}

.voucher-amount .amount {
  font-size: 40rpx;
  font-weight: 700;
}

.voucher-content {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
  overflow: hidden;
}

.voucher-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--td-text-color-primary, #333);
  display: block;
}

.voucher-condition {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #999);
  margin-top: 8rpx;
  display: block;
}

.voucher-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.balance-warning {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(135deg, #FEF0F0 0%, #FFF5F5 100%);
  padding: 24rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
  border: 1rpx solid rgba(250, 81, 81, 0.2);
}

.warning-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.warning-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FA5151;
}

.warning-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.payment-disabled {
  opacity: 0.5;
}

.skeleton-wrapper {
  padding: 24rpx;
  background: #fff;
  min-height: 100vh;
}

.skeleton-card {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
}

.skeleton-line {
  height: 32rpx;
  background: #eee;
  border-radius: 8rpx;
}

.skeleton-animate {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

.w-60 { width: 60%; }
.w-40 { width: 40%; }
.mt-20 { margin-top: 20rpx; }

.error-loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 80vh;
  gap: 32rpx;
}