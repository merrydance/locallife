.settlement-page {
  background: var(--td-bg-color-page);
  --td-input-label-max-width: 6em;
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 140rpx var(--spacer-md);
}

.sync-state {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  padding: var(--spacer-sm);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
  color: var(--td-text-color-primary);
}

.sync-state--success {
  background: var(--td-success-color-light);
}

.sync-state--error {
  background: var(--td-error-color-1);
}

.sync-state__text {
  flex: 1;
  min-width: 0;
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

.form-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
  padding-bottom: var(--spacer-md);
}

.option-group {
  padding: var(--spacer-xs) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
}

.opening-mode-radio {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  min-height: 64rpx;
}

.opening-mode-choice {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: var(--td-tag-medium-padding, 2rpx 14rpx);
  border: 2rpx solid transparent;
  border-radius: var(--td-tag-round-border-radius, 999px);
  color: var(--td-text-color-primary);
  font: var(--td-tag-medium-font, var(--td-font-body-small, 24rpx / 40rpx var(--td-font-family, PingFang SC, Microsoft YaHei, Arial Regular)));
  background: var(--td-bg-color-component);
}

.opening-mode-choice--active {
  border-color: var(--td-brand-color);
  color: var(--td-text-color-anti);
  background: var(--td-brand-color);
  font-weight: 600;
}

.identity-note {
  margin-top: var(--spacer-xs);
  padding: 0 var(--spacer-xs);
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-sm);
  line-height: 1.6;
}

.form-required-label::after {
  content: " *";
  color: var(--td-error-color-6);
}
