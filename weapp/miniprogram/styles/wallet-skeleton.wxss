.loading-center {
  padding: var(--spacer-lg) 0;
  display: flex;
  justify-content: center;
}

.skeleton-breath {
  animation: bg-breath 1.5s infinite ease-in-out;
}

@keyframes bg-breath {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.card-skeleton-content {
  width: 100%;
  box-sizing: border-box;
}

.skeleton-line {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.title-line {
  width: 140rpx;
  height: 32rpx;
}

.amount-line {
  width: 320rpx;
  height: 80rpx;
  margin: 32rpx 0;
}

.skeleton-stats-row {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.stat-cell {
  width: 180rpx;
  height: 48rpx;
  margin-bottom: 0;
}

.skeleton-item {
  margin-bottom: 24rpx;
}