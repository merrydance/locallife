/**
 * 响应式样式混入 (已简化为仅支持移动端)
 * 移除大屏及 PC 端适配逻辑
 */

/* 响应式容器 */
.responsive-container {
  width: 100%;
  padding: 32rpx;
}

/* 顾侧侧页面容器 */
.customer-page-container {
  width: 100%;
  background: #fff;
  min-height: 100vh;
}

/* 响应式网格 - 仅保留单列布局 */
.responsive-grid-2,
.responsive-grid-3,
.responsive-grid-4 {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 响应式卡片 */
.responsive-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 响应式字体 */
.responsive-title {
  font-size: 32rpx;
  font-weight: bold;
}

.responsive-subtitle {
  font-size: 28rpx;
  font-weight: 500;
}

.responsive-body {
  font-size: 28rpx;
}

.responsive-caption {
  font-size: 24rpx;
}

/* 响应式间距 */
.responsive-spacing-sm {
  margin-bottom: 16rpx;
}

.responsive-spacing-md {
  margin-bottom: 24rpx;
}

.responsive-spacing-lg {
  margin-bottom: 32rpx;
}

/* 隐藏/显示工具类 */
.hide-mobile {
  display: none;
}

.hide-tablet {
  display: block;
}

.hide-desktop {
  display: block;
}

.show-mobile {
  display: block;
}

.show-tablet {
  display: none;
}

.show-desktop {
  display: none;
}

/* 响应式多栏布局 */
.responsive-row {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}
