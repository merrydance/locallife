/** app.wxss **/
@import './styles/font-fix.wxss';
@import './styles/common.wxss';

/**
 * 基于color_guide.md的配色方案
 * 使用TDesign的CSS变量系统 + 自定义品牌变量
 */
page {
  /* ========== TDesign主题色覆盖 ========== */
  /* 非顾客侧对齐独立商户接单 App 的绿色品牌系；消费侧在 customer.wxss 中覆盖为暖橙 */
  --td-brand-color: #006B31;
  --td-brand-color-1: #EAF6EE;
  --td-brand-color-2: #CFE8D7;
  --td-brand-color-3: #ADD7BC;
  --td-brand-color-4: #87C79D;
  --td-brand-color-5: #5FB77D;
  --td-brand-color-6: #2F9A59;
  --td-brand-color-7: #006B31;
  --td-brand-color-8: #005625;
  --td-brand-color-9: #00401B;
  --td-brand-color-10: #002C12;
  
  /* 浅色背景变量映射到最淡的色阶，确保文字对比度 */
  --td-brand-color-light: var(--td-brand-color-1);
  --td-brand-color-focus: #005625;
  --td-brand-color-disabled: #ADD7BC;
  
  /* 辅助色：保持 TDesign 语义分层，但与商户侧绿色体系保持同色相家族 */
  --td-success-color: #0A7A46;
  --td-success-color-1: #E8F6EE;
  --td-success-color-5: #4EA36F;
  --td-success-color-7: #0A7A46;
  --td-success-color-light: var(--td-success-color-1);
  
  /* 强调色：沿用商户端高辨识橙色体系 */
  --td-warning-color: #FC820C;
  --td-warning-color-1: #FFF3E6;
  --td-warning-color-5: #FDBA74;
  --td-warning-color-7: #FC820C;
  --td-warning-color-light: var(--td-warning-color-1);
  
  /* 错误色：保留明确告警语义，不与品牌主色混用 */
  --td-error-color: #B6171E;
  --td-error-color-1: #FDEBEC;
  --td-error-color-5: #D55B62;
  --td-error-color-7: #B6171E;
  --td-error-color-light: var(--td-error-color-1);
  
  /* ========== 背景色 (60%使用) ========== */
  --td-bg-color-page: #F5FBF1;
  --td-bg-color-container: #FFFFFF;
  --td-bg-color-secondarycontainer: #EFF5EC;

  /* ========== 边框色 ========== */
  --td-border-level-1-color: #D5E1D3;
  --td-border-level-2-color: #E6EEE3;
  --td-component-border: #DDE7DB;
  
  /* ========== 文字颜色 ========== */
  --td-text-color-primary: #171D17;
  --td-text-color-secondary: #3E4A3F;
  --td-text-color-placeholder: #667365;
  --td-text-color-disabled: #96A396;
  --td-text-color-anti: rgba(255, 255, 255, 0.87); /* 白色文字 */
  
  /* ========== 自定义品牌变量 ========== */
  --brand-primary: #006B31;
  --brand-primary-light: var(--td-brand-color-1);
  --brand-secondary: #1F2A20;
  --brand-accent: #FC820C;
  
  /* 兼容旧变量 */
  --brand-coral: #006B31;
  --brand-coral-gradient: linear-gradient(135deg, #038740 0%, #006B31 100%);
  --brand-teal: #0A7A46;
  --brand-mustard: #FC820C;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  --shadow-card: 0 4rpx 20rpx rgba(0,0,0,0.06);
  --shadow-float: 0 8rpx 32rpx rgba(0,0,0,0.12);

  /* ========== 统一文字系统 (Typography System) ========== */
  --font-size-display: 48rpx;
  --font-size-title: 36rpx;    /* 页面标题 */
  --font-size-heading: 32rpx;  /* 卡片/模块标题 */
  --font-size-base: 28rpx;     /* 正文/列表项 */
  --font-size-sm: 26rpx;       /* 辅助文本 */
  --font-size-xs: 24rpx;       /* 说明/标签 */
  --font-size-xxs: 20rpx;      /* 角标 */

  /* ========== 统一间距系统 (Spacing System) - 8rpx网格 ========== */
  --spacer-xxs: 4rpx;   /* 极微 */
  --spacer-xs: 8rpx;    /* 紧凑 (icon-text) */
  --spacer-sm: 16rpx;   /* 小 (card-margin, tag-gap) */
  --spacer-md: 24rpx;   /* 标准间距 */

  /* Cart Bar Specific Overrides */
  --spacer-lg: 32rpx;   /* 大 (section-gap) */
  --spacer-xl: 48rpx;   /* 超大 */
  --spacer-xxl: 64rpx;  /* 巨型 */


  /* ========== 统一圆角系统 (Radius System) ========== */
  --radius-xs: 4rpx;    /* 极小 (标签) */
  --radius-sm: 8rpx;    /* 小 (小卡片/按钮) */
  --radius-md: 12rpx;   /* 中 (标准卡片/图片) */
  --radius-lg: 16rpx;   /* 大 (大卡片/弹窗) */
  --radius-xl: 24rpx;   /* 超大 (底部面板) */
  --radius-card: 24rpx; /* 新标准卡片 */
  --radius-round: 999rpx; /* 全圆 (胶囊/头像) */
  --radius-pill: 999rpx; /* 药丸 */

  /* ========== 统一层级系统 (Z-Index System) ========== */
  --z-index-base: 1;
  --z-index-sticky: 100;   /* 吸顶元素 */
  --z-index-dropdown: 800; /* 下拉菜单 */
  --z-index-fixed: 1000;   /* 固定底部栏/悬浮按钮 */
  --z-index-modal: 2000;   /* 弹窗/遮罩 */
  --z-index-toast: 3000;   /* 提示框 */

  /* ========== 统一动效系统 (Motion System) ========== */
  --transition-base: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-fade: 0.3s ease-in-out;

  /* ========== 安全区域 (Safe Area) ========== */
  --safe-area-bottom: constant(safe-area-inset-bottom);
  --safe-area-bottom: env(safe-area-inset-bottom);
  --popup-bottom-padding-sm: calc(24rpx + var(--safe-area-bottom));
  --popup-bottom-padding-md: calc(32rpx + var(--safe-area-bottom));
  --popup-bottom-padding-lg: calc(40rpx + var(--safe-area-bottom));
}

/* ========== 深色模式 ========== */
page[data-theme="dark"] {
  /* 品牌色微调（深色模式下更柔和） */
  --td-brand-color: #63B07C;
  --td-brand-color-8: #4F9A67;
  
  /* 背景色 */
  --td-bg-color-page: #111611;
  --td-bg-color-container: #1A211B;
  --td-bg-color-secondarycontainer: #232C24;
  
  /* 文字颜色 */
  --td-text-color-primary: #E7EEE5;
  --td-text-color-secondary: #B6C1B5;
  --td-text-color-placeholder: #899488;
  --td-text-color-disabled: #626B61;
  
  /* 边框 */
  --td-border-level-1-color: #303A31;
  --td-border-level-2-color: #242D25;
  --td-component-border: #354036;
  
  /* 辅助色调整 */
  --td-success-color: #47A26B;
  --td-warning-color: #F0A63C;
  --td-error-color: #DE6B64;
  
  /* 品牌色 */
  --brand-primary: #63B07C;
  --brand-primary-light: #233126;
  --brand-coral: #63B07C;
  --brand-coral-gradient: linear-gradient(135deg, #3D8A59 0%, #63B07C 100%);
  --brand-teal: #47A26B;
  --brand-mustard: #F0A63C;
  
  /* 阴影（深色模式下更明显） */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.5);
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  box-sizing: border-box;
}

.page-shell--with-nav {
  padding-top: calc(var(--page-shell-nav-height, 0px) + var(--page-shell-nav-gap, var(--spacer-sm)));
}

.page-shell--bottom-safe {
  padding-bottom: calc(var(--page-shell-bottom-offset, 0rpx) + var(--safe-area-bottom));
}

.page-shell--page-gutter {
  padding-left: var(--page-shell-horizontal-gutter, var(--spacer-md));
  padding-right: var(--page-shell-horizontal-gutter, var(--spacer-md));
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding-bottom: calc(var(--spacer-md) + var(--safe-area-bottom));
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton-shimmer {
  background: linear-gradient(90deg, var(--td-bg-color-secondarycontainer) 25%, var(--td-bg-color-page) 50%, var(--td-bg-color-secondarycontainer) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-rect {
  background: var(--td-bg-color-secondarycontainer);
}

.skeleton-circle {
  border-radius: 50%;
  background: var(--td-bg-color-secondarycontainer);
}
