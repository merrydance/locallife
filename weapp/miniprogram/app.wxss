/** app.wxss **/
@import './styles/font-fix.wxss';
@import './styles/common.wxss';

/**
 * 基于color_guide.md的配色方案
 * 使用TDesign的CSS变量系统 + 自定义品牌变量
 */
page {
  /* ========== TDesign主题色覆盖 ========== */
  /* 品牌主色 - 活力珊瑚 #FF6B58 (30%使用) */
  --td-brand-color: #FF6B58;
  --td-brand-color-1: #FFF5F3;
  --td-brand-color-2: #FFE8E5;
  --td-brand-color-3: #FFD4CE;
  --td-brand-color-4: #FFBFB6;
  --td-brand-color-5: #FFAA9E;
  --td-brand-color-6: #FF9586;
  --td-brand-color-7: #FF806E;
  --td-brand-color-8: #FF6B58;
  --td-brand-color-9: #E66A5C;
  --td-brand-color-10: #CC5E50;
  
  /* 浅色背景变量映射到最淡的色阶，确保文字对比度 */
  --td-brand-color-light: var(--td-brand-color-1);
  --td-brand-color-focus: #E66A5C;
  --td-brand-color-disabled: #FFBFB6;
  
  /* 辅助色 - 极客深青 #00897B (10%使用) */
  --td-success-color: #00897B;
  --td-success-color-1: #E6F7F5;
  --td-success-color-5: #4DB6AC;
  --td-success-color-7: #00897B;
  --td-success-color-light: var(--td-success-color-1);
  
  /* 强调色 - 日光芥末 #FFC107 (10%使用) */
  --td-warning-color: #FFC107;
  --td-warning-color-1: #FFF9E6;
  --td-warning-color-5: #FFD54F;
  --td-warning-color-7: #FFC107;
  --td-warning-color-light: var(--td-warning-color-1);
  
  /* 错误色 - 警示红 #E53935 */
  --td-error-color: #E53935;
  --td-error-color-1: #FFEBEE;
  --td-error-color-5: #EF5350;
  --td-error-color-7: #E53935;
  --td-error-color-light: var(--td-error-color-1);
  
  /* ========== 背景色 (60%使用) ========== */
  --td-bg-color-page: #FAFAFA;        /* 陶瓷白 - 页面背景 */
  --td-bg-color-container: #FFFFFF;   /* 纯白 - 卡片背景 */
  --td-bg-color-secondarycontainer: #F5F5F5;
  
  /* ========== 文字颜色 ========== */
  --td-text-color-primary: #333333;    /* 炭黑 - 主标题 */
  --td-text-color-secondary: #666666;  /* 副标题 */
  --td-text-color-placeholder: #999999; /* 占位文字 */
  --td-text-color-disabled: #CCCCCC;   /* 禁用 */
  --td-text-color-anti: rgba(255, 255, 255, 0.87); /* 白色文字 */
  
  /* ========== 自定义品牌变量 ========== */
  /* 用于价格、促销等特殊场景 */
  --brand-coral: #FF6B58;
  --brand-coral-gradient: linear-gradient(135deg, #FF8A75 0%, #FF6B58 100%);
  --brand-teal: #00897B;
  --brand-mustard: #FFC107;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);

  /* ========== 消费侧卡片设计 Token ========== */
  /* 仅用于消费侧组件，不影响商户侧 */
  --customer-card-padding: 24rpx;
  --customer-card-gap: 24rpx;
  --customer-card-margin: 16rpx;
  --customer-card-radius: 16rpx;
  --customer-card-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  --customer-card-shadow-active: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --customer-image-size: 180rpx;
  --customer-image-radius: 12rpx;
  --customer-title-size: 32rpx;
  --customer-subtitle-size: 26rpx;
  --customer-caption-size: 24rpx;
  --customer-section-gap: 16rpx;
  --customer-page-padding: 24rpx;

  /* ========== 统一文字系统 (Typography System) ========== */
  --font-size-display: 48rpx;
  --font-size-title: 36rpx;    /* 页面标题 */
  --font-size-heading: 32rpx;  /* 卡片/模块标题 */
  --font-size-base: 28rpx;     /* 正文/列表项 */
  --font-size-sm: 26rpx;       /* 辅助文本 */
  --font-size-xs: 24rpx;       /* 说明/标签 */
  --font-size-xxs: 20rpx;      /* 角标 */

  /* ========== 统一间距系统 (Spacing System) - 8rpx网格 ========== */
  --spacer-xxs: 4rpx;   /* 极微 */
  --spacer-xs: 8rpx;    /* 紧凑 (icon-text) */
  --spacer-sm: 16rpx;   /* 小 (card-margin, tag-gap) */
  --spacer-md: 24rpx;   /* 中 (card-padding) */
  --spacer-lg: 32rpx;   /* 大 (section-gap) */
  --spacer-xl: 48rpx;   /* 超大 */
  --spacer-xxl: 64rpx;  /* 巨型 */


  /* ========== 统一圆角系统 (Radius System) ========== */
  --radius-xs: 4rpx;    /* 极小 (标签) */
  --radius-sm: 8rpx;    /* 小 (小卡片/按钮) */
  --radius-md: 12rpx;   /* 中 (标准卡片/图片) */
  --radius-lg: 16rpx;   /* 大 (大卡片/弹窗) */
  --radius-xl: 24rpx;   /* 超大 (底部面板) */
  --radius-round: 999rpx; /* 全圆 (胶囊/头像) */

  /* ========== 统一层级系统 (Z-Index System) ========== */
  --z-index-base: 1;
  --z-index-sticky: 100;   /* 吸顶元素 */
  --z-index-dropdown: 800; /* 下拉菜单 */
  --z-index-fixed: 1000;   /* 固定底部栏/悬浮按钮 */
  --z-index-modal: 2000;   /* 弹窗/遮罩 */
  --z-index-toast: 3000;   /* 提示框 */

  /* ========== 统一动效系统 (Motion System) ========== */
  --transition-base: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-fade: 0.3s ease-in-out;

  /* ========== 安全区域 (Safe Area) ========== */
  --safe-area-bottom: env(safe-area-inset-bottom);
}

/* ========== 深色模式 ========== */
page[data-theme="dark"] {
  /* 品牌色微调（深色模式下更柔和） */
  --td-brand-color: #FF8A7A;
  --td-brand-color-8: #FF8A7A;
  
  /* 背景色 */
  --td-bg-color-page: #121212;
  --td-bg-color-container: #1E1E1E;
  --td-bg-color-secondarycontainer: #2C2C2C;
  
  /* 文字颜色 */
  --td-text-color-primary: #E0E0E0;
  --td-text-color-secondary: #B0B0B0;
  --td-text-color-placeholder: #808080;
  --td-text-color-disabled: #606060;
  
  /* 边框 */
  --td-border-level-1-color: #3C3C3C;
  --td-border-level-2-color: #2C2C2C;
  
  /* 辅助色调整 */
  --td-success-color: #26A69A;
  --td-warning-color: #FFD54F;
  --td-error-color: #FF6B6B;
  
  /* 品牌色 */
  --brand-coral: #FF8A7A;
  --brand-coral-gradient: linear-gradient(135deg, #FF9B8B 0%, #FF8A7A 100%);
  --brand-teal: #26A69A;
  --brand-mustard: #FFD54F;
  
  /* 阴影（深色模式下更明显） */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.5);
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 全局收紧表单分组标题与内容间距（影响 t-cell-group） */
.t-cell-group {
  margin: 0 !important;
}

.t-cell-group__title {
  padding: 12rpx 24rpx !important;
  font-size: 26rpx !important;
  color: #666 !important;
  background: #f7f7f7 !important;
  line-height: 36rpx !important;
}

.t-cell-group__wrapper {
  margin-top: 0 !important;
}


