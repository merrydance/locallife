.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.page-content {
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.loading-state {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.section-error-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  background: var(--td-error-color-1, #fff1f0);
  border: 1rpx solid var(--td-error-color-3, #ffccc7);
  color: var(--td-error-color);
  border-radius: var(--radius-md);
  padding: var(--spacer-sm) var(--spacer-md);
}

.section-error-text {
  flex: 1;
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

.section-error-action {
  color: var(--td-brand-color);
  font-size: var(--font-size-sm);
  font-weight: 600;
}

.section-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.section-desc {
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-sm);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
}

.section-loading {
  padding: var(--spacer-md) 0;
  display: flex;
  justify-content: center;
}

.section-state-block {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.section-empty-hint {
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  background: var(--td-bg-color-secondarycontainer);
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.reconciliation-tabs {
  --td-tabs-bg-color: transparent;
}

.reconciliation-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.reconciliation-card {
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.reconciliation-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.reconciliation-header-main {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.reconciliation-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.reconciliation-meta {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.reconciliation-summary {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.reconciliation-info-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.reconciliation-label {
  width: 128rpx;
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.reconciliation-value {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  flex: 1;
  word-break: break-all;
}

.reconciliation-sn {
  font-family: 'Courier New', monospace;
  letter-spacing: 1px;
}

.reconciliation-multiline {
  white-space: pre-wrap;
  line-height: 1.6;
}

.reconciliation-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: var(--spacer-xs);
}

.reconciliation-resolved-hint {
  padding-top: var(--spacer-xs);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
  text-align: right;
}

/* ==================== 打印机列表 ==================== */

.printer-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.printer-card {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.printer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.printer-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.printer-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.printer-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-label {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
  width: 100rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

.info-value.sn {
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  letter-spacing: 1px;
}

.scene-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.no-scene {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.printer-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid var(--td-component-stroke);
}

/* ==================== 表单弹窗 ==================== */

.form-popup {
  background: var(--td-bg-color-container);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  max-height: 85vh;
}

.form-scroll {
  max-height: 85vh;
  box-sizing: border-box;
  padding: 32rpx 24rpx var(--popup-bottom-padding-md);
}

.form-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  text-align: center;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-helper {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--td-text-color-placeholder);
  margin-bottom: 12rpx;
}

.form-item-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.required {
  color: var(--td-error-color);
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--td-component-stroke);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  background-color: var(--td-bg-color-secondarycontainer);
}

.inline-options {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding-top: 4rpx;
}

.inline-option {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.form-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 36rpx;
}

.status-popup {
  background: var(--td-bg-color-container);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  padding: 32rpx 24rpx var(--popup-bottom-padding-md);
}

.status-popup-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.status-popup-subtitle {
  margin-top: 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.status-popup-loading {
  padding: 48rpx 0;
  display: flex;
  justify-content: center;
}

.status-panel {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.status-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.status-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.status-value {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
  word-break: break-all;
}

.status-multiline {
  white-space: pre-wrap;
}

.status-popup-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 36rpx;
}

.form-actions t-button {
  flex: 1;
}

.status-popup-actions t-button {
  flex: 1;
}
