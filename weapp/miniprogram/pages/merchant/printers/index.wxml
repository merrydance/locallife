<custom-navbar title="打印设备" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验设备管理权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="{{accessBlockDescription || '打印设备和后厨协同设置仅支持老板或店长管理'}}" />
    <view class="state-meta" wx:if="{{merchantName || accessRoleLabel !== '--'}}">
      <text wx:if="{{merchantName}}">当前门店：{{merchantName}}</text>
      <text wx:if="{{accessRoleLabel !== '--'}}">当前身份：{{accessRoleLabel}}</text>
    </view>
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载设备中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '设备加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重试</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <view class="result-bar">
        <text class="result-summary">{{resultSummaryText}}</text>
      </view>

      <view class="printer-entry-actions">
        <t-button theme="primary" icon="print" bind:tap="onBindSelfCloudPrinter">绑定乐客来福打印机</t-button>
        <t-button theme="default" variant="outline" icon="add" bind:tap="onCreatePrinter">添加其他打印机</t-button>
      </view>

      <view wx:if="{{commandResultText}}" class="command-result">
        <view class="command-result__copy">
          <text class="command-result__title">{{commandResultText}}</text>
          <text class="command-result__note">{{commandResultNote}}</text>
        </view>
        <t-button
          wx:if="{{commandResultPrinterId}}"
          size="small"
          theme="primary"
          variant="outline"
          data-id="{{commandResultPrinterId}}"
          bind:tap="onViewPrinterStatus"
        >查看状态</t-button>
      </view>

      <merchant-printer-reconciliation-section
        jobs="{{reconciliationJobs}}"
        error-message="{{reconciliationErrorMessage}}"
        loading="{{reconciliationLoading}}"
        retrying-job-id="{{retryingReconciliationJobId}}"
        bind:refresh="onRefreshReconciliationJobs"
        bind:retry="onRetryReconciliationJob"
      />

      <view wx:if="{{loading && !printers.length}}" class="loading-state">
        <t-loading theme="circular" size="40rpx" text="加载中..." vertical />
      </view>

      <t-empty wx:elif="{{!loading && !printers.length}}" icon="info-circle" description="当前还没有打印设备，先绑定或添加一台" />

      <view wx:else class="printer-list">
        <block wx:for="{{printers}}" wx:key="id">
          <t-cell-group class="printer-card">
            <view class="printer-card-main" bindtap="onOpenEditPrinter" data-id="{{item.id}}">
              <view class="printer-card__header">
                <view class="printer-card__heading">
                  <view class="printer-card__title-row">
                    <text class="printer-card__title">{{item.printer_name}}</text>
                    <t-tag size="small" theme="{{item.is_active ? 'success' : 'default'}}" variant="light">{{item.active_label}}</t-tag>
                  </view>
                  <text class="printer-card__subtitle">用于{{item.printer_role_label}} · {{item.printer_type_label}}</text>
                </view>
              </view>

              <view class="printer-card__tag-row">
                <t-tag size="small" theme="default" variant="light">{{item.printer_type_label}}</t-tag>
                <t-tag size="small" theme="default" variant="light">{{item.printer_role_label}}</t-tag>
              </view>

              <view class="printer-detail-list">
                <view class="printer-detail-row">
                  <text class="printer-detail-label">设备类型</text>
                  <text class="printer-detail-value">{{item.printer_type_label}}</text>
                </view>
                <view class="printer-detail-row">
                  <text class="printer-detail-label">设备角色</text>
                  <text class="printer-detail-value">{{item.printer_role_label}}</text>
                </view>
                <view class="printer-detail-row">
                  <text class="printer-detail-label">外卖打印</text>
                  <text class="printer-detail-value">{{item.print_takeout_label}}</text>
                </view>
                <view class="printer-detail-row">
                  <text class="printer-detail-label">堂食打印</text>
                  <text class="printer-detail-value">{{item.print_dine_in_label}}</text>
                </view>
                <view class="printer-detail-row">
                  <text class="printer-detail-label">预订打印</text>
                  <text class="printer-detail-value">{{item.print_reservation_label}}</text>
                </view>
                <view class="printer-detail-row">
                  <text class="printer-detail-label">创建时间</text>
                  <text class="printer-detail-value">{{item.created_at_label || '--'}}</text>
                </view>
                <view class="printer-detail-row">
                  <text class="printer-detail-label">更新时间</text>
                  <text class="printer-detail-value">{{item.updated_at_label || '--'}}</text>
                </view>
              </view>
            </view>

            <t-divider />

            <view class="printer-action-bar" catchtap="onActionsCatch">
              <view class="printer-action-slot">
                <t-button class="printer-action-button" variant="text" theme="default" size="small" icon="edit" data-id="{{item.id}}" bind:tap="onOpenEditPrinter">编辑</t-button>
              </view>
              <t-divider layout="vertical" />
              <view class="printer-action-slot">
                <t-button class="printer-action-button" variant="text" theme="primary" size="small" icon="info-circle" loading="{{statusLoading && statusPrinterId === item.id}}" disabled="{{deletingPrinterId === item.id || testingPrinterId === item.id}}" data-id="{{item.id}}" bind:tap="onViewPrinterStatus">状态</t-button>
              </view>
              <t-divider layout="vertical" />
              <view class="printer-action-slot">
                <t-button class="printer-action-button" variant="text" theme="default" size="small" icon="print" loading="{{testingPrinterId === item.id}}" disabled="{{deletingPrinterId === item.id || testingPrinterId === item.id}}" data-id="{{item.id}}" data-name="{{item.printer_name}}" bind:tap="onRequestTestPrinter">测试</t-button>
              </view>
              <t-divider layout="vertical" />
              <view class="printer-action-slot">
                <t-button class="printer-action-button" variant="text" theme="danger" size="small" icon="delete" loading="{{deletingPrinterId === item.id}}" disabled="{{deletingPrinterId === item.id || testingPrinterId === item.id}}" data-id="{{item.id}}" data-name="{{item.printer_name}}" bind:tap="onRequestDeletePrinter">删除</t-button>
              </view>
            </view>
          </t-cell-group>
        </block>
      </view>

      <t-fab icon="add" bind:click="onCreatePrinter" />
    </view>
  </block>

  <t-popup visible="{{statusPopupVisible}}" placement="bottom" bind:visible-change="onStatusPopupVisibleChange">
    <view class="status-popup">
      <view class="status-popup__header">
        <text class="status-popup__title">打印机实时状态</text>
        <text class="status-popup__subtitle">{{statusPrinterName || '打印机'}}</text>
      </view>

      <view wx:if="{{statusLoading}}" class="status-popup__state">
        <t-loading theme="circular" size="36rpx" text="查询设备状态中..." vertical />
      </view>

      <view wx:elif="{{statusErrorMessage}}" class="status-popup__state">
        <t-empty icon="error-circle" description="{{statusErrorMessage}}" />
      </view>

      <view wx:elif="{{liveStatus}}" class="status-panel">
        <view class="status-row">
          <text class="status-label">在线状态</text>
          <t-tag size="small" theme="{{liveStatus.online ? 'success' : 'warning'}}" variant="light">{{liveStatus.online_label}}</t-tag>
        </view>
        <view class="status-row">
          <text class="status-label">工作状态</text>
          <t-tag size="small" theme="{{liveStatus.working ? 'success' : 'warning'}}" variant="light">{{liveStatus.working_label}}</t-tag>
        </view>
        <view class="status-row">
          <text class="status-label">设备角色</text>
          <text class="status-value">{{liveStatus.role_label}}</text>
        </view>
        <view class="status-row" wx:if="{{liveStatus.model}}">
          <text class="status-label">设备型号</text>
          <text class="status-value">{{liveStatus.model}}</text>
        </view>
        <view class="status-row" wx:if="{{liveStatus.print_logo !== undefined}}">
          <text class="status-label">打印 Logo</text>
          <text class="status-value">{{liveStatus.print_logo ? '已开启' : '未开启'}}</text>
        </view>
        <view class="status-row" wx:if="{{liveStatus.scan_switch !== undefined}}">
          <text class="status-label">扫码开关</text>
          <text class="status-value">{{liveStatus.scan_switch ? '已开启' : '未开启'}}</text>
        </view>
        <view class="status-row">
          <text class="status-label">查询时间</text>
          <text class="status-value">{{liveStatus.checked_at_label}}</text>
        </view>
      </view>

      <view class="status-popup__actions">
        <t-button theme="default" bind:tap="closeStatusPopup">关闭</t-button>
        <t-button theme="primary" loading="{{statusLoading}}" bind:tap="onRefreshPrinterStatus">重新查询</t-button>
      </view>
    </view>
  </t-popup>

  <t-dialog
    visible="{{confirmDialogVisible}}"
    title="{{confirmDialogTitle}}"
    using-custom-navbar="{{true}}"
    confirm-btn="{{ { content: confirmDialogConfirmText, theme: confirmDialogConfirmTheme, loading: confirmDialogSubmitting } }}"
    cancel-btn="取消"
    bind:confirm="onConfirmDialogAction"
    bind:cancel="onCancelConfirmDialog"
    bind:close="onCancelConfirmDialog"
  >
    <view slot="content" class="confirm-dialog__content">
      <text>{{confirmDialogContent}}</text>
    </view>
  </t-dialog>
</view>
