<custom-navbar title="打印机管理" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">

  <view wx:if="{{initialLoading}}" class="loading-state">
    <t-loading theme="circular" size="40rpx" text="加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '打印机数据加载失败，请重试'}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <view wx:if="{{refreshErrorMessage}}" class="section-error-hint">
      <text class="section-error-text">{{refreshErrorMessage}}</text>
      <text class="section-error-action" bindtap="onRetryRefresh">重新同步</text>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view>
          <view class="section-title">异常对账任务</view>
          <view class="section-desc">云端补偿未完成时，商户可在这里查看并重试同步。</view>
        </view>
      </view>

      <t-tabs value="{{currentReconciliationStatus}}" bind:change="onReconciliationTabChange" t-class="reconciliation-tabs">
        <t-tab-panel label="待处理" value="pending"><view /></t-tab-panel>
        <t-tab-panel label="已解决" value="resolved"><view /></t-tab-panel>
      </t-tabs>

      <view wx:if="{{loading && initialLoading}}" class="section-loading">
        <t-loading theme="circular" size="32rpx" text="同步对账任务中..." />
      </view>

      <view wx:elif="{{reconciliationError && !reconciliationJobs.length}}" class="section-state-block">
        <t-empty icon="error-circle" description="{{reconciliationErrorMessage || '对账任务加载失败，请稍后重试'}}" />
        <t-button theme="primary" size="small" shape="round" bind:tap="onRetryRefresh">重新加载</t-button>
      </view>

      <view wx:elif="{{reconciliationJobs.length}}" class="reconciliation-list">
        <view class="reconciliation-card" wx:for="{{reconciliationJobs}}" wx:key="id">
          <view class="reconciliation-header">
            <view class="reconciliation-header-main">
              <text class="reconciliation-title">{{item.title}}</text>
              <text class="reconciliation-meta">{{item.printer_name}} · {{item.created_at_label}}</text>
            </view>
            <t-tag size="small" variant="dark" theme="{{item.status_theme}}">{{item.status_label}}</t-tag>
          </view>

          <view class="reconciliation-summary">{{item.summary}}</view>

          <view class="reconciliation-info-row">
            <text class="reconciliation-label">触发来源</text>
            <text class="reconciliation-value">{{item.source_action_label}}</text>
          </view>
          <view class="reconciliation-info-row">
            <text class="reconciliation-label">打印机类型</text>
            <text class="reconciliation-value">{{item.printer_type === 'feieyun' ? '飞鹅云' : item.printer_type === 'yilianyun' ? '易联云' : '其他'}}</text>
          </view>
          <view class="reconciliation-info-row">
            <text class="reconciliation-label">序列号</text>
            <text class="reconciliation-value reconciliation-sn">{{item.printer_sn}}</text>
          </view>
          <view class="reconciliation-info-row">
            <text class="reconciliation-label">重试次数</text>
            <text class="reconciliation-value">{{item.retry_count}}</text>
          </view>
          <view class="reconciliation-info-row" wx:if="{{item.failure_reason_label}}">
            <text class="reconciliation-label">异常原因</text>
            <text class="reconciliation-value reconciliation-multiline">{{item.failure_reason_label}}</text>
          </view>
          <view class="reconciliation-info-row" wx:if="{{item.last_error_label}}">
            <text class="reconciliation-label">最近错误</text>
            <text class="reconciliation-value reconciliation-multiline">{{item.last_error_label}}</text>
          </view>
          <view class="reconciliation-info-row" wx:if="{{item.resolved_at_label}}">
            <text class="reconciliation-label">解决时间</text>
            <text class="reconciliation-value">{{item.resolved_at_label}}</text>
          </view>
          <view class="reconciliation-info-row">
            <text class="reconciliation-label">最近更新</text>
            <text class="reconciliation-value">{{item.updated_at_label}}</text>
          </view>

          <view wx:if="{{item.can_retry}}" class="reconciliation-actions">
            <t-button
              size="small"
              theme="primary"
              shape="round"
              loading="{{retryingReconciliationId === item.id}}"
              disabled="{{retryingReconciliationId === item.id || !item.can_retry}}"
              catchtap="onRetryReconciliationJob"
              data-id="{{item.id}}"
              data-name="{{item.printer_name}}"
            >{{item.action_label}}</t-button>
          </view>
          <view wx:else class="reconciliation-resolved-hint">任务已完成，无需再次重试</view>
        </view>
      </view>

      <view wx:else class="section-empty-hint">{{reconciliationEmptyMessage}}</view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view>
          <view class="section-title">已接入打印机</view>
          <view class="section-desc">维护打印机基础配置、打印场景与测试动作。</view>
        </view>
        <t-button size="small" variant="outline" theme="primary" shape="round" bind:tap="onGoPrintAnomalies">打印异常</t-button>
      </view>

      <view wx:if="{{printersError && !printers.length}}" class="section-state-block">
        <t-empty icon="error-circle" description="{{printersErrorMessage || '打印机列表加载失败，请稍后重试'}}" />
        <t-button theme="primary" size="small" shape="round" bind:tap="onRetryRefresh">重新加载</t-button>
      </view>

      <t-empty wx:elif="{{!(printers && printers.length)}}" icon="info-circle" description="暂无打印机，点击右下角添加" />

      <view wx:else class="printer-list">
        <view class="printer-card" wx:for="{{printers}}" wx:key="id" bindtap="onPrinterClick" data-id="{{item.id}}">
          <view class="printer-header">
            <view class="printer-name-row">
              <t-icon name="print" size="36rpx" color="var(--td-brand-color)" />
              <text class="printer-name">{{item.printer_name}}</text>
            </view>
            <t-tag size="extra-small" variant="dark" theme="{{item.is_active ? 'success' : 'default'}}">
              {{item.is_active ? '启用' : '停用'}}
            </t-tag>
          </view>

          <view class="printer-info">
            <view class="info-row">
              <text class="info-label">类型</text>
              <text class="info-value">{{item.printer_type === 'feieyun' ? '飞鹅云' : item.printer_type === 'yilianyun' ? '易联云' : '其他'}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">角色</text>
              <text class="info-value">{{item.printer_role === 'kitchen' ? '后厨' : '前台'}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">序列号</text>
              <text class="info-value sn">{{item.printer_sn}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">打印场景</text>
              <view class="scene-tags">
                <t-tag wx:if="{{item.print_takeout}}" size="extra-small" variant="outline" theme="primary" shape="round">外卖</t-tag>
                <t-tag wx:if="{{item.print_dine_in}}" size="extra-small" variant="outline" theme="primary" shape="round">堂食</t-tag>
                <t-tag wx:if="{{item.print_reservation}}" size="extra-small" variant="outline" theme="primary" shape="round">预约</t-tag>
                <text wx:if="{{!item.print_takeout && !item.print_dine_in && !item.print_reservation}}" class="no-scene">未配置</text>
              </view>
            </view>
          </view>

          <view class="printer-actions" catchtap="onActionsCatch">
            <t-button size="extra-small" theme="primary" variant="outline" shape="round" loading="{{statusLoading && statusPrinterId === item.id}}" disabled="{{testingPrinterId === item.id || deletingPrinterId === item.id || (statusLoading && statusPrinterId === item.id)}}" catchtap="onViewPrinterStatus" data-id="{{item.id}}">状态</t-button>
            <t-button size="extra-small" theme="default" shape="round" loading="{{testingPrinterId === item.id}}" disabled="{{testingPrinterId === item.id || deletingPrinterId === item.id}}" catchtap="onTestPrinter" data-id="{{item.id}}" data-name="{{item.printer_name}}">测试</t-button>
            <t-button size="extra-small" theme="danger" variant="outline" shape="round" loading="{{deletingPrinterId === item.id}}" disabled="{{testingPrinterId === item.id || deletingPrinterId === item.id}}" catchtap="onDeletePrinter" data-id="{{item.id}}" data-name="{{item.printer_name}}">删除</t-button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <t-fab icon="add" bind:click="onAddPrinter" />

  <t-popup wx:if="{{formVisible}}" visible="{{formVisible}}" placement="bottom" bind:visible-change="onCloseForm">
    <view class="form-popup">
      <scroll-view scroll-y class="form-scroll">
        <view class="form-title">{{isEdit ? '编辑打印机' : '添加打印机'}}</view>

        <view class="form-item">
          <text class="form-label">打印机名称 <text class="required">*</text></text>
          <input class="form-input" value="{{formData.printer_name}}" data-field="printer_name" placeholder="如 前台打印机" bindinput="onTextInput" />
        </view>

        <view class="form-item" wx:if="{{!isEdit}}">
          <text class="form-label">序列号 <text class="required">*</text></text>
          <input class="form-input" value="{{formData.printer_sn}}" data-field="printer_sn" placeholder="打印机机身序列号" bindinput="onTextInput" />
        </view>

        <view class="form-item">
          <text class="form-label">密钥{{isEdit ? '（留空不修改）' : ''}} <text class="required" wx:if="{{!isEdit}}">*</text></text>
          <input class="form-input" value="{{formData.printer_key}}" data-field="printer_key" placeholder="打印机密钥" bindinput="onTextInput" />
        </view>

        <view class="form-item" wx:if="{{!isEdit}}">
          <text class="form-label">打印机品牌 <text class="required">*</text></text>
          <view class="form-helper">当前商户侧新增接入仅支持飞鹅云，历史设备仍会按原类型展示。</view>
          <radio-group class="inline-options" bindchange="onTypeChange">
            <label class="inline-option" wx:for="{{printerTypeOptions}}" wx:key="value">
              <radio value="{{item.value}}" checked="{{formData.printer_type === item.value}}" color="var(--td-brand-color)" />
              <text>{{item.label}}</text>
            </label>
          </radio-group>
        </view>

        <view class="form-item">
          <text class="form-label">打印机角色 <text class="required">*</text></text>
          <radio-group class="inline-options" bindchange="onRoleChange">
            <label class="inline-option" wx:for="{{printerRoleOptions}}" wx:key="value">
              <radio value="{{item.value}}" checked="{{formData.printer_role === item.value}}" color="var(--td-brand-color)" />
              <text>{{item.label}}</text>
            </label>
          </radio-group>
        </view>

        <view class="form-item form-item-switch">
          <text class="form-label">打印外卖订单</text>
          <t-switch value="{{formData.print_takeout}}" data-field="print_takeout" bind:change="onSwitchChange" size="large" />
        </view>

        <view class="form-item form-item-switch">
          <text class="form-label">打印堂食订单</text>
          <t-switch value="{{formData.print_dine_in}}" data-field="print_dine_in" bind:change="onSwitchChange" size="large" />
        </view>

        <view class="form-item form-item-switch">
          <text class="form-label">打印预约订单</text>
          <t-switch value="{{formData.print_reservation}}" data-field="print_reservation" bind:change="onSwitchChange" size="large" />
        </view>

        <view class="form-item form-item-switch" wx:if="{{isEdit}}">
          <text class="form-label">启用打印机</text>
          <t-switch value="{{formData.is_active}}" data-field="is_active" bind:change="onSwitchChange" size="large" />
        </view>

        <view class="form-actions">
          <t-button theme="default" bind:tap="onCloseForm" shape="round">取消</t-button>
          <t-button theme="primary" loading="{{formSubmitting}}" bind:tap="onSubmitForm" shape="round">保存</t-button>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <t-popup wx:if="{{statusPopupVisible}}" visible="{{statusPopupVisible}}" placement="bottom" bind:visible-change="onCloseStatusPopup">
    <view class="status-popup">
      <view class="status-popup-title">打印机实时状态</view>
      <view class="status-popup-subtitle">{{statusPrinterName || '打印机'}}</view>

      <view wx:if="{{statusLoading}}" class="status-popup-loading">
        <t-loading theme="circular" size="36rpx" text="查询云端状态中..." vertical />
      </view>

      <view wx:elif="{{liveStatus}}" class="status-panel">
        <view class="status-row">
          <text class="status-label">在线状态</text>
          <t-tag size="small" theme="{{liveStatus.online ? 'success' : 'warning'}}" variant="light">{{liveStatus.online_label}}</t-tag>
        </view>
        <view class="status-row">
          <text class="status-label">工作状态</text>
          <t-tag size="small" theme="{{liveStatus.working ? 'success' : 'warning'}}" variant="light">{{liveStatus.working_label}}</t-tag>
        </view>
        <view class="status-row">
          <text class="status-label">打印机角色</text>
          <text class="status-value">{{liveStatus.role_label}}</text>
        </view>
        <view class="status-row">
          <text class="status-label">云端返回</text>
          <text class="status-value status-multiline">{{liveStatus.provider_status || '暂无返回'}}</text>
        </view>
        <view class="status-row" wx:if="{{liveStatus.model}}">
          <text class="status-label">设备型号</text>
          <text class="status-value">{{liveStatus.model}}</text>
        </view>
        <view class="status-row" wx:if="{{liveStatus.info_status}}">
          <text class="status-label">信息状态</text>
          <text class="status-value">{{liveStatus.info_status}}</text>
        </view>
        <view class="status-row" wx:if="{{liveStatus.print_logo !== undefined}}">
          <text class="status-label">打印 Logo</text>
          <text class="status-value">{{liveStatus.print_logo ? '已开启' : '未开启'}}</text>
        </view>
        <view class="status-row" wx:if="{{liveStatus.scan_switch !== undefined}}">
          <text class="status-label">扫码开关</text>
          <text class="status-value">{{liveStatus.scan_switch ? '已开启' : '未开启'}}</text>
        </view>
        <view class="status-row">
          <text class="status-label">查询时间</text>
          <text class="status-value">{{liveStatus.checked_at_label}}</text>
        </view>
      </view>

      <view class="status-popup-actions">
        <t-button theme="default" shape="round" bind:tap="onCloseStatusPopup">关闭</t-button>
        <t-button theme="primary" shape="round" loading="{{statusLoading}}" bind:tap="onRefreshPrinterStatus">重新查询</t-button>
      </view>
    </view>
  </t-popup>

</view>
