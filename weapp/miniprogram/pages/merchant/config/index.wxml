<custom-navbar title="配置中心" showBack="{{true}}" />

<view class="page-container" style="padding-top: calc({{navBarHeight}}px + var(--spacer-sm));">
  <view class="hero-card">
    <view class="hero-title">配置中心</view>
    <view class="hero-desc">统一管理门店资料、营业配置、营销规则、收款能力与设备设置。页面布局、底部按钮和弹层间距已按最新设计规范收口。</view>
  </view>

  <view wx:for="{{configSections}}" wx:key="id" class="section-block">
    <view class="section-head">
      <view class="section-title">{{item.title}}</view>
      <view class="section-desc">{{item.desc}}</view>
    </view>

    <t-cell-group theme="card">
      <t-cell
        wx:for="{{item.items}}"
        wx:key="id"
        title="{{item.title}}"
        description="{{item.desc}}"
        arrow
        data-path="{{item.path}}"
        bind:tap="onTapItem"
      />
    </t-cell-group>
  </view>
</view>
