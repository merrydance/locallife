<custom-navbar title="配置中心" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <block wx:elif="{{accessReady}}">
    <view class="hero-card">
      <view class="hero-title">配置中心</view>
      <view class="hero-desc">按主题维护门店资料、经营配置、营销规则、结算能力、设备设置；门店成员协作与品牌合作入口已分开归类。</view>
    </view>

    <view wx:for="{{configSections}}" wx:key="id" class="section-block">
      <view class="section-head">
        <view class="section-title">{{item.title}}</view>
        <view class="section-desc">{{item.desc}}</view>
      </view>

      <view wx:if="{{item.groups && item.groups.length}}" class="section-groups">
        <view wx:for="{{item.groups}}" wx:for-item="group" wx:key="id" class="section-subgroup">
          <view class="subgroup-head">
            <view class="subgroup-title">{{group.title}}</view>
            <view class="subgroup-desc">{{group.desc}}</view>
          </view>

          <t-cell-group theme="card">
            <t-cell
              wx:for="{{group.items}}"
              wx:for-item="entry"
              wx:key="id"
              title="{{entry.title}}"
              description="{{entry.desc}}"
              arrow
              data-path="{{entry.path}}"
              bind:tap="onTapItem"
            />
          </t-cell-group>
        </view>
      </view>

      <t-cell-group wx:else theme="card">
        <t-cell
          wx:for="{{item.items}}"
          wx:key="id"
          title="{{item.title}}"
          description="{{item.desc}}"
          arrow
          data-path="{{item.path}}"
          bind:tap="onTapItem"
        />
      </t-cell-group>
    </view>
  </block>

  <view wx:else class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>
</view>
