.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding: 0 var(--spacer-md) calc(var(--spacer-lg) + var(--safe-area-bottom));
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.hero-card {
  margin-bottom: var(--spacer-md);
  padding: var(--spacer-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.hero-title {
  font-size: var(--font-size-title);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.hero-desc {
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.section-block {
  margin-bottom: var(--spacer-md);
}

.section-groups {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-subgroup {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.section-head {
  margin-bottom: var(--spacer-sm);
}

.subgroup-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  line-height: 1.5;
}

.subgroup-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.subgroup-desc {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}
