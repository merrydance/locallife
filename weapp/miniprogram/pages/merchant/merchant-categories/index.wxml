<custom-navbar title="经营类目设置" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">

  <!-- 重要性提示 -->
  <view class="notice-card">
    <view class="notice-icon">⚡</view>
    <view class="notice-text">
      <view class="notice-title">类目影响您的曝光排名</view>
      <view class="notice-desc">类目标签决定店铺出现在首页哪些分类筛选下，直接影响顾客发现您的概率。建议选择 1-3 个最能代表您店铺的类目。</view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="circular" size="40px" />
  </view>

  <!-- 类目选择 -->
  <view wx:elif="{{tags.length === 0}}" class="empty-wrap">
    <view class="empty-text">暂无可选类目，请联系平台配置</view>
  </view>

  <view wx:else class="tags-section">
    <view class="section-header">
      <text class="section-title">选择经营类目</text>
      <text class="section-count">已选 {{selectedCount}}/5</text>
    </view>
    <view class="tags-grid">
      <view
        wx:for="{{tags}}"
        wx:key="id"
        class="tag-item {{item.selected ? 'tag-selected' : ''}}"
        data-index="{{index}}"
        bindtap="onTagTap"
      >
        <text class="tag-check">{{item.selected ? '✓ ' : ''}}</text>
        <text class="tag-name">{{item.name}}</text>
      </view>
    </view>

    <view class="save-wrap">
      <button
        class="save-btn {{saving ? 'saving' : ''}}"
        disabled="{{saving}}"
        bindtap="onSave"
      >{{saving ? '保存中...' : '保存经营类目'}}</button>
    </view>
  </view>

</view>
