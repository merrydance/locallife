<custom-navbar title="经营类目设置" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">

  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" shape="round" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>

  <block wx:elif="{{accessReady}}">

  <!-- 重要性提示 -->
  <view class="notice-card">
    <view class="notice-icon">⚡</view>
    <view class="notice-text">
      <view class="notice-title">类目影响店铺的分类展示</view>
      <view class="notice-desc">平台会根据类目决定店铺出现在什么分类和筛选中。建议选择 1-3 个最能代表实际经营范围的类目。</view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="circular" size="40px" />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '经营类目加载失败，请重试'}}" />
    <t-button theme="primary" shape="round" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <!-- 类目选择 -->
  <view wx:elif="{{tags.length === 0}}" class="empty-wrap">
    <t-empty description="暂无可选类目，请联系平台配置" />
    <t-button theme="default" shape="round" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="tags-section">
    <view class="section-header">
      <view>
        <text class="section-title">选择经营类目</text>
        <text class="section-tip">保存后将以平台返回的类目结果为准</text>
      </view>
      <view class="section-meta">
        <text class="section-count">已选 {{selectedCount}}/5</text>
        <text class="section-status {{hasChanges ? 'status-pending' : 'status-synced'}}">{{hasChanges ? '待保存' : '已同步'}}</text>
      </view>
    </view>
    <view class="tags-grid">
      <view
        wx:for="{{tags}}"
        wx:key="id"
        class="tag-item {{item.selected ? 'tag-selected' : ''}} {{saving ? 'tag-disabled' : ''}}"
        data-index="{{index}}"
        bindtap="onTagTap"
      >
        <text class="tag-check">{{item.selected ? '✓ ' : ''}}</text>
        <text class="tag-name">{{item.name}}</text>
      </view>
    </view>

    <view class="save-wrap">
      <t-button
        theme="primary"
        shape="round"
        size="large"
        block
        loading="{{saving}}"
        disabled="{{saving || !hasChanges || loading}}"
        bind:tap="onSave"
      >{{saving ? '保存中...' : (hasChanges ? '保存经营类目' : '当前无变更')}}</t-button>
    </view>
  </view>

  </block>

</view>
