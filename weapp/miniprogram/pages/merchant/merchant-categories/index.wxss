.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding: var(--spacer-md);
  box-sizing: border-box;
}

/* 重要性提示卡片 */
.notice-card {
  display: flex;
  gap: var(--spacer-sm);
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.notice-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  line-height: 1.2;
}

.notice-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: #d46b08;
  margin-bottom: 6rpx;
}

.notice-desc {
  font-size: var(--font-size-xs);
  color: #873800;
  line-height: 1.6;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
}

.state-block,
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-md);
  padding: 80rpx 0;
}

/* 类目区域 */
.tags-section {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-tip {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary, #888);
}

.section-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.section-count {
  font-size: var(--font-size-xs);
  color: #888;
}

.section-status {
  font-size: var(--font-size-xxs);
  padding: 6rpx 14rpx;
  border-radius: var(--radius-round);
}

.status-pending {
  background: #fff7e6;
  color: #ad6800;
}

.status-synced {
  background: var(--td-brand-color-light);
  color: var(--td-brand-color);
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
  margin-bottom: 40rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 28rpx;
  border-radius: var(--radius-round);
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
  font-size: var(--font-size-base);
  color: #444;
  transition: all 0.2s;
}

.tag-item.tag-selected {
  border-color: var(--td-brand-color);
  background: var(--td-brand-color-light);
  color: var(--td-brand-color);
  font-weight: 600;
}

.tag-item.tag-disabled {
  opacity: 0.7;
}

.tag-check {
  font-size: 24rpx;
  font-weight: 700;
}

.tag-name {
  font-size: var(--font-size-base);
}

/* 保存按钮 */
.save-wrap {
  padding-top: 8rpx;
}
