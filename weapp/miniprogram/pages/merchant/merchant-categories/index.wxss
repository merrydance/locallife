.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 重要性提示卡片 */
.notice-card {
  display: flex;
  gap: 16rpx;
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.notice-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  line-height: 1.2;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d46b08;
  margin-bottom: 6rpx;
}

.notice-desc {
  font-size: 24rpx;
  color: #873800;
  line-height: 1.6;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
}

/* 空状态 */
.empty-wrap {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 类目区域 */
.tags-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-count {
  font-size: 24rpx;
  color: #888;
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
  font-size: 28rpx;
  color: #444;
  transition: all 0.2s;
}

.tag-item.tag-selected {
  border-color: #07c160;
  background: #e8f9ef;
  color: #07c160;
  font-weight: 600;
}

.tag-check {
  font-size: 24rpx;
  font-weight: 700;
}

.tag-name {
  font-size: 28rpx;
}

/* 保存按钮 */
.save-wrap {
  padding-top: 8rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.save-btn.saving {
  opacity: 0.7;
}
