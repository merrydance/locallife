<custom-navbar title="异议记录" showBack="{{true}}" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载异议记录中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '异议记录加载失败，请重试'}}" />
    <view class="retry-button" bindtap="onRetry">重试</view>
  </view>

  <block wx:else>
    <view class="tips">查看商户已提交的异议记录、平台审核结论和复核备注，点击卡片可进入异议详情。</view>

    <view class="summary-grid">
      <view class="summary-card accent-total">
        <text class="summary-label">全部异议</text>
        <text class="summary-value">{{summary.total}}</text>
      </view>
      <view class="summary-card accent-pending">
        <text class="summary-label">待审核</text>
        <text class="summary-value">{{summary.submitted}}</text>
      </view>
      <view class="summary-card accent-approved">
        <text class="summary-label">已通过</text>
        <text class="summary-value">{{summary.approved}}</text>
      </view>
      <view class="summary-card accent-rejected">
        <text class="summary-label">已驳回</text>
        <text class="summary-value">{{summary.rejected}}</text>
      </view>
    </view>

    <t-tabs value="{{currentTab}}" bind:change="onTabChange" t-class="appeal-tabs">
      <t-tab-panel label="全部" value="all"><view /></t-tab-panel>
      <t-tab-panel label="待审核" value="submitted"><view /></t-tab-panel>
      <t-tab-panel label="已通过" value="approved"><view /></t-tab-panel>
      <t-tab-panel label="已驳回" value="rejected"><view /></t-tab-panel>
    </t-tabs>

    <view wx:if="{{refreshErrorMessage}}" class="notice-banner">
      <t-notice-bar theme="error" visible="{{true}}" content="{{refreshErrorMessage}}">
        <text slot="operation" class="notice-banner-operation" bindtap="onRetryRefresh">重试</text>
      </t-notice-bar>
    </view>

    <view wx:if="{{loading && !filteredAppeals.length}}" class="state-block state-block-compact">
      <t-loading theme="circular" size="40rpx" text="同步异议中..." vertical />
    </view>

    <view wx:elif="{{!loading && filteredAppeals.length === 0}}" class="empty-wrap">
      <t-empty description="当前筛选下暂无异议记录" />
    </view>

    <view wx:else class="appeal-list">
      <view wx:for="{{filteredAppeals}}" wx:key="id" class="appeal-card" data-appeal-id="{{item.id}}" bindtap="onViewAppealDetail">
        <view class="card-header">
          <text class="order-no">订单 {{item.orderNo}}</text>
          <t-tag size="small" variant="dark" theme="{{item.statusTheme}}">{{item.statusLabel}}</t-tag>
        </view>
        <view class="row">
          <text class="label">索赔类型</text>
          <text class="value">{{item.claimTypeLabel}}</text>
        </view>
        <view class="row">
          <text class="label">关联金额</text>
          <text class="value">{{item.claimAmountText}}</text>
        </view>
        <view class="row" wx:if="{{item.compensationAmountText}}">
          <text class="label">复核补偿</text>
          <text class="value">{{item.compensationAmountText}}</text>
        </view>
        <view class="desc">
          <text class="desc-label">索赔说明</text>
          <text class="desc-value">{{item.claimDescription}}</text>
        </view>
        <view class="desc">
          <text class="desc-label">异议理由</text>
          <text class="desc-value">{{item.reason}}</text>
        </view>
        <view class="desc" wx:if="{{item.reviewNotes}}">
          <text class="desc-label">平台备注</text>
          <text class="desc-value">{{item.reviewNotes}}</text>
        </view>
        <view class="card-footer">
          <text class="time">提交于 {{item.createdAtLabel}}</text>
          <text class="time">{{item.resultHint}}</text>
          <text class="time" wx:if="{{item.reviewedAtLabel !== '暂无'}}">复核于 {{item.reviewedAtLabel}}</text>
        </view>
      </view>

      <view wx:if="{{loadingMore}}" class="list-footer">
        <t-loading theme="circular" size="32rpx" text="加载更多异议中..." vertical />
      </view>

      <view wx:elif="{{!hasMore && filteredAppeals.length > 0}}" class="list-footer list-footer-end">
        <text>没有更多异议记录了</text>
      </view>
    </view>
  </block>
</view>
