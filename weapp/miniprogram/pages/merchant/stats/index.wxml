<custom-navbar title="经营统计" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: var(--spacer-lg);"
>
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载经营统计中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '经营统计加载失败，请重试'}}" />
    <view class="retry-button" bindtap="onRetry">重试</view>
  </view>

  <block wx:else>
    <view class="toolbar">
      <view class="range-group">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="key"
          class="range-chip {{currentRange === item.key ? 'range-chip-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onSelectRange"
        >
          {{item.label}}
        </view>
      </view>
      <view class="toolbar-actions">
        <t-button size="small" theme="primary" variant="outline" shape="round" bind:tap="onGoCustomerStats">客户分析</t-button>
        <text class="updated-at">更新于 {{updatedAtLabel}}</text>
      </view>
    </view>

    <view wx:if="{{summaryAvailable}}">
      <view wx:if="{{summaryError}}" class="section-error-hint">
        <text>{{summaryErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetrySummary">重试</text>
      </view>

      <view class="summary-grid">
        <view class="summary-card accent-sales">
          <text class="summary-label">区间成交额</text>
          <text class="summary-value">{{summary.totalSalesText}}</text>
          <text class="summary-meta">{{summary.dateRangeLabel}}</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">完成订单</text>
          <text class="summary-value">{{summary.completedOrders}}</text>
          <text class="summary-meta">总订单 {{summary.totalOrders}}</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">完成率</text>
          <text class="summary-value">{{summary.completionRateText}}</text>
          <text class="summary-meta">取消 {{summary.cancelledOrders}} 单</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">平均客单</text>
          <text class="summary-value">{{summary.avgOrderValueText}}</text>
          <text class="summary-meta">近 {{currentRange === '7d' ? '7' : '30'}} 天订单均值</text>
        </view>
      </view>

      <view class="meta-strip">
        <view class="meta-row">
          <text class="meta-label">日均成交额</text>
          <text class="meta-value">{{summary.avgDailySalesText}}</text>
        </view>
        <view class="meta-row">
          <text class="meta-label">平台服务费</text>
          <text class="meta-value">{{summary.totalCommissionText}}</text>
        </view>
        <view class="meta-row">
          <text class="meta-label">统计口径</text>
          <text class="meta-value">{{summary.dateRangeLabel}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="section-state-block">
      <t-empty description="{{summaryErrorMessage || '经营概览加载失败，请重试'}}" />
      <view class="retry-button" bindtap="onRetrySummary">重试</view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">热销菜</text>
        <text class="section-subtitle">按销量排序，右侧为菜品小计</text>
      </view>

      <view wx:if="{{topDishesError && topDishesAvailable}}" class="section-error-hint section-error-hint-spaced">
        <text>{{topDishesErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetryTopDishes">重试</text>
      </view>

      <view wx:if="{{topDishesAvailable}}">
        <t-empty wx:if="{{!topDishes.length}}" description="当前区间暂无热销菜数据" />

        <view wx:else class="dish-list">
          <view wx:for="{{topDishes}}" wx:key="dish_id" class="dish-card">
            <view class="dish-rank">{{item.rank}}</view>
            <view class="dish-body">
              <view class="dish-head">
                <text class="dish-name">{{item.dish_name}}</text>
                <text class="dish-revenue">小计 {{item.revenueText}}</text>
              </view>
              <view class="dish-meta">
                <text>售出 {{item.soldLabel}}</text>
                <text>单价 {{item.priceText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="section-state-block section-state-block-compact">
        <t-empty description="{{topDishesErrorMessage || '热销菜加载失败，请重试'}}" />
        <view class="retry-button" bindtap="onRetryTopDishes">重试</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">日趋势</text>
        <text class="section-subtitle">观察每天成交额与订单波动</text>
      </view>

      <view wx:if="{{dailyStatsError && dailyStatsAvailable}}" class="section-error-hint section-error-hint-spaced">
        <text>{{dailyStatsErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetryDailyStats">重试</text>
      </view>

      <view wx:if="{{dailyStatsAvailable}}">
        <t-empty wx:if="{{!dailyStats.length}}" description="当前区间暂无日趋势数据" />

        <view wx:else class="insight-list">
          <view wx:for="{{dailyStats}}" wx:key="date" class="insight-card">
            <view class="insight-head">
              <text class="insight-title">{{item.dateLabel}}</text>
              <text class="insight-value">{{item.totalSalesText}}</text>
            </view>
            <view class="insight-meta">
              <text>{{item.orderCountLabel}}</text>
              <text>{{item.orderMixLabel}}</text>
              <text>平台服务费 {{item.commissionText}}</text>
            </view>
            <view class="insight-progress-track">
              <view class="insight-progress-fill insight-progress-fill-daily" style="width: {{item.barWidth}}"></view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="section-state-block section-state-block-compact">
        <t-empty description="{{dailyStatsErrorMessage || '日趋势加载失败，请重试'}}" />
        <view class="retry-button" bindtap="onRetryDailyStats">重试</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">订单来源</text>
        <text class="section-subtitle">看清本期成交结构</text>
      </view>

      <view wx:if="{{sourceStatsError && sourceStatsAvailable}}" class="section-error-hint section-error-hint-spaced">
        <text>{{sourceStatsErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetrySourceStats">重试</text>
      </view>

      <view wx:if="{{sourceStatsAvailable}}">
        <t-empty wx:if="{{!sourceStats.length}}" description="当前区间暂无订单来源数据" />

        <view wx:else class="insight-list">
          <view wx:for="{{sourceStats}}" wx:key="order_type" class="insight-card">
            <view class="insight-head">
              <text class="insight-title">{{item.orderTypeLabel}}</text>
              <text class="insight-value">{{item.totalSalesText}}</text>
            </view>
            <view class="insight-meta">
              <text>{{item.orderCountLabel}}</text>
              <text>{{item.shareText}}</text>
            </view>
            <view class="insight-progress-track">
              <view class="insight-progress-fill" style="width: {{item.barWidth}}"></view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="section-state-block section-state-block-compact">
        <t-empty description="{{sourceStatsErrorMessage || '订单来源加载失败，请重试'}}" />
        <view class="retry-button" bindtap="onRetrySourceStats">重试</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">高峰时段</text>
        <text class="section-subtitle">辅助排班与备餐</text>
      </view>

      <view wx:if="{{hourlyStatsError && hourlyStatsAvailable}}" class="section-error-hint section-error-hint-spaced">
        <text>{{hourlyStatsErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetryHourlyStats">重试</text>
      </view>

      <view wx:if="{{hourlyStatsAvailable}}">
        <t-empty wx:if="{{!hourlyStats.length}}" description="当前区间暂无时段成交数据" />

        <view wx:else class="insight-list">
          <view wx:for="{{hourlyStats}}" wx:key="hour" class="insight-card insight-card-compact">
            <view class="insight-head">
              <text class="insight-title">{{item.hourLabel}}</text>
              <text class="insight-value">{{item.orderCountLabel}}</text>
            </view>
            <view class="insight-progress-track">
              <view class="insight-progress-fill insight-progress-fill-accent" style="width: {{item.barWidth}}"></view>
            </view>
            <view class="insight-meta">
              <text>平均客单 {{item.avgOrderAmountText}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="section-state-block section-state-block-compact">
        <t-empty description="{{hourlyStatsErrorMessage || '高峰时段加载失败，请重试'}}" />
        <view class="retry-button" bindtap="onRetryHourlyStats">重试</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">顾客复购</text>
        <text class="section-subtitle">观察回头客质量</text>
      </view>

      <view wx:if="{{repurchaseError && repurchaseAvailable}}" class="section-error-hint section-error-hint-spaced">
        <text>{{repurchaseErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetryRepurchase">重试</text>
      </view>

      <view wx:if="{{repurchaseAvailable}}" class="insight-grid">
        <view class="insight-stat-card accent-soft">
          <text class="insight-stat-label">复购率</text>
          <text class="insight-stat-value">{{repurchaseSummary.repurchaseRateText}}</text>
          <text class="insight-stat-meta">近 {{currentRange === '7d' ? '7' : '30'}} 天</text>
        </view>
        <view class="insight-stat-card">
          <text class="insight-stat-label">累计顾客</text>
          <text class="insight-stat-value">{{repurchaseSummary.totalUsers}}</text>
          <text class="insight-stat-meta">参与下单用户</text>
        </view>
        <view class="insight-stat-card">
          <text class="insight-stat-label">复购顾客</text>
          <text class="insight-stat-value">{{repurchaseSummary.repeatUsers}}</text>
          <text class="insight-stat-meta">至少下单 2 次</text>
        </view>
        <view class="insight-stat-card">
          <text class="insight-stat-label">人均订单</text>
          <text class="insight-stat-value">{{repurchaseSummary.avgOrdersPerUserText}}</text>
          <text class="insight-stat-meta">顾客平均下单频次</text>
        </view>
      </view>

      <view wx:else class="section-state-block section-state-block-compact">
        <t-empty description="{{repurchaseErrorMessage || '顾客复购加载失败，请重试'}}" />
        <view class="retry-button" bindtap="onRetryRepurchase">重试</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">分类小计</text>
        <text class="section-subtitle">按菜品小计看分类表现</text>
      </view>

      <view wx:if="{{categoryStatsError && categoryStatsAvailable}}" class="section-error-hint section-error-hint-spaced">
        <text>{{categoryStatsErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetryCategoryStats">重试</text>
      </view>

      <view wx:if="{{categoryStatsAvailable}}">
        <t-empty wx:if="{{!categoryStats.length}}" description="当前区间暂无分类小计数据" />

        <view wx:else class="insight-list">
          <view wx:for="{{categoryStats}}" wx:key="category_name" class="insight-card">
            <view class="insight-head">
              <text class="insight-title">{{item.category_name || '未分类菜品'}}</text>
              <text class="insight-value">{{item.totalSalesText}}</text>
            </view>
            <view class="insight-meta">
              <text>{{item.orderCountLabel}}</text>
              <text>{{item.totalQuantityLabel}}</text>
              <text>{{item.shareText}}</text>
            </view>
            <view class="insight-progress-track">
              <view class="insight-progress-fill" style="width: {{item.barWidth}}"></view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="section-state-block section-state-block-compact">
        <t-empty description="{{categoryStatsErrorMessage || '分类小计加载失败，请重试'}}" />
        <view class="retry-button" bindtap="onRetryCategoryStats">重试</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">预订池概览</text>
        <text class="section-subtitle">当前商户预订状态</text>
      </view>

      <view wx:if="{{reservationStatsError && reservationStatsAvailable}}" class="section-error-hint section-error-hint-spaced">
        <text>{{reservationStatsErrorMessage}}</text>
        <text class="section-error-action" bindtap="onRetryReservationStats">重试</text>
      </view>

      <view wx:if="{{reservationStatsAvailable}}" class="reservation-grid">
        <view class="reservation-card">
          <text class="reservation-label">待支付</text>
          <text class="reservation-value">{{reservationStats.pending_count}}</text>
        </view>
        <view class="reservation-card">
          <text class="reservation-label">待确认</text>
          <text class="reservation-value">{{reservationStats.paid_count}}</text>
        </view>
        <view class="reservation-card">
          <text class="reservation-label">已确认</text>
          <text class="reservation-value">{{reservationStats.confirmed_count}}</text>
        </view>
        <view class="reservation-card">
          <text class="reservation-label">已签到</text>
          <text class="reservation-value">{{reservationStats.checked_in_count || 0}}</text>
        </view>
        <view class="reservation-card">
          <text class="reservation-label">已完成</text>
          <text class="reservation-value">{{reservationStats.completed_count}}</text>
        </view>
        <view class="reservation-card warning-card">
          <text class="reservation-label">爽约 / 过期</text>
          <text class="reservation-value">{{reservationStats.no_show_count + reservationStats.expired_count}}</text>
        </view>
      </view>

      <view wx:else class="section-state-block section-state-block-compact">
        <t-empty description="{{reservationStatsErrorMessage || '预订池加载失败，请重试'}}" />
        <view class="retry-button" bindtap="onRetryReservationStats">重试</view>
      </view>
    </view>
  </block>
</view>