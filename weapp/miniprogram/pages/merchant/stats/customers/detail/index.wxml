<custom-navbar title="客户详情" showBack="{{true}}" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载客户详情中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '客户详情加载失败，请重试'}}" />
    <view class="retry-button" bindtap="onRetry">重新加载</view>
  </view>

  <block wx:else>
    <view wx:if="{{refreshErrorMessage}}" class="section-error-hint">
      <text>{{refreshErrorMessage}}</text>
      <text class="section-error-action" bindtap="onRetryRefresh">重新同步</text>
    </view>

    <view wx:if="{{detail}}" class="content">
      <view class="hero-card">
        <view class="hero-head">
          <view>
            <text class="hero-title">{{detail.display_name}}</text>
            <text class="hero-subtitle">{{detail.phone_text}}</text>
          </view>
          <t-button wx:if="{{detail.phone}}" size="small" theme="primary" variant="outline" shape="round" bind:tap="onCallCustomer">联系顾客</t-button>
        </view>

        <view class="stats-grid">
          <view class="stats-card">
            <text class="stats-label">累计消费</text>
            <text class="stats-value">{{detail.total_amount_text}}</text>
          </view>
          <view class="stats-card">
            <text class="stats-label">订单次数</text>
            <text class="stats-value">{{detail.total_orders}}</text>
          </view>
          <view class="stats-card">
            <text class="stats-label">平均客单</text>
            <text class="stats-value">{{detail.avg_order_amount_text}}</text>
          </view>
          <view class="stats-card">
            <text class="stats-label">首次下单</text>
            <text class="stats-value stats-value-small">{{detail.first_order_at_text}}</text>
          </view>
        </view>

        <view class="meta-strip">
          <view class="meta-row">
            <text class="meta-label">最近下单</text>
            <text class="meta-value">{{detail.last_order_at_text}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">顾客 ID</text>
            <text class="meta-value">{{detail.user_id}}</text>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <text class="section-title">偏好菜品</text>
          <t-tag size="small" variant="light" theme="primary">Top {{detail.favorite_dishes_view.length}}</t-tag>
        </view>

        <t-empty wx:if="{{!detail.favorite_dishes_view.length}}" icon="info-circle" description="当前还没有足够的点餐偏好数据" />

        <view wx:else class="dish-list">
          <view wx:for="{{detail.favorite_dishes_view}}" wx:key="dish_id" class="dish-card">
            <view class="dish-head">
              <text class="dish-name">{{item.dish_name}}</text>
              <t-tag size="small" variant="dark">{{item.total_quantity}} 份</t-tag>
            </view>
            <view class="dish-summary">{{item.summary}}</view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>