.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.section-error-hint {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: var(--td-error-color-1);
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-error-action {
  flex-shrink: 0;
  color: var(--td-brand-color);
  font-weight: 600;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-card,
.section-card,
.stats-card,
.dish-card {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-card,
.section-card {
  padding: 24rpx;
}

.hero-head,
.stats-grid,
.meta-row,
.dish-head,
.section-head {
  display: flex;
}

.hero-head,
.meta-row,
.dish-head,
.section-head {
  justify-content: space-between;
  gap: 16rpx;
}

.hero-head {
  align-items: flex-start;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.hero-subtitle,
.stats-label,
.meta-label,
.meta-value,
.dish-summary {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.stats-card {
  padding: 20rpx;
}

.stats-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color);
}

.stats-value-small {
  font-size: 24rpx;
  color: var(--td-text-color-primary);
}

.meta-strip {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.meta-row + .meta-row {
  margin-top: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.dish-card {
  padding: 20rpx;
  background: var(--td-bg-color-secondarycontainer);
  box-shadow: none;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.dish-summary {
  margin-top: 10rpx;
}