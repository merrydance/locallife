.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.section-error-hint {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: var(--td-error-color-1);
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-error-action {
  flex-shrink: 0;
  color: var(--td-brand-color);
  font-weight: 600;
}

.hero-card,
.customer-card {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.hero-subtitle,
.hero-meta,
.customer-phone,
.stats-label,
.meta-label,
.meta-value,
.hint-block,
.load-more {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.sort-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.sort-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-container);
  color: var(--td-text-color-secondary);
  font-size: 24rpx;
  box-shadow: var(--shadow-sm);
}

.sort-chip-active {
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
}

.customer-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.customer-card {
  padding: 24rpx;
}

.customer-header,
.stats-grid,
.meta-row,
.action-row {
  display: flex;
}

.customer-header,
.meta-row,
.action-row {
  justify-content: space-between;
  gap: 16rpx;
}

.customer-header {
  align-items: flex-start;
}

.customer-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.customer-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.stats-grid {
  gap: 16rpx;
  margin-top: 20rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.stats-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color);
}

.meta-row {
  margin-top: 14rpx;
}

.hint-block {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.action-row {
  margin-top: 20rpx;
}

.load-more {
  text-align: center;
  padding: 12rpx 0 24rpx;
}

.load-more-end {
  color: var(--td-text-color-placeholder);
}