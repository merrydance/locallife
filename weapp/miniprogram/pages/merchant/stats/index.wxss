@import "../../../styles/merchant-stats-state.wxss";
@import "../../../styles/merchant-stats-sections.wxss";

.page-container {
  min-height: 100vh;
  padding: 0 var(--spacer-md) 24rpx;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.range-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.range-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-container);
  color: var(--td-text-color-secondary);
  font-size: 24rpx;
}

.range-chip-active {
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
}

.updated-at {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.accent-sales {
  background: linear-gradient(135deg, var(--td-brand-color), #1c7ef5);
}

.accent-sales .summary-label,
.accent-sales .summary-value,
.accent-sales .summary-meta {
  color: var(--td-text-color-anti);
}

.summary-label,
.summary-meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.summary-value {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--td-text-color-primary);
}
