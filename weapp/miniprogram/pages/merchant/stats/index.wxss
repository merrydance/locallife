.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.section-state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 80rpx 24rpx;
  border-radius: 20rpx;
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.section-state-block-compact {
  margin-bottom: 0;
  padding: 48rpx 24rpx 24rpx;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.section-error-hint {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: var(--td-error-color-1);
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-error-hint-spaced {
  margin-bottom: 18rpx;
}

.section-error-action {
  flex-shrink: 0;
  color: var(--td-brand-color);
  font-weight: 600;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.range-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.range-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-container);
  color: var(--td-text-color-secondary);
  font-size: 24rpx;
}

.range-chip-active {
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
}

.updated-at {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.accent-sales {
  background: linear-gradient(135deg, var(--td-brand-color), #1c7ef5);
}

.accent-sales .summary-label,
.accent-sales .summary-value,
.accent-sales .summary-meta {
  color: var(--td-text-color-anti);
}

.summary-label,
.summary-meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.summary-value {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.meta-strip,
.section-block {
  border-radius: 20rpx;
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.meta-strip {
  margin-bottom: 24rpx;
  padding: 16rpx 24rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  font-size: 25rpx;
}

.meta-row + .meta-row {
  border-top: 1px solid var(--td-component-stroke);
}

.meta-label {
  color: var(--td-text-color-secondary);
}

.meta-value {
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.section-block {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dish-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
}

.dish-card + .dish-card {
  border-top: 1px solid var(--td-component-stroke);
}

.dish-rank {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--td-brand-color-1);
  color: var(--td-brand-color);
  font-size: 26rpx;
  font-weight: 700;
}

.dish-body {
  flex: 1;
  min-width: 0;
}

.dish-head,
.dish-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.dish-head {
  margin-bottom: 8rpx;
}

.dish-name,
.dish-revenue {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.dish-name {
  flex: 1;
  min-width: 0;
  font-weight: 600;
}

.dish-revenue {
  font-weight: 700;
}

.dish-meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.reservation-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.reservation-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.warning-card {
  background: var(--td-warning-color-1);
}

.reservation-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.reservation-value {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--td-text-color-primary);
}