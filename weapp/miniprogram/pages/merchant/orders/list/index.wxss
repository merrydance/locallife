.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

.tabs-container {
  background-color: #fff !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.list-section {
  padding: 24rpx 16rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  border-left: 8rpx solid transparent;
}

/* 待接单状态特殊高亮 */
.order-card[data-status="paid"] {
  border-left-color: var(--td-brand-color);
  background-color: #f0f5ff;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--td-component-stroke);
  margin-bottom: 20rpx;
}

.order-no-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  background-color: #f2f3f5;
  color: #5e6066;
}

.type-tag.takeout {
  background-color: #e6f7ff;
  color: #1890ff;
}

.type-tag.dine_in {
  background-color: #f6ffed;
  color: #52c41a;
}

.order-no {
  font-size: 32rpx;
  font-weight: bold;
  font-family: 'Outfit', sans-serif;
}

.status-label {
  font-size: 24rpx;
  font-weight: 500;
}

.card-content {
  margin-bottom: 24rpx;
}

.dish-list {
  margin-bottom: 20rpx;
}

.dish-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.dish-name {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.dish-qty {
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
}

.order-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
  margin-top: 16rpx;
}

.customer-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.notes {
  flex: 1;
  font-size: 24rpx;
  color: var(--td-warning-color);
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-right: 20rpx;
}

.total-info {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.card-actions {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--td-component-stroke);
}

.load-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.loading-state {
  padding: 100rpx 0;
  display: flex;
  justify-content: center;
}
