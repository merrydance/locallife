.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

.page-content {
  gap: var(--spacer-sm);
  padding: 0;
}

.control-panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: var(--td-bg-color-page);
}

.tabs-container {
  background-color: transparent !important;
  box-shadow: none;
  border-radius: 0;
  overflow: visible;
}

.type-filter-strip {
  white-space: nowrap;
  background: transparent;
  padding: 12rpx 0;
  box-shadow: none;
  border-radius: 0;
}

.type-filter-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 0;
}

.type-filter-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-page);
  color: var(--td-text-color-secondary);
  font-size: 24rpx;
  transition: all 0.2s ease;
}

.type-filter-pill.is-active {
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
}

.list-section {
  padding: var(--spacer-sm) 0;
}

.order-card {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  border-left: 8rpx solid transparent;
}

/* 待接单状态特殊高亮 */
.order-card[data-status="paid"] {
  border-left-color: var(--td-brand-color);
  background-color: var(--td-brand-color-1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--td-component-stroke);
  margin-bottom: 20rpx;
}

.order-no-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-tag {
  font-size: var(--font-size-xxs);
  background-color: var(--td-bg-color-secondarycontainer);
  color: var(--td-text-color-secondary);
}

.type-tag.takeout {
  background-color: var(--td-brand-color-1);
  color: var(--td-brand-color-9);
}

.type-tag.dine_in {
  background-color: var(--td-success-color-1);
  color: var(--td-success-color);
}

.type-tag.reservation {
  background-color: var(--td-warning-color-1);
  color: var(--td-warning-color-7);
}

.order-no {
  font-size: 32rpx;
  font-weight: bold;
  font-family: 'Outfit', sans-serif;
}

.status-label {
  font-size: 24rpx;
  font-weight: 500;
}

.card-content {
  margin-bottom: 24rpx;
}

.status-hint {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
  margin-bottom: 16rpx;
}

.dish-list {
  margin-bottom: 20rpx;
}

.dish-item {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.dish-main {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.dish-name {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.dish-specs {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--td-text-color-placeholder);
}

.dish-qty {
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
}

.order-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
  margin-top: 16rpx;
}

.customer-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.notes {
  flex: 1;
  font-size: 24rpx;
  color: var(--td-warning-color);
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-right: 20rpx;
}

.total-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  flex-shrink: 0;
}

.total-line,
.income-line {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  white-space: nowrap;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.income-line {
  color: var(--td-success-color);
}

.income-line--pending {
  color: var(--td-text-color-placeholder);
}

.card-actions {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--td-component-stroke);
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.passive-state {
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-secondarycontainer);
  color: var(--td-text-color-secondary);
  text-align: center;
  font-size: 24rpx;
}

.load-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.loading-state {
  padding: 100rpx 0;
  display: flex;
  justify-content: center;
}

.loading-state-page {
  min-height: 100vh;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.section-error-hint {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-error-color-1);
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-error-action {
  flex-shrink: 0;
  color: var(--td-brand-color);
  font-weight: 600;
}
