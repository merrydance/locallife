<custom-navbar title="{{pageTitle}}" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="loading-state loading-state-page">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="loading-state loading-state-page">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="loading-state loading-state-page">
    <t-loading theme="circular" size="40rpx" text="获取订单中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="loading-state loading-state-page">
    <t-empty icon="info-circle" description="{{initialErrorMessage || '订单加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <t-sticky offset-top="{{navBarHeight}}" z-index="40">
        <view class="control-panel">
          <t-tabs value="{{currentStatus}}" bind:change="onTabChange" t-class="tabs-container">
            <t-tab-panel label="待接单" value="paid" />
            <t-tab-panel label="制作中" value="preparing" />
            <t-tab-panel label="待取餐" value="ready" />
            <t-tab-panel label="今日完成" value="completed" />
            <t-tab-panel label="全部" value="" />
          </t-tabs>

          <scroll-view scroll-x class="type-filter-strip" show-scrollbar="false">
            <view class="type-filter-row">
              <view
                wx:for="{{orderTypeOptions}}"
                wx:key="value"
                class="type-filter-pill {{orderTypeFilter === item.value ? 'is-active' : ''}}"
                data-value="{{item.value}}"
                bindtap="onOrderTypeChange"
              >
                {{item.label}}
              </view>
            </view>
          </scroll-view>
        </view>
      </t-sticky>

      <view class="list-section">
        <view wx:if="{{refreshErrorMessage}}" class="section-error-hint">
          <text>{{refreshErrorMessage}}</text>
          <text class="section-error-action" bindtap="onRetryRefresh">重新同步</text>
        </view>

        <view wx:if="{{loading && !orders.length}}" class="loading-state">
          <t-loading theme="circular" size="40rpx" text="获取订单中..." vertical />
        </view>

        <t-empty wx:elif="{{!loading && !orders.length}}" icon="info-circle" description="暂无相关订单" />

        <block wx:else>
          <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="onViewDetail" data-id="{{item.id}}" data-status="{{item.status}}">
            <!-- 头部：订单号 + 类型标签 -->
            <view class="card-header">
              <view class="order-no-row">
                <t-tag size="extra-small" variant="dark" theme="default" shape="round" class="type-tag {{item.order_type}}">{{item.order_type_label}}</t-tag>
                <text class="order-no">#{{item.order_no_short}}</text>
              </view>
              <view class="status-label" style="color: {{item.status_color}}">{{item.status_label}}</view>
            </view>

            <!-- 内容：商品列表预览 -->
            <view class="card-content">
              <view wx:if="{{item.status_hint_label}}" class="status-hint">{{item.status_hint_label}}</view>

              <view class="dish-list">
                <view class="dish-item" wx:for="{{item.items}}" wx:for-item="dish" wx:key="id">
                  <view class="dish-main">
                    <text class="dish-name">{{dish.name}}</text>
                    <text class="dish-specs" wx:if="{{dish.specs_text}}">{{dish.specs_text}}</text>
                  </view>
                  <text class="dish-qty">x{{dish.quantity}}</text>
                </view>
              </view>
              
              <view class="order-meta">
                <view class="customer-info">
                  <t-icon name="location" size="28rpx" />
                  <text>{{item.scene_label}} · {{item.scene_value}}</text>
                </view>
                <view class="time-info">{{item.time_label}}</view>
              </view>

              <view class="order-total-row">
                 <view class="notes" wx:if="{{item.notes}}">
                   <t-tag theme="warning" variant="dark" size="extra-small">备注</t-tag>
                   <text>{{item.notes}}</text>
                 </view>
                 <view class="total-info">
                   合计 <text class="total-price">¥{{item.total_amount / 100}}</text>
                 </view>
              </view>
            </view>

            <!-- 操作栏 -->
            <view class="card-actions" catchtap="preventBubble">
              <view wx:if="{{item.can_accept || item.can_reject}}" class="action-row">
                <t-button
                  wx:if="{{item.can_reject}}"
                  theme="danger"
                  variant="outline"
                  size="small"
                  bind:tap="onRejectOrder"
                  data-id="{{item.id}}"
                  disabled="{{item.submitting}}"
                  shape="round"
                >
                  拒单退款
                </t-button>
                <t-button
                  wx:if="{{item.can_accept}}"
                  theme="primary"
                  size="small"
                  bind:tap="onAcceptOrder"
                  data-id="{{item.id}}"
                  loading="{{item.submitting}}"
                  shape="round"
                >
                  {{item.order_type === 'reservation' ? '接单备菜' : '接单制作'}}
                </t-button>
              </view>
              
              <t-button 
                wx:if="{{item.can_mark_ready}}" 
                block 
                theme="primary"
                size="small" 
                bind:tap="onMarkReady" 
                data-id="{{item.id}}"
                loading="{{item.submitting}}"
               shape="round">
                制作完成
              </t-button>

              <t-button 
                wx:if="{{item.can_complete}}" 
                block 
                theme="success" 
                size="small" 
                bind:tap="onCompleteOrder" 
                data-id="{{item.id}}"
                loading="{{item.submitting}}"
               shape="round">
                确认送达/核销
              </t-button>

              <view wx:if="{{item.show_passive_state}}" class="passive-state">
                <text>{{item.status_label}}</text>
              </view>
            </view>
          </view>
        </block>

        <view wx:if="{{hasMore}}" class="load-more" bindtap="onLoadMore">
          <text>{{loading ? '正在加载...' : '加载更多'}}</text>
        </view>
      </view>
    </view>
  </block>

</view>
