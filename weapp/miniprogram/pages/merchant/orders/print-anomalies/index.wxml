<custom-navbar title="打印异常列表" showBack="{{true}}" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bindtap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载打印异常中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '打印异常加载失败，请重试'}}" />
    <t-button theme="primary" bindtap="onRetry">重试</t-button>
  </view>

  <block wx:else>
    <view class="hero-card">
      <text class="hero-title">打印异常聚合视图</text>
      <text class="hero-subtitle">集中查看当前仍未恢复的异常打印任务，并直接进入订单详情或补打。</text>
    </view>

    <view wx:if="{{syncMessage}}" class="notice-banner">
      <t-notice-bar theme="info" visible="{{true}}" content="{{syncMessage}}" />
    </view>

    <view wx:if="{{refreshErrorMessage}}" class="notice-banner">
      <t-notice-bar theme="error" visible="{{true}}" content="{{refreshErrorMessage}}">
        <text slot="operation" class="notice-banner-operation" bindtap="onRetryRefresh">重试</text>
      </t-notice-bar>
    </view>

    <view class="filter-row">
      <view wx:for="{{filterOptions}}" wx:key="key" class="filter-chip {{currentFilter === item.key ? 'filter-chip-active' : ''}}" data-key="{{item.key}}" bindtap="onChangeFilter">{{item.label}}</view>
    </view>

    <t-empty wx:if="{{!anomalies.length}}" icon="info-circle" description="当前筛选条件下暂无打印异常" />

    <view wx:else class="anomaly-list">
      <view class="anomaly-card" wx:for="{{anomalies}}" wx:key="print_log_id">
        <view class="anomaly-header">
          <view class="anomaly-main">
            <view class="anomaly-title-row">
              <t-tag size="small" variant="dark">{{item.order_type_label}}</t-tag>
              <text class="anomaly-order-no">#{{item.order_no}}</text>
            </view>
            <text class="anomaly-printer">{{item.printer_name}} · {{item.printer_type_label}}</text>
          </view>
          <t-tag size="small" variant="dark" theme="{{item.status_theme}}">{{item.status_label}}</t-tag>
        </view>

        <view class="anomaly-summary">{{item.summary}}</view>

        <view class="anomaly-row">
          <text class="anomaly-label">最后尝试</text>
          <text class="anomaly-value">{{item.last_attempt_label}}</text>
        </view>

        <view wx:if="{{item.vendor_order_id_label}}" class="anomaly-row anomaly-row-top">
          <text class="anomaly-label">云端单号</text>
          <text class="anomaly-value anomaly-value-break">{{item.vendor_order_id_label}}</text>
        </view>

        <view wx:if="{{item.error_message_label}}" class="anomaly-row anomaly-row-top">
          <text class="anomaly-label">失败原因</text>
          <text class="anomaly-value anomaly-value-break">{{item.error_message_label}}</text>
        </view>

        <view wx:if="{{item.retry_hint_label && !item.can_retry}}" class="anomaly-row anomaly-row-top">
          <text class="anomaly-label">暂不可重试</text>
          <text class="anomaly-value anomaly-value-break">{{item.retry_hint_label}}</text>
        </view>

        <view class="anomaly-actions">
          <t-button size="small" theme="default" shape="round" bindtap="onViewOrder" data-order-id="{{item.order_id}}">查看订单</t-button>
          <t-button wx:if="{{item.can_retry}}" size="small" theme="primary" shape="round" loading="{{retryingPrintLogId === item.print_log_id}}" disabled="{{retryingPrintLogId === item.print_log_id}}" bindtap="onRetryPrint" data-order-id="{{item.order_id}}" data-print-log-id="{{item.print_log_id}}" data-printer-name="{{item.printer_name}}">重试打印</t-button>
        </view>
      </view>

      <view wx:if="{{hasMore}}" class="load-more-wrap">
        <t-button theme="default" shape="round" size="large" bindtap="onReachBottom" loading="{{loading}}">加载更多</t-button>
      </view>
    </view>
  </block>
</view>
