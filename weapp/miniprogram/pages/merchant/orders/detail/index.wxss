.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* 状态横幅 */
.status-banner {
  padding: 60rpx 40rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.status-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 内容卡片 */
.content-section {
  padding: 32rpx;
  margin-top: -30rpx;
}

.card-wrap {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 32rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
}

.address-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.contact-text {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

.call-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--td-brand-color-light);
  border-radius: 50%;
}

/* 商品项 */
.dish-item {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.dish-info {
  flex: 1;
}

.dish-name-row {
  display: flex;
  justify-content: space-between;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 500;
}

.dish-price {
  font-size: 28rpx;
}

.dish-specs {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
  margin-top: 4rpx;
}

.dish-qty {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  margin-top: 8rpx;
}

/* 价格小计 */
.price-summary {
  padding-top: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  margin-bottom: 16rpx;
}

.total-row {
  color: var(--td-text-color-primary);
  font-weight: bold;
  font-size: 30rpx;
  margin-top: 8rpx;
}

.total-val {
  color: var(--td-brand-color);
  font-size: 36rpx;
}

.notes-text {
  color: var(--td-warning-color) !important;
}

/* 底部操作 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 32rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.footer-bar.iphone-x {
  padding-bottom: 64rpx;
}

.status-footer {
  text-align: center;
  font-size: 28rpx;
  color: var(--td-text-color-placeholder);
}

.loading-state {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}
