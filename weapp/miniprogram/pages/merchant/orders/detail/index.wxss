@import '../../../../styles/merchant-order-detail-sections.wxss';

.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

/* 状态横幅 */
.status-banner {
  padding: 60rpx 40rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.status-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.status-subdesc {
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.88;
}

/* 内容卡片 */
.content-section {
  padding: 32rpx;
  margin-top: -30rpx;
}

.card-wrap {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 32rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
}

.contact-row {
  margin-top: 20rpx;
}

.address-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.contact-text {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

.call-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--td-bg-color-secondarycontainer);
  border: 1rpx solid var(--td-component-border);
  border-radius: 50%;
}

/* 商品项 */
.dish-item {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.dish-info {
  flex: 1;
}

.dish-name-row {
  display: flex;
  justify-content: space-between;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 500;
}

.dish-price {
  font-size: 28rpx;
}

.dish-specs {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
  margin-top: 4rpx;
}

.dish-qty {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  margin-top: 8rpx;
}

/* 价格小计 */
.price-summary {
  padding-top: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  margin-bottom: 16rpx;
  gap: 24rpx;
}

.summary-row--total,
.summary-row--income {
  color: var(--td-text-color-primary);
  font-weight: bold;
  font-size: 30rpx;
  margin-top: 8rpx;
}

.summary-row--discount {
  color: var(--td-success-color);
}

.summary-row--fee {
  color: var(--td-text-color-secondary);
}

.settlement-groups {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.settlement-group {
  padding: 20rpx 24rpx;
  border: 1rpx solid var(--td-component-border);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
}

.settlement-group__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.settlement-group__title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.settlement-group__total {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.settlement-row {
  margin-bottom: 12rpx;
}

.settlement-row:last-child {
  margin-bottom: 0;
}

.total-val {
  color: var(--td-brand-color);
  font-size: 36rpx;
}

.income-val {
  color: var(--td-success-color);
  font-size: 36rpx;
}
