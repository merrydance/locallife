.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 140rpx var(--spacer-md);
}

.content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.notice-banner {
  margin-bottom: 0;
}

.notice-banner-operation {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  font-weight: 600;
  color: var(--td-brand-color);
}

.hero-card {
  background: var(--td-bg-color-container);
  color: var(--td-text-color-primary);
  border-radius: var(--radius-card);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--td-border-level-1-color);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-order-row,
.hero-metrics,
.hero-tip-row,
.card-head,
.item-card,
.item-title-row,
.item-meta-row,
.row,
.action-bar {
  display: flex;
}

.hero-order-row,
.item-title-row,
.item-meta-row {
  align-items: center;
}

.hero-order-row,
.hero-tip-row,
.card-head,
.row,
.action-bar {
  justify-content: space-between;
}

.hero-order-row,
.hero-tip-row,
.action-bar {
  gap: 12rpx;
}

.hero-order-no {
  font-size: var(--font-size-heading);
  font-weight: 700;
}

.hero-title {
  font-size: 30rpx;
  font-weight: 600;
}

.hero-subtitle,
.metric-label,
.card-subtitle,
.label,
.desc-label,
.item-meta-row,
.item-customizations-label {
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.hero-subtitle,
.metric-label {
  color: var(--td-text-color-secondary);
}

.hero-metrics {
  gap: 16rpx;
  margin-top: var(--spacer-sm);
}

.hero-metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: var(--spacer-sm);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.metric-value {
  font-size: 28rpx;
  font-weight: 600;
}

.hero-tip-row {
  flex-wrap: wrap;
  margin-top: var(--spacer-sm);
}

.meta-chip {
  padding: 10rpx 18rpx;
  border-radius: var(--radius-round);
  background: var(--td-bg-color-secondarycontainer);
  font-size: var(--font-size-xs);
  line-height: 1.4;
}

.meta-chip-warning {
  background: rgba(255, 193, 7, 0.18);
}

.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-card);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-card);
}

.card-title {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.card-title-tight {
  margin-bottom: 0;
}

.card-subtitle,
.label,
.desc-label,
.item-meta-row,
.item-customizations-label {
  color: var(--td-text-color-secondary);
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.item-card {
  align-items: flex-start;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm);
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
}

.item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.item-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.item-title-row {
  gap: 12rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.item-meta-row {
  gap: 16rpx;
  margin-top: 8rpx;
}

.item-customizations {
  padding: 12rpx 16rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
}

.item-customizations-value,
.desc-value,
.value {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-primary);
  line-height: 1.7;
}

.item-customizations-value,
.desc-value {
  display: block;
  margin-top: 8rpx;
}

.row {
  gap: 20rpx;
  margin: var(--spacer-xs) 0;
}

.value {
  text-align: right;
}

.desc {
  margin-top: var(--spacer-sm);
  padding: var(--spacer-sm);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.action-bar {
  align-items: center;
  justify-content: flex-end;
}