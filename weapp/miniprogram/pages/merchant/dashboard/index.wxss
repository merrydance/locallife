.page-container {
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.dashboard-notice {
  margin-bottom: var(--spacer-md);
  border-radius: var(--radius-card);
  overflow: hidden;
}

.hero-card {
  padding: var(--spacer-md);
  border-radius: var(--radius-card);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-component-border);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--spacer-md);
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.hero-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.hero-title-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--spacer-xs);
}

.hero-title {
  max-width: 100%;
  font-size: var(--font-size-title);
  font-weight: 700;
  line-height: 1.2;
  color: var(--td-text-color-primary);
}

.hero-period {
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
  text-align: right;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
}

.metric-card {
  min-width: 0;
  padding: var(--spacer-sm);
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
}

.metric-label {
  display: block;
  font-size: var(--font-size-xxs);
  line-height: 1.4;
  color: var(--td-text-color-secondary);
}

.metric-value {
  display: block;
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-display);
  font-weight: 700;
  line-height: 1.2;
  color: var(--td-text-color-primary);
}

.metric-card--orders .metric-value {
  color: var(--td-brand-color);
}

.metric-card--complaints .metric-value {
  color: var(--td-warning-color);
}

.metric-note {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.section-list {
  margin-top: var(--spacer-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-lg);
}

.section-block {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.section-header {
  padding: 0 8rpx;
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.dashboard-grid {
  background: transparent;
  --td-grid-item-padding: var(--spacer-md);
  --td-grid-card-radius: var(--radius-card);
}

.dashboard-grid-content {
  min-height: 148rpx;
}

.dashboard-grid-text {
  font-size: var(--font-size-xs);
  font-weight: 600;
  line-height: 1.4;
  color: var(--td-text-color-primary);
  text-align: center;
  white-space: normal;
}
