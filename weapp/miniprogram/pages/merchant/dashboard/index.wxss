.page-container {
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.dashboard-notice {
  margin-bottom: var(--spacer-md);
  border-radius: var(--radius-card);
  overflow: hidden;
}

.hero-card {
  padding: var(--spacer-md);
  border-radius: var(--radius-card);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-component-border);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--spacer-md);
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.hero-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.hero-meta-row {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.hero-refresh-trigger {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-refresh-trigger.is-syncing {
  opacity: 0.5;
}

.hero-title-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--spacer-xs);
}

.hero-title {
  max-width: 100%;
  font-size: var(--font-size-title);
  font-weight: 700;
  line-height: 1.2;
  color: var(--td-text-color-primary);
}

.hero-period {
  font-size: var(--font-size-xs);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
  text-align: right;
}

.hero-status-row {
  margin-top: var(--spacer-sm);
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.hero-status-control {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  min-width: 0;
}

.hero-status-text {
  font-size: var(--font-size-sm);
  line-height: 1.4;
  color: var(--td-text-color-primary);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
}

.metric-card {
  min-width: 0;
  padding: var(--spacer-sm);
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
}

.metric-label {
  display: block;
  font-size: var(--font-size-xxs);
  line-height: 1.4;
  color: var(--td-text-color-secondary);
}

.metric-value {
  display: block;
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-display);
  font-weight: 700;
  line-height: 1.2;
  color: var(--td-text-color-primary);
}

.metric-card--orders .metric-value {
  color: var(--td-brand-color);
}

.metric-card--complaints .metric-value {
  color: var(--td-warning-color);
}

.metric-note {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.section-list {
  margin-top: var(--spacer-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-lg);
}

.section-block {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding: var(--spacer-md);
  border-radius: var(--radius-card);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-component-border);
}

.section-header {
  padding-bottom: var(--spacer-xs);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.dashboard-grid {
  background: transparent;
  --td-grid-item-padding: var(--spacer-md);
  --td-grid-card-radius: var(--radius-card);
}

.dashboard-grid-content {
  min-height: 148rpx;
}

.dashboard-grid-text {
  font-size: var(--font-size-xs);
  font-weight: 600;
  line-height: 1.4;
  color: var(--td-text-color-primary);
  text-align: center;
  white-space: normal;
}

.app-bind-modal {
  width: 640rpx;
  max-width: calc(100vw - 64rpx);
  padding: var(--spacer-lg);
  border-radius: var(--radius-card);
  background: var(--td-bg-color-container);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.app-bind-header {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.app-bind-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.app-bind-subtitle {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.app-bind-state {
  min-height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.app-bind-body {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.app-bind-code-card {
  padding: 40rpx 24rpx;
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
  display: flex;
  align-items: center;
  justify-content: center;
}

.app-bind-code {
  font-size: 72rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 12rpx;
  color: var(--td-brand-color);
}

.app-bind-countdown {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
  text-align: center;
}

.app-bind-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--spacer-sm);
}
