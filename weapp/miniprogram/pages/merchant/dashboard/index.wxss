.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部卡片 */
.merchant-header-card {
  padding: 40rpx 32rpx 60rpx;
  background: linear-gradient(180deg, #0052D9 0%, #003A99 100%);
  color: #fff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.merchant-profile {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.merchant-name {
  font-size: 36rpx;
  font-weight: 600;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.2);
}

.tag-open {
  border: 1rpx solid #a8f0cc;
  color: #a8f0cc;
}

.tag-closed {
  border: 1rpx solid #ffcfd1;
  color: #ffcfd1;
}

/* 指标网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
  font-family: 'Outfit', -apple-system, sans-serif;
}

/* 操作条 */
.ops-bar-container {
  padding: 0 32rpx;
  margin-top: -30rpx;
  margin-bottom: 32rpx;
}

.ops-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.ops-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ops-text {
  font-size: 28rpx;
  font-weight: 500;
}

.is-open .ops-info {
  color: var(--td-success-color);
}

.is-closed .ops-info {
  color: var(--td-error-color);
}

/* 卡片区域 */
.card-section {
  margin-bottom: 32rpx;
}

.card-title {
  padding: 0 32rpx 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}

.ranking-list {
  padding: 0 32rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 24rpx 32rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.rank-num {
  width: 44rpx;
  height: 44rpx;
  background-color: #f2f3f5;
  color: #5e6066;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 24rpx;
}

.rank-num.top-three {
  background-color: #ffead4;
  color: #ff7d00;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--td-text-color-primary);
  margin-bottom: 4rpx;
}

.dish-sales {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
}

.dish-revenue {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  font-family: 'Outfit', sans-serif;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
