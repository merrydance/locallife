.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: var(--spacer-lg);
}

.console-error-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin: 0 var(--spacer-lg) var(--spacer-md);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
}

.console-error-banner__body {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.console-error-banner__text {
  flex: 1;
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.state-block,
.section-state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.refresh-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin: 0 var(--spacer-lg) var(--spacer-md);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-error-color-1);
  color: var(--td-text-color-primary);
}

.refresh-banner-text {
  flex: 1;
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.state-block {
  min-height: 60vh;
  padding: var(--spacer-lg);
}

.section-state-block {
  padding: var(--spacer-lg) 0;
}

/* 头部卡片 */
.merchant-header-card {
  padding: var(--spacer-lg) var(--spacer-lg) 60rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.merchant-profile {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.merchant-name {
  font-size: var(--font-size-title);
  font-weight: 600;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: var(--font-size-xxs);
}

.tag-open {
  background: var(--td-success-color-1);
  color: var(--td-success-color);
}

.tag-closed {
  background: var(--td-error-color-1);
  color: var(--td-error-color);
}

/* 指标网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.shortcut-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 28rpx;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.shortcut-card {
  position: relative;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(8rpx);
}

.shortcut-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.shortcut-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-anti);
}

.shortcut-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.82);
}

.shortcut-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--td-brand-color);
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-label {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-anti);
  margin-bottom: 8rpx;
  opacity: 0.75;
}

.stats-value {
  font-size: var(--font-size-title);
  font-weight: bold;
}

/* 操作条 */
.ops-bar-container {
  padding: 0 32rpx;
  margin-top: -30rpx;
  margin-bottom: 32rpx;
}

.ops-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: var(--td-bg-color-container);
  padding: var(--spacer-md) var(--spacer-lg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.ops-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ops-text {
  font-size: var(--font-size-base);
  font-weight: 500;
}

.is-open .ops-info {
  color: var(--td-success-color);
}

.is-closed .ops-info {
  color: var(--td-error-color);
}

/* 卡片区域 */
.card-section {
  margin-bottom: 32rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 var(--spacer-lg) var(--spacer-md);
}

.card-title {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.order-tabs {
  background: var(--td-bg-color-container);
}

.order-flow-list {
  padding: 0 24rpx;
}

.section-error-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md);
  margin-bottom: var(--spacer-sm);
  border-radius: var(--radius-md);
  background: var(--td-error-color-1);
  color: var(--td-text-color-primary);
  font-size: var(--font-size-xs);
}

.order-card {
  display: flex;
  flex-direction: column;
  background: var(--td-bg-color-container);
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  gap: 14rpx;
}

.order-header,
.order-footer,
.order-left {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-left {
  gap: 12rpx;
}

.order-no {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.order-status {
  font-size: var(--font-size-xs);
}

.order-items {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.order-item-line {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.order-time {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-secondary);
}

.order-total {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.more-wrap {
  display: flex;
  justify-content: center;
  padding-top: 8rpx;
}
