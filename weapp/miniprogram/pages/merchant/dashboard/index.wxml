<custom-navbar title="商户工作台" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <t-empty wx:if="{{accessDenied}}" icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />

  <block wx:else>
  <t-skeleton 
    loading="{{initialLoading}}" 
    rowCol="{{ [{ width: '100%', height: '300rpx' }] }}" 
    t-class="skeleton-header"
  >
    <!-- 1. 营业状态切换与商户名称 -->
    <view class="merchant-header-card">
      <view class="header-top">
        <view class="merchant-profile">
          <t-icon name="avatar" size="48rpx" color="rgba(255,255,255,0.8)" />
          <view class="merchant-name">{{merchantInfo.name || '核心商圈店'}}</view>
          <t-tag size="small" variant="dark" theme="default" shape="round" class="status-tag {{isOpen ? 'tag-open' : 'tag-closed'}}">
            {{isOpen ? '营业中' : '休息中'}}
          </t-tag>
        </view>
        <view class="setting-entry" bindtap="onGoToSettings">
          <t-icon name="setting" size="40rpx" color="#fff" />
        </view>
      </view>

      <!-- 今日核心指标 -->
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-label">今日营业额</text>
          <text class="stats-value">¥{{todayStats.revenue / 100}}</text>
        </view>
        <view class="stats-item">
          <text class="stats-label">今日订单</text>
          <text class="stats-value">{{todayStats.orderCount}}</text>
        </view>
        <view class="stats-item">
          <text class="stats-label">实付客单</text>
          <text class="stats-value">¥{{todayStats.avgOrderPrice / 100}}</text>
        </view>
      </view>
    </view>
  </t-skeleton>

  <!-- 2. 在线开关 (粘性设计) -->
  <t-sticky offsetTop="{{navBarHeight}}">
    <view class="ops-bar-container">
      <view class="ops-bar {{isOpen ? 'is-open' : 'is-closed'}}">
        <view class="ops-info">
          <t-icon name="{{isOpen ? 'check-circle' : 'error-circle'}}" size="32rpx" />
          <text class="ops-text">{{isOpen ? '正在接收订单中' : '已暂停接单'}}</text>
        </view>
        <t-button size="extra-small" theme="primary" bind:tap="onToggleBusiness" shape="round">
          {{isOpen ? '打烊' : '开门'}}
        </t-button>
      </view>
    </view>
  </t-sticky>

  <t-skeleton 
    loading="{{initialLoading}}" 
    theme="paragraph"
    t-class="skeleton-body"
    rowCol="{{ [1, 1, { width: '100%', height: '400rpx' }, 1, 1] }}"
  >
    <view class="card-section">
      <view class="card-title">订单流</view>
      <t-tabs value="{{currentOrderTab}}" bind:change="onOrderTabChange" t-class="order-tabs">
        <t-tab-panel label="待接单" value="paid" />
        <t-tab-panel label="制作中" value="preparing" />
        <t-tab-panel label="待完成" value="ready" />
        <t-tab-panel label="已完成" value="completed" />
      </t-tabs>

      <view wx:if="{{orderFlowLoading && !orderFlow.length}}" class="loading-state">
        <t-loading theme="circular" text="加载订单中..." vertical />
      </view>

      <t-empty wx:elif="{{!orderFlow.length}}" icon="info-circle" description="当前分类暂无订单" />

      <view wx:else class="order-flow-list">
        <view class="order-card" wx:for="{{orderFlow}}" wx:key="id" data-id="{{item.id}}" bindtap="onOrderTap">
          <view class="order-header">
            <view class="order-left">
              <t-tag size="small" variant="dark">{{item.order_type_label}}</t-tag>
              <text class="order-no">#{{item.order_no_short}}</text>
            </view>
            <text class="order-status" style="color: {{item.status_color}}">{{item.status_label}}</text>
          </view>

          <view class="order-items">
            <text wx:for="{{item.items}}" wx:key="id" wx:for-item="dish" wx:if="{{index < 2}}" class="order-item-line">
              {{dish.name}} x{{dish.quantity}}
            </text>
          </view>

          <view class="order-footer">
            <text class="order-time">{{item.time_label}}</text>
            <text class="order-total">¥{{item.total_amount / 100}}</text>
          </view>
        </view>

        <view class="more-wrap">
          <t-button size="small" theme="primary" bind:tap="onGoOrderList" shape="round">查看更多订单</t-button>
        </view>
      </view>
    </view>
  </t-skeleton>
  </block>
</view>
