<custom-navbar title="商户管理" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: var(--spacer-lg);"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>

  <block wx:else>
    <t-notice-bar
      wx:if="{{refreshErrorMessage && !initialError}}"
      visible="{{true}}"
      theme="warning"
      content="{{refreshErrorMessage}}"
      prefixIcon="error-circle"
      t-class="dashboard-notice"
    />

    <view wx:if="{{initialError}}" class="state-block">
      <t-empty icon="error-circle" description="{{initialErrorMessage || '商户首页加载失败，请重试'}}" />
      <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
    </view>

    <block wx:else>
      <t-skeleton loading="{{initialLoading}}" rowCol="{{skeletonRows}}">
        <view class="hero-card">
          <view class="hero-top">
            <view class="hero-copy">
              <view class="hero-title-row">
                <view class="hero-title-main">
                  <text class="hero-title">{{activeMerchant.name || '商户中心'}}</text>
                </view>
                <view class="hero-meta-row">
                  <text class="hero-period">{{monthRangeLabel}}</text>
                    <view class="hero-refresh-trigger {{isPageSyncing ? 'is-syncing' : ''}}" bind:tap="onManualRefresh">
                      <t-icon name="refresh" size="36rpx" color="var(--td-text-color-secondary)" />
                    </view>
                </view>
              </view>

                <view class="hero-status-row">
                  <view class="hero-status-stack">
                    <view class="hero-status-control">
                      <text class="hero-status-text">{{businessStateTitle}}</text>
                      <t-switch
                        value="{{isOpen}}"
                        size="medium"
                        loading="{{openStatusSubmitting}}"
                        disabled="{{isPageSyncing}}"
                        bind:change="onOpenStatusSwitchChange"
                      />
                    </view>
                    <text wx:if="{{businessStateHint}}" class="hero-status-hint">{{businessStateHint}}</text>
                  </view>
                </view>
            </view>
          </view>

          <view class="metric-grid">
            <view wx:for="{{overviewMetrics}}" wx:key="id" class="metric-card">
              <text class="metric-label">{{item.label}}</text>
              <text class="metric-value">{{item.value}}</text>
              <text class="metric-note">{{item.note}}</text>
            </view>
          </view>
        </view>

        <view class="section-list">
          <view wx:for="{{sections}}" wx:key="id" class="section-block">
            <view class="section-header">
              <text class="section-title">{{item.title}}</text>
            </view>

            <t-grid column="4" gutter="{{gridGutter}}" border="{{false}}" theme="card" hover="{{true}}" t-class="dashboard-grid">
              <t-grid-item
                wx:for="{{item.items}}"
                wx:for-item="entry"
                wx:key="id"
                icon="{{entry.icon}}"
                text="{{entry.title}}"
                badge-props="{{entry.badgeProps}}"
                data-id="{{entry.id}}"
                data-path="{{entry.path}}"
                bind:click="onTapEntry"
                t-class="dashboard-grid-item"
                t-class-content="dashboard-grid-content"
                t-class-text="dashboard-grid-text"
              />
            </t-grid>
          </view>
        </view>
      </t-skeleton>
    </block>
  </block>

  <t-popup wx:if="{{appBindPopupVisible}}" visible="{{appBindPopupVisible}}" placement="center" bind:visible-change="onCloseAppBindPopup">
    <view class="app-bind-modal">
      <view class="app-bind-header">
        <text class="app-bind-title">绑定商户端 App</text>
        <text class="app-bind-subtitle">打开商户端 App，在登录页输入下面的 6 位绑定码即可完成绑定。</text>
      </view>

      <view wx:if="{{appBindLoading}}" class="app-bind-state">
        <t-loading theme="circular" size="40rpx" text="生成绑定码中..." vertical />
      </view>

      <view wx:elif="{{appBindError}}" class="app-bind-state">
        <t-empty icon="error-circle" description="{{appBindErrorMessage || '生成绑定码失败，请重试'}}" />
        <t-button theme="primary" size="small" shape="round" bind:tap="onRetryAppBindCode">重新生成</t-button>
      </view>

      <view wx:else class="app-bind-body">
        <view class="app-bind-code-card">
          <text class="app-bind-code">{{appBindCode}}</text>
        </view>
        <text class="app-bind-countdown">{{appBindRemainingLabel}}</text>
        <view class="app-bind-actions">
          <t-button theme="default" shape="round" size="medium" bind:tap="onRetryAppBindCode">重新生成</t-button>
          <t-button theme="primary" shape="round" size="medium" bind:tap="onCopyAppBindCode">复制绑定码</t-button>
        </view>
      </view>
    </view>
  </t-popup>

</view>
