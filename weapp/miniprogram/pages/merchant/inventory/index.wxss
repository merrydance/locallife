.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: 24rpx;
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 0 32rpx;
}

.date-card {
  margin: 24rpx 24rpx 20rpx;
  padding: 18rpx 20rpx;
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
  box-shadow: var(--shadow-sm);
}

.date-card__body {
  display: flex;
  width: 100%;
}

.date-entry-wrap {
  margin-left: auto;
  display: flex;
  justify-content: flex-end;
}

.date-entry-button {
  min-width: 248rpx;
}

.refresh-banner {
  margin: 0 24rpx 20rpx;
  padding: 18rpx 20rpx;
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.refresh-banner__text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--td-warning-color);
}

.loading-state {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.empty-state {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.inventory-list {
  padding: 0 24rpx;
}

.inventory-card {
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.inventory-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 0;
}

.inventory-total {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--td-brand-color);
  font-weight: 600;
}

.inventory-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.inventory-stat {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--td-text-color-secondary);
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-page);
}

.actions {
  width: 100%;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  column-gap: 12rpx;
  row-gap: 12rpx;
  min-height: 72rpx;
}

.actions__middle {
  min-width: 0;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.actions__save {
  display: flex;
  justify-content: flex-end;
}

.input-wrap {
  display: flex;
  min-height: 72rpx;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.input-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.qty-input {
  width: 220rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.qty-input__inner {
  font-size: 28rpx;
  font-weight: 600;
}

.unlimited-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.unlimited-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}
