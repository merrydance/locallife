<custom-navbar title="服务费明细" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady && !accessDenied}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="正在校验页面权限..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty description="{{accessErrorMessage || '当前账号暂时不能查看服务费'}}" />
    <t-button theme="primary" variant="outline" size="small" bind:tap="onBack">返回上一页</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="服务费明细加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage}}" />
    <t-button theme="primary" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-notice-bar wx:if="{{refreshErrorMessage}}" class="page-notice" theme="warning" content="{{refreshErrorMessage}}" />

    <view class="toolbar-panel">
      <view class="range-group">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="key"
          class="range-chip {{currentRange === item.key ? 'range-chip-active' : ''}}"
          data-key="{{item.key}}"
          bind:tap="onSelectRange"
        >
          {{item.label}}
        </view>
      </view>
      <text class="toolbar-meta">{{dateRangeLabel}} · 更新于 {{updatedAtLabel}}</text>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">服务费概览</text>
        <text class="section-subtitle">按天聚合</text>
      </view>
      <view class="summary-grid">
        <view class="summary-card summary-card--strong">
          <text class="summary-label">总服务费</text>
          <text class="summary-value">{{formatAmountText(summary.total_service_fee)}}</text>
          <text class="summary-note">平台费与运营费合计</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">平台费</text>
          <text class="summary-value">{{formatAmountText(summary.total_platform_fee)}}</text>
          <text class="summary-note">平台服务成本</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">运营费</text>
          <text class="summary-value">{{formatAmountText(summary.total_operator_fee)}}</text>
          <text class="summary-note">运营服务成本</text>
        </view>
      </view>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">按日明细</text>
        <text class="section-subtitle">拆分平台费与运营费</text>
      </view>
      <t-cell-group theme="card">
        <block wx:if="{{details.length > 0}}">
          <view wx:for="{{details}}" wx:key="date" class="record-item">
            <view class="record-row">
              <view>
                <text class="record-amount">{{formatAmountText(item.total_fee)}}</text>
                <view class="record-meta">{{item.date}} · {{getOrderSourceText(item.order_source)}}</view>
              </view>
              <text class="record-meta">{{item.order_count}} 单</text>
            </view>
            <view class="finance-fee-row">
              <text>订单金额 {{formatAmountText(item.total_amount)}}</text>
              <text>平台费 {{formatAmountText(item.platform_fee)}}</text>
              <text>运营费 {{formatAmountText(item.operator_fee)}}</text>
            </view>
          </view>
        </block>
        <t-empty wx:else description="当前区间暂无服务费记录" />
      </t-cell-group>
    </view>
  </view>
</view>