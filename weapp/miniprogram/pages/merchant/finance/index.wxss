.page {
  min-height: 100vh;
  background: #f5f6f9;
}

.content {
  height: calc(100vh - 88rpx);
  box-sizing: border-box;
  padding: 24rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  margin: 0 0 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.submit-wrap {
  margin-top: 20rpx;
}

.record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.record-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.record-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

/* ── Applyment ── */

.applyment-placeholder {
  padding: 24rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.applyment-hint {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
  background: #f3f4f6;
  color: #374151;
}

.applyment-warn {
  background: #fffbeb;
  color: #92400e;
}

.applyment-error {
  background: #fff1f2;
  color: #9f1239;
}

.applyment-success {
  background: #f0fdf4;
  color: #166534;
}

.hint-label {
  font-weight: 600;
  margin-right: 4rpx;
}

.sign-url {
  margin-top: 8rpx;
  padding: 12rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 8rpx;
  font-size: 22rpx;
  word-break: break-all;
  font-family: monospace;
  color: #4338ca;
}

/* ── Bind bank form ── */

.bind-form {
  margin-top: 16rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.form-radio-row {
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: #ffffff;
}

.form-label {
  font-size: 28rpx;
  color: #374151;
}

.form-actions {
  margin-top: 20rpx;
}
