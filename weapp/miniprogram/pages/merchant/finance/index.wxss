.page {
  min-height: 100vh;
  background: #f5f6f9;
}

.content {
  height: calc(100vh - 88rpx);
  box-sizing: border-box;
  padding: 24rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  margin: 0 0 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.submit-wrap {
  margin-top: 20rpx;
}

.record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.record-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.record-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}
