.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.page-notice {
  border-radius: var(--radius-md);
  overflow: hidden;
}

.wallet-card {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding: var(--spacer-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.wallet-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.wallet-card__label {
  display: block;
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.wallet-card__amount {
  display: block;
  margin-top: 8rpx;
  color: var(--td-text-color-primary);
  font-size: 56rpx;
  line-height: 1.2;
  font-weight: 700;
}

.section-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.section-title,
.balance-value,
.summary-value,
.record-amount {
  color: var(--td-text-color-primary);
}

.section-caption {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-size-xs);
  line-height: 1.7;
  color: var(--td-text-color-secondary);
}

.balance-grid {
  overflow: hidden;
  border-radius: var(--radius-lg);
}

.balance-grid__value {
  color: var(--td-text-color-primary);
  font-size: var(--font-size-sm);
  font-weight: 700;
}

.summary-label,
.record-meta,
.inline-note,
.hint-row,
.meta-row {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.section-top,
.record-row,
.meta-row,
.action-row,
.hint-row {
  display: flex;
}

.section-top {
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.readiness-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
  padding: var(--spacer-md);
  border-radius: var(--radius-lg);
}

.readiness-panel__top {
  align-items: flex-start;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.inline-note {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  padding: 24rpx;
  background: var(--td-bg-color-page);
  border-radius: var(--radius-md);
}

.inline-note--warning {
  background: var(--td-warning-color-1);
  color: var(--td-text-color-primary);
}

.inline-note--error {
  background: var(--td-error-color-1);
  color: var(--td-text-color-primary);
}

.meta-strip {
  margin-top: var(--spacer-sm);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-page);
}

.meta-row,
.hint-row {
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.record-item:last-child {
  border-bottom: none;
}

.record-row {
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-xs);
}

.record-amount {
  font-size: 30rpx;
  font-weight: 600;
}

.action-row {
  margin-top: var(--spacer-sm);
  justify-content: flex-end;
}

.dialog-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}