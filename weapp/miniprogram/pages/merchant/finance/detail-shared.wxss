.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}


.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.page-notice {
  border-radius: var(--radius-md);
  overflow: hidden;
}

.toolbar-panel,
.section-panel,
.summary-card,
.meta-strip,
.entry-card {
  border-radius: var(--radius-lg);
}

.entry-card {
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
  padding: var(--spacer-md);
}

.toolbar-panel,
.section-panel {
  padding: 0;
}

.range-group,
.filter-chip-group,
.summary-grid,
.record-row,
.finance-fee-row,
.meta-row,
.entry-grid,
.entry-card__top {
  display: flex;
}

.toolbar-panel,
.record-row,
.meta-row,
.entry-card__top,
.section-top {
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-top {
  margin-bottom: var(--spacer-sm);
}

.toolbar-panel,
.section-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.range-group,
.filter-chip-group,
.summary-grid,
.finance-fee-row,
.entry-grid {
  flex-wrap: wrap;
}

.range-group,
.filter-chip-group,
.entry-grid {
  gap: 16rpx;
}

.toolbar-panel,
.section-top,
.record-row,
.meta-row,
.entry-card__top {
  align-items: center;
}

.toolbar-meta,
.section-subtitle,
.summary-label,
.summary-note,
.record-meta,
.finance-fee-row,
.meta-row,
.inline-error,
.inline-loading,
.entry-card__desc,
.entry-card__hint,
.entry-card__meta,
.hero-subtitle {
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.range-chip,
.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-round);
  background: var(--td-bg-color-page);
  color: var(--td-text-color-secondary);
}

.range-chip-active,
.filter-chip-active {
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 28rpx;
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
  border: 1rpx solid var(--td-component-border);
  box-shadow: var(--shadow-sm);
}

.hero-title,
.section-title,
.record-amount,
.summary-value,
.entry-card__value,
.entry-card__title {
  color: var(--td-text-color-primary);
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.summary-grid {
  gap: var(--spacer-sm);
}

.summary-card {
  flex: 1 1 calc(50% - var(--spacer-sm));
  min-width: 0;
  background: var(--td-bg-color-page);
  padding: var(--spacer-md);
}

.summary-card--strong {
  background: var(--td-bg-color-secondarycontainer);
}

.summary-card--full {
  flex-basis: 100%;
}

.summary-value,
.entry-card__value {
  display: block;
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-title);
  font-weight: 700;
}

.summary-note,
.entry-card__hint {
  display: block;
  margin-top: 6rpx;
}

.meta-strip {
  background: transparent;
  padding: 0;
}

.entry-grid {
  gap: var(--spacer-sm);
}

.entry-card {
  flex: 1 1 calc(50% - var(--spacer-sm));
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.entry-card__title {
  font-size: var(--font-size-sm);
  font-weight: 600;
}

.finance-record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.finance-record-item:last-child,
.record-item:last-child {
  border-bottom: none;
}

.record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.record-amount {
  font-size: 30rpx;
  font-weight: 600;
}

.finance-fee-row {
  gap: 20rpx;
  margin: 8rpx 0;
}

.inline-error,
.inline-loading {
  padding: 24rpx;
  background: var(--td-bg-color-page);
  border-radius: var(--radius-md);
}

@media (max-width: 420px) {
  .entry-card,
  .summary-card {
    flex-basis: 100%;
  }
}