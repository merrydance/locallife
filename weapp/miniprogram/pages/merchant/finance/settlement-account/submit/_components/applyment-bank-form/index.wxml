<view class="bank-form {{embedded ? 'bank-form--embedded' : ''}}">
  <t-cell-group theme="{{embedded ? 'default' : 'card'}}">
    <t-cell wx:if="{{showAccountTypeSelector}}" title="账户类型">
      <view slot="note" class="tag-check-list">
        <t-check-tag
          checked="{{form.account_type === 'ACCOUNT_TYPE_BUSINESS'}}"
          content="对公账户"
          shape="round"
          data-value="ACCOUNT_TYPE_BUSINESS"
          bind:change="onAccountTypeSelect"
        />
        <t-check-tag
          wx:if="{{!allowedAccountTypes.length || allowedAccountTypes.indexOf('ACCOUNT_TYPE_PRIVATE') >= 0}}"
          checked="{{form.account_type === 'ACCOUNT_TYPE_PRIVATE'}}"
          content="对私账户"
          shape="round"
          data-value="ACCOUNT_TYPE_PRIVATE"
          bind:change="onAccountTypeSelect"
        />
      </view>
    </t-cell>

    <t-input
      label="开户名称"
      t-class-label="{{requireAccountName ? 'form-required-label' : ''}}"
      placeholder="{{requireAccountName ? (form.account_type === 'ACCOUNT_TYPE_BUSINESS' ? '企业或机构全称' : '持卡人姓名') : ''}}"
      value="{{form.account_name}}"
      data-field="account_name"
      align="right"
      bind:change="onTextFieldChange"
    />

    <t-input
      wx:if="{{requireContactEmail}}"
      label="管理邮箱"
      t-class-label="form-required-label"
      placeholder="name@example.com"
      value="{{form.contact_email}}"
      data-field="contact_email"
      align="right"
      bind:change="onTextFieldChange"
    />

    <view wx:if="{{requireContactEmail}}" class="contact-email-tip">用于接收微信支付开户邮件和业务通知，请填写商户自己的邮箱。</view>

    <t-input
      label="银行账号"
      t-class-label="form-required-label"
      placeholder="{{form.account_type === 'ACCOUNT_TYPE_PRIVATE' ? '银行卡号' : '对公账号'}}"
      value="{{form.account_number}}"
      data-field="account_number"
      align="right"
      maxlength="30"
      bind:change="onTextFieldChange"
    />

    <t-input
      label="开户银行"
      t-class-label="form-required-label"
      placeholder="例如 招商银行"
      value="{{form.account_bank}}"
      data-field="account_bank"
      align="right"
      bind:change="onManualBankFieldChange"
    />

    <t-input
      label="开户省份"
      t-class-label="form-required-label"
      placeholder="例如 浙江省"
      value="{{form.bank_address_code}}"
      data-field="bank_address_code"
      align="right"
      bind:change="onManualBankFieldChange"
    />

    <t-input
      label="开户城市"
      t-class-label="form-required-label"
      placeholder="例如 杭州市"
      value="{{form.manual_bank_city}}"
      data-field="manual_bank_city"
      align="right"
      bind:change="onManualBankFieldChange"
    />

    <t-input
      label="开户支行"
      t-class-label="form-required-label"
      placeholder="例如 招商银行杭州支行"
      value="{{form.bank_name}}"
      data-field="bank_name"
      align="right"
      bind:change="onManualBankFieldChange"
    />

  </t-cell-group>

  <view wx:if="{{showContactFields}}" class="section-panel">
    <view class="section-top">
      <text class="section-title">联系人信息</text>
    </view>

    <t-cell-group theme="card">
      <t-cell
        title="默认联系人"
        description="系统会直接复用入驻时保存的法人姓名和身份证号，无需重复填写。"
      />

      <t-cell
        title="联系人不是法人"
        description="仅当微信支付联系人与法人不一致时开启，并补充超级管理员证件。"
      >
        <t-switch slot="note" value="{{form.contact_type === 'SUPER'}}" bind:change="onSuperContactSwitchChange" />
      </t-cell>

      <block wx:if="{{form.contact_type === 'SUPER'}}">
        <t-cell title="证件类型" note="中国大陆居民身份证" />

        <t-input
          label="管理员"
          t-class-label="form-required-label"
          value="{{form.contact_name}}"
          data-field="contact_name"
          align="right"
          bind:change="onTextFieldChange"
        />

        <t-input
          label="管理证件"
          t-class-label="form-required-label"
          placeholder="18位身份证号"
          value="{{form.contact_id_card_number}}"
          data-field="contact_id_card_number"
          align="right"
          bind:change="onTextFieldChange"
        />

        <view class="document-hint">请上传超级管理员身份证人像面与国徽面，确保头像、号码和有效期清晰完整。</view>

        <view class="document-grid">
          <document-uploader
            type="id-front"
            title="上传人像面"
            value="{{form.contact_id_doc_copy_url}}"
            rawUrl="{{form.contact_id_doc_copy_raw_url}}"
            feedbackState="{{contactDocCopyFeedbackState}}"
            feedbackTitle="{{contactDocCopyFeedbackTitle}}"
            feedbackDescription="{{contactDocCopyFeedbackDescription}}"
            bind:change="onContactIDDocCopyChange"
            bind:remove="onContactIDDocCopyRemove"
          />

          <document-uploader
            type="id-back"
            title="上传国徽面"
            value="{{form.contact_id_doc_copy_back_url}}"
            rawUrl="{{form.contact_id_doc_copy_back_raw_url}}"
            feedbackState="{{contactDocCopyBackFeedbackState}}"
            feedbackTitle="{{contactDocCopyBackFeedbackTitle}}"
            feedbackDescription="{{contactDocCopyBackFeedbackDescription}}"
            bind:change="onContactIDDocCopyBackChange"
            bind:remove="onContactIDDocCopyBackRemove"
          />
        </view>

        <t-input
          label="开始日期"
          t-class-label="form-required-label"
          placeholder="例如 2020-01-01"
          value="{{form.contact_id_doc_period_begin}}"
          data-field="contact_id_doc_period_begin"
          align="right"
          bind:change="onTextFieldChange"
        />

        <view class="tag-check-list tag-check-list--subtle">
          <t-check-tag
            checked="{{form.contact_id_doc_period_end === '长期'}}"
            content="长期有效"
            shape="round"
            bind:change="onContactDocLongTermToggle"
          />
        </view>

        <t-cell wx:if="{{form.contact_id_doc_period_end === '长期'}}" title="证件有效期结束" note="长期" />

        <t-input
          wx:else
          label="结束日期"
          t-class-label="form-required-label"
          placeholder="例如 2030-01-01 或填写 长期"
          value="{{form.contact_id_doc_period_end}}"
          data-field="contact_id_doc_period_end"
          align="right"
          bind:change="onTextFieldChange"
        />

        <view class="document-tip">有效期建议按证件原文填写，支持 YYYY-MM-DD 和“长期”两种格式。</view>
      </block>
    </t-cell-group>
  </view>

  <view wx:if="{{showSubmitActions}}" class="form-actions {{submitBlock ? 'form-actions--block' : ''}}">
    <t-button theme="primary" block="{{submitBlock}}" loading="{{submitting}}" disabled="{{submitting}}" bind:tap="onSubmit">{{submitLabel}}</t-button>
    <t-button wx:if="{{showCancelButton}}" theme="default" variant="outline" block="{{submitBlock}}" disabled="{{submitting}}" bind:tap="onCancel">取消</t-button>
  </view>

</view>
