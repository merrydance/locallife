<custom-navbar title="微信提现卡" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载提现银行卡中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '提现银行卡页面加载失败，请重试'}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">当前提现银行卡</text>
        <t-button
          wx:if="{{canManageMerchantApplyment && settlementAccount && settlementAccount.account_status === 'active'}}"
          theme="primary"
          size="small"
          shape="round"
          bind:tap="onGoEditSettlementAccount"
        >更换银行卡</t-button>
      </view>

      <view wx:if="{{!settlementAccount || settlementAccount.account_status !== 'active'}}" class="inline-note inline-note--warning">
        <text>{{settlementStatusDesc || '当前收付通账户未激活，暂不可查看微信提现卡信息。'}}</text>
        <t-button theme="primary" shape="round" size="small" bind:tap="onGoApplyment">去完成进件</t-button>
      </view>

      <block wx:else>
        <view class="bank-hero">
          <text class="bank-hero__label">微信提现卡号</text>
          <text class="bank-hero__value">{{formatAccountNumber(settlementAccount.account.account_number)}}</text>
          <text class="bank-hero__caption">{{settlementAccount.account.account_bank}}{{settlementAccount.account.bank_name ? ' · ' + settlementAccount.account.bank_name : ''}}</text>
        </view>

        <view wx:if="{{!canManageMerchantApplyment}}" class="inline-note">
          <text>当前账号可查看已绑定的微信提现卡信息，更换银行卡仅支持老板账号操作。</text>
        </view>

        <t-cell-group theme="card">
        <t-cell title="账户类型" note="{{getAccountTypeText(settlementAccount.account.account_type)}}" />
        <t-cell title="开户银行" note="{{settlementAccount.account.account_bank}}" />
        <t-cell wx:if="{{settlementAccount.account.bank_name}}" title="开户支行" note="{{settlementAccount.account.bank_name}}" />
        <t-cell title="银行账号" note="{{formatAccountNumber(settlementAccount.account.account_number)}}" />
        <t-cell title="校验结果">
          <view slot="note">
            <t-tag theme="{{getVerifyResultTheme(settlementAccount.account.verify_result)}}" variant="dark">{{getVerifyResultText(settlementAccount.account.verify_result)}}</t-tag>
          </view>
        </t-cell>
        <t-cell wx:if="{{settlementAccount.account.verify_fail_reason}}" title="失败原因" note="{{settlementAccount.account.verify_fail_reason}}" />
        </t-cell-group>
      </block>
    </view>

    <view wx:if="{{applicationNo}}" class="section-panel">
      <view class="section-top">
        <text class="section-title">最近一次换卡申请</text>
        <t-button theme="default" size="small" shape="round" loading="{{refreshingApplication}}" bind:tap="onRefreshApplication">刷新结果</t-button>
      </view>

      <view wx:if="{{applicationLoading}}" class="inline-note">
        <t-loading theme="circular" size="32rpx" text="查询申请结果中..." vertical />
      </view>

      <view wx:elif="{{applicationError}}" class="inline-note inline-note--error">
        <text>{{applicationErrorMessage}}</text>
      </view>

      <t-cell-group wx:elif="{{applicationResult}}" theme="card">
        <t-cell title="申请单号" note="{{applicationNo}}" />
        <t-cell title="账户类型" note="{{getAccountTypeText(applicationResult.account_type)}}" />
        <t-cell title="开户银行" note="{{applicationResult.account_bank}}" />
        <t-cell wx:if="{{applicationResult.bank_name}}" title="开户支行" note="{{applicationResult.bank_name}}" />
        <t-cell title="银行账号" note="{{formatAccountNumber(applicationResult.account_number)}}" />
        <t-cell title="审核结果">
          <view slot="note">
            <t-tag theme="{{getVerifyResultTheme(applicationResult.verify_result)}}" variant="dark">{{getVerifyResultText(applicationResult.verify_result)}}</t-tag>
          </view>
        </t-cell>
        <t-cell wx:if="{{applicationResult.verify_fail_reason}}" title="失败原因" note="{{applicationResult.verify_fail_reason}}" />
        <t-cell wx:if="{{applicationResult.verify_finish_time}}" title="完成时间" note="{{applicationResult.verify_finish_time}}" />
      </t-cell-group>
    </view>
  </view>
</view>