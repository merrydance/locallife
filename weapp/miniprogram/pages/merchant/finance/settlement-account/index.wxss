.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}


.section-panel {
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
}

.section-top,
.inline-note {
  display: flex;
}

.section-top {
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.section-title {
  color: var(--td-text-color-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.bank-hero {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: var(--spacer-sm);
  padding: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
  border: 1rpx solid var(--td-component-border);
}

.bank-hero__label,
.bank-hero__caption {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.bank-hero__value {
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.inline-note {
  flex-direction: column;
  gap: var(--spacer-sm);
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-page);
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.inline-note--warning {
  background: var(--td-warning-color-1);
  color: var(--td-text-color-primary);
}

.inline-note--error {
  background: var(--td-error-color-1);
  color: var(--td-text-color-primary);
}