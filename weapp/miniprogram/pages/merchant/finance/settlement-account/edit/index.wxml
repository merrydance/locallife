<custom-navbar title="更换提现银行卡" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="{{accessDeniedMessage}}" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载银行卡信息中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '更换银行卡页面加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <view class="section-panel">
      <view class="section-top-main">
        <text class="section-title">当前绑定银行卡</text>
        <text class="section-caption">请先确认当前绑定的银行卡信息，再发起换卡申请。</text>
      </view>

      <block wx:if="{{settlementAccount}}">
        <t-cell-group theme="card">
          <t-cell title="银行账号" note="{{formatAccountNumber(settlementAccount.account.account_number)}}" />
          <t-cell title="开户银行" note="{{settlementAccount.account.account_bank}}" />
          <t-cell wx:if="{{settlementAccount.account.bank_name}}" title="开户支行" note="{{settlementAccount.account.bank_name}}" />
          <t-cell title="账户类型" note="{{getAccountTypeText(settlementAccount.account.account_type)}}" />
        </t-cell-group>
      </block>
    </view>

    <view wx:if="{{!canEdit}}" class="section-panel">
      <view class="inline-note inline-note--warning">
        <text>{{settlementStatusDesc || '当前收付通账户未激活，暂不可更换银行卡。'}}</text>
        <t-button theme="primary" size="small" bind:tap="onGoApplyment">{{paymentReadiness && paymentReadiness.actionText ? paymentReadiness.actionText : '去完成进件'}}</t-button>
      </view>
    </view>

    <view wx:else class="section-panel">
      <view class="section-top-main">
        <text class="section-title">填写新银行卡</text>
        <text class="section-caption">请填写微信支付要求的银行卡信息；若开户名称不变，可留空沿用当前绑定信息。提交后会发起新的审核申请。</text>
      </view>

      <applyment-bank-form
        apiBasePath="/v1/merchant/applyment"
        initialDraft="{{bindBankDraft}}"
        defaultAccountType="ACCOUNT_TYPE_BUSINESS"
        preloadCatalogs="{{true}}"
        requireAccountName="{{false}}"
        submitLabel="提交换卡申请"
        submitting="{{submitting}}"
        bind:submit="onSubmitForm"
        bind:cancel="onCancelEdit"
        bind:draftchange="onBindDraftChange"
      />
    </view>
  </view>
</view>