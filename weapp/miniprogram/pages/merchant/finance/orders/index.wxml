<custom-navbar title="订单收入" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady && !accessDenied}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="正在校验页面权限..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty description="{{accessErrorMessage || '当前账号暂时不能查看订单收入'}}" />
    <t-button theme="primary" variant="outline" size="small" bind:tap="onBack">返回上一页</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="订单收入加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage}}" />
    <t-button theme="primary" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-notice-bar wx:if="{{refreshErrorMessage}}" class="page-notice" theme="warning" content="{{refreshErrorMessage}}" />

    <view class="toolbar-panel">
      <view class="range-group">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="key"
          class="range-chip {{currentRange === item.key ? 'range-chip-active' : ''}}"
          data-key="{{item.key}}"
          bind:tap="onSelectRange"
        >
          {{item.label}}
        </view>
      </view>
      <text class="toolbar-meta">{{dateRangeLabel}} · 更新于 {{updatedAtLabel}}</text>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">收入概览</text>
        <text class="section-subtitle">最近 20 笔订单</text>
      </view>
      <view class="summary-grid">
        <view class="summary-card summary-card--strong">
          <text class="summary-label">商户收入</text>
          <text class="summary-value">{{formatAmountText(totalMerchantAmount)}}</text>
          <text class="summary-note">当前列表累计</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">订单金额</text>
          <text class="summary-value">{{formatAmountText(totalAmount)}}</text>
          <text class="summary-note">订单实收总额</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">平台费</text>
          <text class="summary-value">{{formatAmountText(totalPlatformCommission)}}</text>
          <text class="summary-note">平台服务费</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">运营费</text>
          <text class="summary-value">{{formatAmountText(totalOperatorCommission)}}</text>
          <text class="summary-note">运营服务费</text>
        </view>
      </view>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">订单明细</text>
        <text class="section-subtitle">按订单查看结算构成</text>
      </view>
      <t-cell-group theme="card">
        <block wx:if="{{orders.length > 0}}">
          <view wx:for="{{orders}}" wx:key="id" class="record-item">
            <view class="record-row">
              <view>
                <text class="record-amount">{{formatAmountText(item.merchant_amount)}}</text>
                <view class="record-meta">{{getOrderSourceText(item.order_source)}} · 订单 #{{item.order_id || item.payment_order_id}}</view>
              </view>
              <t-tag theme="{{getFinanceOrderStatusTheme(item.status)}}" variant="dark">{{getFinanceOrderStatusText(item.status)}}</t-tag>
            </view>
            <view class="finance-fee-row">
              <text>订单金额 {{formatAmountText(item.total_amount)}}</text>
              <text>平台费 {{formatAmountText(item.platform_commission)}}</text>
              <text>运营费 {{formatAmountText(item.operator_commission)}}</text>
            </view>
            <view class="record-meta">创建时间：{{formatDateTime(item.created_at)}}</view>
          </view>
        </block>
        <t-empty wx:else description="当前区间暂无订单收入记录" />
      </t-cell-group>
    </view>
  </view>
</view>