<custom-navbar title="资金账户" showBack="{{true}}" showLocation="{{false}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载资金账户中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '资金账户加载失败，请重试'}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-notice-bar
      wx:if="{{refreshErrorMessage}}"
      visible="{{true}}"
      theme="warning"
      content="{{refreshErrorMessage}}"
      prefixIcon="error-circle"
      t-class="page-notice"
    />

    <view class="wallet-card">
      <view class="wallet-card__top">
        <view>
          <text class="wallet-card__label">可提现</text>
          <text class="wallet-card__amount">¥{{formatAmount(balance.withdrawable_amount)}}</text>
        </view>
        <t-tag theme="{{getWithdrawPanelTheme()}}" variant="light">{{getWithdrawPanelText()}}</t-tag>
      </view>

      <t-grid column="3" gutter="12" border="{{false}}" theme="card" t-class="balance-grid">
        <t-grid-item text="可提现" description="¥{{formatAmount(balance.withdrawable_amount)}}" t-class-description="balance-grid__value" />
        <t-grid-item text="可用" description="¥{{formatAmount(balance.available_amount)}}" t-class-description="balance-grid__value" />
        <t-grid-item text="待结算" description="¥{{formatAmount(balance.pending_amount)}}" t-class-description="balance-grid__value" />
      </t-grid>

      <t-button
        theme="primary"
        size="large"
        shape="round"
        block
        disabled="{{!canSubmitWithdraw() || loading}}"
        bind:tap="onOpenWithdrawDialog"
      >
        申请提现
      </t-button>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">提现记录</text>
      </view>

      <t-cell-group wx:if="{{withdrawals.length > 0}}" theme="card">
        <view wx:for="{{withdrawals}}" wx:key="id" class="record-item">
          <view class="record-row">
            <view>
              <text class="record-amount">¥{{formatAmount(item.amount)}}</text>
              <view class="record-meta">{{formatDateTime(item.created_at)}}</view>
            </view>
            <t-tag theme="{{getStatusTheme(item.status)}}" variant="dark">{{getStatusText(item.status)}}</t-tag>
          </view>
          <view class="record-meta">更新时间：{{formatDateTime(item.updated_at)}}</view>
          <view class="record-meta" wx:if="{{item.reason}}">原因：{{item.reason}}</view>
          <view class="action-row">
            <t-button
              size="small"
              theme="default"
              shape="round"
              data-id="{{item.id}}"
              bind:tap="onRefreshWithdrawal"
              loading="{{withdrawSyncingId === item.id}}"
              disabled="{{withdrawSyncingId === item.id}}"
            >
              同步状态
            </t-button>
          </view>
        </view>
      </t-cell-group>

      <t-empty wx:else icon="info-circle" description="暂无提现记录" />
    </view>
  </view>
</view>

<t-dialog
  visible="{{isWithdrawDialogVisible}}"
  title="申请提现"
  confirm-btn="{{ { content: submitting ? '提交中...' : '确认提现', variant: 'base', theme: 'primary' } }}"
  cancel-btn="取消"
  bind:confirm="onSubmitWithdraw"
  bind:cancel="onCloseWithdrawDialog"
>
  <view slot="content" class="dialog-content">
    <t-input
      type="digit"
      label="金额(元)"
      placeholder="请输入提现金额"
      value="{{withdrawAmountYuan}}"
      bind:change="onWithdrawAmountChange"
    />
    <t-input
      label="备注"
      placeholder="请输入提现备注"
      value="{{withdrawRemark}}"
      bind:change="onWithdrawRemarkChange"
    />
    <t-cell title="可提现上限" note="¥{{formatAmount(balance.withdrawable_amount)}}" bordered="{{false}}" />
  </view>
</t-dialog>
