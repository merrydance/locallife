<custom-navbar title="财务" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: var(--spacer-lg);"
>
  <view wx:if="{{!accessReady}}" class="page-content">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="page-content">
    <t-empty icon="lock-on" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="page-content">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="page-content">
    <t-loading theme="circular" size="40rpx" text="加载财务信息中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="page-content">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '财务信息加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-cell-group wx:if="{{refreshErrorMessage}}">
      <t-cell title="部分数据同步失败" note="{{refreshErrorMessage}}">
        <view slot="right-icon">
          <t-button size="extra-small" theme="primary" variant="text" loading="{{loadingFinance}}" bind:tap="onManualRefresh">重试</t-button>
        </view>
      </t-cell>
    </t-cell-group>

    <t-cell-group>
      <t-cell
        wx:for="{{entries}}"
        wx:key="id"
        title="{{item.title}}"
        left-icon="{{item.icon}}"
        arrow
        url="{{item.path}}"
      />
    </t-cell-group>
  </view>
</view>
