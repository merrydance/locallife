<custom-navbar title="财务日报" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady && !accessDenied}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="正在校验页面权限..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty description="{{accessErrorMessage || '当前账号暂时不能查看财务日报'}}" />
    <t-button theme="primary" variant="outline" size="small" bind:tap="onBack">返回上一页</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="财务日报加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage}}" />
    <t-button theme="primary" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <view class="toolbar-panel">
      <view class="range-group">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="key"
          class="range-chip {{currentRange === item.key ? 'range-chip-active' : ''}}"
          data-key="{{item.key}}"
          bind:tap="onSelectRange"
        >
          {{item.label}}
        </view>
      </view>
      <text class="toolbar-meta">{{dateRangeLabel}} · 更新于 {{updatedAtLabel}}</text>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">日报概览</text>
        <text class="section-subtitle">按日查看经营走势</text>
      </view>
      <view class="summary-grid">
        <view class="summary-card summary-card--strong">
          <text class="summary-label">商户净收入</text>
          <text class="summary-value">{{formatAmountText(summary.totalMerchantIncome)}}</text>
          <text class="summary-note">当前区间累计</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">交易额</text>
          <text class="summary-value">{{formatAmountText(summary.totalGmv)}}</text>
          <text class="summary-note">全部订单交易额</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">服务费</text>
          <text class="summary-value">{{formatAmountText(summary.totalFee)}}</text>
          <text class="summary-note">平台费与运营费</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">订单数</text>
          <text class="summary-value">{{summary.totalOrderCount}}</text>
          <text class="summary-note">完成订单合计</text>
        </view>
      </view>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">日报列表</text>
        <text class="section-subtitle">逐日复盘收入变化</text>
      </view>
      <t-cell-group theme="card">
        <block wx:if="{{rows.length > 0}}">
          <view wx:for="{{rows}}" wx:key="date" class="record-item">
            <view class="record-row">
              <view>
                <text class="record-amount">{{formatAmountText(item.merchant_income)}}</text>
                <view class="record-meta">{{item.date}}</view>
              </view>
              <text class="record-meta">{{item.order_count}} 单</text>
            </view>
            <view class="finance-fee-row">
              <text>交易额 {{formatAmountText(item.total_gmv)}}</text>
              <text>服务费 {{formatAmountText(item.total_fee)}}</text>
            </view>
          </view>
        </block>
        <t-empty wx:else description="当前区间暂无日报数据" />
      </t-cell-group>
    </view>
  </view>
</view>