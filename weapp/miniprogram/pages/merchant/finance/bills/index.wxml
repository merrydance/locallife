<custom-navbar title="订单流水" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: var(--spacer-lg);">
  <view wx:if="{{initialLoading}}" class="page-content"><t-loading theme="circular" size="40rpx" text="加载订单流水中..." vertical /></view>
  <view wx:elif="{{initialError}}" class="page-content"><t-empty icon="error-circle" description="{{initialErrorMessage || '订单流水加载失败，请重试'}}" /><t-button theme="primary" bind:tap="onRetry">重新加载</t-button></view>

  <view wx:else class="page-content">
    <t-cell-group wx:if="{{refreshErrorMessage}}">
      <t-cell title="刷新失败" note="{{refreshErrorMessage}}">
        <view slot="right-icon"><t-button size="extra-small" theme="primary" variant="text" loading="{{loadingBills}}" bind:tap="onRetry">重试</t-button></view>
      </t-cell>
    </t-cell-group>

    <t-empty wx:if="{{!rows.length}}" description="当前区间暂无订单流水" />
    <t-cell-group wx:else>
      <t-cell wx:for="{{rows}}" wx:key="id" title="{{item.title}}" description="{{item.note}}" note="{{item.amountText}}">
        <view slot="right-icon"><t-tag theme="{{item.statusTheme}}" size="small">{{item.statusText}}</t-tag></view>
      </t-cell>
    </t-cell-group>
    <t-button wx:if="{{hasMore}}" theme="default" loading="{{loadingBills}}" bind:tap="onLoadMore">加载更多</t-button>
  </view>
</view>