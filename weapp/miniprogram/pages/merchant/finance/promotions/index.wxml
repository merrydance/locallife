<custom-navbar title="营销支出" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady && !accessDenied}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="正在校验页面权限..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty description="{{accessErrorMessage || '当前账号暂时不能查看营销支出'}}" />
    <t-button theme="primary" variant="outline" size="small" bind:tap="onBack">返回上一页</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="营销支出加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage}}" />
    <t-button theme="primary" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-notice-bar wx:if="{{refreshErrorMessage}}" class="page-notice" theme="warning" content="{{refreshErrorMessage}}" />

    <view class="toolbar-panel">
      <view class="range-group">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="key"
          class="range-chip {{currentRange === item.key ? 'range-chip-active' : ''}}"
          data-key="{{item.key}}"
          bind:tap="onSelectRange"
        >
          {{item.label}}
        </view>
      </view>
      <text class="toolbar-meta">{{dateRangeLabel}} · 更新于 {{updatedAtLabel}}</text>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">支出概览</text>
        <text class="section-subtitle">配送优惠与活动支出</text>
      </view>
      <view class="summary-grid">
        <view class="summary-card summary-card--strong">
          <text class="summary-label">优惠支出</text>
          <text class="summary-value">{{formatAmountText(summary.total_promo_amount)}}</text>
          <text class="summary-note">当前区间累计</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">优惠订单</text>
          <text class="summary-value">{{summary.total_promo_orders}}</text>
          <text class="summary-note">发生优惠的订单数</text>
        </view>
      </view>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">优惠订单明细</text>
        <text class="section-subtitle">查看每笔优惠支出构成</text>
      </view>
      <t-cell-group theme="card">
        <block wx:if="{{orders.length > 0}}">
          <view wx:for="{{orders}}" wx:key="id" class="record-item">
            <view class="record-row">
              <view>
                <text class="record-amount">{{formatAmountText(item.delivery_fee_discount)}}</text>
                <view class="record-meta">{{getOrderSourceText(item.order_type)}} · {{item.order_no}}</view>
              </view>
              <text class="record-meta">优惠单</text>
            </view>
            <view class="finance-fee-row">
              <text>商品小计 {{formatAmountText(item.subtotal)}}</text>
              <text>配送费 {{formatAmountText(item.delivery_fee)}}</text>
              <text>优惠减免 {{formatAmountText(item.delivery_fee_discount)}}</text>
            </view>
            <view class="record-meta">创建时间：{{formatDateTime(item.created_at)}}</view>
          </view>
        </block>
        <t-empty wx:else description="当前区间暂无营销支出记录" />
      </t-cell-group>
    </view>
  </view>
</view>