<custom-navbar title="结算流水" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady && !accessDenied}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="正在校验页面权限..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty description="{{accessErrorMessage || '当前账号暂时不能查看结算流水'}}" />
    <t-button theme="primary" variant="outline" size="small" bind:tap="onBack">返回上一页</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="结算流水加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage}}" />
    <t-button theme="primary" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <view class="toolbar-panel">
      <view class="range-group">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="key"
          class="range-chip {{currentRange === item.key ? 'range-chip-active' : ''}}"
          data-key="{{item.key}}"
          bind:tap="onSelectRange"
        >
          {{item.label}}
        </view>
      </view>
      <text class="toolbar-meta">{{dateRangeLabel}} · 更新于 {{updatedAtLabel}}</text>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">流水概览</text>
        <text class="section-subtitle">最近 20 条记录</text>
      </view>
      <view class="summary-grid">
        <view class="summary-card summary-card--strong">
          <text class="summary-label">流水条数</text>
          <text class="summary-value">{{summary.totalCount}}</text>
          <text class="summary-note">当前列表数量</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">商户金额</text>
          <text class="summary-value">{{formatAmountText(summary.totalMerchantAmount)}}</text>
          <text class="summary-note">含分账与调整</text>
        </view>
        <view class="summary-card summary-card--full">
          <text class="summary-label">调整条数</text>
          <text class="summary-value">{{summary.adjustmentCount}}</text>
          <text class="summary-note">帮助识别结算修正记录</text>
        </view>
      </view>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">流水列表</text>
        <text class="section-subtitle">分账与调整统一时间线</text>
      </view>
      <t-cell-group theme="card">
        <block wx:if="{{timeline.length > 0}}">
          <view wx:for="{{timeline}}" wx:key="id" class="record-item">
            <view class="record-row">
              <view>
                <text class="record-amount">{{formatAmountText(item.merchant_amount || item.total_amount || 0)}}</text>
                <view class="record-meta">{{getTimelineRecordTypeText(item.record_type)}} · {{item.out_order_no || ('#' + item.payment_order_id)}}</view>
              </view>
              <t-tag theme="{{getFinanceOrderStatusTheme(item.status)}}" variant="dark">{{getFinanceOrderStatusText(item.status)}}</t-tag>
            </view>
            <view class="finance-fee-row">
              <text wx:if="{{item.record_type === 'adjustment'}}">{{getAdjustmentTypeText(item.adjustment_type)}}</text>
              <text wx:elif="{{item.record_type === 'profit_sharing'}}">商户入账 {{formatAmountText(item.merchant_amount)}}</text>
              <text wx:if="{{item.related_type}}">关联 {{item.related_type}} #{{item.related_id}}</text>
            </view>
            <view class="record-meta">创建时间：{{formatDateTime(item.created_at)}}</view>
          </view>
        </block>
        <t-empty wx:else description="当前区间暂无结算流水" />
      </t-cell-group>
    </view>
  </view>
</view>