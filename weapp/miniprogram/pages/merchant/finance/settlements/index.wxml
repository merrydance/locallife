<custom-navbar title="结算记录" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: var(--spacer-lg);">
  <view wx:if="{{initialLoading}}" class="page-content">
    <t-loading theme="circular" size="40rpx" text="加载结算记录中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="page-content">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '结算记录加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重试</t-button>
  </view>

  <view wx:else class="page-content">
    <t-cell-group>
      <t-cell title="区间分账" note="{{summary.settlementAmountText}}" />
      <t-cell title="订单金额" note="{{summary.totalOrderAmountText}}" />
      <t-cell title="费用扣减" note="{{summary.deductionAmountText}}" />
      <t-cell title="结算笔数" note="{{summary.totalCountText}}" />
      <t-cell title="账单区间" note="{{summary.rangeLabel}}" arrow bind:tap="onOpenRangePicker" />
    </t-cell-group>

    <view class="quick-range-row">
      <t-button
        wx:for="{{quickRanges}}"
        wx:key="id"
        size="small"
        theme="{{item.active ? 'primary' : 'default'}}"
        variant="{{item.active ? 'base' : 'outline'}}"
        data-range="{{item.id}}"
        disabled="{{loadingSettlements}}"
        bind:tap="onUseQuickRange"
      >{{item.label}}</t-button>
    </view>

    <t-cell-group wx:if="{{refreshErrorMessage}}">
      <t-cell title="账单同步失败" note="{{refreshErrorMessage}}">
        <view slot="right-icon">
          <t-button size="extra-small" theme="primary" variant="text" loading="{{loadingSettlements}}" bind:tap="onRetry">重试</t-button>
        </view>
      </t-cell>
    </t-cell-group>

    <t-empty wx:if="{{!rows.length}}" icon="info-circle" description="当前区间暂无结算单" />
    <t-cell-group wx:else>
      <t-cell
        wx:for="{{rows}}"
        wx:key="id"
        title="{{item.title}}"
        description="{{item.note}}"
        note="{{item.amountText}}"
      >
        <view slot="right-icon">
          <t-tag theme="{{item.statusTheme}}" size="small">{{item.statusText}}</t-tag>
        </view>
      </t-cell>
    </t-cell-group>

    <t-button wx:if="{{hasMore}}" theme="default" loading="{{loadingSettlements}}" bind:tap="onLoadMore">加载更多</t-button>
  </view>

  <t-calendar
    title="选择账单区间"
    type="range"
    visible="{{rangePickerVisible}}"
    value="{{rangePickerValue}}"
    minDate="{{rangePickerMinDate}}"
    maxDate="{{rangePickerMaxDate}}"
    confirmBtn="确定"
    bind:confirm="onConfirmRangePicker"
    bind:close="onCancelRangePicker"
  />
</view>
