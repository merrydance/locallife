<custom-navbar title="结算记录" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady && !accessDenied}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="正在校验页面权限..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty description="{{accessErrorMessage || '当前账号暂时不能查看结算记录'}}" />
    <t-button theme="primary" variant="outline" size="small" bind:tap="onBack">返回上一页</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="72rpx" text="结算记录加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage}}" />
    <t-button theme="primary" size="small" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <view class="toolbar-panel">
      <view class="range-group">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="key"
          class="range-chip {{currentRange === item.key ? 'range-chip-active' : ''}}"
          data-key="{{item.key}}"
          bind:tap="onSelectRange"
        >
          {{item.label}}
        </view>
      </view>
      <text class="toolbar-meta">{{dateRangeLabel}} · 更新于 {{updatedAtLabel}}</text>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">状态筛选</text>
        <text class="section-subtitle">按结算状态查看</text>
      </view>
      <view class="filter-chip-group">
        <view
          wx:for="{{statusOptions}}"
          wx:key="key"
          class="filter-chip {{currentStatus === item.key ? 'filter-chip-active' : ''}}"
          data-key="{{item.key}}"
          bind:tap="onSelectStatus"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">结算概览</text>
        <text class="section-subtitle">当前筛选结果</text>
      </view>
      <view class="summary-grid">
        <view class="summary-card summary-card--strong">
          <text class="summary-label">商户入账</text>
          <text class="summary-value">{{formatAmountText(summary.total_merchant_amount)}}</text>
          <text class="summary-note">当前列表累计</text>
        </view>
        <view class="summary-card">
          <text class="summary-label">结算总额</text>
          <text class="summary-value">{{formatAmountText(summary.total_amount)}}</text>
          <text class="summary-note">订单实收总额</text>
        </view>
        <view class="summary-card summary-card--full">
          <text class="summary-label">服务费合计</text>
          <text class="summary-value">{{formatAmountText(summary.total_platform_fee + summary.total_operator_fee)}}</text>
          <text class="summary-note">平台费与运营费合计</text>
        </view>
      </view>
    </view>

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">结算列表</text>
        <text class="section-subtitle">最近 20 笔结算</text>
      </view>
      <t-cell-group theme="card">
        <block wx:if="{{settlements.length > 0}}">
          <view wx:for="{{settlements}}" wx:key="id" class="record-item">
            <view class="record-row">
              <view>
                <text class="record-amount">{{formatAmountText(item.merchant_amount)}}</text>
                <view class="record-meta">{{getOrderSourceText(item.order_source)}} · {{item.out_order_no || ('#' + item.payment_order_id)}}</view>
              </view>
              <t-tag theme="{{getFinanceOrderStatusTheme(item.status)}}" variant="dark">{{getFinanceOrderStatusText(item.status)}}</t-tag>
            </view>
            <view class="finance-fee-row">
              <text>订单金额 {{formatAmountText(item.total_amount)}}</text>
              <text>平台费 {{formatAmountText(item.platform_commission)}}</text>
              <text>运营费 {{formatAmountText(item.operator_commission)}}</text>
            </view>
            <view class="record-meta">创建时间：{{formatDateTime(item.created_at)}}</view>
          </view>
        </block>
        <t-empty wx:else description="当前筛选下暂无结算记录" />
      </t-cell-group>
    </view>
  </view>
</view>