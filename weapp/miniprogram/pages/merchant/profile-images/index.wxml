<custom-navbar title="店铺图片管理" showBack="{{true}}" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">

  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>

  <block wx:elif="{{accessReady}}">

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading && !hasLoaded}}">
    <t-loading theme="circular" size="60rpx" text="加载中..." layout="vertical" />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '店铺图片加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>

    <view wx:if="{{!hasAnyImages}}" class="state-block state-block-compact">
      <t-empty description="还没有上传店铺图片，建议先补齐 Logo、门头照和环境照" />
      <text class="state-tip">图片会影响顾客搜索、详情页展示和平台审核效率。</text>
    </view>

    <!-- Logo -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">店铺 Logo</text>
        <text class="section-desc">建议使用正方形图片</text>
      </view>
      <view class="logo-upload-wrap">
        <t-upload
          mediaType="{{['image']}}"
          max="{{1}}"
          gridConfig="{{ { column: 1, width: 220, height: 220 } }}"
          files="{{logoFiles}}"
          disabled="{{logoUploading}}"
          bind:add="onLogoUpload"
          bind:remove="onLogoRemove"
        />
        <view class="upload-tip">Logo 会展示在顾客搜索结果和详情页</view>
      </view>
    </view>

    <t-divider />

    <!-- 门头照 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">门头照</text>
        <text class="section-count">{{storefrontImages.length}}/3</text>
      </view>
      <view class="upload-wrap">
        <t-upload
          mediaType="{{['image']}}"
          max="{{3}}"
          gridConfig="{{ { column: 3, width: 200, height: 200 } }}"
          files="{{storefrontFiles}}"
          disabled="{{storefrontSaving}}"
          bind:add="onStorefrontUpload"
          bind:remove="onStorefrontRemove"
        />
        <view class="upload-tip">请上传店铺门头清晰照片，最多3张</view>
      </view>
    </view>

    <t-divider />

    <!-- 环境照 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">店内环境照</text>
        <text class="section-count">{{environmentImages.length}}/5</text>
      </view>
      <view class="upload-wrap">
        <t-upload
          mediaType="{{['image']}}"
          max="{{5}}"
          gridConfig="{{ { column: 3, width: 200, height: 200 } }}"
          files="{{environmentFiles}}"
          disabled="{{environmentSaving}}"
          bind:add="onEnvironmentUpload"
          bind:remove="onEnvironmentRemove"
        />
        <view class="upload-tip">请上传店内环境照片，最多5张</view>
      </view>
    </view>

  </block>

  </block>

</view>
