<custom-navbar title="套餐管理" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view wx:if="{{loading && !combos.length}}" class="loading-state">
    <t-loading theme="circular" text="加载套餐中..." vertical />
  </view>

  <t-empty wx:elif="{{!loading && !combos.length}}" icon="info-circle" description="暂无套餐" />

  <view wx:else class="combo-list">
    <view class="combo-card" wx:for="{{combos}}" wx:key="id" bindtap="onEditCombo" data-id="{{item.id}}">
      <view class="combo-main">
        <view class="combo-name">{{item.name}}</view>
        <view class="combo-desc">{{item.description || '无描述'}}</view>
      </view>
      <view class="combo-side">
        <view class="combo-price">¥{{item.combo_price / 100}}</view>
        <t-tag theme="{{item.is_online ? 'success' : 'default'}}" variant="dark" size="small">
          {{item.is_online ? '已上架' : '未上架'}}
        </t-tag>
      </view>
      <view class="combo-actions">
        <t-button
          size="small"
          theme="danger"
          shape="round"
          data-id="{{item.id}}"
          catch:tap="onDeleteCombo"
        >
          删除
        </t-button>
        <t-button
          size="small"
          theme="primary"
          variant="base"
          shape="round"
          loading="{{item.submitting}}"
          data-id="{{item.id}}"
          catch:tap="onToggleOnline"
        >
          {{item.is_online ? '下架' : '上架'}}
        </t-button>
      </view>
    </view>

    <view wx:if="{{hasMore}}" class="load-more" bindtap="loadCombos">
      <text>{{loading ? '正在加载...' : '加载更多'}}</text>
    </view>
  </view>

  <t-fab icon="add" bind:click="onCreateCombo" />
</view>
