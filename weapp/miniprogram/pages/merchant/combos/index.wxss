.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}


.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.page-notice {
  border-radius: var(--radius-md);
  overflow: hidden;
}

.control-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  background: var(--td-bg-color-page);
}

.filter-panel {
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.filter-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.filter-label {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.result-bar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: var(--spacer-sm);
  padding: 0 4rpx;
}

.result-summary {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.loading-state,
.load-more {
  display: flex;
  justify-content: center;
}

.loading-state {
  padding: 100rpx 0;
}

.combo-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.combo-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.combo-card-main {
  display: flex;
  flex-direction: column;
}

.combo-content {
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.combo-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.combo-header-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.combo-name {
  font-size: var(--font-size-heading);
  line-height: 1.35;
  font-weight: 700;
  color: var(--td-text-color-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.combo-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.combo-switch-wrap {
  margin-left: auto;
  flex-shrink: 0;
}

.combo-meta-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.combo-price-row,
.combo-tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.price-value {
  font-size: var(--font-size-title);
  line-height: 1;
  color: var(--td-brand-color);
  font-weight: 700;
}

.combo-original-price {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
}

.combo-action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacer-md);
}

.combo-action-slot {
  flex: 1;
  display: flex;
  justify-content: center;
}

.combo-action-button {
  flex: 0 0 auto;
}

.dialog-content {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.load-more {
  padding: var(--spacer-sm) 0 8rpx;
}

.list-end {
  display: flex;
  justify-content: center;
  padding: var(--spacer-sm) 0 8rpx;
}

.list-end__text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

@media (max-width: 420px) {
  .combo-action-bar {
    padding: 0 var(--spacer-sm);
  }
}
