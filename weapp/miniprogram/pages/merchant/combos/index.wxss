.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: 120rpx;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx;
  padding-bottom: 0;
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-container);
  color: var(--td-text-color-secondary);
  box-shadow: var(--shadow-sm);
  font-size: 24rpx;
}

.filter-chip-active {
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
}

.loading-state {
  padding: 120rpx 0;
}

.combo-list {
  padding: 24rpx;
}

.combo-card {
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.combo-cover {
  position: relative;
  margin-bottom: 18rpx;
}

.combo-cover-image {
  width: 100%;
  height: 240rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-component);
}

.combo-cover-badge {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.58);
  color: #fff;
  font-size: 22rpx;
}

.combo-main {
  margin-bottom: 16rpx;
}

.combo-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.combo-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.combo-side {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.combo-price-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.combo-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.combo-price {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.combo-original-price {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
}

.combo-savings {
  font-size: 22rpx;
  color: var(--td-brand-color);
}

.combo-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  flex-wrap: wrap;
}

.load-more {
  text-align: center;
  color: var(--td-text-color-placeholder);
  font-size: 24rpx;
  padding: 20rpx 0;
}
