<custom-navbar title="{{isEdit ? '编辑套餐' : '新建套餐'}}" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view wx:if="{{loading}}" class="loading-state">
    <t-loading theme="circular" text="加载中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '套餐编辑页加载失败，请重试'}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="section">
      <view class="section-title">1. 选择菜品（可多选）</view>
      <view class="filter-row">
        <text class="filter-label">仅显示已上架菜品</text>
        <t-switch value="{{showOnlineOnly}}" size="small" bind:change="onShowOnlineOnlyChange" />
      </view>
      <checkbox-group bindchange="onDishCheckChange">
        <view class="dish-option" wx:for="{{dishes}}" wx:key="id">
          <image wx:if="{{item.image_url}}" class="dish-thumb" src="{{item.image_url}}" mode="aspectFill" />
          <checkbox
            value="{{item.id}}"
            checked="{{item.checked}}"
            color="var(--td-brand-color)"
          />
          <view class="dish-meta">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-extra">¥{{item.price / 100}} · {{item.is_online ? '已上架' : '未上架'}}</view>
          </view>
          <view wx:if="{{item.checked}}" class="dish-qty-control">
            <text class="dish-qty-label">份数</text>
            <t-stepper
              value="{{item.quantity}}"
              min="{{1}}"
              max="{{99}}"
              theme="filled"
              data-id="{{item.id}}"
              bind:change="onDishQuantityChange"
            />
          </view>
        </view>
      </checkbox-group>
      <t-empty wx:if="{{!dishes.length}}" icon="info-circle" description="{{dishEmptyDescription}}" />
    </view>

    <view class="section">
      <view class="section-title">2. 价格策略（单选）</view>
      <radio-group bindchange="onPricingModeChange">
        <label class="radio-option" wx:for="{{pricingModeOptions}}" wx:key="value">
          <radio
            value="{{item.value}}"
            checked="{{pricingMode === item.value}}"
            color="var(--td-brand-color)"
            disabled="{{item.value === 'keep' && !isEdit}}"
          />
          <text class="radio-label">{{item.label}}</text>
        </label>
      </radio-group>
    </view>

    <view class="section">
      <view class="section-title">3. 套餐信息</view>
      <t-input
        label="套餐名称"
        placeholder="请输入套餐名称"
        value="{{comboName}}"
        maxlength="100"
        bind:change="onComboNameChange"
      />
      <t-textarea
        value="{{comboDescription}}"
        placeholder="可填写套餐卖点、适用人群或搭配说明"
        maxlength="500"
        indicator
        bind:change="onComboDescriptionChange"
      />
      <view class="summary-note summary-note-inline">默认会根据已选菜品生成名称，你也可以手动修改。</view>
    </view>

    <view class="section">
      <view class="section-title">4. 套餐标签</view>
      <view class="tag-header">
        <text class="filter-label">用于标记套餐属性或活动主题</text>
        <t-button size="small" variant="outline" shape="round" loading="{{tagSubmitting}}" bind:tap="onCreateTag">新增标签</t-button>
      </view>
      <checkbox-group bindchange="onTagChange" wx:if="{{availableTags.length}}">
        <view class="tag-grid">
          <label class="tag-option" wx:for="{{availableTags}}" wx:key="id">
            <checkbox value="{{item.id + ''}}" checked="{{selectedTagIds.indexOf(item.id) !== -1}}" color="var(--td-brand-color)" />
            <text class="tag-option-label">{{item.name}}</text>
          </label>
        </view>
      </checkbox-group>
      <t-empty wx:else icon="info-circle" description="暂无套餐标签，可先新增标签" />
    </view>

    <view class="section">
      <view class="section-title">5. 上下架状态（单选）</view>
      <radio-group bindchange="onOnlineChoiceChange">
        <label class="radio-option">
          <radio value="online" checked="{{onlineChoice === 'online'}}" color="var(--td-brand-color)" />
          <text class="radio-label">创建后上架</text>
        </label>
        <label class="radio-option">
          <radio value="offline" checked="{{onlineChoice === 'offline'}}" color="var(--td-brand-color)" />
          <text class="radio-label">先不上架</text>
        </label>
      </radio-group>
    </view>

    <view class="summary-card">
      <view class="summary-previews" wx:if="{{selectedDishPreviews.length}}">
        <image class="summary-preview-image" wx:for="{{selectedDishPreviews}}" wx:key="*this" src="{{item}}" mode="aspectFill" />
      </view>
      <view class="summary-row">
        <text class="label">套餐名称</text>
        <text class="value">{{comboName || autoName}}</text>
      </view>
      <view class="summary-row">
        <text class="label">已选菜品</text>
        <text class="value">{{selectedDishIds.length}} 款 / {{selectedDishQuantityTotal}} 份</text>
      </view>
      <view class="summary-row">
        <text class="label">原价合计</text>
        <text class="value">¥{{originalTotal / 100}}</text>
      </view>
      <view class="summary-row">
        <text class="label">套餐价格</text>
        <text class="value">¥{{comboPricePreview / 100}}</text>
      </view>
      <view class="summary-note">自动建议名称：{{autoName}}</view>
    </view>

    <view class="footer">
      <t-button
        block
        theme="primary"
        loading="{{submitting}}"
        disabled="{{selectedDishIds.length === 0}}"
        bind:tap="onSubmit"
       shape="round">
        {{isEdit ? '保存套餐' : '创建套餐'}}
      </t-button>
    </view>
  </block>
</view>
