.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}


.loading-state {
  padding: 120rpx 0;
}

.state-block {
  padding: 140rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-md);
}

.notice-banner {
  margin-top: 20rpx;
}

.notice-text {
  font-size: 24rpx;
  line-height: 1.6;
}

.section-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  background: var(--td-bg-color-container);
  border-radius: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-top-action {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-top-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-top-main--spaced {
  margin-bottom: 20rpx;
}

.section-top-button {
  flex-shrink: 0;
}

.section-caption {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.section-switch {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.filter-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.tag-check-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-empty-text {
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.dish-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-component-stroke);
}

.dish-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.dish-card__main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dish-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 14rpx;
  margin-right: 16rpx;
  background: var(--td-bg-color-component);
}

.dish-meta {
  flex: 1;
  min-width: 0;
}

.dish-qty-control {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.dish-qty-label {
  font-size: 22rpx;
  color: var(--td-text-color-secondary);
}

.dish-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.dish-extra {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--td-text-color-secondary);
}

.dish-inline-error {
  margin-left: 120rpx;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: var(--td-warning-color-1);
}

.dish-inline-error__text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--td-warning-color-7);
}

.dish-spec-panel {
  margin-left: 120rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: var(--td-bg-color-page);
}

.dish-spec-group {
  margin-top: 18rpx;
}

.dish-spec-group:first-child {
  margin-top: 0;
}

.dish-spec-group__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dish-spec-group__title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.dish-spec-group__note {
  font-size: 22rpx;
  color: var(--td-text-color-secondary);
}

.dish-spec-group__options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.summary-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--td-bg-color-container);
}

.summary-previews {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.summary-preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-component);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.value {
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.summary-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.summary-note-inline {
  margin-top: 16rpx;
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
}

.dialog-form {
  padding-top: 8rpx;
}
