.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: 120rpx;
}

.loading-state {
  padding: 120rpx 0;
}

.state-block {
  padding: 140rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-md);
}

.section {
  margin: 20rpx 24rpx 0;
  padding: 20rpx;
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.filter-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.dish-option {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.dish-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 14rpx;
  margin-right: 16rpx;
  background: var(--td-bg-color-component);
}

.dish-meta {
  margin-left: 12rpx;
}

.dish-name {
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.dish-extra {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--td-text-color-secondary);
}

.radio-option {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.radio-label {
  margin-left: 10rpx;
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.summary-card {
  margin: 20rpx 24rpx 0;
  padding: 20rpx;
  border-radius: 12rpx;
  background: var(--td-bg-color-container);
}

.summary-previews {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.summary-preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-component);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.value {
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.summary-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx 30rpx;
  background: var(--td-bg-color-container);
}
