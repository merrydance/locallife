.intent-page {
  min-height: 100vh;
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.sync-state {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--td-error-color);
  background: var(--td-error-color-light);
  border-radius: var(--radius-sm);
  padding: 16rpx;
}

.sync-state__text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.45;
}

.status-section,
.qr-section,
.state-panel {
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-border-level-1-color);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-sizing: border-box;
}

.status-section {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.status-section__main {
  flex: 1;
  min-width: 0;
}

.status-section__title {
  color: var(--td-text-color-primary);
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.35;
}

.status-section__desc {
  margin-top: 8rpx;
  color: var(--td-text-color-secondary);
  font-size: 26rpx;
  line-height: 1.5;
}

.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.qr-frame {
  width: 520rpx;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--td-bg-color-page);
  border: 1rpx solid var(--td-border-level-1-color);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  box-sizing: border-box;
}

.qr-image {
  width: 100%;
  height: 100%;
}

.qr-meta {
  color: var(--td-text-color-placeholder);
  font-size: 24rpx;
  line-height: 1.4;
}

.guide-section {
  display: block;
  overflow: hidden;
  border: 1rpx solid var(--td-border-level-1-color);
  border-radius: var(--radius-md);
}

.state-panel {
  min-height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-state {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: var(--radius-sm);
  color: var(--td-text-color-secondary);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-border-level-1-color);
}

.save-state__text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.45;
}

.save-state--saved {
  color: var(--td-success-color);
  background: var(--td-success-color-light);
}

.save-state--permission_denied,
.save-state--download_failed,
.save-state--save_failed {
  color: var(--td-error-color);
  background: var(--td-error-color-light);
}

.action-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
