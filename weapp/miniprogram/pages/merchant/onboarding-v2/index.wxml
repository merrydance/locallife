<custom-navbar title="商户入驻进度" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="onboarding-page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载入驻进度中..." layout="vertical" />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '入驻进度加载失败，请重试'}}" />
    <t-button theme="primary" bindtap="onRetry">重新加载</t-button>
  </view>

  <view wx:elif="{{viewState}}" class="page-content">
    <view class="progress-section">
      <t-steps current="{{viewState.currentStep}}" theme="dot">
        <t-step-item title="平台入驻" />
        <t-step-item title="宝付开户" />
        <t-step-item title="开户意愿确认" />
      </t-steps>
    </view>

    <view wx:if="{{refreshError}}" class="sync-state">
      <t-icon name="error-circle" size="32rpx" />
      <text class="sync-state__text">{{refreshError}}</text>
      <t-button size="small" theme="primary" variant="text" bindtap="onRefresh">重试</t-button>
    </view>

    <view class="task-panel">
      <view class="task-panel__head">
        <view>
          <view class="task-panel__title">{{viewState.currentTitle}}</view>
          <view class="task-panel__desc">{{viewState.currentDescription}}</view>
        </view>
        <t-tag theme="{{viewState.currentStatusTheme}}">{{viewState.currentStatusText}}</t-tag>
      </view>

      <view class="stage-list">
        <view wx:for="{{viewState.stages}}" wx:key="key" class="stage-row stage-row--{{item.status}}">
          <view class="stage-row__main">
            <view class="stage-row__title">{{item.title}}</view>
            <view class="stage-row__desc">{{item.description}}</view>
          </view>
          <view class="stage-row__status">{{item.statusText}}</view>
        </view>
      </view>

      <view class="action-area">
        <t-button
          wx:if="{{viewState.primaryActionText}}"
          theme="primary"
          block
          loading="{{refreshing && viewState.primaryAction === 'refresh'}}"
          disabled="{{refreshing || navigating}}"
          bindtap="onPrimaryAction"
        >
          {{viewState.primaryActionText}}
        </t-button>
        <t-button
          theme="default"
          block
          loading="{{refreshing && viewState.secondaryAction === 'refresh'}}"
          disabled="{{refreshing || navigating}}"
          bindtap="onSecondaryAction"
        >
          {{viewState.secondaryActionText}}
        </t-button>
      </view>
    </view>
  </view>
</view>
