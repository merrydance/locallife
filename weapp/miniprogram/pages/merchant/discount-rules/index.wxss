.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(160rpx + var(--safe-area-bottom));
  box-sizing: border-box;
}

.hero-card,
.rule-card,
.form-popup {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.hero-card {
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy,
.rule-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-title,
.rule-name,
.form-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.hero-subtitle,
.rule-desc,
.rule-meta-label,
.rule-meta-value,
.form-label {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.state-block {
  padding: 180rpx 0;
  display: flex;
  justify-content: center;
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.rule-card {
  padding: var(--spacer-md);
}

.rule-header,
.rule-meta-row,
.rule-actions,
.form-item-switch,
.form-actions,
.form-row {
  display: flex;
}

.rule-header,
.rule-meta-row,
.form-item-switch,
.form-actions {
  justify-content: space-between;
  gap: 16rpx;
}

.rule-body {
  margin-top: 18rpx;
}

.rule-highlight {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-brand-color);
  margin-bottom: 16rpx;
}

.rule-meta-row + .rule-meta-row {
  margin-top: 12rpx;
}

.rule-meta-label {
  width: 132rpx;
  flex-shrink: 0;
}

.rule-meta-value {
  flex: 1;
  text-align: right;
  color: var(--td-text-color-primary);
}

.rule-actions {
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--td-component-stroke);
  flex-wrap: wrap;
}

.form-popup {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  max-height: 84vh;
}

.form-scroll {
  max-height: 85vh;
  padding: 32rpx 24rpx var(--popup-bottom-padding-md);
  box-sizing: border-box;
}

.form-title {
  text-align: center;
  margin-bottom: 32rpx;
}

.form-row {
  gap: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item-half {
  flex: 1;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  color: var(--td-text-color-primary);
}

.required {
  color: var(--td-error-color);
}

.form-input,
.form-textarea,
.form-picker {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid var(--td-component-stroke);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.form-input,
.form-picker {
  min-height: 84rpx;
  display: flex;
  align-items: center;
}

.form-textarea {
  min-height: 180rpx;
}

.form-picker.is-placeholder {
  color: var(--td-text-color-placeholder);
}

.form-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
}