@import '../../../styles/merchant-config-shared.wxss';

.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(160rpx + var(--safe-area-bottom));
  box-sizing: border-box;
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-success {
  background: var(--td-success-color-1);
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.rule-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.hero-copy,
.rule-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rule-name {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.rule-desc,
.rule-meta-label,
.rule-meta-value {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.rule-card {
  padding: var(--spacer-md);
}

.rule-header,
.rule-meta-row,
.list-footer,
.form-item-switch,
.form-row {
  display: flex;
}

.rule-header,
.rule-meta-row,
.list-footer,
.form-item-switch,
.form-row {
  justify-content: space-between;
  gap: 16rpx;
}

.rule-header {
  align-items: flex-start;
}

.rule-body {
  margin-top: 18rpx;
}

.rule-highlight {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-brand-color);
  margin-bottom: 16rpx;
}

.rule-meta-row + .rule-meta-row {
  margin-top: 12rpx;
}

.rule-meta-label {
  width: 132rpx;
  flex-shrink: 0;
}

.rule-meta-value {
  flex: 1;
  text-align: right;
  color: var(--td-text-color-primary);
}

.rule-footer {
  display: flex;
  flex-direction: column;
  margin-top: 20rpx;
  gap: 16rpx;
}

.rule-action-hint {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-placeholder);
}

.rule-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.list-footer {
  justify-content: center;
  margin-top: 8rpx;
}

.list-footer-text {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.form-item {
  margin-bottom: 24rpx;
}

.required {
  color: var(--td-error-color);
}