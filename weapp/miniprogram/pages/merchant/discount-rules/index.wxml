<custom-navbar title="满减规则管理" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载满减规则中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '满减规则加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <view class="result-bar">
        <text class="result-summary">{{resultSummaryText}}</text>
      </view>

      <view wx:if="{{loading && !rules.length}}" class="loading-state">
        <t-loading theme="circular" size="40rpx" text="加载满减规则中..." vertical />
      </view>

      <t-empty wx:elif="{{!loading && !rules.length}}" icon="info-circle" description="{{emptyDescription}}" />

      <view wx:else class="rule-list">
        <block wx:for="{{rules}}" wx:key="id">
          <t-cell-group class="rule-card">
            <view class="rule-card-main" bindtap="onEditRule" data-id="{{item.id}}">
              <view class="rule-content">
                <view class="rule-header">
                  <view class="rule-header-main">
                    <text class="rule-name">{{item.name}}</text>
                    <text class="rule-desc">{{item.description || '未填写规则说明'}} </text>
                  </view>
                  <view class="rule-switch-wrap" catchtap="onActionsCatch">
                    <t-switch
                      value="{{item.is_active}}"
                      size="small"
                      loading="{{item.statusPending}}"
                      disabled="{{item.deletePending}}"
                      bind:change="onToggleRuleStatus"
                      data-id="{{item.id}}"
                    />
                  </view>
                </view>

                <view class="rule-meta-group">
                  <view class="rule-price-row">
                    <text class="meta-label">门槛</text>
                    <text class="price-value">¥{{item.min_order_amount_yuan}}</text>
                    <text class="meta-divider">减</text>
                    <text class="price-value price-value--accent">¥{{item.discount_amount_yuan}}</text>
                  </view>

                  <view class="rule-tag-row">
                    <t-tag theme="{{item.status_theme}}" variant="light" size="small">{{item.status_label}}</t-tag>
                  </view>

                  <view class="rule-meta-row">
                    <text class="meta-label">叠加</text>
                    <text class="meta-value">{{item.stacking_text}}</text>
                  </view>

                  <view class="rule-meta-row">
                    <text class="meta-label">有效期</text>
                    <text class="meta-value">{{item.valid_range_text}}</text>
                  </view>
                </view>
              </view>
            </view>

            <t-divider />

            <view class="rule-action-bar" catchtap="onActionsCatch">
              <view class="rule-action-slot">
                <t-button class="rule-action-button" variant="text" theme="default" size="small" bind:tap="onEditRule" data-id="{{item.id}}">编辑</t-button>
              </view>
              <t-divider layout="vertical" />
              <view class="rule-action-slot">
                <t-button
                  class="rule-action-button"
                  variant="text"
                  theme="danger"
                  size="small"
                  loading="{{item.deletePending}}"
                  disabled="{{item.deletePending || item.statusPending}}"
                  bind:tap="onRequestDeleteRule"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                >删除</t-button>
              </view>
            </view>
          </t-cell-group>
        </block>

        <view class="list-footer">
          <t-loading wx:if="{{loadingMore}}" theme="circular" size="32rpx" text="加载更多规则中..." />
          <t-button wx:elif="{{hasMore}}" theme="default" bind:tap="onLoadMore">继续加载更多</t-button>
          <text wx:else class="list-footer-text">已完成当前结果加载</text>
        </view>
      </view>
    </view>

    <t-fab icon="add" bind:click="onAddRule" />
  </block>

  <t-dialog
    visible="{{deleteDialogVisible}}"
    title="确认删除满减规则"
    using-custom-navbar="{{true}}"
    confirm-btn="{{ { content: '确认删除', theme: 'danger', loading: deleteDialogSubmitting } }}"
    cancel-btn="取消"
    bind:confirm="onConfirmDeleteRule"
    bind:cancel="onCancelDeleteDialog"
    bind:close="onCancelDeleteDialog"
  >
    <view slot="content" class="dialog-content">
      <text>删除后无法恢复，确定要删除“{{deleteDialogRuleName}}”吗？</text>
    </view>
  </t-dialog>
</view>