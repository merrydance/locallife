.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.notice-banner-operation {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.order-type-list,
.option-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.order-type-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-md);
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.order-type-main {
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.order-type-title,
.option-editor__title {
  font-size: var(--font-size-base);
  line-height: 1.4;
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.order-type-desc,
.option-editor__state {
  font-size: var(--font-size-xs);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
}

.option-editor {
  overflow: hidden;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-border-level-1-color);
}

.option-editor--deleted {
  opacity: 0.74;
}

.option-editor__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-md);
  padding: var(--spacer-md);
  background: var(--td-bg-color-secondarycontainer);
}

.option-editor__title-wrap {
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.option-editor__actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.option-editor__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-md) var(--spacer-md);
}

.option-editor__footer > t-cell {
  flex: 1;
}

.section-action {
  display: flex;
  justify-content: flex-end;
  padding-top: var(--spacer-sm);
}

.empty-inline {
  padding: var(--spacer-md) 0;
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}

@media (max-width: 420px) {
  .order-type-row,
  .option-editor__footer {
    align-items: flex-start;
    flex-direction: column;
  }
}
