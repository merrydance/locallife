.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.state-block,
.popup-state,
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.state-block {
  min-height: 60vh;
  padding: 0 var(--spacer-lg);
}

.empty-wrap {
  padding: 140rpx var(--spacer-md);
}

.page-notice {
  border-radius: var(--radius-md);
  overflow: hidden;
}

.section-panel,
.summary-strip,
.staff-card,
.popup-sheet {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.section-panel {
  position: relative;
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.staff-summary-panel {
  padding-right: 96rpx;
}

.section-head {
  min-height: 64rpx;
  display: flex;
  align-items: center;
}

.invite-trigger-anchor {
  position: absolute;
  top: var(--spacer-md);
  right: var(--spacer-md);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.invite-trigger-btn {
  flex-shrink: 0;
}

.section-caption,
.summary-label,
.staff-submeta,
.pending-tip,
.popup-subtitle,
.invite-expire,
.invite-tip,
.role-desc {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.summary-value,
.staff-name,
.popup-title,
.invite-code,
.role-label {
  color: var(--td-text-color-primary);
}

.popup-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
}

.refresh-action-wrap {
  display: flex;
  justify-content: flex-end;
}

.summary-strip {
  display: flex;
  overflow: hidden;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: var(--spacer-sm) var(--spacer-xs);
}

.summary-item + .summary-item {
  border-left: 1px solid var(--td-component-stroke);
}

.summary-value {
  font-size: var(--font-size-title);
  font-weight: 700;
}

.staff-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.staff-card {
  overflow: hidden;
}

.staff-card-main {
  padding: var(--spacer-md);
}

.staff-header,
.staff-profile,
.popup-actions,
.role-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.staff-header {
  justify-content: space-between;
  align-items: flex-start;
}

.staff-profile {
  flex: 1;
  min-width: 0;
}

.staff-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-secondarycontainer);
  flex-shrink: 0;
}

.staff-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color);
}

.staff-meta,
.staff-tags,
.invite-body,
.role-copy {
  display: flex;
  flex-direction: column;
}

.staff-meta,
.role-copy {
  gap: 6rpx;
  min-width: 0;
}

.staff-name {
  font-size: var(--font-size-base);
  font-weight: 600;
}

.staff-tags {
  gap: 12rpx;
  align-items: flex-end;
}

.pending-tip {
  margin-top: var(--spacer-sm);
  padding: var(--spacer-sm);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
}

.staff-action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacer-md);
}

.staff-action-slot {
  flex: 1;
  display: flex;
  justify-content: center;
}

.staff-action-button {
  flex: 0 0 auto;
}

.popup-sheet {
  padding: var(--spacer-md);
  padding-bottom: var(--popup-bottom-padding-md);
}

.invite-modal {
  width: 560rpx;
  max-width: calc(100vw - 64rpx);
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
  padding: var(--spacer-md);
  box-sizing: border-box;
}

.popup-state {
  padding: 48rpx 0 var(--spacer-sm);
}

.invite-qr-only {
  padding: 28rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
  display: flex;
  align-items: center;
  justify-content: center;
}

.role-options {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
  margin-top: var(--spacer-sm);
}

.role-option {
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.role-label {
  font-size: var(--font-size-sm);
  font-weight: 600;
}

.popup-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--spacer-xs);
  margin-top: var(--spacer-sm);
}

@media (max-width: 420px) {
  .invite-modal {
    width: calc(100vw - 48rpx);
    max-width: calc(100vw - 48rpx);
  }
}