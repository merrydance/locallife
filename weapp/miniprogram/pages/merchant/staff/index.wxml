<custom-navbar title="员工管理" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bindtap="onRetryAccess">重新校验</t-button>
  </view>

  <block wx:elif="{{accessReady}}">
    <view wx:if="{{initialLoading}}" class="state-block">
      <t-loading theme="circular" size="40rpx" text="加载员工列表中..." vertical />
    </view>

    <view wx:elif="{{initialError}}" class="state-block">
      <t-empty description="{{initialErrorMessage || '员工列表加载失败，请重试'}}" />
      <t-button theme="primary" bindtap="onRetry">重试</t-button>
    </view>

    <block wx:else>
    <view class="page-content">
    <view class="section-panel staff-summary-panel">
      <view class="section-head">
        <text class="section-title">门店协作成员</text>
      </view>
      <view wx:if="{{canGenerateInvite}}" class="invite-trigger-anchor">
        <t-button class="invite-trigger-btn" size="small" theme="primary" shape="circle" icon="add" bind:tap="onOpenInvitePopup"></t-button>
      </view>
      <text class="section-caption">当前身份：{{currentUserRoleLabel}}</text>

      <view class="summary-strip">
        <view class="summary-item">
          <text class="summary-value">{{staffCount}}</text>
          <text class="summary-label">总人数</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{pendingCount}}</text>
          <text class="summary-label">待分配岗位</text>
        </view>
      </view>

      <view wx:if="{{refreshErrorMessage}}" class="refresh-action-wrap">
        <t-button size="small" variant="text" theme="primary" bind:tap="onRetryRefresh">重试</t-button>
      </view>
    </view>

    <view wx:if="{{!staff.length}}" class="empty-wrap">
      <t-empty description="门店还没有成员，先生成扫码邀请，让店员从“我的”页头像卡右上角的扫码入口加入。" />
      <t-button wx:if="{{canGenerateInvite}}" theme="primary" icon="add" bind:tap="onOpenInvitePopup">生成邀请二维码</t-button>
    </view>

    <view wx:else class="staff-list">
      <t-cell-group wx:for="{{staff}}" wx:key="id" class="staff-card" theme="card">
        <view class="staff-card-main">
          <view class="staff-header">
            <view class="staff-profile">
              <t-image wx:if="{{item.avatar_url}}" class="staff-avatar" src="{{item.avatar_url}}" mode="aspectFill" />
              <view wx:else class="staff-avatar staff-avatar-fallback">{{item.displayInitial}}</view>
              <view class="staff-meta">
                <text class="staff-name">{{item.displayName}}</text>
                <text class="staff-submeta">用户 ID {{item.user_id}} · 加入于 {{item.joinedAtLabel}}</text>
              </view>
            </view>
            <view class="staff-tags">
              <t-tag size="small" variant="dark" theme="{{item.roleTheme}}">{{item.roleLabel}}</t-tag>
              <t-tag size="small" variant="dark" theme="{{item.statusTheme}}">{{item.statusLabel}}</t-tag>
            </view>
          </view>

          <view wx:if="{{item.role === 'pending'}}" class="pending-tip">该员工已入职，但还未分配具体岗位。建议尽快设置角色，避免权限和工作流不清晰。</view>
        </view>

        <t-divider />

        <view class="staff-action-bar">
          <view class="staff-action-slot">
            <t-button wx:if="{{item.canEditRole}}" class="staff-action-button" variant="text" theme="default" size="small" data-id="{{item.id}}" bind:tap="onOpenRolePopup">改角色</t-button>
          </view>

          <t-divider wx:if="{{item.canEditRole && item.canRemove}}" layout="vertical" />

          <view class="staff-action-slot">
            <t-button wx:if="{{item.canRemove}}" class="staff-action-button" variant="text" theme="danger" size="small" icon="delete" data-id="{{item.id}}" disabled="{{removingStaffId === item.id}}" bind:tap="onRemoveStaff">移除</t-button>
          </view>
        </view>
      </t-cell-group>
    </view>
    </view>
    </block>
  </block>

  <view wx:else class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>

  <t-popup wx:if="{{inviteVisible}}" visible="{{inviteVisible}}" placement="center" bind:visible-change="onCloseInvitePopup">
    <view class="invite-modal">

      <view wx:if="{{inviteLoading}}" class="popup-state">
        <t-loading theme="circular" size="40rpx" text="生成邀请二维码中..." vertical />
      </view>

      <view wx:elif="{{inviteError}}" class="popup-state">
        <t-empty description="{{inviteErrorMessage || '生成邀请失败，请重试'}}" />
      </view>

      <view wx:else class="invite-content">
        <view wx:if="{{inviteCode}}" class="invite-qr-only">
          <t-qrcode value="{{inviteQRCodeValue}}" size="220" level="M" borderless="{{true}}" />
        </view>
        <view wx:else class="popup-state">
          <t-empty description="当前邀请码已停用" />
          <t-button theme="primary" loading="{{inviteLoading}}" bind:tap="onRetryInviteCode">重新生成</t-button>
        </view>
        <text wx:if="{{inviteCode}}" class="invite-expire">有效期至 {{inviteExpiresAtLabel}}</text>
        <view wx:if="{{inviteCode}}" class="invite-actions">
          <t-button size="small" theme="default" disabled="{{inviteActionSubmitting}}" bind:tap="onCopyInviteCode">复制</t-button>
          <t-button size="small" theme="primary" loading="{{inviteActionSubmitting}}" disabled="{{inviteActionSubmitting}}" bind:tap="onRotateInviteCode">更换</t-button>
          <t-button size="small" theme="danger" variant="outline" loading="{{inviteActionSubmitting}}" disabled="{{inviteActionSubmitting}}" bind:tap="onRevokeInviteCode">停用</t-button>
        </view>
      </view>
    </view>
  </t-popup>

  <t-popup wx:if="{{rolePopupVisible}}" visible="{{rolePopupVisible}}" placement="bottom" bind:visible-change="onCloseRolePopup">
    <view class="popup-sheet">
      <view class="popup-title">分配岗位</view>
      <text class="popup-subtitle">为 {{editingStaffName}} 选择在门店中的职责角色。</text>
      <t-radio-group class="role-options" value="{{editingRole}}" borderless="{{true}}" icon="line" bind:change="onRoleChange">
        <view wx:for="{{roleOptions}}" wx:key="value" class="role-option">
          <t-radio value="{{item.value}}">
            <view slot="label" class="role-copy">
              <text class="role-label">{{item.label}}</text>
              <text class="role-desc">{{item.desc}}</text>
            </view>
          </t-radio>
        </view>
      </t-radio-group>
      <view class="popup-actions">
        <t-button theme="default" bind:tap="onCloseRolePopup">取消</t-button>
        <t-button theme="primary" loading="{{roleSubmitting}}" bind:tap="onSubmitRole">保存角色</t-button>
      </view>
    </view>
  </t-popup>
</view>
