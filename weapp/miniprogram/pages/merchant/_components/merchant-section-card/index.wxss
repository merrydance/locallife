.merchant-section-card {
  display: flex;
  flex-direction: column;
  border-radius: var(--radius-card);
  background: var(--td-bg-color-container);
  overflow: hidden;
}

.merchant-section-card__header {
  padding: var(--spacer-md) var(--spacer-md) var(--spacer-xs);
}

.merchant-section-card__title {
  display: block;
  margin-bottom: 0;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--td-border-level-2-color);
  font-size: var(--font-size-heading);
  font-weight: 700;
  line-height: 1.3;
  color: var(--td-text-color-primary);
}

.merchant-section-card__subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.merchant-section-card__body {
  padding: 0 var(--spacer-sm) var(--spacer-sm);
}

.merchant-section-card__body--none {
  padding: 0;
}
