.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding-bottom: calc(var(--spacer-md) + var(--safe-area-bottom));
}

.state-block,
.loading-state,
.state-inline {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.state-block {
  min-height: 60vh;
  padding: 0 var(--spacer-lg);
}

.loading-state,
.state-inline {
  min-height: 320rpx;
}

.page-notice {
  border-radius: var(--radius-md);
}

.section-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding: var(--spacer-md);
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.section-top {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-caption {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.option-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.option-group--disabled {
  opacity: 0.66;
}

.option-group__header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-group__title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.option-group__desc,
.option-group__help {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.option-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}
