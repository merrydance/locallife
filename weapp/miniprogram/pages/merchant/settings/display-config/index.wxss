.page-container {
  min-height: 100vh;
  padding: var(--spacer-md);
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.loading-shell,
.state-block {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.state-block {
  align-items: center;
  justify-content: center;
  padding: 140rpx var(--spacer-md);
}

.retry-button {
  padding: var(--spacer-sm) var(--spacer-lg);
  border-radius: var(--radius-round);
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: var(--font-size-sm);
}

.hero-card,
.section-block {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
  padding: 28rpx;
  margin-bottom: var(--spacer-md);
}

.inline-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  border-radius: var(--radius-md);
  padding: var(--spacer-sm) var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.inline-banner-danger {
  background: rgba(229, 57, 53, 0.08);
  color: var(--td-error-color);
}

.inline-banner-text {
  flex: 1;
  font-size: var(--font-size-sm);
  line-height: 1.6;
}

.inline-banner-action {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--td-brand-color);
}

.hero-title,
.section-title {
  color: var(--td-text-color-primary);
}

.hero-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
}

.hero-subtitle,
.section-desc {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.section-block {
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: var(--spacer-sm);
}

.section-desc {
  margin-bottom: var(--spacer-sm);
}

.save-wrap {
  padding-bottom: var(--spacer-lg);
}

.hero-card-loading,
.section-block-loading {
  overflow: hidden;
}

.skeleton-line,
.skeleton-switch {
  background: var(--td-bg-color-secondarycontainer);
}

.skeleton-line {
  border-radius: var(--radius-sm);
}

.skeleton-title {
  width: 280rpx;
  height: 36rpx;
}

.skeleton-text {
  width: 100%;
  height: 24rpx;
}

.skeleton-short {
  width: 70%;
}

.skeleton-heading {
  width: 180rpx;
  height: 30rpx;
  margin-bottom: var(--spacer-sm);
}

.skeleton-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  padding: 20rpx 0;
}

.skeleton-cell + .skeleton-cell {
  border-top: 1px solid var(--td-bg-color-secondarycontainer);
}

.skeleton-cell-title {
  flex: 1;
  height: 28rpx;
}

.skeleton-switch {
  width: 72rpx;
  height: 40rpx;
  border-radius: var(--radius-round);
}