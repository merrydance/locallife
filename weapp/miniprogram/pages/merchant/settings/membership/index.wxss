.page-container {
  min-height: 100vh;
  padding: 0 var(--spacer-md) var(--popup-bottom-padding-md);
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.page-notice {
  margin-bottom: 24rpx;
}

.notice-action {
  margin: -8rpx 0 24rpx;
}

.section-block {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.section-block {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scene-card {
  padding: 22rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
  border: 1px solid transparent;
}

.scene-card-active {
  border-color: var(--td-brand-color-3);
  background: var(--td-brand-color-1);
}

.scene-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.scene-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.scene-check,
.scene-desc {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.scene-desc {
  line-height: 1.6;
}

.save-wrap {
  padding-bottom: var(--popup-bottom-padding-sm);
}