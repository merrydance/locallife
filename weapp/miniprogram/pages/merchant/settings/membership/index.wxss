.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}


.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.page-notice {
  margin-bottom: 24rpx;
}

.notice-action {
  margin: 0;
  align-self: flex-start;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scene-card {
  position: relative;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
  border: 1rpx solid transparent;
}

.scene-card-active {
  border-color: var(--td-brand-color-3);
  background: var(--td-brand-color-1);
}

.scene-mark {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scene-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.scene-card-active .scene-head {
  padding-left: 40rpx;
}

.scene-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.scene-desc {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.scene-check {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.scene-card-active .scene-check {
  color: var(--td-brand-color);
}

.scene-desc {
  line-height: 1.6;
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}