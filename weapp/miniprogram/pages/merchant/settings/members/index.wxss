.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block,
.popup-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.state-compact {
  padding: 80rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-info {
  background: var(--td-brand-color-1);
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.member-card,
.popup-sheet,
.summary-strip,
.transaction-card {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-title,
.member-name,
.summary-value,
.detail-name,
.popup-title,
.transaction-amount {
  color: var(--td-text-color-primary);
}

.hero-title,
.popup-title {
  font-size: 32rpx;
  font-weight: 700;
}

.hero-subtitle,
.hero-stat,
.member-submeta,
.member-stat-label,
.summary-label,
.detail-submeta,
.popup-subtitle,
.transaction-label,
.transaction-value,
.transaction-notes,
.detail-empty,
.load-more {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.hero-stat {
  flex-shrink: 0;
}

.member-list,
.transaction-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.member-card {
  padding: 24rpx;
}

.member-header,
.member-profile,
.member-stats,
.member-footer,
.detail-header,
.detail-name-row,
.detail-actions,
.summary-strip,
.transaction-header,
.transaction-row,
.popup-actions,
.direction-row {
  display: flex;
}

.member-header,
.member-footer,
.detail-header,
.transaction-header,
.transaction-row,
.popup-actions {
  justify-content: space-between;
  gap: 16rpx;
}

.member-header,
.detail-header {
  align-items: flex-start;
}

.member-profile {
  flex: 1;
  min-width: 0;
  gap: 16rpx;
}

.member-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-secondarycontainer);
  flex-shrink: 0;
}

.member-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color);
}

.member-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.member-name,
.detail-name {
  font-size: 30rpx;
  font-weight: 600;
}

.member-stats,
.summary-strip {
  margin-top: 20rpx;
}

.member-stats,
.direction-row {
  gap: 16rpx;
}

.member-stat,
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.member-stat-value,
.summary-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-brand-color);
}

.member-footer {
  align-items: center;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--td-component-stroke);
}

.member-footer-text,
.member-footer-arrow {
  font-size: 24rpx;
  color: var(--td-brand-color);
}

.load-more {
  padding: 16rpx 0 8rpx;
  text-align: center;
}

.load-more-end {
  color: var(--td-text-color-placeholder);
}

.popup-sheet {
  padding: 32rpx 24rpx var(--popup-bottom-padding-md);
}

.detail-sheet {
  max-height: 85vh;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.detail-scroll {
  max-height: 80vh;
}

.detail-header {
  margin-bottom: 24rpx;
}

.detail-name-row {
  align-items: center;
  gap: 12rpx;
}

.detail-submeta {
  display: block;
  margin-top: 10rpx;
}

.detail-actions {
  flex-direction: column;
  align-items: flex-end;
}

.detail-section {
  margin-top: 24rpx;
}

.detail-section-title,
.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.detail-empty {
  margin-top: 20rpx;
}

.transaction-card {
  padding: 20rpx;
}

.transaction-amount {
  font-size: 28rpx;
  font-weight: 700;
}

.transaction-row {
  margin-top: 12rpx;
}

.transaction-notes {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.popup-subtitle {
  margin-top: 12rpx;
}

.direction-row {
  margin-top: 28rpx;
}

.direction-chip {
  flex: 1;
  padding: 18rpx 20rpx;
  text-align: center;
  border-radius: 999rpx;
  background: var(--td-bg-color-secondarycontainer);
  color: var(--td-text-color-secondary);
  font-size: 26rpx;
}

.direction-chip.is-active {
  background: var(--td-brand-color-1);
  color: var(--td-brand-color);
  font-weight: 600;
}

.form-item {
  margin-top: 24rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid var(--td-component-stroke);
  border-radius: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.form-textarea {
  min-height: 180rpx;
}

.popup-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 28rpx;
}