@import '../../../../styles/merchant-config-shared.wxss';

.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(160rpx + var(--safe-area-bottom));
  box-sizing: border-box;
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-success {
  background: var(--td-success-color-1);
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.rule-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.rule-desc,
.form-label {
  color: var(--td-text-color-primary);
}

.rule-desc,
.rule-desc {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.rule-card {
  padding: var(--spacer-md);
}

.rule-header,
.rule-actions,
.form-item-switch,
.form-row {
  display: flex;
}

.rule-header,
.form-item-switch,
.form-row {
  justify-content: space-between;
  gap: 16rpx;
}

.rule-header {
  align-items: flex-start;
}

.rule-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rule-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.rule-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
}

.rule-desc {
  margin-top: 18rpx;
}

.rule-actions {
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--td-component-stroke);
  flex-wrap: wrap;
}

.form-item {
  margin-bottom: 24rpx;
}

.required {
  color: var(--td-error-color);
}