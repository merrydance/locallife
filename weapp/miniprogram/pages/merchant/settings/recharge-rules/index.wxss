.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.rule-card,
.form-popup {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.rule-desc,
.form-label {
  color: var(--td-text-color-primary);
}

.rule-desc,
.rule-desc {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.page-toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: var(--spacer-md);
}

.state-block {
  padding: 180rpx 0;
  display: flex;
  justify-content: center;
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.rule-card {
  padding: var(--spacer-md);
}

.rule-header,
.rule-actions,
.form-actions,
.form-item-switch,
.form-row {
  display: flex;
}

.rule-header,
.form-item-switch,
.form-actions {
  justify-content: space-between;
  gap: 16rpx;
}

.rule-header {
  align-items: flex-start;
}

.rule-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rule-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.rule-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
}

.rule-desc {
  margin-top: 18rpx;
}

.rule-actions {
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--td-component-stroke);
  flex-wrap: wrap;
}

.form-popup {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  max-height: 82vh;
}

.form-scroll {
  max-height: 82vh;
  padding: 32rpx 24rpx var(--popup-bottom-padding-md);
  box-sizing: border-box;
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
  text-align: center;
  margin-bottom: 32rpx;
}

.form-row {
  gap: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item-half {
  flex: 1;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.required {
  color: var(--td-error-color);
}

.form-input,
.form-picker {
  width: 100%;
  min-height: 84rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 1rpx solid var(--td-component-stroke);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.form-picker.is-placeholder {
  color: var(--td-text-color-placeholder);
}

.form-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
}