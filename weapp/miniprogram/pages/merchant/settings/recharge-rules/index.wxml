<custom-navbar title="充值规则管理" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view class="page-toolbar">
    <t-button theme="primary" shape="round" size="small" bind:tap="onAddRule">新建规则</t-button>
  </view>

  <view wx:if="{{loading && !rules.length}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载充值规则中..." vertical />
  </view>

  <t-empty wx:elif="{{!loading && !rules.length}}" description="当前还没有充值规则，点击“新建规则”开始创建" />

  <view wx:else class="rule-list">
    <view wx:for="{{rules}}" wx:key="id" class="rule-card">
      <view class="rule-header">
        <view class="rule-main">
          <text class="rule-title">充 {{item.recharge_amount_text}}</text>
          <text class="rule-subtitle">赠 {{item.bonus_amount_text}}，到账 {{item.total_amount_text}}</text>
        </view>
        <t-tag size="small" variant="dark" theme="{{item.status_theme}}">{{item.status_label}}</t-tag>
      </view>

      <view class="rule-desc">有效期 {{item.valid_range_text}}</view>

      <view class="rule-actions">
        <t-button size="small" theme="default" variant="outline" shape="round" data-id="{{item.id}}" bind:tap="onEditRule">编辑</t-button>
        <t-button size="small" theme="primary" variant="outline" shape="round" data-id="{{item.id}}" data-active="{{item.is_active}}" bind:tap="onToggleRuleStatus">{{item.is_active ? '停用' : '启用'}}</t-button>
        <t-button size="small" theme="danger" variant="outline" shape="round" data-id="{{item.id}}" bind:tap="onDeleteRule">删除</t-button>
      </view>
    </view>
  </view>

  <t-popup visible="{{formVisible}}" placement="bottom" bind:visible-change="onCloseForm">
    <view class="form-popup">
      <scroll-view scroll-y class="form-scroll">
        <view class="form-title">{{isEdit ? '编辑充值规则' : '新建充值规则'}}</view>

        <view class="form-row">
          <view class="form-item form-item-half">
            <text class="form-label">充值金额（元） <text class="required">*</text></text>
            <input class="form-input" type="digit" value="{{form.recharge_amount_yuan}}" data-field="recharge_amount_yuan" placeholder="如 100" bindinput="onTextInput" />
          </view>
          <view class="form-item form-item-half">
            <text class="form-label">赠送金额（元） <text class="required">*</text></text>
            <input class="form-input" type="digit" value="{{form.bonus_amount_yuan}}" data-field="bonus_amount_yuan" placeholder="如 20，没赠送填 0" bindinput="onTextInput" />
          </view>
        </view>

        <view class="form-row">
          <view class="form-item form-item-half">
            <text class="form-label">开始日期 <text class="required">*</text></text>
            <picker mode="date" value="{{form.valid_from}}" data-field="valid_from" bindchange="onDateChange">
              <view class="form-picker {{form.valid_from ? '' : 'is-placeholder'}}">{{form.valid_from || '请选择开始日期'}}</view>
            </picker>
          </view>
          <view class="form-item form-item-half">
            <text class="form-label">结束日期 <text class="required">*</text></text>
            <picker mode="date" value="{{form.valid_until}}" data-field="valid_until" bindchange="onDateChange">
              <view class="form-picker {{form.valid_until ? '' : 'is-placeholder'}}">{{form.valid_until || '请选择结束日期'}}</view>
            </picker>
          </view>
        </view>

        <view class="form-item form-item-switch" wx:if="{{isEdit}}">
          <text class="form-label">立即启用</text>
          <t-switch value="{{form.is_active}}" bind:change="onSwitchChange" size="large" />
        </view>

        <view class="form-actions">
          <t-button theme="default" shape="round" bind:tap="onCloseForm">取消</t-button>
          <t-button theme="primary" shape="round" loading="{{submitting}}" bind:tap="onSubmitForm">保存</t-button>
        </view>
      </scroll-view>
    </view>
  </t-popup>
</view>