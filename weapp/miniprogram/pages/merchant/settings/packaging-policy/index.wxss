.page-container {
  min-height: 100vh;
  padding: 0 24rpx var(--popup-bottom-padding-md);
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 120rpx 24rpx;
  box-sizing: border-box;
}

.hero-card,
.section-block {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.hero-subtitle,
.hero-meta {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-success {
  background: var(--td-success-color-1);
}

.inline-banner-warning {
  background: var(--td-warning-color-1, #fff7e8);
}

.dish-loading {
  padding: 32rpx 0;
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.section-block {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title,
.section-title-row {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.type-list,
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-card,
.dish-card {
  padding: 22rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
  border: 1px solid transparent;
}

.type-card-active,
.dish-card-active {
  border-color: var(--td-brand-color-3);
  background: var(--td-brand-color-1);
}

.type-head,
.dish-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.type-title,
.dish-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.type-check,
.type-desc,
.dish-check,
.dish-price {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.type-desc {
  line-height: 1.6;
}

.dish-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.save-wrap {
  padding-bottom: var(--popup-bottom-padding-sm);
}