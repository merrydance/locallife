<custom-navbar title="包装费策略" showBack="{{true}}" />

<view class="page-container" style="padding-top: calc({{navBarHeight}}px + var(--spacer-sm));">
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" size="medium" shape="round" bindtap="onRetryAccess">重新校验</t-button>
  </view>

  <block wx:else>
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载包装费策略中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '包装费策略加载失败，请重试'}}" />
    <t-button theme="primary" size="medium" shape="round" bindtap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view wx:if="{{actionNoticeMessage}}" class="inline-banner inline-banner-success">
      <text class="inline-banner-text">{{actionNoticeMessage}}</text>
    </view>

    <view wx:if="{{refreshErrorMessage}}" class="inline-banner inline-banner-danger">
      <text class="inline-banner-text">{{refreshErrorMessage}}</text>
      <text class="inline-banner-action" bindtap="onRetryRefresh">重新同步</text>
    </view>

    <view class="hero-card">
      <view class="hero-copy">
        <text class="hero-title">统一包装费命中范围</text>
        <text class="hero-subtitle">选择需要校验包装菜品的订单类型，并维护可作为包装费命中的菜品候选。</text>
      </view>
      <text class="hero-meta">当前已选 {{form.selectedDishIds.length}} 个包装菜品候选</text>
    </view>

    <view class="section-block">
      <view class="section-title">适用订单类型</view>
      <view class="type-list">
        <view wx:for="{{orderTypeOptions}}" wx:key="key" class="type-card {{form.orderTypes[item.key] ? 'type-card-active' : ''}}" data-key="{{item.key}}" bindtap="onToggleOrderType">
          <view class="type-head">
            <text class="type-title">{{item.label}}</text>
            <text class="type-check">{{form.orderTypes[item.key] ? '已启用' : '未启用'}}</text>
          </view>
          <text class="type-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-title-row">
        <view class="section-title">包装菜品候选</view>
        <text class="section-meta">{{dishesLoading ? '菜品候选同步中...' : '已选 ' + form.selectedDishIds.length + ' 个'}}</text>
      </view>

      <view wx:if="{{dishesError}}" class="inline-banner inline-banner-warning">
        <text class="inline-banner-text">{{dishesErrorMessage}}</text>
        <text class="inline-banner-action" bindtap="onRetryDishes">重新同步</text>
      </view>

      <view wx:if="{{dishesLoading && !dishOptions.length}}" class="dish-loading">
        <t-loading theme="circular" size="32rpx" text="同步菜品候选中..." vertical />
      </view>

      <t-empty wx:elif="{{!dishesError && !dishOptions.length}}" icon="info-circle" description="当前暂无可配置的菜品，请先维护门店菜品" />

      <view wx:else class="dish-list">
        <view wx:for="{{dishOptions}}" wx:key="id" class="dish-card {{item.selected ? 'dish-card-active' : ''}}" data-id="{{item.id}}" bindtap="onToggleDish">
          <view class="dish-head">
            <view>
              <view class="dish-name">{{item.name}}</view>
              <view class="dish-price">¥{{item.price / 100}}</view>
            </view>
            <text class="dish-check">{{item.selected ? '已选中' : '点击选择'}}</text>
          </view>
          <view class="dish-tags">
            <t-tag size="small" variant="dark" theme="{{item.is_online ? 'success' : 'default'}}">{{item.is_online ? '已上架' : '未上架'}}</t-tag>
            <t-tag size="small" variant="dark" theme="{{item.is_available ? 'primary' : 'warning'}}">{{item.is_available ? '可售' : '暂停售卖'}}</t-tag>
          </view>
        </view>
      </view>
    </view>

    <view class="save-wrap">
      <t-button theme="primary" size="large" shape="round" block loading="{{saving}}" disabled="{{saving || !hasChanges}}" bindtap="onSave">保存包装费策略</t-button>
    </view>
  </block>
  </block>
</view>