<custom-navbar title="修改结算账户" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{!accessReady}}" class="page-content">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="page-content">
    <t-empty icon="lock-on" description="{{accessDeniedMessage}}" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="page-content">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="page-content">
    <t-loading theme="circular" size="40rpx" text="加载结算账户中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="page-content">
    <t-empty description="{{initialErrorMessage || '结算账户加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-cell-group wx:if="{{refreshErrorMessage}}">
      <t-cell title="结算账户刷新失败" note="{{refreshErrorMessage}}">
        <view slot="right-icon">
          <t-button size="extra-small" theme="primary" variant="text" bind:tap="onRetry" loading="{{accountLoading}}">重试</t-button>
        </view>
      </t-cell>
    </t-cell-group>

    <t-cell-group>
      <t-cell title="当前结算账户" note="{{settlementAccountView.statusDesc || settlementAccountView.statusText}}">
        <view slot="right-icon">
          <t-tag theme="{{settlementAccountView.tagTheme}}" size="small">{{settlementAccountView.statusText}}</t-tag>
        </view>
      </t-cell>
      <t-cell
        wx:for="{{currentAccountItems}}"
        wx:key="label"
        title="{{item.label}}"
        note="{{item.value}}"
      />
    </t-cell-group>

    <t-cell-group wx:if="{{applicationNo}}">
      <t-cell title="修改申请" note="{{settlementApplicationView.applicationNo}}">
        <view slot="right-icon">
          <t-tag theme="{{settlementApplicationView.tagTheme}}" size="small">{{settlementApplicationView.statusText}}</t-tag>
        </view>
      </t-cell>
      <t-cell wx:if="{{applicationLoading}}" title="申请状态" note="同步中" />
      <t-cell wx:if="{{!applicationLoading && applicationErrorMessage}}" title="申请状态加载失败" note="{{applicationErrorMessage}}">
        <view slot="right-icon">
          <t-button size="extra-small" theme="primary" variant="text" bind:tap="onRetryApplication" loading="{{applicationLoading}}">重试</t-button>
        </view>
      </t-cell>
      <block wx:if="{{!applicationLoading && !applicationErrorMessage}}">
        <t-cell
          wx:for="{{settlementApplicationView.items}}"
          wx:key="label"
          title="{{item.label}}"
          note="{{item.value}}"
        />
      </block>
    </t-cell-group>

    <block wx:if="{{canEditSettlementAccount && !applicationNo}}">
      <applyment-bank-form
        apiBasePath="/v1/merchant/applyment"
        initialDraft="{{bankDraft}}"
        defaultAccountType="{{bankDraft.account_type}}"
        preloadCatalogs="{{true}}"
        showContactFields="{{false}}"
        requireAccountName="{{false}}"
        submitLabel="提交修改申请"
        submitting="{{submitting}}"
        bind:submit="onSubmitSettlementAccount"
        bind:cancel="onBack"
      />
    </block>

    <view wx:if="{{!canEditSettlementAccount && !applicationNo}}">
      <t-empty description="当前结算账户状态暂不能修改" />
    </view>
  </view>
</view>