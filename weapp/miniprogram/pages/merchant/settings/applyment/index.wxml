<custom-navbar title="收付通进件" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="{{accessDeniedMessage}}" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" shape="round" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载进件状态中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '进件状态加载失败，请重试'}}" />
    <t-button theme="primary" shape="round" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-notice-bar
      wx:if="{{refreshErrorMessage}}"
      visible="{{true}}"
      theme="warning"
      content="{{refreshErrorMessage}}"
      prefixIcon="error-circle"
      t-class="page-notice"
    />

    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">当前进件状态</text>
      </view>

      <t-cell-group theme="card">
        <t-cell title="当前状态">
          <view slot="note">
            <t-tag theme="{{applymentView.tagTheme}}" variant="dark">{{applymentView.tagText}}</t-tag>
          </view>
        </t-cell>
        <t-cell wx:if="{{applymentView.statusDesc}}" title="状态说明" note="{{applymentView.statusDesc}}" />
        <t-cell wx:if="{{applymentView.subMchId !== '-'}}" title="子商户号" note="{{applymentView.subMchId}}" />
        <t-cell wx:if="{{applymentView.showRejectReason}}" title="拒绝原因" note="{{applymentView.rejectReason}}" />
      </t-cell-group>

      <view wx:if="{{!showBindForm}}" class="action-row">
        <t-button
          wx:if="{{applymentView.canSubmitOpenInfo}}"
          theme="primary"
          shape="round"
          bind:tap="onShowBindForm"
        >{{applymentView.submitActionLabel}}</t-button>
        <t-button
          wx:if="{{applymentView.needsSign && applymentView.signURL}}"
          theme="primary"
          variant="outline"
          shape="round"
          bind:tap="onCopySignUrl"
        >复制签约链接</t-button>
        <t-button
          wx:if="{{!applymentView.isOpened && !applymentView.canSubmitOpenInfo}}"
          theme="default"
          shape="round"
          loading="{{refreshingStatus}}"
          bind:tap="onRefreshStatus"
        >刷新状态</t-button>
      </view>
    </view>

    <view wx:if="{{showBindForm}}" class="section-panel form-panel">
      <view class="section-top">
        <text class="section-title">填写结算账户</text>
      </view>
      <applyment-bank-form
        apiBasePath="/v1/merchant/applyment"
        initialDraft="{{bindBankDraft}}"
        defaultAccountType="ACCOUNT_TYPE_BUSINESS"
        submitLabel="提交银行账户信息"
        submitting="{{submittingBind}}"
        bind:submit="onSubmitBindBank"
        bind:cancel="onHideBindForm"
        bind:draftchange="onBindDraftChange"
      />
    </view>
  </view>
</view>