<custom-navbar title="微信支付开户" showBack="{{true}}" bind:navheight="onNavHeight" />

<t-toast id="t-toast" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="{{accessDeniedMessage}}" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载开户状态中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '开户状态加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-cell-group wx:if="{{refreshErrorMessage}}" theme="card">
      <t-cell title="状态刷新失败" note="{{refreshErrorMessage}}">
        <view slot="right-icon">
          <t-button size="extra-small" theme="primary" variant="text" bind:tap="onRefreshStatus" loading="{{refreshingStatus}}">重试</t-button>
        </view>
      </t-cell>
    </t-cell-group>

    <t-cell-group theme="card">
      <t-cell
        wx:if="{{workflowView.primaryActionIntent !== 'none'}}"
        title="{{workflowView.headline}}"
        note="{{workflowView.stageTitle}}"
        hover
        arrow
        bind:click="onOpenPrimaryAction"
      >
        <view slot="right-icon">
          <t-tag theme="{{workflowView.statusView.tagTheme}}" size="small">{{workflowView.statusView.tagText}}</t-tag>
        </view>
      </t-cell>
      <t-cell
        wx:else
        title="{{workflowView.headline}}"
        note="{{workflowView.stageTitle}}"
        bordered="{{false}}"
      >
        <view slot="right-icon">
          <t-tag theme="{{workflowView.statusView.tagTheme}}" size="small">{{workflowView.statusView.tagText}}</t-tag>
        </view>
      </t-cell>
    </t-cell-group>

    <t-button
      wx:if="{{workflowView.primaryActionIntent !== 'none'}}"
      theme="primary"
      block
      loading="{{refreshingStatus && workflowView.primaryActionIntent === 'refresh'}}"
      bind:tap="onOpenPrimaryAction"
    >{{workflowView.primaryActionText}}</t-button>

    <t-steps current="{{workflowView.statusView.flowCurrent}}" theme="dot" readonly>
      <t-step-item
        wx:for="{{workflowView.statusView.flowSteps}}"
        wx:key="key"
        title="{{item.title}}"
      />
    </t-steps>

    <t-cell-group wx:if="{{displayStatusItems.length}}" theme="card">
      <t-cell
        wx:for="{{displayStatusItems}}"
        wx:key="label"
        title="{{item.label}}"
        note="{{item.value}}"
      />
    </t-cell-group>

    <block wx:if="{{workflowView.currentStage === 'opened'}}">
      <t-cell-group theme="card">
        <t-cell
          title="{{openedSummary.title}}"
          note="{{openedSummary.description}}"
          bordered="{{false}}"
        >
          <view slot="right-icon">
            <t-tag theme="success" size="small">已开通</t-tag>
          </view>
        </t-cell>
        <t-cell title="微信支付商户号" note="{{openedSummary.subMchId}}" />
        <t-cell title="后续说明" note="{{openedSummary.financeHint}}" />
        <t-cell title="资金管理" note="{{openedSummary.merchantAssistantHint}}" />
      </t-cell-group>

      <t-cell-group theme="card">
        <t-cell
          title="结算账户"
          note="{{settlementAccountView.statusDesc || settlementAccountView.statusText}}"
          hover
          arrow
          bind:click="onOpenSettlementAccountPage"
        >
          <view slot="right-icon">
            <t-tag theme="{{settlementAccountView.tagTheme}}" size="small">{{settlementAccountView.statusText}}</t-tag>
          </view>
        </t-cell>
      </t-cell-group>

      <view wx:if="{{settlementLoading && !settlementLoaded}}" class="settlement-state">
        <t-loading theme="circular" size="40rpx" text="加载结算账户中..." vertical />
      </view>

      <t-cell-group wx:elif="{{settlementErrorMessage}}" theme="card">
        <t-cell title="结算账户加载失败" note="{{settlementErrorMessage}}">
          <view slot="right-icon">
            <t-button size="extra-small" theme="primary" variant="text" bind:tap="onRetrySettlementAccount" loading="{{settlementLoading}}">重试</t-button>
          </view>
        </t-cell>
      </t-cell-group>

      <t-cell-group wx:elif="{{settlementAccountView.items.length}}" theme="card">
        <t-cell
          wx:for="{{settlementAccountView.items}}"
          wx:key="label"
          title="{{item.label}}"
          note="{{item.value}}"
        />
      </t-cell-group>

      <t-button
        theme="primary"
        block
        bind:tap="onOpenSettlementAccountPage"
      >{{openedSummary.settlementActionText}}</t-button>
    </block>

    <t-cell-group wx:if="{{workflowView.secondaryTasks.length}}" theme="card">
      <t-cell
        wx:for="{{workflowView.secondaryTasks}}"
        wx:key="label"
        title="{{item.label}}"
        note="{{item.value || ''}}"
        hover
        arrow
        data-type="{{item.type}}"
        data-action-intent="{{item.actionIntent}}"
        data-action-path="{{item.actionPath}}"
        data-value="{{item.value}}"
        bind:click="onTapSecondaryTask"
      />
    </t-cell-group>
  </view>
</view>
