<custom-navbar title="收付通进件" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="{{accessDeniedMessage}}" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载进件状态中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '进件状态加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-notice-bar wx:if="{{refreshErrorMessage}}" theme="error" visible="{{true}}" content="{{refreshErrorMessage}}">
      <text slot="operation" bind:tap="onRefreshStatus">刷新</text>
    </t-notice-bar>

    <t-cell-group theme="card">
      <t-cell
        wx:if="{{workflowView.primaryActionIntent !== 'none'}}"
        title="{{workflowView.headline}}"
        note="{{workflowView.stageTitle}}"
        hover
        arrow
        bind:click="onOpenPrimaryAction"
      >
        <view slot="right-icon">
          <t-tag theme="{{workflowView.statusView.tagTheme}}" size="small">{{workflowView.statusView.tagText}}</t-tag>
        </view>
      </t-cell>
      <t-cell
        wx:else
        title="{{workflowView.headline}}"
        note="{{workflowView.stageTitle}}"
        bordered="{{false}}"
      >
        <view slot="right-icon">
          <t-tag theme="{{workflowView.statusView.tagTheme}}" size="small">{{workflowView.statusView.tagText}}</t-tag>
        </view>
      </t-cell>
    </t-cell-group>

    <t-button
      wx:if="{{workflowView.primaryActionIntent !== 'none'}}"
      theme="primary"
      block
      loading="{{refreshingStatus && workflowView.primaryActionIntent === 'refresh'}}"
      bind:tap="onOpenPrimaryAction"
    >{{workflowView.primaryActionText}}</t-button>

    <t-steps current="{{workflowView.statusView.flowCurrent}}" theme="dot" readonly>
      <t-step-item
        wx:for="{{workflowView.statusView.flowSteps}}"
        wx:key="key"
        title="{{item.title}}"
      />
    </t-steps>

    <t-cell-group wx:if="{{displayStatusItems.length}}" theme="card">
      <t-cell
        wx:for="{{displayStatusItems}}"
        wx:key="label"
        title="{{item.label}}"
        note="{{item.value}}"
      />
    </t-cell-group>

    <t-cell-group wx:if="{{workflowView.secondaryTasks.length}}" theme="card">
      <t-cell
        wx:for="{{workflowView.secondaryTasks}}"
        wx:key="label"
        title="{{item.label}}"
        note="{{item.value || ''}}"
        hover
        arrow
        data-type="{{item.type}}"
        data-action-intent="{{item.actionIntent}}"
        data-action-path="{{item.actionPath}}"
        data-value="{{item.value}}"
        bind:click="onTapSecondaryTask"
      />
    </t-cell-group>
  </view>
</view>