<custom-navbar title="提交开户资料" showBack="{{true}}" bind:navheight="onNavHeight" />

<t-toast id="t-toast" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="{{accessDeniedMessage}}" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载提交页中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '开户状态加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="page-content">
    <t-cell-group theme="card">
      <t-cell title="商户名称" note="{{subjectSummary.merchantName}}" />
      <t-cell title="营业执照号" note="{{subjectSummary.businessLicenseNumber}}" />
      <t-cell title="法人姓名" note="{{subjectSummary.legalPersonName}}" />
      <t-cell title="联系电话" note="{{subjectSummary.contactPhone}}" />
    </t-cell-group>

    <applyment-bank-form
      apiBasePath="/v1/merchant/applyment"
      uploadBusinessType="merchant"
      initialDraft="{{bindBankDraft}}"
      defaultAccountType="ACCOUNT_TYPE_PRIVATE"
      showContactFields="{{false}}"
      requireContactEmail="{{true}}"
      submitLabel="提交银行账户信息"
      submitting="{{submitting}}"
      bind:submit="onSubmitBindBank"
      bind:cancel="onBackToStatus"
      bind:draftchange="onBindDraftChange"
    />

    <view wx:if="{{submitErrorMessage}}" class="submit-error-panel">
      <view class="submit-error-title">{{submitErrorMessage}}</view>
      <view class="submit-error-actions">
        <t-button theme="light" size="small" shape="round" open-type="contact">联系平台客服</t-button>
      </view>
    </view>
  </view>
</view>
