<custom-navbar title="提交进件资料" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验权限中..." vertical />
  </view>

  <view wx:elif="{{accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="{{accessDeniedMessage}}" />
  </view>

  <view wx:elif="{{accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载提交页中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '进件状态加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <view wx:elif="{{!canSubmit}}" class="state-block">
    <t-empty description="{{blockMessage || '当前状态暂不支持重新提交进件资料'}}" />
    <t-button theme="primary" bind:tap="onBackToStatus">返回状态页</t-button>
  </view>

  <view wx:else class="page-content">
    <view class="section-panel">
      <view class="section-top">
        <text class="section-title">填写结算账户</text>
        <text class="section-subtitle">填写结算账户资料后提交；仅当联系人不是法人时，再补充超级管理员资料。</text>
      </view>

      <applyment-bank-form
        apiBasePath="/v1/merchant/applyment"
        uploadBusinessType="merchant"
        initialDraft="{{bindBankDraft}}"
        defaultAccountType="ACCOUNT_TYPE_BUSINESS"
        showContactFields="{{true}}"
        submitLabel="提交银行账户信息"
        submitting="{{submitting}}"
        bind:submit="onSubmitBindBank"
        bind:cancel="onBackToStatus"
        bind:draftchange="onBindDraftChange"
      />
    </view>
  </view>
</view>