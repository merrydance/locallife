.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.page-notice {
  border-radius: var(--radius-md);
  overflow: hidden;
}

.section-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding: var(--spacer-md);
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.section-top {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.form-panel {
  padding-bottom: var(--spacer-lg);
}