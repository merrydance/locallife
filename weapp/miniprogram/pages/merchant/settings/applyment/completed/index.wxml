<custom-navbar title="开通完成" showBack="{{false}}" />

<view class="page" style="padding-top: {{navBarHeight}}px;">
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" shape="round" bindtap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{loading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载开通结果中..." vertical />
  </view>

  <view wx:elif="{{error}}" class="state-block">
    <t-empty description="{{error}}" />
    <t-button theme="primary" shape="round" bindtap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="content">
    <view class="result-card">
      <t-icon name="check-circle-filled" size="120rpx" color="var(--td-success-color-6)" />
      <view class="result-title">{{completed ? '收付通已开通' : '当前尚未开通完成'}}</view>
      <view class="result-message">{{completed ? (statusDesc || '当前已完成收付通开通，可前往资金账户查看余额与提现。') : '当前进件尚未完成，返回进件页继续处理即可。'}}</view>

      <view wx:if="{{completed && subMchId}}" class="info-block">
        <view class="info-label">子商户号</view>
        <view class="info-value">{{subMchId}}</view>
      </view>
    </view>

    <view class="action-group">
      <t-button wx:if="{{completed}}" theme="primary" block shape="round" size="large" bindtap="onGoFinance">查看资金账户</t-button>
      <t-button wx:else theme="primary" block shape="round" size="large" bindtap="onBackToApplyment">返回进件页</t-button>
      <t-button wx:if="{{completed}}" theme="default" block shape="round" size="large" bindtap="onBackToApplyment">查看进件页</t-button>
    </view>
  </view>
</view>
