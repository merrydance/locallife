.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.hero-card,
.section-block {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.hero-subtitle,
.special-note,
.closed-tip,
.day-subtitle,
.time-label,
.special-day,
.special-time {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.section-block {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.day-header,
.slot-head,
.time-row,
.special-header,
.special-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.day-title,
.section-title,
.slot-title,
.special-date {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.closed-tip {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.slot-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.slot-card,
.special-card {
  padding: 22rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.slot-remove {
  font-size: 24rpx;
  color: var(--td-error-color);
}

.time-row {
  justify-content: flex-start;
  margin-top: 16rpx;
}

.time-field {
  min-width: 220rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-container);
}

.time-value {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.time-separator {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-secondary);
}

.special-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.save-wrap {
  padding-bottom: 32rpx;
}