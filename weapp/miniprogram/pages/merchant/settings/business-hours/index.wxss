.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding-bottom: calc(var(--spacer-md) + var(--safe-area-bottom));
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.notice-copy,
.section-copy {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.notice-banner {
  margin-bottom: 0;
}

.notice-text,
.section-note,
.special-day,
.special-time {
  flex: 1;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.notice-banner-operation {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.section-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-top,
.special-header,
.special-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-title,
.special-date {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.special-card {
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.special-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}

@media (max-width: 420px) {
  .notice-card,
  .section-top,
  .special-header,
  .special-row {
    align-items: flex-start;
    flex-direction: column;
  }
}