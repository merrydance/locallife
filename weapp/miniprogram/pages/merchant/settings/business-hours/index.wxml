<custom-navbar title="营业时间" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bindtap="onRetryAccess">重新校验</t-button>
  </view>

  <block wx:else>
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载营业时间中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '营业时间加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <scroll-view
      class="page-content business-hours-scroll"
      scroll-y="{{!timePickerVisible}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
      bounces="{{false}}"
    >
      <view wx:if="{{actionNoticeMessage}}" class="notice-banner">
        <t-notice-bar theme="success" visible="{{true}}" content="{{actionNoticeMessage}}" />
      </view>

      <view wx:if="{{refreshErrorMessage}}" class="notice-banner">
        <t-notice-bar theme="warning" visible="{{true}}" content="{{refreshErrorMessage}}">
          <text slot="operation" class="notice-banner-operation" bind:tap="onRetryRefresh">重新同步</text>
        </t-notice-bar>
      </view>

      <view class="section-panel">
        <view class="auto-business-header">
          <view class="section-copy">
            <view class="auto-business-title-row">
              <text class="section-title">自动营业</text>
              <t-switch value="{{autoOpenByBusinessHours}}" size="medium" bind:change="onAutoOpenSwitchChange" />
            </view>
            <text class="section-note">开启后，系统会按营业时间自动切换营业与打烊；关闭后完全依赖手动开店和打烊。</text>
          </view>
          <t-button
            size="small"
            theme="light"
            icon="copy"
            disabled="{{saving || initialLoading}}"
            bind:tap="onSyncFirstBusinessDay"
          >同步</t-button>
        </view>
      </view>

      <business-hours-weekly-editor
        weeklyHours="{{weeklyHours}}"
        bind:toggleclosed="onToggleClosed"
        bind:changetime="onTimeChange"
        bind:addslot="onAddSlot"
        bind:removeslot="onRemoveSlot"
        bind:pickervisibilitychange="onTimePickerVisibilityChange"
      />

      <view wx:if="{{specialHours.length}}" class="section-panel">
        <view class="special-header">
          <text class="section-title">已保留的特殊日期</text>
        </view>
        <view class="special-list">
          <view class="special-card" wx:for="{{specialHours}}" wx:key="key" wx:for-item="special">
            <view class="special-row">
              <text class="special-date">{{special.special_date}}</text>
              <text class="special-day">{{special.day_name}}</text>
            </view>
            <text class="special-time">{{special.is_closed ? '休息' : special.open_time + ' - ' + special.close_time}}</text>
          </view>
        </view>
      </view>
      <view class="form-actions">
        <t-button theme="primary" loading="{{saving}}" disabled="{{saving || initialLoading || timePickerVisible}}" bind:tap="onSave">保存营业时间</t-button>
      </view>
    </scroll-view>
  </block>
  </block>
</view>
