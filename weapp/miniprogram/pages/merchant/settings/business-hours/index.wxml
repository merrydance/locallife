<custom-navbar title="营业时间" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载营业时间中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '营业时间加载失败，请重试'}}" />
    <view class="retry-button" bindtap="onRetry">重新加载</view>
  </view>

  <block wx:else>
    <view class="hero-card">
      <text class="hero-title">每周营业时段</text>
      <text class="hero-subtitle">支持为同一天配置多个营业时段。已有特殊日期安排会在保存时原样保留，不会被这次修改覆盖。</text>
      <view class="hero-tags">
        <t-tag theme="primary" variant="light" size="small">每周配置</t-tag>
        <t-tag wx:if="{{specialHours.length}}" theme="warning" variant="light" size="small">特殊日期 {{specialHours.length}} 条</t-tag>
      </view>
    </view>

    <view class="section-block" wx:for="{{weeklyHours}}" wx:key="day_of_week" wx:for-item="day">
      <view class="day-header">
        <view>
          <text class="day-title">{{day.day_name}}</text>
          <text class="day-subtitle">{{day.is_closed ? '当天休息，不接单' : '按配置时段接单'}}</text>
        </view>
        <t-switch value="{{day.is_closed}}" data-day="{{day.day_of_week}}" bind:change="onToggleClosed" size="large" />
      </view>

      <view wx:if="{{day.is_closed}}" class="closed-tip">当前设置为休息日。重新打开后可继续编辑时段。</view>

      <view wx:else class="slot-list">
        <view class="slot-card" wx:for="{{day.slots}}" wx:key="key" wx:for-item="slot" wx:for-index="slotIndex">
          <view class="slot-head">
            <text class="slot-title">时段 {{slotIndex + 1}}</text>
            <view wx:if="{{day.slots.length > 1}}" class="slot-remove" data-day="{{day.day_of_week}}" data-slot-index="{{slotIndex}}" catchtap="onRemoveSlot">删除</view>
          </view>
          <view class="time-row">
            <picker mode="time" value="{{slot.open_time}}" data-day="{{day.day_of_week}}" data-slot-index="{{slotIndex}}" data-field="open_time" bindchange="onTimeChange">
              <view class="time-field">
                <text class="time-label">开始</text>
                <text class="time-value">{{slot.open_time}}</text>
              </view>
            </picker>
            <text class="time-separator">-</text>
            <picker mode="time" value="{{slot.close_time}}" data-day="{{day.day_of_week}}" data-slot-index="{{slotIndex}}" data-field="close_time" bindchange="onTimeChange">
              <view class="time-field">
                <text class="time-label">结束</text>
                <text class="time-value">{{slot.close_time}}</text>
              </view>
            </picker>
          </view>
        </view>

        <t-button size="small" theme="primary" variant="outline" shape="round" data-day="{{day.day_of_week}}" bindtap="onAddSlot">新增营业时段</t-button>
      </view>
    </view>

    <view wx:if="{{specialHours.length}}" class="section-block">
      <view class="special-header">
        <text class="section-title">已保留的特殊日期</text>
        <text class="special-note">当前仅展示，保存时会原样保留</text>
      </view>
      <view class="special-list">
        <view class="special-card" wx:for="{{specialHours}}" wx:key="key" wx:for-item="special">
          <view class="special-row">
            <text class="special-date">{{special.special_date}}</text>
            <text class="special-day">{{special.day_name}}</text>
          </view>
          <text class="special-time">{{special.is_closed ? '休息' : special.open_time + ' - ' + special.close_time}}</text>
        </view>
      </view>
    </view>

    <view class="save-wrap">
      <t-button theme="primary" size="large" shape="round" block loading="{{saving}}" disabled="{{saving || !hasChanges}}" bindtap="onSave">保存营业时间</t-button>
    </view>
  </block>
</view>