.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}


.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  min-height: 60vh;
  padding: 0 var(--spacer-lg);
}

.section-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.section-title,
.certificate-title {
  color: var(--td-text-color-primary);
}

.section-tip {
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.section-panel {
  width: 100%;
  box-sizing: border-box;
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-panel--status {
  position: relative;
  overflow: hidden;
}

.status-badge {
  width: 100%;
  display: flex;
}

.status-badge__content {
  width: 100%;
  display: block;
}

.status-badge__count {
  font-size: 28rpx;
  font-weight: 600;
}

.section-head,
.upload-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-head {
  align-items: flex-start;
}

.section-head-tight {
  gap: 12rpx;
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 700;
}

.certificate-card {
  padding: 8rpx 0 24rpx;
  border-bottom: 1px solid var(--td-component-stroke);
}

.certificate-card-last {
  border-bottom: 0;
  padding-bottom: 0;
}

.certificate-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.certificate-title {
  font-size: var(--font-size-base);
  font-weight: 600;
}

.certificate-image {
  width: 100%;
  height: 360rpx;
  background: var(--td-bg-color-secondarycontainer);
  overflow: hidden;
}

@media (max-width: 420px) {
  .certificate-image {
    height: 300rpx;
  }
}
