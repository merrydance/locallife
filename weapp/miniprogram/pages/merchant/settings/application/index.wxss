.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  min-height: 60vh;
  padding: 0 var(--spacer-lg);
}

.section-panel,
.notice-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.section-title,
.certificate-title,
.notice-title {
  color: var(--td-text-color-primary);
}

.section-tip,
.notice-text {
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.section-panel {
  width: 100%;
  box-sizing: border-box;
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-panel--status {
  position: relative;
  overflow: hidden;
}

.status-badge {
  width: 100%;
  display: flex;
}

.status-badge__content {
  width: 100%;
  display: block;
}

.status-badge__count {
  font-size: 28rpx;
  font-weight: 600;
}

.section-head,
.upload-head,
.notice-head,
.notice-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-head {
  align-items: flex-start;
}

.section-head-tight {
  gap: 12rpx;
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 700;
}

.notice-card {
  padding: var(--spacer-sm) var(--spacer-md);
}

.notice-card-inner {
  padding: 20rpx 24rpx;
}

.notice-card-success {
  background: var(--td-success-color-1);
}

.notice-card-error {
  background: var(--td-error-color-1);
}

.notice-card-info,
.notice-card-warning {
  background: var(--td-bg-color-secondarycontainer);
}

.notice-card-warning {
  background: var(--td-warning-color-1);
}

.notice-title {
  flex: 1;
  font-size: var(--font-size-sm);
  line-height: 1.6;
}

.notice-text-flex {
  flex: 1;
}

.notice-action {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  color: var(--td-brand-color);
  font-weight: 600;
}

.certificate-card {
  padding: 8rpx 0 24rpx;
  border-bottom: 1px solid var(--td-component-stroke);
}

.certificate-card-last {
  border-bottom: 0;
  padding-bottom: 0;
}

.certificate-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.certificate-title {
  font-size: var(--font-size-base);
  font-weight: 600;
}

.certificate-image {
  width: 100%;
  height: 360rpx;
  background: var(--td-bg-color-secondarycontainer);
  overflow: hidden;
}

@media (max-width: 420px) {
  .notice-head,
  .notice-card {
    align-items: flex-start;
    flex-direction: column;
  }

  .notice-action {
    align-self: flex-end;
  }

  .certificate-image {
    height: 300rpx;
  }
}