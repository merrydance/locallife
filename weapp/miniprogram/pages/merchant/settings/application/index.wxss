.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: var(--radius-round);
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.hero-card,
.meta-strip,
.section-block {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-title,
.section-title,
.upload-title,
.meta-value {
  color: var(--td-text-color-primary);
}

.hero-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.hero-subtitle,
.meta-label,
.section-tip,
.upload-status,
.upload-tip,
.hint-card {
  color: var(--td-text-color-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.meta-strip {
  padding: 10rpx 24rpx;
  margin-bottom: 24rpx;
}

.meta-row,
.section-head,
.upload-head,
.location-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meta-row {
  padding: 16rpx 0;
}

.meta-row + .meta-row {
  border-top: 1px solid var(--td-component-stroke);
}

.meta-value {
  font-size: 24rpx;
  font-weight: 500;
  text-align: right;
}

.section-block {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.section-head {
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.hint-card {
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
}

.hint-card-error {
  background: var(--td-error-color-1);
  color: var(--td-text-color-primary);
}

.hint-card-warning {
  background: var(--td-brand-color-light);
  color: var(--td-text-color-primary);
}

.hint-card-success {
  background: var(--td-success-color-1);
  color: var(--td-text-color-primary);
}

.action-notice-card {
  margin-bottom: 24rpx;
}

.action-notice-text {
  font-size: 24rpx;
  line-height: 1.6;
}

.ocr-notice-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.ocr-notice-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
}

.upload-card {
  padding: 24rpx 0;
  border-bottom: 1px solid var(--td-component-stroke);
}

.upload-card-last {
  border-bottom: 0;
  padding-bottom: 0;
}

.upload-head {
  margin-bottom: 16rpx;
}

.upload-title {
  font-size: 28rpx;
  font-weight: 600;
}

.upload-status {
  font-size: 22rpx;
}

.upload-tip {
  margin-top: 12rpx;
}

.location-card {
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-page);
}

.location-head {
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.location-title,
.location-value {
  color: var(--td-text-color-primary);
}

.location-title {
  font-size: 28rpx;
  font-weight: 600;
}

.location-value {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.location-hint {
  color: var(--td-text-color-secondary);
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.actions-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 32rpx;
}