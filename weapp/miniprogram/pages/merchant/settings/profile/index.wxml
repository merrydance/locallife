<custom-navbar title="门店基础资料" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 176rpx;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>

  <block wx:else>
    <view wx:if="{{initialLoading}}" class="state-block">
      <t-loading theme="circular" size="40rpx" text="加载店铺资料中..." vertical />
    </view>

    <view wx:elif="{{initialError}}" class="state-block">
      <t-empty description="{{initialErrorMessage || '店铺资料加载失败，请重试'}}" />
      <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
    </view>

    <block wx:else>
      <view class="page-content">
        <view wx:if="{{refreshErrorMessage}}" class="notice-card notice-card--warning notice-card--split">
          <view class="notice-copy">
            <text class="notice-text">{{refreshErrorMessage}}</text>
          </view>
          <text class="notice-action" bind:tap="onRetryRefresh">重新同步</text>
        </view>

        <view class="section-panel">
          <view class="section-top">
            <text class="section-title">基础信息</text>
          </view>

          <t-cell-group theme="card">
            <view class="input-cell">
              <t-input
                label="店铺名称"
                value="{{form.name}}"
                data-field="name"
                placeholder="请输入店铺名称"
                maxlength="50"
                bind:change="onInputChange"
              />
            </view>

            <view class="input-cell">
              <t-input
                label="联系电话"
                value="{{form.phone}}"
                data-field="phone"
                type="number"
                maxlength="11"
                placeholder="11 位联系电话，可留空"
                bind:change="onInputChange"
              />
            </view>
          </t-cell-group>

          <t-textarea
            value="{{form.description}}"
            data-field="description"
            placeholder="介绍招牌菜、经营特色和门店氛围"
            maxlength="500"
            indicator
            autosize
            bordered
            bind:change="onInputChange"
          />
        </view>

        <view class="section-panel section-panel--plain">
          <view class="section-top">
            <text class="section-title">经营类目</text>
            <text class="section-count">已选 {{selectedCategoryCount}}/5</text>
          </view>

          <view wx:if="{{categoryLoading && !tags.length}}" class="section-state section-state--embedded">
            <t-loading theme="circular" size="40rpx" text="加载经营类目中..." vertical />
          </view>

          <view wx:elif="{{categoryErrorMessage && !tags.length}}" class="section-state section-state--embedded">
            <t-empty description="{{categoryErrorMessage}}" />
            <t-button theme="primary" size="small" shape="round" bind:tap="onRetryCategories">重新加载</t-button>
          </view>

          <view wx:elif="{{!tags.length}}" class="section-state section-state--embedded">
            <t-empty description="暂无可选经营类目" />
          </view>

          <block wx:else>
            <t-cell-group theme="card">
              <t-cell
                title="添加经营类目"
                note="{{categoryPickerTriggerText}}"
                hover
                arrow
                bordered="{{selectedCategoryTags.length > 0}}"
                bind:click="onOpenCategoryPicker"
              />

              <t-cell
                wx:if="{{selectedCategoryTags.length}}"
                wx:for="{{selectedCategoryTags}}"
                wx:key="id"
                title="{{item.name}}"
                bordered="{{index !== selectedCategoryTags.length - 1}}"
                t-class="category-list-item category-list-item--selected {{saving || categoryLoading ? 'category-list-item--disabled' : ''}}"
              >
                <view slot="note" class="category-note-action">
                  <t-button
                    t-class="category-note-action__button"
                    size="extra-small"
                    theme="danger"
                    variant="text"
                    shape="circle"
                    icon="remove"
                    disabled="{{saving || categoryLoading}}"
                    data-id="{{item.id}}"
                    bind:tap="onRemoveCategory"
                  />
                </view>
              </t-cell>
            </t-cell-group>

            <view wx:if="{{categoryErrorMessage}}" class="inline-feedback">
              <text class="inline-feedback__text">{{categoryErrorMessage}}</text>
              <text class="inline-feedback__action" bind:tap="onRetryCategories">重新同步</text>
            </view>

            <t-picker
              visible="{{categoryPickerVisible}}"
              value="{{[categoryPickerValue || (categoryPickerOptions.length ? categoryPickerOptions[0].value : '')]}}"
              title="选择经营类目"
              cancelBtn="取消"
              confirmBtn="确定"
              bind:confirm="onCategoryPickerConfirm"
              bind:cancel="onCloseCategoryPicker"
              bind:close="onCloseCategoryPicker"
            >
              <t-picker-item options="{{categoryPickerOptions}}" />
            </t-picker>
          </block>
        </view>

        <view class="section-panel">
          <view class="section-top">
            <text class="section-title">经营位置</text>
          </view>

          <t-cell-group theme="card">
            <t-cell title="经营地址" description="{{addressDisplay}}" align="top" />
            <t-cell title="经纬度" bordered="{{false}}">
              <view slot="note" class="location-picker-note">
                <text class="location-picker-value">{{coordinateSummary}}</text>
                <t-button
                  theme="primary"
                  size="small"
                  shape="circle"
                  icon="location"
                  disabled="{{loading || saving}}"
                  bind:tap="onChooseLocation"
                />
              </view>
            </t-cell>
          </t-cell-group>
        </view>

      </view>

      <view class="footer-bar">
        <t-button theme="primary" size="large" shape="round" block loading="{{saving}}" disabled="{{saving || initialLoading}}" bind:tap="onSave">保存店铺资料</t-button>
      </view>
    </block>
  </block>
</view>