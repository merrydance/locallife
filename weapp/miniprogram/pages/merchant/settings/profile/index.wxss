.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-success {
  background: var(--td-success-color-1);
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.hero-card,
.meta-strip,
.section-block {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.hero-subtitle {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.meta-strip {
  padding: 10rpx 24rpx;
  margin-bottom: 24rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
}

.meta-row + .meta-row {
  border-top: 1px solid var(--td-component-stroke);
}

.meta-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.meta-value {
  font-size: 24rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.section-block {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.section-head {
  margin-bottom: 16rpx;
}

.section-tip {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.location-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.location-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.location-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.location-value {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.location-hint {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.save-wrap {
  padding-bottom: 32rpx;
}