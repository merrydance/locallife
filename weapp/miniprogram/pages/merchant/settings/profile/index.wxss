.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.notice-card,
.section-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.notice-copy {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.notice-text {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.notice-card {
  padding: var(--spacer-sm) var(--spacer-md);
}

.notice-card--warning {
  background: var(--td-warning-color-1);
  border: 1rpx solid rgba(255, 193, 7, 0.35);
}

.notice-card--split {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.notice-action {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.section-panel {
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-panel--plain {
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.section-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-count {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.input-cell {
  width: 100%;
}

.section-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-sm);
  min-height: 240rpx;
}

.section-state--embedded {
  min-height: 180rpx;
  padding: var(--spacer-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.category-list-item {
  transition: opacity 0.2s ease, background 0.2s ease;
}

.category-list-item--selected {
  background: var(--td-brand-color-light);
}

.category-list-item--disabled {
  opacity: 0.7;
}

.section-panel--plain .t-cell-group {
  overflow: hidden;
}

.category-note-action {
  width: 72rpx;
  display: flex;
  justify-content: flex-end;
  margin-right: -8rpx;
}

.category-note-action__button {
  opacity: 0.88;
}

.inline-feedback {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
}

.inline-feedback__text {
  flex: 1;
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.inline-feedback__action {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.location-picker-note {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.location-picker-value {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-index-fixed);
  padding: var(--spacer-md);
  padding-bottom: calc(var(--spacer-md) + var(--safe-area-bottom));
  background: var(--td-bg-color-container);
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.06);
}

@media (max-width: 420px) {
  .notice-card--split,
  .section-top,
  .inline-feedback {
    align-items: flex-start;
    flex-direction: column;
  }
}