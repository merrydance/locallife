.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.notice-banner-operation {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.section-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-sm);
  min-height: 240rpx;
}

.category-list-item {
  transition: opacity 0.2s ease, background 0.2s ease;
}

.category-list-item--selected {
  background: var(--td-brand-color-light);
}

.category-list-item--disabled {
  opacity: 0.7;
}

.category-note-action {
  width: 72rpx;
  display: flex;
  justify-content: flex-end;
}

.category-note-action__button {
  opacity: 0.88;
}

.inline-feedback {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
}

.inline-feedback__text {
  flex: 1;
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.inline-feedback__action {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.location-picker-note {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.location-picker-value {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}

@media (max-width: 420px) {
  .inline-feedback {
    align-items: flex-start;
    flex-direction: column;
  }
}
