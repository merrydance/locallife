<custom-navbar title="桌台房间" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{!accessReady}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>

  <block wx:else>
    <view wx:if="{{initialLoading}}" class="state-block">
      <t-loading theme="circular" size="40rpx" text="加载桌台列表中..." vertical />
    </view>

    <view wx:elif="{{initialError}}" class="state-block">
      <t-empty icon="error-circle" description="{{initialErrorMessage || '桌台列表加载失败，请重试'}}" />
      <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
    </view>

    <block wx:else>
      <view class="page-content">
        <t-notice-bar
          wx:if="{{refreshErrorMessage}}"
          visible="{{true}}"
          theme="warning"
          content="{{refreshErrorMessage}}"
          prefixIcon="error-circle"
          t-class="page-notice"
        />

        <t-sticky offset-top="{{navBarHeight}}" z-index="40">
          <view class="control-panel">
            <view class="tabs-shell tabs-shell--top">
              <t-tabs value="{{currentTab}}" bind:change="onTabChange">
                <t-tab-panel wx:for="{{tabOptions}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" />
              </t-tabs>
            </view>

            <view class="filter-panel">
              <view class="filter-block">
                <text class="filter-label">状态筛选</text>
                <view class="filter-tags">
                  <t-check-tag
                    wx:for="{{statusFilterOptions}}"
                    wx:key="value"
                    checked="{{currentStatus === item.value}}"
                    content="{{item.label}}"
                    size="small"
                    shape="round"
                    data-value="{{item.value}}"
                    bind:change="onStatusFilterChange"
                  />
                </view>
              </view>
            </view>
          </view>
        </t-sticky>

        <view class="result-bar">
          <text class="result-summary">{{resultSummaryText}}</text>
          <view wx:if="{{loading && loadedTables.length}}" class="inline-loading">
            <t-loading theme="dots" size="28rpx" />
          </view>
        </view>

        <view wx:if="{{loading && !tables.length}}" class="loading-state">
          <t-loading theme="circular" size="40rpx" text="加载中..." vertical />
        </view>

        <t-empty wx:elif="{{!loading && !tables.length}}" icon="info-circle" description="{{emptyDescription}}" />

        <block wx:else>
          <view class="table-list">
            <t-cell-group wx:for="{{tables}}" wx:key="id" class="table-card" theme="card">
              <view class="table-card-main" bindtap="onEditTable" data-id="{{item.id}}">
                <t-image
                  t-class="table-cover"
                  src="{{item.coverImageUrl || '/assets/icons/empty.svg'}}"
                  mode="aspectFill"
                  width="100%"
                  height="280rpx"
                  shape="square"
                />

                <view class="table-content">
                  <view class="table-header">
                    <view class="table-header-main">
                      <text class="table-no">{{item.table_no}}</text>
                      <text class="table-desc">{{item.descriptionText}}</text>
                    </view>
                    <view class="table-status-wrap">
                      <t-tag size="small" theme="{{item.statusTheme}}" variant="dark">{{item.statusLabel}}</t-tag>
                    </view>
                  </view>

                  <view class="table-meta-row">
                    <view class="table-capacity-row">
                      <text class="table-capacity-value">{{item.capacityText}}</text>
                      <t-tag wx:if="{{item.minimumSpendText}}" theme="warning" variant="dark" size="small">低消 {{item.minimumSpendText}}</t-tag>
                    </view>

                    <view class="table-category-row">
                      <t-tag theme="default" variant="light" size="small">{{item.typeLabel}}</t-tag>
                      <t-tag theme="default" variant="light" size="small">{{item.typeDescription}}</t-tag>
                    </view>

                    <view wx:if="{{item.visibleTags.length}}" class="table-tag-row">
                      <t-tag wx:for="{{item.visibleTags}}" wx:key="*this" size="small" theme="default" variant="light">{{item}}</t-tag>
                    </view>

                    <view wx:else class="table-tag-row table-tag-row--muted">
                      <text class="tag-summary">{{item.tagSummaryText}}</text>
                    </view>
                  </view>
                </view>
              </view>

              <t-divider />

              <view class="table-action-bar">
                <view class="table-action-slot">
                  <t-button class="table-action-button" variant="text" theme="default" size="small" bind:tap="onEditTable" data-id="{{item.id}}">编辑</t-button>
                </view>

                <t-divider layout="vertical" />

                <view class="table-action-slot">
                  <t-button
                    wx:if="{{item.canRelease}}"
                    class="table-action-button"
                    variant="text"
                    theme="primary"
                    size="small"
                    bind:tap="onReleaseTable"
                    data-id="{{item.id}}"
                    data-no="{{item.table_no}}"
                  >手动释放</t-button>

                  <t-button
                    wx:else
                    class="table-action-button"
                    variant="text"
                    theme="default"
                    size="small"
                    bind:tap="onShowQRCode"
                    data-id="{{item.id}}"
                    data-no="{{item.table_no}}"
                    data-url="{{item.qrCodeUrl}}"
                  >桌台二维码</t-button>
                </view>
              </view>

            </t-cell-group>
          </view>

          <view wx:if="{{loading && tables.length}}" class="load-more">
            <t-loading theme="dots" size="32rpx" text="同步桌台列表中..." />
          </view>

          <view wx:elif="{{tables.length > 0}}" class="list-end">
            <text class="list-end__text">当前共 {{tables.length}} 项桌台 / 包间</text>
          </view>
        </block>

        <t-fab icon="add" bind:click="onAddTable" />
      </view>

      <t-popup wx:if="{{qrCodeVisible}}" visible="{{qrCodeVisible}}" placement="bottom" bind:visible-change="onCloseQRCodePopup">
        <view class="popup-panel qr-popup">
          <view class="popup-copy">
            <text class="popup-title">{{qrCodeTableNo ? qrCodeTableNo + ' 桌台二维码' : '桌台二维码'}}</text>
            <text class="popup-hint">下载后可直接转发打印，也可以长期张贴到桌台或包间门口。</text>
          </view>

          <view wx:if="{{qrCodeLoading}}" class="state-block qr-popup-state">
            <t-loading theme="circular" size="40rpx" text="生成二维码中..." vertical />
          </view>

          <view wx:elif="{{qrCodeError}}" class="state-block qr-popup-state">
            <t-empty icon="error-circle" description="{{qrCodeErrorMessage || '生成二维码失败，请重试'}}" />
          </view>

          <view wx:else class="qr-card">
            <image class="qr-image" src="{{qrCodeImageUrl}}" mode="aspectFit" />
            <text class="qr-popup-tip">顾客扫码即可进入当前桌台点餐页面。</text>
          </view>

          <view class="popup-actions">
            <t-button block size="large" shape="round" theme="default" bind:tap="onCloseQRCodePopup">关闭</t-button>
            <t-button wx:if="{{qrCodeError}}" block size="large" shape="round" theme="primary" bind:tap="onRetryQRCode">重新生成</t-button>
            <t-button wx:else block size="large" shape="round" theme="primary" bind:tap="onDownloadQRCode" loading="{{qrCodeDownloading}}" disabled="{{qrCodeLoading || !qrCodeImageUrl}}">下载二维码</t-button>
          </view>
        </view>
      </t-popup>
    </block>
  </block>
</view>
