@import '../../../styles/merchant-config-shared.wxss';

.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}


.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.page-notice,
.table-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.page-notice {
  border-radius: var(--radius-md);
  overflow: hidden;
}

.filter-label,
.table-desc,
.tag-summary,
.popup-hint,
.qr-popup-tip {
  font-size: var(--font-size-xs);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
}

.table-no,
.popup-title,
.result-summary {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.control-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  background: var(--td-bg-color-page);
}

.tabs-shell {
  overflow: visible;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.filter-panel {
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.filter-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.filter-label {
  font-size: var(--font-size-xs);
}

.filter-tags,
.table-capacity-row,
.table-tag-row,
.popup-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.result-bar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: var(--spacer-sm);
  padding: 0 4rpx;
}

.inline-loading {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.loading-state,
.load-more {
  display: flex;
  justify-content: center;
}

.loading-state {
  padding: 100rpx 0;
}

.table-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.table-card {
  overflow: hidden;
}

.table-card-main {
  display: flex;
  flex-direction: column;
}

.table-cover {
  display: block;
}

.table-content {
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.table-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.table-header-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.table-status-wrap {
  margin-left: auto;
  flex-shrink: 0;
}

.table-meta-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.table-category-row,
.table-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.table-capacity-value {
  font-size: var(--font-size-title);
  line-height: 1;
  color: var(--td-brand-color);
  font-weight: 700;
}

.table-tag-row--muted {
  align-items: flex-start;
}

.table-action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacer-md);
}

.table-action-slot {
  flex: 1;
  display: flex;
  justify-content: center;
}

.table-action-button {
  flex: 0 0 auto;
}

.popup-panel {
  padding: var(--spacer-md);
  padding-bottom: var(--popup-bottom-padding-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.popup-copy {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.qr-popup-state {
  min-height: 360rpx;
}

.qr-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 24rpx;
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
}

.qr-image {
  width: 440rpx;
  height: 440rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
}

.qr-popup-tip {
  text-align: center;
}

.qr-poster-canvas-shell {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 0;
  height: 0;
  overflow: hidden;
  pointer-events: none;
}

.qr-poster-canvas {
  width: 720px;
  height: 1120px;
}

.load-more {
  padding: var(--spacer-sm) 0 8rpx;
}

.list-end {
  display: flex;
  justify-content: center;
  padding: var(--spacer-sm) 0 8rpx;
}

.list-end__text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

@media (max-width: 420px) {
  .table-header,
  .popup-actions {
    align-items: flex-start;
    flex-direction: column;
  }

  .table-action-bar {
    padding: 0 var(--spacer-sm);
  }
}
