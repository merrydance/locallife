.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.tabs-container {
  background-color: #fff !important;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.content-section {
  padding: 32rpx 24rpx;
}

.table-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.table-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  position: relative;
  transition: all 0.2s ease;
  border: 4rpx solid transparent;
}

.table-card.occupied {
  border-color: rgba(var(--td-error-color-rgb), 0.1);
}

.table-card.reserved {
  border-color: rgba(var(--td-warning-color-rgb), 0.1);
}

.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.table-no {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  font-family: 'Outfit', sans-serif;
}

.table-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.capacity {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.type-label {
  font-size: 20rpx;
  color: var(--td-text-color-placeholder);
  background: var(--td-bg-color-secondarycontainer);
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.table-footer {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  height: 48rpx;
  align-items: center;
}

.loading-state {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}

.state-block {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-md);
}

.form-popup {
  background: var(--td-bg-color-container);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  max-height: 80vh;
}

.form-scroll {
  max-height: 80vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(24rpx + constant(safe-area-inset-bottom));
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  min-height: 72rpx;
  border: 1rpx solid var(--td-component-border);
  border-radius: 10rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  background: var(--td-bg-color-page);
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  border: 1rpx solid var(--td-component-border);
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  background: var(--td-bg-color-page);
}

.inline-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.inline-option {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-primary);
}

.tags-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}

.tag-option {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 60rpx;
  padding: 0 8rpx;
  border-radius: 8rpx;
  background: var(--td-bg-color-page);
  font-size: 24rpx;
  color: var(--td-text-color-primary);
}

.tag-name {
  max-width: 180rpx;
}

.tag-delete {
  color: var(--td-error-color);
  font-size: 24rpx;
}

.tag-manage-actions {
  margin-bottom: 12rpx;
}

.image-actions {
  margin-bottom: 12rpx;
}

.image-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.image-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 10rpx;
}

.image-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #e5e7eb;
}

.image-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.image-primary {
  color: #10b981;
  font-size: 24rpx;
}

.image-link {
  color: #2563eb;
  font-size: 24rpx;
}

.image-link.danger {
  color: #ef4444;
}

.form-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
