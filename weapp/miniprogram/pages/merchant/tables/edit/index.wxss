.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}


.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.notice-banner,
.section-panel,
.popup-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.notice-text,
.section-caption,
.popup-hint,
.uploading-text,
.qr-popup-tip {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.section-panel {
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-top,
.section-top-action {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-top-main {
  flex: 1;
  min-width: 0;
}

.section-top-button {
  margin-left: auto;
  flex-shrink: 0;
}

.section-title,
.popup-title {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.selector-group {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.selector-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.tag-check-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.image-upload-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--spacer-md);
}

.image-upload-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  min-width: 0;
}

.image-upload-title {
  font-size: var(--font-size-sm);
  line-height: 1.5;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.tag-empty-text {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.uploading-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.image-action-row,
.popup-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}

.qr-action-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}

.popup-panel {
  padding: var(--spacer-md);
  padding-bottom: var(--popup-bottom-padding-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.popup-copy {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.dialog-form {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.qr-popup-state {
  min-height: 360rpx;
}

.qr-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 24rpx;
  border-radius: var(--radius-lg);
  background: var(--td-bg-color-secondarycontainer);
}

.qr-image {
  width: 440rpx;
  height: 440rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
}

.qr-poster-canvas-shell {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 0;
  height: 0;
  overflow: hidden;
  pointer-events: none;
}

.qr-poster-canvas {
  width: 720px;
  height: 1120px;
}

@media (max-width: 420px) {
  .image-upload-grid,
  .section-top,
  .section-top-action,
  .popup-actions,
  .form-actions {
    grid-template-columns: 1fr;
    align-items: flex-start;
    flex-direction: column;
  }
}
