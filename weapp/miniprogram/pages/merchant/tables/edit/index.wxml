<custom-navbar title="{{isEdit ? '编辑桌台' : '新增桌台'}}" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载桌台编辑信息中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '桌台编辑页加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <view wx:if="{{loadWarningMessage}}" class="notice-banner">
        <t-notice-bar theme="warning" visible="{{true}}" content="{{loadWarningMessage}}" />
      </view>

      <view class="section-panel">
        <view class="section-top">
          <text class="section-title">桌台图片</text>
        </view>

        <view class="image-upload-grid">
          <view class="image-upload-panel">
            <text class="image-upload-title">封面（主图）</text>
            <t-upload
              mediaType="{{['image']}}"
              files="{{coverUploadFiles}}"
              max="{{1}}"
              gridConfig="{{ { column: 1, width: 180, height: 180 } }}"
              disabled="{{imageUploading || imageMutating || submitting}}"
              bind:add="onCoverAdd"
              bind:remove="onCoverRemove"
            />
          </view>

          <view class="image-upload-panel">
            <text class="image-upload-title">配图</text>
            <t-upload
              mediaType="{{['image']}}"
              files="{{galleryUploadFiles}}"
              gridConfig="{{ { column: 2, width: 120, height: 120 } }}"
              disabled="{{imageUploading || imageMutating || submitting}}"
              bind:add="onGalleryAdd"
              bind:remove="onGalleryRemove"
            />
          </view>
        </view>
      </view>

      <view class="section-panel">
        <view class="section-top">
          <text class="section-title">基础信息</text>
        </view>

        <view class="selector-group">
          <text class="selector-label">桌台类型</text>
          <view class="tag-check-list">
            <t-check-tag checked="{{formData.table_type === 'table'}}" content="大厅桌台" shape="round" data-value="table" bind:change="onTypeSelect" />
            <t-check-tag checked="{{formData.table_type === 'room'}}" content="包间" shape="round" data-value="room" bind:change="onTypeSelect" />
          </view>
        </view>

        <t-cell-group theme="card">
          <t-cell required title="{{formData.table_type === 'room' ? '包间名' : '桌号'}}">
            <t-input
              slot="note"
              placeholder="{{formData.table_type === 'room' ? '例如 二楼包间 1' : '例如 A01'}}"
              value="{{formData.table_no}}"
              data-field="table_no"
              borderless
              align="right"
              bind:change="onInputChange"
            />
          </t-cell>

          <t-cell required title="容纳人数">
            <t-input
              slot="note"
              type="number"
              placeholder="1-100"
              value="{{formData.capacity}}"
              borderless
              align="right"
              bind:change="onCapacityChange"
            />
          </t-cell>

          <t-input
            label="最低消费"
            type="digit"
            suffix="元"
            placeholder="可选，如 88.00"
            value="{{formData.minimum_spend_yuan}}"
            data-field="minimum_spend_yuan"
            bind:change="onInputChange"
          />
        </t-cell-group>

        <t-textarea
          placeholder="补充位置、朝向、环境说明等信息"
          value="{{formData.description}}"
          data-field="description"
          bind:change="onInputChange"
          bordered
          maxlength="200"
          indicator
        />
      </view>

      <view wx:if="{{isEdit}}" class="section-panel">
        <view class="section-top">
          <text class="section-title">经营状态</text>
        </view>

        <view class="tag-check-list">
          <t-check-tag
            wx:for="{{statusOptions}}"
            wx:key="value"
            checked="{{formData.status === item.value}}"
            content="{{item.label}}"
            shape="round"
            data-value="{{item.value}}"
            bind:change="onStatusSelect"
          />
        </view>
      </view>

      <view class="section-panel">
        <view class="section-top-action">
          <view class="section-top-main">
            <text class="section-title">桌台标签</text>
            <text class="section-caption">已选 {{formData.tag_ids.length}} 个，用于列表识别与筛选</text>
          </view>
          <view class="section-top-button">
            <t-button size="small" theme="primary" icon="add" loading="{{tagSubmitting}}" bind:tap="onManageTags">管理标签</t-button>
          </view>
        </view>

        <view wx:if="{{availableTags.length}}" class="tag-check-list">
          <t-check-tag
            wx:for="{{availableTags}}"
            wx:key="id"
            checked="{{selectedTagState[item.id]}}"
            content="{{item.name}}"
            shape="round"
            data-tag-id="{{item.id}}"
            bind:change="onTagToggle"
          />
        </view>

        <view wx:else class="inline-note-card">暂无桌台标签，可直接新增后立即选择。</view>
      </view>

      <view wx:if="{{isEdit}}" class="section-panel">
        <view class="section-top">
          <text class="section-title">桌台二维码</text>
          <text class="section-caption">顾客扫码后可进入当前桌台点餐，也可下载后打印张贴</text>
        </view>

        <view class="qr-action-row">
          <t-button theme="primary" bind:tap="onGenerateQRCode" loading="{{qrCodeLoading && qrCodeVisible}}" disabled="{{submitting || qrCodeDownloading}}">刷新二维码</t-button>
          <t-button theme="default" bind:tap="onShowQRCode">展示二维码</t-button>
        </view>
      </view>
      <view class="form-actions">
        <t-button theme="primary" loading="{{submitting}}" bind:tap="onSubmit">{{isEdit ? '保存桌台' : '创建桌台'}}</t-button>
      </view>
    </view>

    <t-popup wx:if="{{qrCodeVisible}}" visible="{{qrCodeVisible}}" placement="bottom" bind:visible-change="onCloseQRCodePopup">
      <view class="popup-panel qr-popup">
        <view class="popup-copy">
          <text class="popup-title">{{qrCodeTableNo ? qrCodeTableNo + ' 桌台二维码' : '桌台二维码'}}</text>
          <text class="popup-hint">下载后可直接转发打印，也可以长期张贴到桌台或包间门口。</text>
        </view>

        <view wx:if="{{qrCodeLoading}}" class="state-block qr-popup-state">
          <t-loading theme="circular" size="40rpx" text="生成二维码中..." vertical />
        </view>

        <view wx:elif="{{qrCodeError}}" class="state-block qr-popup-state">
          <t-empty icon="error-circle" description="{{qrCodeErrorMessage || '生成二维码失败，请重试'}}" />
        </view>

        <view wx:else class="qr-card">
          <t-image class="qr-image" src="{{qrCodeImageUrl}}" mode="aspectFit" />
          <text class="qr-popup-tip">顾客扫码即可进入当前桌台点餐页面，保存时会自动生成大字版打印海报。</text>
        </view>

        <view class="popup-actions">
          <t-button theme="default" bind:tap="onCloseQRCodePopup">关闭</t-button>
          <t-button wx:if="{{qrCodeError}}" theme="primary" bind:tap="onRetryQRCode">重新生成</t-button>
          <t-button wx:else theme="primary" bind:tap="onDownloadQRCode" loading="{{qrCodeDownloading}}" disabled="{{qrCodeLoading || !qrCodeImageUrl}}">下载打印海报</t-button>
        </view>
      </view>
    </t-popup>

    <view class="qr-poster-canvas-shell" aria-hidden="true">
      <canvas
        canvas-id="tableQrPosterCanvas"
        class="qr-poster-canvas"
        disable-scroll="true"
      />
    </view>

    <t-dialog
      visible="{{createTagDialogVisible}}"
      title="新增桌台标签"
      confirm-btn="{{ { content: '确定', loading: tagSubmitting } }}"
      cancel-btn="取消"
      bind:confirm="onConfirmCreateTagDialog"
      bind:cancel="onCloseCreateTagDialog"
    >
      <view slot="content" class="dialog-form">
        <t-input
          label="标签名称"
          value="{{createTagInputValue}}"
          bind:change="onCreateTagInputChange"
        />
      </view>
    </t-dialog>
  </block>
</view>
