.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--td-bg-color-page);
}

.state-block,
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.state-block-compact {
  padding: 80rpx 24rpx;
}

.notice-banner {
  margin-bottom: 24rpx;
}

.notice-banner-operation {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.summary-strip,
.complaint-card {
  background: var(--td-bg-color-container);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.hero-title,
.summary-value,
.complaint-id,
.amount {
  color: var(--td-text-color-primary);
}

.summary-label,
.complaint-time,
.label,
.detail-preview,
.status-text,
.status-tip {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.summary-strip {
  display: flex;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
}

.summary-item + .summary-item {
  border-left: 1px solid var(--td-component-stroke);
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
}

.complaint-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.complaint-card {
  padding: 24rpx;
}

.card-header,
.card-head-left,
.info-row,
.status-strip {
  display: flex;
}

.card-header,
.info-row,
.status-strip {
  justify-content: space-between;
  gap: 20rpx;
}

.card-header {
  align-items: flex-start;
}

.card-head-left {
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.complaint-id {
  font-size: 30rpx;
  font-weight: 600;
}

.info-row {
  align-items: center;
  margin-top: 18rpx;
}

.label {
  flex-shrink: 0;
}

.value {
  font-size: 26rpx;
  color: var(--td-text-color-primary);
  text-align: right;
}

.detail-preview {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.status-strip {
  flex-direction: column;
  margin-top: 18rpx;
}

.status-text {
  color: var(--td-text-color-primary);
}

.status-tip {
  color: var(--td-brand-color);
}

.more-wrap {
  display: flex;
  justify-content: center;
  padding: 12rpx 0 32rpx;
}