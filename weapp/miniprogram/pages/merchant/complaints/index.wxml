<custom-navbar title="投诉处理" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载投诉列表中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '投诉列表加载失败，请重试'}}" />
    <view class="retry-button" bindtap="onRetry">重新加载</view>
  </view>

  <block wx:else>
    <view class="hero-card">
      <view class="hero-copy">
        <text class="hero-title">微信交易投诉</text>
        <text class="hero-subtitle">需要及时回复顾客投诉，并在协商完成后主动完结，避免工单长期挂起。</text>
        <text class="hero-meta">当前筛选：{{currentTabLabel}}</text>
      </view>
    </view>

    <view wx:if="{{refreshErrorMessage}}" class="inline-banner inline-banner-danger">
      <text class="inline-banner-text">{{refreshErrorMessage}}</text>
      <text class="inline-banner-action" bindtap="onRetryRefresh">重新同步</text>
    </view>

    <view class="summary-strip">
      <view class="summary-item">
        <text class="summary-value">{{loadedCount}}</text>
        <text class="summary-label">已加载</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{respondedCount}}</text>
        <text class="summary-label">已回复</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{completedCount}}</text>
        <text class="summary-label">已完结</text>
      </view>
    </view>

    <t-tabs value="{{currentTab}}" bind:change="onTabChange" t-class="complaint-tabs">
      <t-tab-panel label="全部" value="all"><view /></t-tab-panel>
      <t-tab-panel label="待回复" value="PENDING_RESPONSE"><view /></t-tab-panel>
      <t-tab-panel label="处理中" value="PROCESSING"><view /></t-tab-panel>
      <t-tab-panel label="已完结" value="PROCESSED"><view /></t-tab-panel>
    </t-tabs>

    <view wx:if="{{loading && !complaints.length}}" class="state-block state-block-compact">
      <t-loading theme="circular" size="40rpx" text="刷新投诉中..." vertical />
    </view>

    <view wx:elif="{{!loading && !complaints.length}}" class="empty-wrap">
      <t-empty description="当前筛选下暂无投诉记录" />
    </view>

    <view wx:else class="complaint-list">
      <view wx:for="{{complaints}}" wx:key="complaintId" class="complaint-card" data-complaint-id="{{item.complaintId}}" bindtap="onViewDetail">
        <view class="card-header">
          <view class="card-head-left">
            <text class="complaint-id">投诉单 {{item.complaintId}}</text>
            <text class="complaint-time">{{item.complaintTimeLabel}}</text>
          </view>
          <t-tag size="small" variant="dark" theme="{{item.stateTheme}}">{{item.stateLabel}}</t-tag>
        </view>

        <view class="info-row">
          <text class="label">关联订单</text>
          <text class="value">{{item.orderNoLabel}}</text>
        </view>
        <view class="info-row">
          <text class="label">投诉金额</text>
          <text class="value amount">{{item.amountText}}</text>
        </view>

        <view class="detail-preview">{{item.detailPreview}}</view>

        <view class="status-strip">
          <text class="status-text">{{item.responseStatusLabel}}</text>
          <text class="status-tip">{{item.actionHint}}</text>
        </view>
      </view>

      <view wx:if="{{hasMore}}" class="more-wrap">
        <t-button size="small" theme="primary" variant="outline" shape="round" loading="{{loadingMore}}" bindtap="onLoadMore">加载更多</t-button>
      </view>
    </view>
  </block>
</view>