<custom-navbar title="{{isEdit ? '编辑代取优惠' : '新增代取优惠'}}" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载代取优惠信息中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '代取优惠编辑页加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重试</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <view class="section-panel">
        <view class="section-top">
          <text class="section-title">优惠规则</text>
        </view>

        <t-cell-group theme="card">
          <t-cell required title="优惠名称">
            <t-input
              slot="note"
              placeholder="例如：满30减5"
              value="{{formData.name}}"
              data-field="name"
              borderless
              align="right"
              bind:change="onFormInputChange"
            />
          </t-cell>
          <t-cell required title="最低金额">
            <t-input
              slot="note"
              type="digit"
              suffix="元"
              placeholder="如 30.00"
              value="{{formData.min_order_yuan}}"
              data-field="min_order_yuan"
              borderless
              align="right"
              bind:change="onFormInputChange"
            />
          </t-cell>
          <t-cell required title="优惠金额">
            <t-input
              slot="note"
              type="digit"
              suffix="元"
              placeholder="如 5.00"
              value="{{formData.discount_yuan}}"
              data-field="discount_yuan"
              borderless
              align="right"
              bind:change="onFormInputChange"
            />
          </t-cell>
        </t-cell-group>
      </view>

      <view class="section-panel">
        <view class="section-top">
          <text class="section-title">生效时间</text>
        </view>

        <t-cell-group theme="card">
          <t-cell title="开始日期" arrow note="{{formData.valid_from || '请选择'}}" bind:tap="showValidFromPicker" />
          <t-cell title="结束日期" arrow note="{{formData.valid_until || '请选择'}}" bind:tap="showValidUntilPicker" />
        </t-cell-group>
      </view>

      <view wx:if="{{isEdit}}" class="section-panel">
        <view class="section-top">
          <text class="section-title">生效状态</text>
        </view>

        <t-cell-group theme="card">
          <t-cell title="启用状态" description="关闭后当前优惠不再参与新的代取费计算">
            <t-switch slot="note" value="{{formData.is_active}}" data-field="is_active" bind:change="onSwitchChange" />
          </t-cell>
        </t-cell-group>
      </view>
      <view class="form-actions">
        <t-button theme="primary" loading="{{submitting}}" bind:tap="onSubmit">
        {{isEdit ? '保存代取优惠' : '创建代取优惠'}}
        </t-button>
      </view>
    </view>

    <t-date-time-picker
      title="选择开始日期"
      visible="{{validFromPickerVisible}}"
      mode="date"
      format="YYYY-MM-DD"
      defaultValue="{{formData.valid_from}}"
      bind:confirm="onValidFromConfirm"
      bind:cancel="hideValidFromPicker"
    />

    <t-date-time-picker
      title="选择结束日期"
      visible="{{validUntilPickerVisible}}"
      mode="date"
      format="YYYY-MM-DD"
      defaultValue="{{formData.valid_until}}"
      bind:confirm="onValidUntilConfirm"
      bind:cancel="hideValidUntilPicker"
    />
  </block>
</view>
