<custom-navbar title="代取优惠管理" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载代取优惠中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '代取优惠加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <view class="result-bar">
        <text class="result-summary">{{resultSummaryText}}</text>
      </view>

      <view wx:if="{{loading && !promotions.length}}" class="loading-state">
        <t-loading theme="circular" size="40rpx" text="加载代取优惠中..." vertical />
      </view>

      <t-empty wx:elif="{{!loading && !promotions.length}}" icon="info-circle" description="{{emptyDescription}}" />

      <view wx:else class="promotion-list">
        <block wx:for="{{promotions}}" wx:key="id">
          <t-cell-group class="promotion-card">
            <view class="promotion-card-main" bindtap="onEditPromotion" data-id="{{item.id}}">
              <view class="promotion-content">
                <view class="promotion-header">
                  <view class="promotion-header-main">
                    <text class="promotion-name">{{item.name}}</text>
                    <text class="promotion-desc">订单满 {{item.min_order_yuan}} 可减 {{item.discount_yuan}}</text>
                  </view>
                  <view class="promotion-switch-wrap" catchtap="onActionsCatch">
                    <t-switch
                      value="{{item.is_active}}"
                      size="small"
                      loading="{{item.statusPending}}"
                      disabled="{{item.deletePending}}"
                      bind:change="onTogglePromoStatus"
                      data-id="{{item.id}}"
                    />
                  </view>
                </view>

                <view class="promotion-meta-row">
                  <view class="promotion-price-row">
                    <text class="meta-label">门槛</text>
                    <text class="price-value">¥{{item.min_order_yuan}}</text>
                    <text class="meta-divider">减</text>
                    <text class="price-value price-value--accent">¥{{item.discount_yuan}}</text>
                  </view>

                  <view class="promotion-tag-row">
                    <t-tag theme="{{item.status_theme}}" variant="light" size="small">{{item.status_label}}</t-tag>
                  </view>

                  <view class="promotion-date-row">
                    <text class="meta-label">有效期</text>
                    <text class="meta-value">{{item.valid_from_date}} 至 {{item.valid_until_date}}</text>
                  </view>
                </view>
              </view>
            </view>

            <t-divider />

            <view class="promotion-action-bar" catchtap="onActionsCatch">
              <view class="promotion-action-slot">
                <t-button class="promotion-action-button" variant="text" theme="default" size="small" icon="edit" bind:tap="onEditPromotion" data-id="{{item.id}}">编辑</t-button>
              </view>
              <t-divider layout="vertical" />
              <view class="promotion-action-slot">
                <t-button
                  class="promotion-action-button"
                  variant="text"
	                  theme="danger"
	                  size="small"
	                  icon="delete"
	                  loading="{{item.deletePending}}"
                  disabled="{{item.deletePending || item.statusPending}}"
                  bind:tap="onRequestDeletePromotion"
                  data-id="{{item.id}}"
                >删除</t-button>
              </view>
            </view>
          </t-cell-group>
        </block>
      </view>
    </view>

    <t-fab icon="add" bind:click="onAddPromotion" />
  </block>

  <t-dialog
    visible="{{deleteDialogVisible}}"
    title="确认删除代取优惠"
    using-custom-navbar="{{true}}"
    confirm-btn="{{ { content: '确认删除', theme: 'danger', loading: deleteDialogSubmitting } }}"
    cancel-btn="取消"
    bind:confirm="onConfirmDeletePromotion"
    bind:cancel="onCancelDeleteDialog"
    bind:close="onCancelDeleteDialog"
  >
    <view slot="content" class="dialog-content">
      <text>删除后无法恢复，确定要删除“{{deleteDialogPromotionName}}”吗？</text>
    </view>
  </t-dialog>
</view>
