.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

/* ==================== 状态 ==================== */

.center-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

/* ==================== 列表 ==================== */

.list-section {
  padding: var(--spacer-sm) 0 120rpx;
}

.promo-card {
  background-color: var(--td-bg-color-container);
  margin: var(--spacer-sm) var(--spacer-lg);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  border: 1rpx solid var(--td-component-stroke);
}

.promo-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacer-sm);
}

.promo-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  flex-wrap: wrap;
}

.promo-name {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.promo-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: var(--spacer-sm);
}

.promo-rule {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rule-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.rule-amount {
  color: var(--td-error-color);
  font-weight: 600;
}

.promo-date {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.promo-footer {
  display: flex;
  justify-content: flex-end;
}

.swipe-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--td-error-color);
  color: #fff;
  font-size: var(--font-size-sm);
  width: 140rpx;
  height: 100%;
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
}

/* ==================== 弹窗表单 ==================== */

.form-popup {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

.form-scroll {
  max-height: 80vh;
  box-sizing: border-box;
  padding: var(--spacer-lg);
  padding-bottom: calc(var(--spacer-lg) + env(safe-area-inset-bottom));
}

.form-title {
  font-size: var(--font-size-title);
  font-weight: 700;
  color: var(--td-text-color-primary);
  text-align: center;
  margin-bottom: var(--spacer-lg);
}

.form-row {
  display: flex;
  gap: var(--spacer-md);
}

.form-item {
  margin-bottom: var(--spacer-md);
}

.form-item.half {
  flex: 1;
}

.form-item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  margin-bottom: 8rpx;
}

.form-label.required::before {
  content: '*';
  color: var(--td-error-color);
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid var(--td-component-stroke);
  border-radius: var(--radius-sm);
  padding: 0 var(--spacer-sm);
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  box-sizing: border-box;
  background-color: var(--td-bg-color-page);
}

.form-picker {
  height: 72rpx;
  border: 1rpx solid var(--td-component-stroke);
  border-radius: var(--radius-sm);
  padding: 0 var(--spacer-sm);
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  background-color: var(--td-bg-color-page);
  display: flex;
  align-items: center;
}

.form-picker.placeholder {
  color: var(--td-text-color-placeholder);
}

.form-actions {
  display: flex;
  gap: var(--spacer-md);
  margin-top: var(--spacer-lg);
}
