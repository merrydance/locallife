@import '../../../styles/merchant-config-shared.wxss';

.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: calc(140rpx + var(--safe-area-bottom));
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin: 0 var(--spacer-lg) var(--spacer-md);
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-success {
  background: var(--td-success-color-1);
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.hero-card {
  margin: var(--spacer-sm) var(--spacer-lg) var(--spacer-md);
}

/* ==================== 列表 ==================== */

.list-section {
  padding: 0 var(--spacer-lg) calc(160rpx + var(--safe-area-bottom));
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.promo-card {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.promo-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacer-sm);
}

.promo-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  flex-wrap: wrap;
}

.promo-name {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.promo-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: var(--spacer-sm);
}

.promo-rule {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rule-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.rule-amount {
  color: var(--td-error-color);
  font-weight: 600;
}

.promo-date {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.promo-footer {
  display: flex;
  flex-direction: column;
  margin-top: 12rpx;
  gap: 16rpx;
}

.promo-action-hint {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-placeholder);
}

.promo-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

/* ==================== 弹窗表单 ==================== */

.form-row {
  gap: var(--spacer-md);
}

.form-item {
  margin-bottom: var(--spacer-md);
}

.form-item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
