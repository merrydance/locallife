<custom-navbar title="预订管理" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter reservations-page"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{initialLoading && !listAvailable}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="正在加载预订列表..." vertical />
  </view>

  <view wx:elif="{{accessDenied || accessErrorMessage || initialError}}" class="state-block">
    <t-empty
      image="error-circle"
      description="{{accessDenied ? '当前账号暂无预订管理权限' : accessErrorMessage || initialErrorMessage || '预订页暂时无法打开'}}"
    />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">
      {{accessDenied ? '重新校验权限' : '重新加载'}}
    </t-button>
  </view>

  <block wx:else>
    <view class="page-content reservations-page__content">
      <t-sticky offset-top="{{navBarHeight}}">
        <view class="control-panel reservations-control-panel">
          <view class="tabs-shell tabs-shell--compact">
            <t-tabs value="{{currentTab}}" bind:change="onTabChange">
              <t-tab-panel wx:for="{{tabOptions}}" wx:key="key" value="{{item.key}}" label="{{item.label}}"></t-tab-panel>
            </t-tabs>
          </view>

          <view class="filter-panel filter-panel--single reservations-filter-panel">
            <view class="date-filter-combo" bindtap="onOpenDatePicker">
              <view class="date-filter-label-group">
                <text class="date-filter-label">营业日期</text>
                <text class="date-filter-value">{{date}}</text>
              </view>
              <view class="date-filter-actions" catchtap="onActionsCatch">
                <view class="date-filter-divider"></view>
                <view class="date-filter-icon-button" bindtap="onManualRefresh">
                  <t-icon name="refresh" size="36rpx" />
                </view>
              </view>
            </view>
          </view>
        </view>
      </t-sticky>

      <view class="result-bar">
        <text class="result-bar__text">{{listSummaryText}}</text>
      </view>

      <view wx:if="{{listLoading && !reservations.length}}" class="state-block state-block--inline">
        <t-loading theme="circular" size="40rpx" text="正在加载预订列表..." vertical />
      </view>

      <view wx:elif="{{!listLoading && listInitialError && !reservations.length}}" class="state-block state-block--inline">
        <t-empty image="error-circle" description="{{listInitialErrorMessage || '预订列表加载失败'}}" />
        <t-button theme="primary" size="small" shape="round" bind:tap="onRetryList">重试加载</t-button>
      </view>

      <t-empty wx:elif="{{!listLoading && !reservations.length}}" icon="info-circle" description="当前筛选条件下暂无预订" />

      <view wx:else class="reservation-list">
        <view wx:for="{{reservations}}" wx:key="id" class="reservation-card card-surface">
            <view class="reservation-card__main" data-id="{{item.id}}" bindtap="onReservationCardTap">
              <view class="reservation-card__header">
                <view class="reservation-card__title-group">
                  <text class="reservation-card__title">{{item.titleText}}</text>
                  <text class="reservation-card__subtitle">{{item.subtitleText}}</text>
                </view>
                <t-tag theme="{{item.statusTheme}}" variant="dark">{{item.statusLabel}}</t-tag>
              </view>

              <view class="reservation-card__meta-list">
                <view class="reservation-card__meta-item">
                  <text class="reservation-card__meta-label">来源</text>
                  <text class="reservation-card__meta-value">{{item.sourceLabel}}</text>
                </view>
                <view class="reservation-card__meta-item">
                  <text class="reservation-card__meta-label">支付方式</text>
                  <text class="reservation-card__meta-value">{{item.paymentLabel}}</text>
                </view>
                <view class="reservation-card__meta-item">
                  <text class="reservation-card__meta-label">人数</text>
                  <text class="reservation-card__meta-value">{{item.guest_count}} 人</text>
                </view>
              </view>

              <view class="reservation-card__info-block">
                <text class="reservation-card__info-label">预点菜</text>
                <text class="reservation-card__info-text">{{item.itemPreview}}</text>
              </view>

              <view wx:if="{{item.notes}}" class="reservation-card__info-block reservation-card__info-block--notes">
                <text class="reservation-card__info-label">备注</text>
                <text class="reservation-card__info-text">{{item.notes}}</text>
              </view>

              <view wx:if="{{item.cookingStartedNotice}}" class="reservation-card__notice">
                <text>{{item.cookingStartedNotice}}</text>
              </view>
            </view>

            <view class="card-divider"></view>

            <view class="reservation-card__actions" catchtap="onActionsCatch">
              <view class="reservation-card__action" data-id="{{item.id}}" bindtap="onOpenEditPage">{{item.canEdit ? '编辑' : '查看'}}</view>
              <view wx:if="{{item.primaryActionKey}}" class="card-action-divider"></view>
              <view
                wx:if="{{item.primaryActionKey}}"
                class="reservation-card__action reservation-card__action--primary"
                data-id="{{item.id}}"
                data-action="{{item.primaryActionKey}}"
                data-contact="{{item.contact_name}}"
                bindtap="onPrimaryAction"
              >
                {{item.primaryActionLabel}}
              </view>
              <view wx:if="{{item.showMoreActions}}" class="card-action-divider"></view>
              <view wx:if="{{item.showMoreActions}}" class="reservation-card__action" data-id="{{item.id}}" bindtap="onOpenMoreActions">更多</view>
            </view>
          </view>

        <view wx:if="{{listLoading && reservations.length}}" class="list-loading-more">
          <t-loading size="32rpx" text="正在加载更多..." />
        </view>

        <view wx:elif="{{listHasMore}}" class="load-more-trigger">
          <t-button variant="text" theme="primary" bind:tap="onLoadMore">加载更多</t-button>
        </view>

        <view wx:else class="list-end-text">已经到底了</view>
      </view>
    </view>

  </block>

  <t-fab icon="add" bind:click="onOpenCreatePage" />
</view>

<t-action-sheet
  visible="{{actionSheetVisible}}"
  description="{{actionSheetDescription}}"
  items="{{actionSheetItems}}"
  using-custom-navbar="{{true}}"
  bind:selected="onActionSheetSelected"
  bind:cancel="onActionSheetCancel"
  bind:close="onActionSheetClose"
/>

<t-dialog
  visible="{{confirmDialogVisible}}"
  title="{{confirmDialogTitle}}"
  using-custom-navbar="{{true}}"
  confirm-btn="{{ { content: confirmDialogConfirmText, theme: confirmDialogConfirmTheme, loading: confirmDialogSubmitting } }}"
  cancel-btn="取消"
  bind:confirm="onConfirmDialogAction"
  bind:cancel="onCancelConfirmDialog"
  bind:close="onCancelConfirmDialog"
>
  <view slot="content" class="confirm-dialog__content">
    <text>{{confirmDialogContent}}</text>
  </view>
</t-dialog>

<t-toast id="t-toast" />

<t-date-time-picker
  visible="{{datePickerVisible}}"
  mode="date"
  value="{{date}}"
  title="选择营业日期"
  format="YYYY-MM-DD"
  bind:confirm="onDateConfirm"
  bind:cancel="onCloseDatePicker"
  bind:close="onCloseDatePicker"
/>
