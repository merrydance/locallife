.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: 24rpx;
}

.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 140rpx 24rpx;
}

.retry-button {
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color);
  color: var(--td-text-color-anti);
  font-size: 26rpx;
}

.section-state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 60rpx 24rpx 24rpx;
}

.section-state-block-spaced {
  margin: 0 24rpx 24rpx;
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
}

.section-error-hint {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-error-color-1);
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-error-hint-spaced {
  margin: 0 24rpx 16rpx;
}

.section-error-action {
  flex-shrink: 0;
  color: var(--td-brand-color);
  font-weight: 600;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  flex-wrap: wrap;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: auto;
}

.date-trigger {
  background: var(--td-bg-color-container);
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  color: var(--td-text-color-primary);
  font-size: 26rpx;
}

.summary-card {
  margin: 0 24rpx;
  padding: 20rpx;
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.summary-item {
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 10rpx;
  min-height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.value {
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section {
  margin-top: 24rpx;
  padding: 0 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-subtitle,
.notice-banner,
.reservation-items,
.popup-subtitle,
.form-tip {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.loading-state {
  padding: 80rpx 0;
}

.notice-banner {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--td-warning-color-1);
}

.dish-card,
.reservation-card {
  background: var(--td-bg-color-container);
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 14rpx;
}

.dish-header,
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-name,
.table {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.reservation-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-total,
.time {
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.dish-meta,
.secondary {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.reservation-items {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.reservation-actions {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.popup-sheet {
  background: var(--td-bg-color-container);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx 40rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.popup-subtitle {
  display: block;
  margin: 12rpx 0 24rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--td-text-color-primary);
}

.picker-trigger {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
  color: var(--td-text-color-primary);
  font-size: 26rpx;
}

.picker-trigger-disabled {
  color: var(--td-text-color-placeholder);
}

.form-tip {
  display: block;
  margin-top: 10rpx;
}

.source-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.source-option {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: var(--td-bg-color-secondarycontainer);
  font-size: 24rpx;
  color: var(--td-text-color-primary);
}

.popup-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 28rpx;
}
