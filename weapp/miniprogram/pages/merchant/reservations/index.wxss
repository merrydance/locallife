.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: 24rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.date-trigger {
  background: var(--td-bg-color-container);
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  color: var(--td-text-color-primary);
  font-size: 26rpx;
}

.summary-card {
  margin: 0 24rpx;
  padding: 20rpx;
  background: var(--td-bg-color-container);
  border-radius: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.summary-item {
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 10rpx;
  min-height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.value {
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section {
  margin-top: 24rpx;
  padding: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.loading-state {
  padding: 80rpx 0;
}

.dish-card,
.reservation-card {
  background: var(--td-bg-color-container);
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 14rpx;
}

.dish-header,
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-name,
.table {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.dish-total,
.time {
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.dish-meta,
.secondary {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}
