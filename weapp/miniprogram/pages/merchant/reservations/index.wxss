.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.control-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  background: var(--td-bg-color-page);
}

.tabs-shell {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.filter-panel {
  padding: var(--spacer-sm) var(--spacer-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.state-block--inline {
  min-height: 320rpx;
  padding: 48rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.reservations-control-panel {
  gap: 20rpx;
}

.reservations-filter-panel {
  padding: 0;
  background: transparent;
}

.date-filter-combo {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  min-height: 104rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
}

.date-filter-label-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  padding: 0 28rpx;
}

.date-filter-label {
  font-size: 24rpx;
  color: #8b93a6;
}

.date-filter-value {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #1f2937;
}

.date-filter-actions {
  display: flex;
  align-items: stretch;
}

.date-filter-divider {
  width: 1rpx;
  margin: 22rpx 0;
  background: rgba(15, 23, 42, 0.08);
}

.date-filter-icon-button {
  width: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
}

.result-bar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: var(--spacer-sm);
  padding: 0 4rpx;
}

.result-bar__text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.reservation-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-surface {
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
}

.reservation-card__main {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 28rpx;
}

.reservation-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.reservation-card__title-group {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.reservation-card__title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #111827;
}

.reservation-card__subtitle {
  font-size: 24rpx;
  line-height: 36rpx;
  color: #6b7280;
}

.reservation-card__meta-list {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.reservation-card__meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.reservation-card__meta-label {
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8b93a6;
}

.reservation-card__meta-value {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

.reservation-card__info-block {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reservation-card__info-block--notes {
  padding-top: 4rpx;
}

.reservation-card__info-label {
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8b93a6;
}

.reservation-card__info-text {
  font-size: 26rpx;
  line-height: 38rpx;
  color: #374151;
}

.reservation-card__notice {
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(14, 116, 144, 0.08);
  font-size: 24rpx;
  line-height: 36rpx;
  color: #0f766e;
}

.card-divider {
  height: 1rpx;
  margin: 0 28rpx;
  background: rgba(15, 23, 42, 0.08);
}

.reservation-card__actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
}

.reservation-card__action {
  flex: 1;
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #475569;
}

.reservation-card__action--primary {
  font-weight: 600;
  color: var(--td-brand-color, #0052d9);
}

.card-action-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(15, 23, 42, 0.08);
}

.list-loading-more,
.load-more-trigger,
.list-end-text {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 8rpx;
}

.list-end-text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.confirm-dialog__content {
  padding: 8rpx 0;
  font-size: 28rpx;
  line-height: 44rpx;
  color: var(--td-text-color-secondary);
}
