.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

.search-wrap {
  background-color: #fff;
  padding: 16rpx 32rpx;
}

.tabs-container {
  background-color: #fff !important;
  margin-bottom: 4rpx;
}

.list-section {
  padding: 24rpx 0;
}

.loading-state {
  padding: 100rpx 0;
  display: flex;
  justify-content: center;
}

.dish-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #fff;
  border-bottom: 1rpx solid var(--td-component-stroke);
}

.dish-main {
  display: flex;
  flex: 1;
  gap: 24rpx;
}

.dish-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.dish-desc {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin: 4rpx 0;
}

.dish-price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-unit {
  font-size: 24rpx;
  color: var(--td-brand-color);
  font-weight: bold;
}

.price-value {
  font-size: 34rpx;
  color: var(--td-brand-color);
  font-weight: bold;
  font-family: 'Outfit', sans-serif;
}

.member-price {
  font-size: 20rpx;
  color: #faad14;
  margin-left: 12rpx;
  background: rgba(250, 173, 20, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.dish-status-toggle {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  min-width: 120rpx;
}

.toggle-label {
  font-size: 20rpx;
  color: var(--td-text-color-placeholder);
}

/* 滑动操作 */
.swipe-action-wrap {
  display: flex;
  height: 100%;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  width: 120rpx;
  font-size: 28rpx;
}

.edit-btn {
  background-color: var(--td-brand-color);
}

.delete-btn {
  background-color: var(--td-error-color);
}

.load-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}
