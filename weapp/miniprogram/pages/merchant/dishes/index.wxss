.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: var(--spacer-lg);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-lg) 0;
}

.search-wrap {
  background-color: var(--td-bg-color-container);
  padding: var(--spacer-sm) var(--spacer-lg);
}

.filter-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  padding: 0 var(--spacer-lg) var(--spacer-sm);
  background-color: var(--td-bg-color-container);
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.filter-group-label {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.filter-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-page);
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1;
}

.filter-chip-active {
  background: rgba(0, 82, 217, 0.12);
  color: var(--td-brand-color);
  font-weight: 600;
}

.tabs-container {
  background-color: var(--td-bg-color-container) !important;
  margin-bottom: 4rpx;
}

.list-section {
  padding: var(--spacer-md) 0;
}

.batch-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin: 0 var(--spacer-lg) var(--spacer-md);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: rgba(0, 82, 217, 0.06);
}

.batch-toolbar-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.batch-toolbar-action {
  font-size: var(--font-size-sm);
  color: var(--td-brand-color);
  font-weight: 600;
}

.inline-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md);
  margin: 0 var(--spacer-lg) var(--spacer-md);
  border-radius: var(--radius-md);
}

.inline-banner-danger {
  background: rgba(229, 57, 53, 0.08);
  color: var(--td-error-color);
}

.inline-banner-text {
  flex: 1;
  font-size: var(--font-size-sm);
  line-height: 1.6;
}

.inline-banner-action {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--td-brand-color);
}

.loading-state {
  padding: 100rpx 0;
  display: flex;
  justify-content: center;
}

.dish-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-md) var(--spacer-lg);
  background-color: var(--td-bg-color-container);
  border-bottom: 1rpx solid var(--td-component-stroke);
}

.dish-item-batch {
  gap: 20rpx;
}

.dish-select-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.dish-main {
  display: flex;
  flex: 1;
  gap: 24rpx;
}

.dish-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  background-color: var(--td-bg-color-page);
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dish-name {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.dish-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin: 4rpx 0;
}

.dish-price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-unit {
  font-size: var(--font-size-xs);
  color: var(--td-brand-color);
  font-weight: bold;
}

.price-value {
  font-size: var(--font-size-title);
  color: var(--td-brand-color);
  font-weight: bold;
}

.member-price {
  font-size: var(--font-size-xxs);
  color: var(--td-warning-color);
  margin-left: 12rpx;
  background: var(--td-brand-color-light);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
}

.dish-status-toggle {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  min-width: 120rpx;
}

.toggle-label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.dish-status-summary {
  flex-shrink: 0;
  min-width: 120rpx;
  display: flex;
  justify-content: flex-end;
  text-align: right;
}

/* 滑动操作 */
.swipe-action-wrap {
  display: flex;
  height: 100%;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--td-text-color-anti);
  width: 120rpx;
  font-size: var(--font-size-base);
}

.delete-btn {
  background-color: var(--td-error-color);
}

.load-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.batch-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-md);
  padding: var(--spacer-md) var(--spacer-lg) calc(var(--spacer-md) + env(safe-area-inset-bottom));
  background: var(--td-bg-color-container);
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.batch-action-summary {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.batch-selected-count {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.batch-summary-hint {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.batch-action-buttons {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  flex-shrink: 0;
}
