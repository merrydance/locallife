.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

.header-actions {
  padding: var(--spacer-sm) var(--spacer-lg) 0;
}

.search-wrap {
  background-color: var(--td-bg-color-container);
  padding: var(--spacer-sm) var(--spacer-lg);
}

.tabs-container {
  background-color: var(--td-bg-color-container) !important;
  margin-bottom: 4rpx;
}

.list-section {
  padding: var(--spacer-md) 0;
}

.loading-state {
  padding: 100rpx 0;
  display: flex;
  justify-content: center;
}

.dish-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-md) var(--spacer-lg);
  background-color: var(--td-bg-color-container);
  border-bottom: 1rpx solid var(--td-component-stroke);
}

.dish-main {
  display: flex;
  flex: 1;
  gap: 24rpx;
}

.dish-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  background-color: var(--td-bg-color-page);
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dish-name {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.dish-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin: 4rpx 0;
}

.dish-price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-unit {
  font-size: var(--font-size-xs);
  color: var(--td-brand-color);
  font-weight: bold;
}

.price-value {
  font-size: var(--font-size-title);
  color: var(--td-brand-color);
  font-weight: bold;
}

.member-price {
  font-size: var(--font-size-xxs);
  color: var(--td-warning-color);
  margin-left: 12rpx;
  background: var(--td-brand-color-light);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
}

.dish-status-toggle {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  min-width: 120rpx;
}

.toggle-label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

/* 滑动操作 */
.swipe-action-wrap {
  display: flex;
  height: 100%;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--td-text-color-anti);
  width: 120rpx;
  font-size: var(--font-size-base);
}

.delete-btn {
  background-color: var(--td-error-color);
}

.load-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}
