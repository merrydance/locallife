<custom-navbar title="菜品管理" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载菜品中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '菜品加载失败，请重试'}}" />
    <t-button theme="primary" size="small" shape="round" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="header-actions">
      <t-button size="small" theme="primary" bind:tap="onManageCategories" shape="round">分类管理</t-button>
    </view>

    <view class="search-wrap">
      <t-search value="{{searchKeyword}}" placeholder="搜索菜品名称" bind:change="onSearchChange" bind:submit="onSearchSubmit" center />
    </view>

    <t-tabs value="{{currentCategoryId}}" bind:change="onTabChange" t-class="tabs-container">
      <t-tab-panel label="全部" value="{{0}}" />
      <t-tab-panel wx:for="{{categories || []}}" wx:key="id" label="{{item.name}}" value="{{item.id}}" />
    </t-tabs>

    <view class="list-section">
      <view wx:if="{{refreshErrorMessage}}" class="inline-banner inline-banner-danger">
        <text class="inline-banner-text">{{refreshErrorMessage}}</text>
        <text class="inline-banner-action" bindtap="onRetryRefresh">重新同步</text>
      </view>

      <view wx:if="{{loading && !dishes.length}}" class="loading-state">
        <t-loading theme="circular" size="40rpx" text="加载中..." vertical />
      </view>

      <t-empty wx:elif="{{!loading && !dishes.length}}" icon="info-circle" description="{{searchKeyword ? '未找到匹配菜品' : '暂无菜品'}}" />

      <block wx:else>
        <t-swipe-cell wx:for="{{dishes || []}}" wx:key="id">
          <view class="dish-item" bindtap="onEditDish" data-id="{{item.id}}">
            <view class="dish-main">
              <image class="dish-img" src="{{item.image_url || '/assets/icons/empty.svg'}}" mode="aspectFill" binderror="onDishImageError" data-id="{{item.id}}" />
              <view class="dish-info">
                <view class="dish-name-row">
                  <text class="dish-name">{{item.name}}</text>
                  <t-tag wx:if="{{!item.is_online}}" theme="danger" variant="dark" size="extra-small">已下架</t-tag>
                </view>
                <view class="dish-desc">{{item.description || '暂无描述'}}</view>
                <view class="dish-price-row">
                  <text class="price-unit">¥</text>
                  <text class="price-value">{{item.price / 100}}</text>
                  <text wx:if="{{item.member_price}}" class="member-price">会员价 ¥{{item.member_price / 100}}</text>
                </view>
              </view>
            </view>

            <view class="dish-status-toggle" catchtap="onToggleStatus" data-id="{{item.id}}" data-online="{{item.is_online}}">
              <text class="toggle-label">{{item.is_online ? '上架中' : '已下架'}}</text>
              <t-switch value="{{item.is_online}}" size="small" />
            </view>
          </view>

          <view slot="right" class="swipe-action-wrap">
            <view class="action-btn delete-btn" bindtap="onDeleteDish" data-id="{{item.id}}">删除</view>
          </view>
        </t-swipe-cell>
      </block>

      <view wx:if="{{hasMore && !searchKeyword}}" class="load-more" bindtap="onLoadMore">
        <t-loading wx:if="{{loading}}" theme="dots" size="32rpx" />
        <text wx:else>加载更多</text>
      </view>
    </view>
  </block>

  <!-- 悬浮添加按钮 -->
  <t-fab icon="add" bind:click="onAddDish" />
</view>

<!-- 删除确认 -->
<t-dialog id="t-dialog" />
