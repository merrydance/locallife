<!-- 菜品管理 - 桌面级 SaaS 界面 -->

<!-- WXS 模块 - 处理数组操作 -->
<wxs module="utils">
  module.exports = {
    contains: function(arr, id) {
      if (!arr || !arr.length) return false;
      for (var i = 0; i < arr.length; i++) {
        if (arr[i] === id) return true;
      }
      return false;
    }
  }
</wxs>

<match-media max-width="1599">
  <view class="desktop-only-notice">
    <view class="notice-box">
      <view class="notice-icon">🖥️</view>
      <text class="notice-title">此功能需要在电脑端使用</text>
      <text class="notice-desc">请使用 1600px 以上分辨率的显示器访问菜品管理</text>
      <button class="btn-back" bindtap="goBack">返回工作台</button>
    </view>
  </view>
</match-media>

<match-media min-width="1600">
  <view class="saas-layout">
    <!-- 侧边栏 -->

    <!-- 主区域 -->
    <view class="main-area" style="margin-left: 0;">
      <!-- 顶部栏 -->
      <merchant-header 
        merchant-name="{{merchantName}}"
        is-open="{{isOpen}}"
      />

      <!-- 页面内容 -->
      <view class="page-container">
        <!-- 左侧分类导航 -->
        <view class="category-nav">
          <view class="nav-header">
            <text class="nav-title">菜品分类</text>
            <view class="btn-add-category" bindtap="onOpenCategoryManager">⚙️</view>
          </view>
          <scroll-view class="nav-list" scroll-y>
            <view 
              wx:for="{{categories}}" 
              wx:key="id" 
              class="nav-item {{activeCategoryId === item.id ? 'active' : ''}}"
              bindtap="onCategoryChange"
              data-id="{{item.id}}"
            >
              <text class="nav-label">{{item.name}}</text>
              <text class="nav-count" wx:if="{{item.dish_count}}">{{item.dish_count}}</text>
            </view>
          </scroll-view>
        </view>

        <!-- 右侧内容区 -->
        <view class="content-area">
          <!-- 工具栏 -->
          <view class="toolbar">
            <view class="search-box">
              <input 
                class="search-input" 
                placeholder="搜索菜品名称..." 
                value="{{searchKeyword}}"
                bindinput="onSearch"
              />
            </view>
            <view class="toolbar-actions">
              <button 
                class="btn-secondary {{isMultiSelectMode ? 'active' : ''}}" 
                bindtap="onToggleMultiSelect"
              >
                {{isMultiSelectMode ? '取消多选' : '批量操作'}}
              </button>
              <button class="btn-primary" bindtap="onAddDish">+ 添加菜品</button>
            </view>
          </view>

          <!-- 菜品列表 -->
          <view class="dishes-content">
            <!-- 左侧菜品列表 -->
            <view class="dishes-list">
              <view wx:if="{{loading}}" class="loading-state">
                <text>加载中...</text>
              </view>
              <view wx:elif="{{dishes.length === 0}}" class="empty-state">
                <text class="empty-icon">🍽️</text>
                <text class="empty-text">暂无菜品</text>
              </view>
              <scroll-view wx:else class="dish-scroll" scroll-y>
                <view 
                  wx:for="{{dishes}}" 
                  wx:key="id" 
                  class="dish-card {{selectedDishId === item.id ? 'selected' : ''}} {{isMultiSelectMode && utils.contains(selectedDishIds, item.id) ? 'checked' : ''}}"
                  bindtap="onDishTap"
                  data-item="{{item}}"
                  data-id="{{item.id}}"
                >
                  <!-- 多选复选框 -->
                  <view wx:if="{{isMultiSelectMode}}" class="dish-checkbox">
                    <view class="checkbox {{utils.contains(selectedDishIds, item.id) ? 'checked' : ''}}">
                      <text wx:if="{{utils.contains(selectedDishIds, item.id)}}">✓</text>
                    </view>
                  </view>
                  <image 
                    class="dish-image" 
                    src="{{item.image_url || '/assets/images/dish-placeholder.png'}}" 
                    mode="aspectFill"
                  />
                  <view class="dish-info">
                    <view class="dish-name-row">
                      <text class="dish-name">{{item.name}}</text>
                      <view class="dish-status {{item.is_online ? 'online' : 'offline'}}">
                        {{item.is_online ? '在售' : '下架'}}
                      </view>
                    </view>
                    <view class="dish-meta">
                      <text class="dish-price">¥{{item.priceDisplay}}</text>
                      <text class="dish-category" wx:if="{{item.category_name}}">{{item.category_name}}</text>
                    </view>
                  </view>
                </view>
              </scroll-view>

              <!-- 批量操作工具栏 -->
              <view wx:if="{{isMultiSelectMode}}" class="batch-toolbar">
                <view class="batch-info">
                  <text>已选 {{selectedDishIds.length}} 项</text>
                  <text class="batch-select-all" bindtap="onSelectAll">
                    {{selectedDishIds.length === dishes.length ? '取消全选' : '全选'}}
                  </text>
                </view>
                <view class="batch-actions">
                  <button 
                    class="btn-batch online" 
                    bindtap="onBatchOnline" 
                    disabled="{{selectedDishIds.length === 0}}"
                  >
                    批量上架
                  </button>
                  <button 
                    class="btn-batch offline" 
                    bindtap="onBatchOffline" 
                    disabled="{{selectedDishIds.length === 0}}"
                  >
                    批量下架
                  </button>
                </view>
              </view>
            </view>

            <!-- 右侧编辑面板 -->
            <view class="editor-panel">
              <view wx:if="{{!selectedDish && !isAdding}}" class="editor-placeholder">
                <text class="placeholder-icon">👆</text>
                <text class="placeholder-text">选择菜品进行编辑</text>
              </view>

              <view wx:else class="editor-content">
                <view class="editor-header">
                  <text class="editor-title">{{isAdding ? '添加菜品' : '编辑菜品'}}</text>
                  <view class="editor-actions">
                    <button class="btn-cancel" bindtap="onCancelEdit">取消</button>
                    <button class="btn-save" bindtap="onSaveDish" disabled="{{saving}}">
                      {{saving ? '保存中...' : '保存'}}
                    </button>
                  </view>
                </view>

                <view class="editor-form">
                  <!-- 基本信息 -->
                  <view class="form-section">
                    <view class="section-title">基本信息</view>
                    
                    <view class="form-group">
                      <label class="form-label">菜品名称 <text class="required">*</text></label>
                      <input 
                        class="form-input" 
                        placeholder="请输入菜品名称" 
                        value="{{selectedDish.name}}"
                        data-field="name"
                        bindinput="onFieldChange"
                      />
                    </view>

                    <view class="form-group">
                      <label class="form-label">所属分类</label>
                      <view class="custom-select" bindtap="onToggleCategoryDropdown">
                        <view class="select-value {{selectedDish.category_name ? '' : 'placeholder'}}">
                          {{selectedDish.category_name || '请选择分类'}}
                        </view>
                        <text class="select-arrow {{showCategoryDropdown ? 'open' : ''}}">▼</text>
                        <!-- 下拉选项列表 -->
                        <view class="select-dropdown {{showCategoryDropdown ? 'visible' : ''}}" catchtap="stopPropagation">
                          <view 
                            class="select-option {{item.id === selectedDish.category_id ? 'selected' : ''}}"
                            wx:for="{{categoryOptions}}"
                            wx:key="id"
                            data-item="{{item}}"
                            catchtap="onSelectCategory"
                          >
                            {{item.name}}
                          </view>
                          <view class="select-option empty" wx:if="{{categoryOptions.length === 0}}">
                            暂无分类
                          </view>
                        </view>
                      </view>
                    </view>

                    <view class="form-group">
                      <label class="form-label">菜品图片</label>
                      <view class="image-upload" bindtap="onUploadImage">
                        <image 
                          wx:if="{{selectedDish.image_url_display || selectedDish.image_url}}" 
                          class="upload-preview" 
                          src="{{selectedDish.image_url_display || selectedDish.image_url}}" 
                          mode="aspectFill"
                        />
                        <view wx:else class="upload-placeholder">
                          <text class="upload-icon">📷</text>
                          <text class="upload-text">点击上传</text>
                        </view>
                      </view>
                    </view>

                    <view class="form-group">
                      <label class="form-label">菜品描述</label>
                      <textarea 
                        class="form-textarea" 
                        placeholder="请输入菜品描述（选填）" 
                        value="{{selectedDish.description}}"
                        data-field="description"
                        bindinput="onFieldChange"
                        maxlength="500"
                      />
                    </view>
                  </view>

                  <!-- 价格设置 -->
                  <view class="form-section">
                    <view class="section-title">价格设置</view>
                    
                    <view class="form-row">
                      <view class="form-group flex-1">
                        <label class="form-label">售价 (元) <text class="required">*</text></label>
                        <input 
                          class="form-input" 
                          type="digit" 
                          placeholder="0.00" 
                          value="{{selectedDish.price ? selectedDish.price / 100 : ''}}"
                          data-field="price"
                          bindinput="onPriceFieldChange"
                        />
                      </view>
                      <view class="form-group flex-1">
                        <label class="form-label">会员价 (元)</label>
                        <input 
                          class="form-input" 
                          type="digit" 
                          placeholder="0.00" 
                          value="{{selectedDish.member_price ? selectedDish.member_price / 100 : ''}}"
                          data-field="member_price"
                          bindinput="onPriceFieldChange"
                        />
                      </view>
                    </view>
                  </view>

                  <!-- 属性标签 -->
                  <view class="form-section">
                    <view class="section-header">
                      <view class="section-title">属性标签</view>
                      <view class="section-action" bindtap="onOpenTagManager" data-type="dish">管理</view>
                    </view>
                    <view class="tags-container">
                      <view 
                        wx:for="{{availableTags}}" 
                        wx:key="id" 
                        class="tag-item {{utils.contains(selectedTagIds, item.id) ? 'selected' : ''}}"
                        bindtap="onTagToggle"
                        data-id="{{item.id}}"
                      >
                        <text class="tag-name">{{item.name}}</text>
                        <text class="tag-check" wx:if="{{utils.contains(selectedTagIds, item.id)}}">✓</text>
                      </view>
                      <view wx:if="{{availableTags.length === 0}}" class="tags-empty">
                        <text>暂无可用标签</text>
                      </view>
                    </view>
                  </view>

                  <!-- 定制分组 -->
                  <view class="form-section">
                    <view class="section-header">
                      <view class="section-title">定制分组 <text class="section-hint">(支持多分组/必选)</text></view>
                      <view class="section-action" bindtap="onAddCustomizationGroup">新增分组</view>
                      <view class="section-action" bindtap="onOpenTagManager" data-type="customization">管理标签</view>
                    </view>

                    <view wx:if="{{customizationGroupsDraft.length === 0}}" class="tags-empty">
                      <text>暂无分组，请先新增</text>
                    </view>

                    <view class="customization-groups">
                      <view wx:for="{{customizationGroupsDraft}}" wx:key="index" wx:for-item="group" wx:for-index="index" class="customization-group">
                        <view class="group-header">
                          <input class="group-name-input" placeholder="分组名称" value="{{group.name}}" data-index="{{index}}" bindinput="onCustomizationGroupNameInput" />
                          <view class="group-required">
                            <text>必选</text>
                            <switch checked="{{group.is_required}}" data-index="{{index}}" bindchange="onCustomizationGroupRequiredChange" />
                          </view>
                          <view class="group-actions">
                            <view class="group-toggle {{activeCustomizationGroupIndex === index ? 'active' : ''}}" bindtap="onSelectCustomizationGroup" data-index="{{index}}">编辑</view>
                            <view class="group-delete" bindtap="onRemoveCustomizationGroup" data-index="{{index}}">×</view>
                          </view>
                        </view>

                        <view wx:if="{{activeCustomizationGroupIndex === index}}">
                          <view class="tags-container">
                            <view 
                              wx:for="{{customizationTags}}" 
                              wx:key="id" 
                              wx:for-item="tag"
                              class="tag-item customization {{utils.contains(group.tag_ids, tag.id) ? 'selected' : ''}}"
                              bindtap="onCustomizationTagToggle"
                              data-id="{{tag.id}}"
                              data-name="{{tag.name}}"
                            >
                              <text class="tag-name">{{tag.name}}</text>
                              <text class="tag-check" wx:if="{{utils.contains(group.tag_ids, tag.id)}}">✓</text>
                            </view>
                            <view wx:if="{{customizationTags.length === 0}}" class="tags-empty">
                              <text>暂无定制标签</text>
                            </view>
                          </view>

                          <view wx:if="{{group.options.length > 0}}" class="group-options">
                            <view wx:for="{{group.options}}" wx:key="tag_id" wx:for-item="opt" class="option-item">
                              <text class="option-name">{{opt.tag_name}}</text>
                              <input 
                                class="option-price-input" 
                                type="digit"
                                placeholder="0"
                                value="{{opt.extra_price ? opt.extra_price / 100 : ''}}"
                                data-tag-id="{{opt.tag_id}}"
                                data-group-index="{{index}}"
                                bindinput="onCustomizationPriceChange"
                              />
                            </view>
                          </view>
                        </view>
                      </view>
                    </view>
                  </view>

                  <!-- 状态设置 -->
                  <view class="form-section">
                    <view class="section-title">状态设置</view>
                    
                    <view class="form-group horizontal">
                      <label class="form-label">上架销售</label>
                      <view 
                        class="toggle {{selectedDish.is_online ? 'on' : ''}}" 
                        bindtap="onToggleOnline"
                      >
                        <view class="toggle-handle"></view>
                      </view>
                    </view>
                  </view>

                  <!-- 删除按钮 -->
                  <view wx:if="{{!isAdding && selectedDish.id}}" class="form-section">
                    <button class="btn-danger" bindtap="onDeleteDish">删除此菜品</button>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</match-media>

<!-- 分类管理弹窗 -->
<view class="modal-mask {{showCategoryManager ? 'visible' : ''}}" bindtap="onCloseCategoryManager"></view>
<view class="modal-panel {{showCategoryManager ? 'visible' : ''}}" catchtap="">
  <view class="modal-header">
    <text class="modal-title">分类管理</text>
    <view class="modal-close" bindtap="onCloseCategoryManager">✕</view>
  </view>
  <view class="modal-body">
    <!-- 添加分类 -->
    <view class="add-category-box">
      <input 
        class="form-input" 
        placeholder="输入新分类名称" 
        value="{{newCategoryName}}"
        bindinput="onNewCategoryNameChange"
      />
      <button class="btn-primary" bindtap="onConfirmAddCategory">添加</button>
    </view>
    
    <!-- 分类列表 -->
    <view class="category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="id" 
        wx:if="{{item.id !== 'all'}}"
        class="category-item"
      >
        <text class="category-name">{{item.name}}</text>
        <view class="category-actions">
          <text class="btn-delete" bindtap="onDeleteCategory" data-id="{{item.id}}" data-name="{{item.name}}">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 分类选择弹窗 -->
<view class="modal-mask {{showCategorySelector ? 'visible' : ''}}" bindtap="onCloseCategorySelector"></view>
<view class="modal-panel small {{showCategorySelector ? 'visible' : ''}}" catchtap="">
  <view class="modal-header">
    <text class="modal-title">选择分类</text>
    <view class="modal-close" bindtap="onCloseCategorySelector">✕</view>
  </view>
  <view class="modal-body">
    <view 
      wx:for="{{categories}}" 
      wx:key="id" 
      wx:if="{{item.id !== 'all'}}"
      class="select-item"
      bindtap="onSelectCategory"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
    >
      {{item.name}}
    </view>
  </view>
</view>

<!-- 标签管理弹窗 -->
<view class="modal-mask {{showTagManager ? 'visible' : ''}}" bindtap="onCloseTagManager"></view>
<view class="modal-panel {{showTagManager ? 'visible' : ''}}" catchtap="">
  <view class="modal-header">
    <text class="modal-title">{{tagManagerType === 'dish' ? '属性标签管理' : '定制标签管理'}}</text>
    <view class="modal-close" bindtap="onCloseTagManager">✕</view>
  </view>
  <view class="modal-body">
    <view class="add-tag-row">
      <input 
        class="tag-input" 
        placeholder="输入新标签名称" 
        value="{{newTagName}}"
        bindinput="onNewTagNameInput"
      />
      <button class="btn-primary btn-small" bindtap="onAddTag">添加</button>
    </view>
    <view class="tag-list">
      <view 
        wx:for="{{tagManagerType === 'dish' ? availableTags : customizationTags}}" 
        wx:key="id"
        class="tag-list-item"
      >
        <text class="tag-list-name">{{item.name}}</text>
        <text class="tag-list-delete" bindtap="onDeleteTag" data-id="{{item.id}}" data-name="{{item.name}}">删除</text>
      </view>
      <view wx:if="{{tagManagerType === 'dish' && availableTags.length === 0}}" class="tag-list-empty">
        暂无标签，请添加
      </view>
      <view wx:if="{{tagManagerType === 'customization' && customizationTags.length === 0}}" class="tag-list-empty">
        暂无标签，请添加
      </view>
    </view>
  </view>
</view>
