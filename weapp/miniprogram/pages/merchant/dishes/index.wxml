<custom-navbar title="菜品管理" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载菜品中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '菜品加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <t-sticky offset-top="{{navBarHeight}}" z-index="40">
        <view class="control-panel">
          <view class="tabs-shell tabs-shell--top">
            <t-tabs value="{{currentCategoryId}}" bind:change="onTabChange">
              <t-tab-panel label="全部" value="{{0}}" />
              <t-tab-panel wx:for="{{categories || []}}" wx:key="id" label="{{item.name}}" value="{{item.id}}" />
            </t-tabs>
          </view>

          <view class="filter-panel">
            <view class="filter-block">
              <text class="filter-label">上架状态</text>
              <view class="filter-tags">
                <t-check-tag
                  wx:for="{{onlineFilterOptions}}"
                  wx:key="value"
                  checked="{{currentOnlineFilter === item.value}}"
                  content="{{item.label}}"
                  size="small"
                  shape="round"
                  data-value="{{item.value}}"
                  bind:change="onOnlineFilterChange"
                />
              </view>
            </view>
          </view>
        </view>
      </t-sticky>

      <view class="result-bar">
        <text class="result-summary">{{resultSummaryText}}</text>
      </view>

      <view wx:if="{{loading && !dishes.length}}" class="loading-state">
        <t-loading theme="circular" size="40rpx" text="加载中..." vertical />
      </view>

      <t-empty wx:elif="{{!loading && !dishes.length}}" icon="info-circle" description="{{emptyDescription}}" />

      <block wx:else>
        <view class="dish-list">
          <block wx:for="{{dishes}}" wx:key="id">
            <t-cell-group class="dish-card">
              <view class="dish-card-main" bindtap="onDishCardTap" data-id="{{item.id}}">
                <t-image
                  t-class="dish-cover"
                  src="{{item.image_url || '/assets/icons/empty.svg'}}"
                  mode="aspectFill"
                  width="100%"
                  height="280rpx"
                  shape="square"
                  bind:error="onDishImageError"
                  data-id="{{item.id}}"
                />

                <view class="dish-content">
                  <view class="dish-header">
                    <view class="dish-header-main">
                      <text class="dish-name">{{item.name}}</text>
                      <text class="dish-desc">{{item.description || '暂无描述'}}</text>
                    </view>
                    <view class="dish-switch-wrap" catchtap="onActionsCatch">
                      <t-switch
                        value="{{item.is_online}}"
                        label="{{onlineSwitchLabels}}"
                        size="small"
                        loading="{{item.statusPending}}"
                        disabled="{{item.deletePending || item.is_packaging}}"
                        bind:change="onSwitchStatusChange"
                        data-id="{{item.id}}"
                      />
                    </view>
                  </view>

                  <view class="dish-meta-row">
                    <view class="dish-price-row">
                      <text class="price-value">¥{{item.price / 100}}</text>
                      <t-tag wx:if="{{item.member_price}}" theme="warning" variant="dark" size="small">会员价 ¥{{item.member_price / 100}}</t-tag>
                      <t-tag wx:if="{{item.is_packaging}}" theme="primary" variant="light" size="small">包装</t-tag>
                    </view>
                    <view wx:if="{{item.category_name}}" class="dish-category-row">
                      <t-tag theme="default" variant="light" size="small">{{item.category_name}}</t-tag>
                    </view>
                  </view>
                </view>
              </view>

              <t-divider />

              <view class="dish-action-bar" catchtap="onActionsCatch">
                <view class="dish-action-slot">
                  <t-button class="dish-action-button" variant="text" theme="default" size="small" bind:tap="onDishCardTap" data-id="{{item.id}}">编辑</t-button>
                </view>
                <t-divider layout="vertical" />
                <view class="dish-action-slot">
                  <t-button
                    class="dish-action-button"
                    variant="text"
                    theme="danger"
                    size="small"
                    loading="{{item.deletePending}}"
                    disabled="{{item.deletePending || item.statusPending}}"
                    bind:tap="onRequestDeleteDish"
                    data-id="{{item.id}}"
                  >删除</t-button>
                </view>
              </view>
            </t-cell-group>
          </block>
        </view>

        <view wx:if="{{loading && dishes.length}}" class="load-more">
          <t-loading theme="dots" size="32rpx" text="加载更多菜品中..." />
        </view>

        <view wx:elif="{{!hasMore && dishes.length > 0}}" class="list-end">
          <text class="list-end__text">已加载全部菜品，共 {{dishes.length}} 项</text>
        </view>
      </block>
    </view>
  </block>

  <t-dialog
    visible="{{deleteDialogVisible}}"
    title="确认删除菜品"
    using-custom-navbar="{{true}}"
    confirm-btn="{{ { content: '确认删除', theme: 'danger', loading: deleteDialogSubmitting } }}"
    cancel-btn="取消"
    bind:confirm="onConfirmDeleteDish"
    bind:cancel="onCancelDeleteDialog"
    bind:close="onCancelDeleteDialog"
  >
    <view slot="content" class="dialog-content">
      <text>删除后无法恢复，确定要删除“{{deleteDialogDishName}}”吗？</text>
    </view>
  </t-dialog>

  <t-fab icon="add" bind:click="onAddDish" />
</view>