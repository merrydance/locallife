.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: calc(96rpx + var(--safe-area-bottom));
}

.page-content {
  padding-top: var(--spacer-md);
  padding-bottom: 0;
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.list-section,
.category-row,
.popup-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.notice-banner {
  margin-bottom: 0;
}

.action-strip {
  padding: var(--spacer-md);
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.notice-banner-operation {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.list-section {
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.list-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.list-title {
  display: block;
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.section-empty,
.popup-empty {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.category-row {
  padding: var(--spacer-md);
}

.category-row-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-md);
}

.category-row-copy {
  flex: 1;
  min-width: 0;
}

.category-name {
  display: block;
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.category-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 8rpx;
}

.category-meta {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.category-actions {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.popup-panel {
  padding: var(--spacer-md);
  padding-bottom: var(--popup-bottom-padding-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.popup-copy {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.popup-title {
  font-size: var(--font-size-heading);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.popup-hint {
  font-size: var(--font-size-sm);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
}

.popup-body {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.popup-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--spacer-sm);
}

@media (max-width: 420px) {
  .popup-actions {
    grid-template-columns: 1fr;
  }

  .action-strip,
  .list-header,
  .category-row-main,
  .category-actions {
    align-items: flex-start;
    flex-direction: column;
  }
}