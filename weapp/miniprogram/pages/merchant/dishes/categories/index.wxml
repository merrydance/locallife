<custom-navbar title="菜品分类管理" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view class="page-tip">点击右下角 + 通过下拉选择已有分类并关联，或在右侧直接新增分类。</view>

  <view wx:if="{{loading && !categories.length}}" class="loading-state">
    <t-loading theme="circular" text="加载分类中..." vertical />
  </view>

  <t-empty wx:elif="{{!loading && !categories.length}}" icon="info-circle" description="暂无分类，请先创建" />

  <view wx:else class="category-list">
    <view class="category-card" wx:for="{{categories}}" wx:key="id" bindtap="onEditCategory" data-id="{{item.id}}" data-name="{{item.name}}">
      <view class="category-main">
        <text class="category-name">{{item.name}}</text>
      </view>
      <view class="category-actions">
        <t-button size="small" variant="text" theme="danger" shape="round" data-id="{{item.id}}" catch:tap="onDeleteCategory">删除</t-button>
      </view>
    </view>
  </view>

  <t-fab icon="add" bind:click="onAddCategory" />

  <t-popup
    visible="{{addPopupVisible}}"
    placement="bottom"
    bind:visible-change="onCloseAddPopup"
  >
    <view class="add-popup">
      <view class="popup-title">添加分类</view>

      <view class="picker-row">
        <view class="picker-trigger" bind:tap="onOpenPicker">
          <text class="picker-text">{{selectedCategoryName || '请选择已有分类'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
        <t-button size="small" theme="primary" shape="round" bind:tap="onCreateCategory">
          新增分类
        </t-button>
      </view>

      <view class="popup-actions">
        <t-button size="small" theme="default" shape="round" bind:tap="onCloseAddPopup">取消</t-button>
        <t-button size="small" theme="primary" shape="round" loading="{{submitting}}" bind:tap="onConfirmLinkCategory">关联分类</t-button>
      </view>
    </view>
  </t-popup>

  <t-picker
    visible="{{pickerVisible}}"
    value="{{[selectedCategoryId || (pickerOptions.length ? pickerOptions[0].value : '')]}}"
    title="选择已有分类"
    bind:confirm="onPickerConfirm"
    bind:cancel="onPickerCancel"
  >
    <t-picker-item options="{{pickerOptions}}" />
  </t-picker>
</view>
