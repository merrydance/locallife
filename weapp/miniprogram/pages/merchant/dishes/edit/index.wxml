<custom-navbar title="{{isEdit ? '编辑菜品' : '新增菜品'}}" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view class="form-shell">
    <view class="card">
      <view class="section-title">菜品图片</view>
      <t-upload
        mediaType="{{['image']}}"
        max="{{1}}"
        files="{{fileList}}"
        gridConfig="{{ { column: 1 } }}"
        bind:add="onImageAdd"
        bind:remove="onImageRemove"
        bind:preview="onImagePreview"
      />
      <view class="helper-text">建议上传 1:1 或 4:3 图片，上传后可点击预览</view>
      <view wx:if="{{imageUploading}}" class="uploading-row">
        <t-loading theme="dots" size="28rpx" />
        <text class="uploading-text">图片上传中...</text>
      </view>
    </view>

    <view class="card">
      <view class="section-title">基础信息</view>
      <t-cell-group theme="card">
        <t-input
          label="菜品名称"
          placeholder="请输入菜品名称"
          value="{{formData.name}}"
          bind:change="onInputChange"
          data-field="name"
          required
        />

        <t-cell title="菜品分类" arrow bind:tap="showCategoryPicker" note="{{selectedCategoryName || '请选择分类'}}" />

        <t-input
          label="价格(元)"
          type="digit"
          placeholder="0.00"
          value="{{displayPrice}}"
          bind:change="onPriceChange"
          required
        />

        <t-input
          label="会员价(元)"
          type="digit"
          placeholder="可选"
          value="{{displayMemberPrice}}"
          bind:change="onMemberPriceChange"
        />
      </t-cell-group>
    </view>

    <view class="card">
      <view class="section-title">详情描述</view>
      <t-textarea
        placeholder="请输入菜品详细介绍..."
        value="{{formData.description}}"
        bind:change="onInputChange"
        data-field="description"
        bordered
        maxlength="200"
        indicator
      />
    </view>

    <view class="card">
      <view class="section-title">售卖设置</view>
      <t-cell-group theme="card">
        <t-cell title="是否上架">
          <t-switch
            slot="note"
            value="{{formData.is_online}}"
            bind:change="onSwitchChange"
            data-field="is_online"
          />
        </t-cell>
        <t-cell title="库存储备可用">
          <t-switch
            slot="note"
            value="{{formData.is_available}}"
            bind:change="onSwitchChange"
            data-field="is_available"
          />
        </t-cell>
        <t-input
          label="预估出餐(分)"
          type="number"
          placeholder="15"
          value="{{formData.prepare_time}}"
          bind:change="onInputChange"
          data-field="prepare_time"
        />
      </t-cell-group>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="footer-bar {{isIPhoneX ? 'iphone-x' : ''}}">
    <t-button block size="large" shape="round" theme="primary" loading="{{submitting}}" bind:tap="onSubmit">
      保存提交
    </t-button>
  </view>

  <!-- 分类选择器 -->
  <t-picker
    visible="{{categoryVisible}}"
    value="{{[selectedCategoryValue || (categoryOptions.length ? categoryOptions[0].value : '')]}}"
    title="选择菜品分类"
    cancelBtn="取消"
    confirmBtn="确定"
    bind:confirm="onCategoryConfirm"
    bind:cancel="onCategoryCancel"
  >
    <t-picker-item options="{{categoryOptions}}" />
  </t-picker>
</view>
