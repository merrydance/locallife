<custom-navbar title="{{isEdit ? '编辑菜品' : '新增菜品'}}" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载菜品编辑信息中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '菜品编辑页加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重试</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <view wx:if="{{loadWarningMessage}}" class="notice-banner">
        <t-notice-bar theme="warning" visible="{{true}}" content="{{loadWarningMessage}}" />
      </view>

      <view class="section-panel">
        <view class="section-top">
          <text class="section-title">基础信息</text>
        </view>

        <view class="cover-field">
          <text class="cover-title">菜品封面</text>
          <t-upload
            mediaType="{{['image']}}"
            max="{{1}}"
            files="{{fileList}}"
            gridConfig="{{ { column: 1, width: 240, height: 240 } }}"
            bind:add="onImageAdd"
            bind:remove="onImageRemove"
            bind:preview="onImagePreview"
          />
          <view wx:if="{{imageUploading}}" class="uploading-row">
            <t-loading theme="dots" size="28rpx" />
            <text class="uploading-text">图片上传中...</text>
          </view>
        </view>

        <t-cell-group theme="card">
          <t-cell required title="菜品名称">
            <t-input
              slot="note"
              value="{{formData.name}}"
              bind:change="onInputChange"
              data-field="name"
              borderless
              align="right"
            />
          </t-cell>

          <view class="field-action-row">
            <view class="field-action-main">
              <t-cell title="菜品分类" arrow bind:tap="showCategoryPicker" note="{{selectedCategoryName || (categoryOptions.length ? '请选择分类' : '请先创建分类')}}" />
            </view>
            <t-button size="small" theme="primary" icon="add" loading="{{categoryCreateSubmitting}}" bind:tap="onManageCategories">管理分类</t-button>
          </view>

          <text wx:if="{{!categoryOptions.length}}" class="section-caption">{{formData.category_id ? '当前分类不可调整' : '当前还没有可选分类'}}</text>

          <t-cell required title="价格">
            <t-input
              slot="note"
              type="digit"
              suffix="元"
              placeholder="0.00"
              value="{{displayPrice}}"
              bind:change="onPriceChange"
              borderless
              align="right"
            />
          </t-cell>

          <t-input
            label="会员价(元)"
            type="digit"
            placeholder="{{isEdit ? '留空则清除会员价' : '可选'}}"
            value="{{displayMemberPrice}}"
            bind:change="onMemberPriceChange"
          />
        </t-cell-group>

        <t-textarea
          placeholder="介绍口味、分量或推荐搭配"
          value="{{formData.description}}"
          bind:change="onInputChange"
          data-field="description"
          bordered
          maxlength="200"
          indicator
        />
      </view>

      <view class="section-panel">
        <view class="section-top">
          <text class="section-title">售卖与展示</text>
        </view>

        <t-cell-group theme="card">
          <t-cell title="包装菜品" description="{{formData.is_packaging ? '当前会固定用于外卖与自取包装方式选择，并保持上架、可售' : '开启后，该菜品会作为包装方式参与外卖与自取下单校验'}}">
            <t-switch slot="note" value="{{formData.is_packaging}}" bind:change="onSwitchChange" data-field="is_packaging" />
          </t-cell>
          <t-cell title="是否上架">
            <t-switch slot="note" value="{{formData.is_online}}" disabled="{{formData.is_packaging}}" bind:change="onSwitchChange" data-field="is_online" />
          </t-cell>
          <t-input
            label="预估出餐"
            suffix="分钟"
            type="number"
            placeholder="15"
            value="{{formData.prepare_time}}"
            bind:change="onInputChange"
            data-field="prepare_time"
            align="right"
          />
          <t-cell title="推荐标签">
            <t-switch slot="note" value="{{isFeatured}}" bind:change="onFeaturedTagToggle" data-tag="推荐" />
          </t-cell>
          <t-cell title="热卖标签">
            <t-switch slot="note" value="{{isHotSelling}}" bind:change="onFeaturedTagToggle" data-tag="热卖" />
          </t-cell>
        </t-cell-group>

      </view>

      <view class="section-panel">
        <view class="section-top-action">
          <view class="section-top-main">
            <text class="section-title">普通标签</text>
            <text wx:if="{{availableDishTags.length}}" class="section-caption">已选 {{selectedDishTagIds.length}} 个</text>
          </view>
          <view class="section-top-button">
            <t-button size="small" theme="primary" icon="add" bind:tap="onCreateDishTag" loading="{{tagSubmitting}}">新增标签</t-button>
          </view>
        </view>

        <view wx:if="{{availableDishTags.length}}" class="tag-check-list">
          <t-check-tag
            wx:for="{{availableDishTags}}"
            wx:key="id"
            checked="{{selectedDishTagState[item.id]}}"
            content="{{item.name}}"
            shape="round"
            data-tag-id="{{item.id}}"
            bind:change="onDishTagToggle"
          />
        </view>

        <view wx:else class="tag-empty-text">暂无普通菜品标签，可先新增标签。</view>
      </view>

      <view class="section-panel">
        <view class="section-top-action">
          <view class="section-top-main">
            <text class="section-title">规格与加价</text>
            <text wx:if="{{customizationGroups.length}}" class="section-caption">默认必选，共 {{customizationGroups.length}} 组</text>
          </view>
          <view class="section-top-button">
            <t-button size="small" theme="primary" icon="add" bind:tap="onAddCustomizationGroup">新增规格组</t-button>
          </view>
        </view>

        <customization-editor id="customizationEditor" value="{{customizationGroups}}" bind:change="onCustomizationGroupsChange" />
    </view>

      <view class="form-actions">
        <t-button theme="primary" loading="{{submitting}}" disabled="{{!categoryOptions.length && !formData.category_id}}" bind:tap="onSubmit">{{isEdit ? '保存菜品' : '创建菜品'}}</t-button>
      </view>
    </view>

    <t-picker
      visible="{{categoryVisible}}"
      value="{{[selectedCategoryValue || (categoryOptions.length ? categoryOptions[0].value : '')]}}"
      title="选择菜品分类"
      cancelBtn="取消"
      confirmBtn="确定"
      bind:confirm="onCategoryConfirm"
      bind:cancel="onCategoryCancel"
    >
      <t-picker-item options="{{categoryOptions}}" />
    </t-picker>

    <t-dialog
      visible="{{createPopupVisible}}"
      title="{{createPopupMode === 'category' ? '新增菜品分类' : '新增菜品标签'}}"
      confirm-btn="{{ { content: '确定', loading: createPopupMode === 'category' ? categoryCreateSubmitting : tagSubmitting } }}"
      cancel-btn="取消"
      bind:confirm="onConfirmCreatePopup"
      bind:cancel="onCloseCreatePopup"
    >
      <view slot="content" class="dialog-form">
          <t-input
            label="{{createPopupMode === 'category' ? '分类名称' : '标签名称'}}"
            value="{{createInputValue}}"
            bind:change="onCreateInputChange"
          />
      </view>
    </t-dialog>

  </block>
</view>
