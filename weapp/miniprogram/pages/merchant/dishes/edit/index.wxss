.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: 220rpx;
}

.form-shell {
  padding: var(--spacer-md);
}

.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
  margin-bottom: var(--spacer-md);
}

.helper-text {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.helper-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-md);
}

.tag-grid {
  margin-top: var(--spacer-md);
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.tag-option {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 56rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-page);
}

.tag-option-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
}

.spec-empty {
  margin-top: var(--spacer-md);
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-page);
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-sm);
}

.spec-group {
  margin-top: var(--spacer-md);
  padding: var(--spacer-md);
  border: 1rpx solid var(--td-border-level-1-color);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-page);
}

.spec-group-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.spec-group-summary {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.spec-group-badge {
  font-size: var(--font-size-xs);
  color: var(--td-brand-color);
  font-weight: 600;
}

.spec-group-meta {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.spec-group-header {
  margin-bottom: var(--spacer-md);
}

.spec-group-name,
.spec-option-name,
.spec-option-price {
  min-height: 80rpx;
  padding: 0 var(--spacer-md);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--td-border-level-1-color);
  background: var(--td-bg-color-container);
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  box-sizing: border-box;
}

.spec-required-toggle {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.spec-required-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.spec-options {
  margin: var(--spacer-md) 0;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.spec-option-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.spec-option-header-title {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.spec-option-header-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.spec-option-empty {
  padding: var(--spacer-md);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-container);
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.spec-submit-hint {
  color: var(--td-warning-color);
}

.spec-option-card {
  padding: var(--spacer-md);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-border-level-1-color);
}

.spec-option-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.spec-option-index {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.spec-option-fields {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 180rpx;
  gap: var(--spacer-sm);
  align-items: center;
}

.spec-group-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  flex-wrap: wrap;
}

.spec-group-note {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.uploading-row {
  margin-top: var(--spacer-sm);
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.uploading-text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--td-bg-color-container);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  z-index: var(--z-index-fixed);
}

.footer-bar.iphone-x {
  padding-bottom: calc(var(--spacer-md) + env(safe-area-inset-bottom));
}

@media (max-width: 420px) {
  .spec-option-fields {
    grid-template-columns: 1fr;
  }

  .spec-group-actions,
  .spec-option-header,
  .spec-group-top,
  .spec-option-card-header {
    align-items: flex-start;
    flex-direction: column;
  }
}
