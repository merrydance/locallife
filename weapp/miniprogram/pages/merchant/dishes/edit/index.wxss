.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}


.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.notice-banner,
.section-panel {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.notice-copy {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.notice-text,
.section-caption {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.notice-card--split {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.notice-title,
.section-title,
.cover-title,
.spec-group-title {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.spec-option-title,
.spec-options-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-panel {
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.section-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-top--split {
  align-items: center;
}

.field-action-row {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: var(--spacer-sm);
}

.field-action-main {
  flex: 1;
  min-width: 0;
}

.section-top-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.section-top-main {
  flex: 1;
  min-width: 0;
}

.section-top-button {
  margin-left: auto;
  flex-shrink: 0;
}

.cover-field {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.uploading-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.uploading-text,
.spec-group-meta {
  font-size: var(--font-size-xs);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
}

.tag-empty-text {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.tag-check-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
}

.dialog-form {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

@media (max-width: 420px) {
  .notice-card--split,
  .section-top {
    align-items: flex-start;
    flex-direction: column;
  }
}
