.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.form-section {
  padding: 32rpx 0;
}

.upload-wrap {
  padding: 32rpx;
  background-color: #fff;
  margin: 0 32rpx 32rpx;
  border-radius: 16rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
  margin-bottom: 24rpx;
}

.textarea-wrap {
  padding: 32rpx;
  background-color: #fff;
}

.card-wrap {
  margin: 0 32rpx 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 24rpx 32rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.footer-bar.iphone-x {
  padding-bottom: 64rpx;
}

.dialog-content {
  padding: 32rpx 0;
}
