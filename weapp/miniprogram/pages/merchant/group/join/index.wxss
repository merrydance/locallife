.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.search-section {
  background: #FFFFFF;
  padding: 24rpx;
  position: sticky;
  z-index: 10;
}

.result-list {
  padding: var(--spacer-md);
}

.request-status-panel {
  margin: var(--spacer-md) var(--spacer-md) 0;
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-md);
  border: 1rpx solid var(--td-component-stroke);
}

.request-status-panel__main {
  min-width: 0;
  flex: 1;
}

.request-status-panel__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.request-status-panel__meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.inline-warning {
  margin: var(--spacer-md) var(--spacer-md) 0;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.inline-warning__text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--td-warning-color-8);
}

.status-loading {
  padding: var(--spacer-md) 0 0;
}

.group-card {
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-sm);
}

.group-info {
  flex: 1;
  margin-right: 24rpx;
}

.group-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.group-addr {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  margin-bottom: 12rpx;
}

.search-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
  color: var(--td-text-color-placeholder);
}

.search-tip text {
  margin-top: 24rpx;
  font-size: 26rpx;
}

.dialog-content {
  padding: 32rpx 0;
}

.input-label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  margin-bottom: 16rpx;
}
