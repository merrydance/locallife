<custom-navbar title="申请加入集团" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="error-circle" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <block wx:elif="{{accessReady}}">
    <view class="search-section" style="top: {{navBarHeight}}px;">
      <t-search
        placeholder="搜索集团或品牌名称"
        bind:change="onSearchChange"
        bind:submit="onSearchSubmit"
        focus
      />
    </view>

    <view class="content">
      <view wx:if="{{pendingJoinRequest}}" class="request-status-panel">
        <view class="request-status-panel__main">
          <view class="request-status-panel__title">{{pendingJoinRequest.groupName}}</view>
          <view class="request-status-panel__meta">提交时间 {{pendingJoinRequest.createdAtText}}</view>
        </view>
        <t-tag size="small" theme="{{pendingJoinRequest.statusTheme}}" variant="light">{{pendingJoinRequest.statusLabel}}</t-tag>
      </view>

      <view wx:if="{{joinRequestsErrorMessage}}" class="inline-warning">
        <view class="inline-warning__text">{{joinRequestsErrorMessage}}</view>
        <t-button theme="primary" variant="text" size="small" bind:tap="onRetryJoinRequests">重新同步</t-button>
      </view>

      <view wx:if="{{joinRequestsLoading}}" class="status-loading">
        <t-loading theme="circular" size="32rpx" text="同步申请状态..." />
      </view>

      <block wx:if="{{loading}}">
        <view class="skeleton-container animate-fade-in">
          <list-skeleton row="3" />
        </view>
      </block>

      <block wx:else>
        <view class="result-list animate-fade-in" wx:if="{{groups.length > 0}}">
          <view class="group-card" wx:for="{{groups}}" wx:key="id">
            <view class="group-info">
              <view class="group-name">{{item.name}}</view>
              <view class="group-addr">地址: {{item.address}}</view>
              <t-tag wx:if="{{item.pending}}" size="small" theme="{{item.statusTheme}}" variant="light">{{item.statusLabel}}</t-tag>
            </view>
            <t-button
              theme="primary"
              size="small"
              bindtap="onApply"
              data-id="{{item.id}}"
              data-name="{{item.name}}"
              shape="round"
              loading="{{item.applying}}"
              disabled="{{item.actionDisabled || applying}}"
            >{{item.actionText}}</t-button>
          </view>
        </view>
        <view class="empty-state" wx:elif="{{searchErrorMessage}}">
          <t-empty icon="error-circle" description="{{searchErrorMessage}}" />
          <t-button theme="primary" bind:tap="onSearchSubmit">重新搜索</t-button>
        </view>
        <view class="empty-state" wx:elif="{{searched && groups.length === 0}}">
          <t-empty icon="search" description="未搜索到相关集团或品牌" />
        </view>
        <view class="search-tip" wx:elif="{{!searched}}">
          <t-icon name="info-circle" size="32rpx" />
          <text>请输入集团或品牌名称全称、简称或关键字进行搜索</text>
        </view>
      </block>
    </view>

    <t-dialog
      visible="{{dialogVisible}}"
      title="申请加入 {{selectedGroupName}}"
      confirm-btn="{{ { content: '确认申请', variant: 'base' } }}"
      cancel-btn="取消"
      bind:confirm="confirmApply"
      bind:cancel="closeDialog"
    >
      <view slot="content" class="dialog-content">
        <view class="input-label">申请备注 (可选)</view>
        <t-textarea
          placeholder="例如：我是 XX 分店的店主"
          bordered
          value="{{applyReason}}"
          bindchange="onReasonChange"
        />
      </view>
    </t-dialog>
  </block>

  <view wx:else class="state-block">
    <t-loading theme="circular" size="40rpx" text="校验商户权限中..." vertical />
  </view>
</view>
