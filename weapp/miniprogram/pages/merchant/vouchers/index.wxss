@import '../../../styles/merchant-config-shared.wxss';

.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(160rpx + var(--safe-area-bottom));
  box-sizing: border-box;
}

.inline-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
}

.inline-banner-danger {
  background: var(--td-error-color-1);
}

.inline-banner-success {
  background: var(--td-success-color-1);
}

.inline-banner-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.inline-banner-action {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.voucher-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.voucher-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.list-footer {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.list-footer-text {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.voucher-card {
  padding: var(--spacer-md);
}

.voucher-header,
.voucher-amount-row,
.voucher-info-row,
.form-item-switch {
  display: flex;
}

.voucher-header,
.voucher-amount-row,
.voucher-info-row,
.form-item-switch {
  justify-content: space-between;
  gap: 16rpx;
}

.voucher-header {
  align-items: flex-start;
}

.voucher-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.voucher-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.voucher-code,
.voucher-desc,
.voucher-info-label,
.voucher-info-value {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.voucher-amount-row {
  align-items: baseline;
  margin-top: 20rpx;
}

.voucher-amount {
  font-size: var(--font-size-display);
  font-weight: 700;
  color: var(--td-brand-color);
}

.voucher-threshold {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.voucher-desc {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.voucher-info-row {
  align-items: flex-start;
  margin-top: 16rpx;
}

.voucher-info-label {
  width: 140rpx;
  flex-shrink: 0;
}

.voucher-info-value {
  flex: 1;
  text-align: right;
  color: var(--td-text-color-primary);
}

.voucher-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.voucher-footer {
  display: flex;
  flex-direction: column;
  margin-top: 20rpx;
  gap: 16rpx;
}

.voucher-action-hint {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-placeholder);
}

.voucher-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.form-item {
  margin-bottom: 24rpx;
}


.form-item-grid {
  display: flex;
  gap: 20rpx;
}


.required {
  color: var(--td-error-color);
}

.order-type-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.order-type-option {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: var(--td-bg-color-secondarycontainer);
  color: var(--td-text-color-secondary);
  font-size: 24rpx;
}

.order-type-option.is-selected {
  background: var(--td-brand-color-light);
  color: var(--td-brand-color);
  font-weight: 600;
}
