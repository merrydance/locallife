<custom-navbar title="代金券管理" showBack="{{true}}" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 32rpx;"
>
  <view wx:if="{{accessReady && accessDenied}}" class="state-block">
    <t-empty icon="lock-on" description="当前账号无商户权限，请返回“我的”切换身份" />
  </view>

  <view wx:elif="{{accessReady && accessErrorMessage}}" class="state-block">
    <t-empty icon="error-circle" description="{{accessErrorMessage}}" />
    <t-button theme="primary" bind:tap="onRetryAccess">重新校验</t-button>
  </view>

  <view wx:elif="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载代金券中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '代金券加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="page-content">
      <view class="result-bar">
        <text class="result-summary">{{resultSummaryText}}</text>
      </view>

      <view wx:if="{{loading && !vouchers.length}}" class="loading-state">
        <t-loading theme="circular" size="40rpx" text="加载代金券中..." vertical />
      </view>

      <t-empty wx:elif="{{!loading && !vouchers.length}}" icon="info-circle" description="{{emptyDescription}}" />

      <view wx:else class="voucher-list">
        <block wx:for="{{vouchers}}" wx:key="id">
          <t-cell-group class="voucher-card">
            <view class="voucher-card-main" bindtap="onEditVoucher" data-id="{{item.id}}">
              <view class="voucher-content">
                <view class="voucher-header">
                  <view class="voucher-header-main">
                    <text class="voucher-name">{{item.name}}</text>
                    <text class="voucher-desc">券码 {{item.code || '自动生成'}}{{item.description ? ' · ' + item.description : ''}}</text>
                  </view>
                  <view class="voucher-switch-wrap" catchtap="onActionsCatch">
                    <t-switch
                      value="{{item.is_active}}"
                      size="small"
                      loading="{{item.statusPending}}"
                      disabled="{{item.deletePending}}"
                      bind:change="onToggleVoucherStatus"
                      data-id="{{item.id}}"
                    />
                  </view>
                </view>

                <view class="voucher-meta-group">
                  <view class="voucher-price-row">
                    <text class="price-value">¥{{item.amount_yuan}}</text>
                    <text class="meta-value">{{item.usage_condition_text}}</text>
                  </view>

                  <view class="voucher-tag-row">
                    <t-tag theme="{{item.status_theme}}" variant="light" size="small">{{item.status_label}}</t-tag>
                    <t-tag wx:for="{{item.order_type_labels}}" wx:key="*this" theme="primary" variant="light" size="small">{{item}}</t-tag>
                  </view>

                  <view class="voucher-meta-row">
                    <text class="meta-label">发放进度</text>
                    <text class="meta-value">已领 {{item.claimed_quantity}}，已用 {{item.used_quantity}}，剩余 {{item.remaining_quantity_text}}</text>
                  </view>

                  <view class="voucher-meta-row">
                    <text class="meta-label">有效期</text>
                    <text class="meta-value">{{item.valid_range_text}}</text>
                  </view>
                </view>
              </view>
            </view>

            <t-divider />

            <view class="voucher-action-bar" catchtap="onActionsCatch">
              <view class="voucher-action-slot">
                <t-button class="voucher-action-button" variant="text" theme="default" size="small" bind:tap="onEditVoucher" data-id="{{item.id}}">编辑</t-button>
              </view>
              <t-divider layout="vertical" />
              <view class="voucher-action-slot">
                <t-button
                  class="voucher-action-button"
                  variant="text"
                  theme="danger"
                  size="small"
                  loading="{{item.deletePending}}"
                  disabled="{{item.deletePending || item.statusPending}}"
                  bind:tap="onRequestDeleteVoucher"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                >删除</t-button>
              </view>
            </view>
          </t-cell-group>
        </block>

        <view class="list-footer">
          <t-loading wx:if="{{loadingMore}}" theme="circular" size="32rpx" text="加载更多代金券中..." />
          <t-button wx:elif="{{hasMore}}" theme="default" bind:tap="onLoadMore">继续加载更多</t-button>
          <text wx:else class="list-footer-text">已完成当前结果加载</text>
        </view>
      </view>
    </view>

    <t-fab icon="add" bind:click="onAddVoucher" />
  </block>

  <t-dialog
    visible="{{deleteDialogVisible}}"
    title="确认删除代金券"
    using-custom-navbar="{{true}}"
    confirm-btn="{{ { content: '确认删除', theme: 'danger', loading: deleteDialogSubmitting } }}"
    cancel-btn="取消"
    bind:confirm="onConfirmDeleteVoucher"
    bind:cancel="onCancelDeleteDialog"
    bind:close="onCancelDeleteDialog"
  >
    <view slot="content" class="dialog-content">
      <text>删除后无法恢复，若仍有未使用券后端会拒绝删除，确定要删除“{{deleteDialogVoucherName}}”吗？</text>
    </view>
  </t-dialog>
</view>