.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.page-content {
  padding-bottom: calc(var(--spacer-md) + var(--safe-area-bottom));
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.section-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  background: var(--td-bg-color-container);
  border-radius: 24rpx;
}

.section-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-count {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.tag-check-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.inline-note-card {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-page);
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.inline-note-card--warning {
  background: var(--td-warning-color-1);
  color: var(--td-text-color-primary);
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
}