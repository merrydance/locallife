.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  padding: 32rpx;
  box-sizing: border-box;
}

/* 成功状态 */
.success-state {
  padding-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.role-desc {
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
  margin-top: 16rpx;
}

.success-actions {
  width: 100%;
  margin-top: 80rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.mt-md {
  margin-top: 24rpx;
}

/* 输入状态 */
.input-state {
  margin-top: 40rpx;
}

.page-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.header-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  background: #E1EAFF;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

/* 表单区域 */
.form-section {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-sm);
}

.invite-input-wrap {
  padding: 32rpx !important;
}

/* 操作区域 */
.action-section {
  margin-bottom: 60rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider .line {
  flex: 1;
  height: 1rpx;
  background: var(--td-component-stroke);
}

.divider .text {
  padding: 0 32rpx;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

/* 提示卡片 */
.tips-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.tips-content {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
