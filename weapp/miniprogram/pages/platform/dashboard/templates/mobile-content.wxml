<!-- 顶部操作区 -->
<view class="header-actions">
  <t-tabs value="{{selectedDateRange}}" bind:change="onDateRangeChange" t-class="date-range-tabs">
    <t-tab-panel wx:for="{{dateRangeOptions}}" wx:key="label" value="{{index}}" label="{{item.label}}" />
  </t-tabs>
</view>

<!-- 实时数据 -->
<view class="card" style="margin-bottom: 24rpx; background: #fff; padding: 24rpx; border-radius: 16rpx;">
  <view class="responsive-title" style="margin-bottom: 16rpx;">实时数据</view>
  <t-grid border="{{false}}" column="{{2}}">
    <t-grid-item text="活跃商户" description="{{realtimeData.realtime_stats.active_merchants || 0}}" icon="shop" />
    <t-grid-item text="在线骑手" description="{{realtimeData.realtime_stats.online_riders || 0}}" icon="user" />
  </t-grid>
</view>

<!-- 其他内容 (缩略版) -->
<t-tabs defaultValue="{{activeTab}}" bind:change="onTabChange" theme="card">
  <t-tab-panel label="今日数据" value="overview">
    <t-grid border="{{false}}" column="{{2}}">
      <t-grid-item text="订单" description="{{realtimeData.realtime_stats.pending_orders || 0}}" />
      <t-grid-item text="GMV" description="¥{{realtimeData.today_stats.today_gmv / 100}}" />
    </t-grid>
  </t-tab-panel>
</t-tabs>
