@import "../../../styles/responsive.wxss";

.platform-dashboard {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

.dashboard-scroll {
  height: 100%;
  box-sizing: border-box;
}

.dashboard-container {
  padding: var(--spacer-md);
}

.console-error-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-md);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
}

.console-error-banner__body {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.console-error-banner__text {
  flex: 1;
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.section-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacer-sm);
}

.section-title {
  font-size: var(--font-size-heading);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacer-sm);
}

.skeleton-card {
  height: 132rpx;
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-secondarycontainer);
}

.state-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.state-item {
  display: flex;
  align-items: center;
  justify-content: center;
  justify-content: space-between;
  padding: var(--spacer-sm);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-page);
}

.state-label-wrap {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.state-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-round);
}

.state-success {
  background: var(--td-success-color);
}

.state-warning {
  background: var(--td-warning-color);
}

.state-danger {
  background: var(--td-error-color);
}

.state-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.state-value {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.alert-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.alert-card {
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: linear-gradient(180deg, #FFF5F3 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(255, 107, 88, 0.18);
}

.alert-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.alert-card__title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  flex-wrap: wrap;
}

.alert-card__title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.alert-card__time {
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.alert-card__message {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.alert-card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: var(--spacer-sm);
}

.alert-card__chip {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-round);
  background: rgba(255, 107, 88, 0.1);
  font-size: var(--font-size-xs);
  color: #C75042;
}

.alert-card__hint {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-xs);
  color: var(--td-brand-color);
}

.stats-grid,
.actions-grid {
  margin-top: var(--spacer-xs);
}

.status-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}
