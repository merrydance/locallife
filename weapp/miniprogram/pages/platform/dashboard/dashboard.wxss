@import "../../../styles/responsive.wxss";

.platform-dashboard {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

.dashboard-scroll {
  height: 100%;
  box-sizing: border-box;
}

.dashboard-container {
  padding: 0;
}

.console-error-banner {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-md);
}

.section-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacer-sm);
}

.section-title {
  font-size: var(--font-size-heading);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.operations-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.operations-eyebrow {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.operations-title {
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-heading);
  line-height: 1.35;
  color: var(--td-text-color-primary);
  font-weight: 700;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-md);
}

.metric-grid--compact {
  margin-bottom: 0;
}

.metric-card {
  min-height: 148rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: var(--spacer-xs);
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-border-level-2-color);
  box-sizing: border-box;
}

.metric-card--primary {
  border-color: var(--td-brand-color-2);
}

.metric-card--success {
  border-color: var(--td-success-color-1);
}

.metric-card--warning {
  border-color: var(--td-warning-color-1);
}

.metric-card--danger {
  border-color: var(--td-error-color-1);
}

.metric-card--skeleton {
  height: 148rpx;
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-secondarycontainer);
}

.metric-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.metric-value {
  font-size: var(--font-size-title);
  line-height: 1.2;
  color: var(--td-text-color-primary);
  font-weight: 700;
}

.metric-value--compact {
  font-size: var(--font-size-heading);
}

.metric-note,
.operations-sync,
.state-note,
.entry-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.operations-meta,
.risk-list,
.risk-copy,
.entry-list,
.entry-copy {
  display: flex;
  flex-direction: column;
}

.operations-meta {
  flex-shrink: 0;
  align-items: flex-end;
  gap: var(--spacer-xs);
}

.risk-list {
  gap: var(--spacer-sm);
}

.risk-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  padding: var(--spacer-md);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-page);
  border: 1rpx solid var(--td-border-level-2-color);
}

.risk-item--danger {
  background: var(--td-error-color-1);
  border-color: rgba(182, 23, 30, 0.16);
}

.risk-item--warning {
  background: var(--td-warning-color-1);
  border-color: rgba(252, 130, 12, 0.18);
}

.risk-item--success {
  background: var(--td-success-color-1);
  border-color: rgba(10, 122, 70, 0.16);
}

.risk-copy {
  min-width: 0;
  gap: var(--spacer-xs);
}

.risk-title {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.risk-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  line-height: 1.4;
}

.risk-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  color: var(--td-text-color-secondary);
}

.risk-value {
  max-width: 144rpx;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
  text-align: right;
}

.state-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacer-sm);
}

.state-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--spacer-xs);
  padding: var(--spacer-sm);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-page);
}

.state-label-wrap {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.state-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-round);
}

.state-success {
  background: var(--td-success-color);
}

.state-warning {
  background: var(--td-warning-color);
}

.state-danger {
  background: var(--td-error-color);
}

.state-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.state-value {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.alert-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.alert-card {
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-error-color-1);
  border: 1rpx solid rgba(255, 107, 88, 0.14);
}

.alert-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.alert-card__title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  flex-wrap: wrap;
}

.alert-card__title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.alert-card__time {
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.alert-card__message {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.alert-card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: var(--spacer-sm);
}

.alert-card__chip {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-round);
  background: rgba(255, 107, 88, 0.1);
  font-size: var(--font-size-xs);
  color: #C75042;
}

.alert-card__hint {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-xs);
  color: var(--td-brand-color);
}

.entry-list {
  gap: 0;
}

.entry-item {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) 0;
  border-bottom: 1rpx solid var(--td-border-level-2-color);
}

.entry-item:last-child {
  border-bottom: 0;
}

.entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--td-brand-color);
  background: var(--td-brand-color-1);
  flex-shrink: 0;
}

.entry-copy {
  min-width: 0;
  flex: 1;
  gap: var(--spacer-xs);
}

.entry-title {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.status-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}
