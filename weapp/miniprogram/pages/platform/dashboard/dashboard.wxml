<custom-navbar title="平台管理中心" show-back="{{true}}" show-location="{{false}}" bind:navheight="onNavHeight" />

<view class="platform-dashboard page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <scroll-view
    scroll-y
    class="dashboard-scroll"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    style="height: calc(100vh - {{navBarHeight}}px);"
  >
    <view class="dashboard-container">
      <view wx:if="{{error}}" class="console-error-banner">
        <t-notice-bar theme="warning" visible="{{true}}" content="{{error}}" />
        <t-button wx:if="{{errorCanRetry}}" theme="primary" bind:tap="onRetry">重试</t-button>
      </view>

      <view class="operations-header">
        <view>
          <view class="operations-eyebrow">平台运行</view>
          <view class="operations-title">{{dashboardView.operationsStatus.summary}}</view>
        </view>
        <view class="operations-meta">
          <t-tag theme="{{dashboardView.operationsStatus.healthTheme}}" variant="dark">{{dashboardView.operationsStatus.healthText}}</t-tag>
          <text class="operations-sync">{{dashboardView.operationsStatus.syncText}}</text>
        </view>
      </view>

      <view wx:if="{{loading}}" class="metric-grid metric-grid--primary">
        <view wx:for="{{4}}" wx:key="index" class="metric-card metric-card--skeleton skeleton-shimmer"></view>
      </view>

      <view wx:else class="metric-grid metric-grid--primary">
        <view wx:for="{{dashboardView.todayCards}}" wx:key="key" class="metric-card metric-card--{{item.theme}}">
          <text class="metric-label">{{item.label}}</text>
          <text class="metric-value">{{item.value}}</text>
          <text class="metric-note">{{item.note}}</text>
        </view>
      </view>

      <view class="section-card section-card--priority">
        <view class="section-head">
          <text class="section-title">待办与风险</text>
          <t-tag theme="warning" variant="light">优先处理</t-tag>
        </view>
        <view class="risk-list">
          <view
            wx:for="{{dashboardView.riskItems}}"
            wx:key="key"
            class="risk-item risk-item--{{item.theme}}"
            bindtap="onRiskTap"
            data-url="{{item.url}}"
          >
            <view class="risk-copy">
              <text class="risk-title">{{item.title}}</text>
              <text class="risk-desc">{{item.desc}}</text>
            </view>
            <view class="risk-action">
              <text class="risk-value">{{item.value}}</text>
              <t-icon wx:if="{{item.url}}" name="chevron-right" size="28rpx" />
            </view>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <text class="section-title">实时履约</text>
          <t-tag theme="success" variant="light">自动同步</t-tag>
        </view>

        <view wx:if="{{loading}}" class="state-grid">
          <view wx:for="{{3}}" wx:key="index" class="state-item skeleton-shimmer"></view>
        </view>

        <view wx:else class="state-grid">
          <view wx:for="{{dashboardView.realtimeRows}}" wx:key="key" class="state-item">
            <view class="state-label-wrap">
              <view class="state-dot state-{{item.theme}}"></view>
              <text class="state-label">{{item.label}}</text>
            </view>
            <text class="state-value">{{item.value}}</text>
            <text class="state-note">{{item.note}}</text>
          </view>
        </view>
      </view>

      <view class="section-card" wx:if="{{abnormalRefundAlerts.length > 0}}">
        <view class="section-head">
          <text class="section-title">异常退款人工处理</text>
          <t-tag theme="danger" variant="dark">实时告警</t-tag>
        </view>

        <view class="alert-list">
          <view
            wx:for="{{abnormalRefundAlerts}}"
            wx:key="refundOrderId"
            class="alert-card"
            bindtap="onAbnormalRefundAlertTap"
            data-index="{{index}}"
          >
            <view class="alert-card__head">
              <view class="alert-card__title-wrap">
                <text class="alert-card__title">{{item.title}}</text>
                <t-tag theme="danger" variant="dark">需平台管理员</t-tag>
              </view>
              <text class="alert-card__time">{{item.timeDisplay}}</text>
            </view>
            <view class="alert-card__message">{{item.message}}</view>
            <view class="alert-card__chips">
              <text class="alert-card__chip">退款单 #{{item.refundOrderId}}</text>
              <text class="alert-card__chip">退款ID {{item.refundId}}</text>
              <text class="alert-card__chip">去向 {{item.defaultType}}</text>
            </view>
            <view class="alert-card__hint">点按查看处理说明</view>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <text class="section-title">经营累计</text>
          <t-tag theme="primary" variant="light">近30天</t-tag>
        </view>

        <view class="metric-grid metric-grid--compact">
          <view wx:for="{{dashboardView.cumulativeCards}}" wx:key="key" class="metric-card metric-card--compact">
            <text class="metric-label">{{item.label}}</text>
            <text class="metric-value metric-value--compact">{{item.value}}</text>
            <text class="metric-note">{{item.note}}</text>
          </view>
        </view>
      </view>

      <view class="entry-section">
        <view wx:for="{{dashboardView.entryGroups}}" wx:key="title" class="section-card entry-group">
          <view class="section-head">
            <text class="section-title">{{item.title}}</text>
          </view>
          <view class="entry-list">
            <view
              wx:for="{{item.items}}"
              wx:for-item="entry"
              wx:key="id"
              class="entry-item"
              bindtap="onEntryTap"
              data-id="{{entry.id}}"
              data-title="{{entry.title}}"
              data-url="{{entry.url}}"
            >
              <view class="entry-icon">
                <t-icon name="{{entry.icon}}" size="36rpx" />
              </view>
              <view class="entry-copy">
                <text class="entry-title">{{entry.title}}</text>
                <text class="entry-desc">{{entry.desc}}</text>
              </view>
              <t-icon name="chevron-right" size="28rpx" />
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{!loading && !error && dashboardView.cumulativeCards[0].value === '0'}}" class="section-card status-wrap">
        <t-empty description="暂无统计数据" />
      </view>
    </view>
  </scroll-view>
</view>
