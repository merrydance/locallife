<custom-navbar title="平台管理中心" show-back="{{true}}" show-location="{{false}}" bind:navheight="onNavHeight" />

<view class="platform-dashboard" style="padding-top: {{navBarHeight}}px;">
  <scroll-view
    scroll-y
    class="dashboard-scroll"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    style="height: calc(100vh - {{navBarHeight}}px);"
  >
    <view class="dashboard-container">
      <view wx:if="{{error}}" class="console-error-banner">
        <view class="console-error-banner__body">
          <t-icon name="error-circle" size="32rpx" color="var(--td-warning-color-7)" />
          <text class="console-error-banner__text">{{error}}</text>
        </view>
        <t-button wx:if="{{errorCanRetry}}" theme="primary" shape="round" size="small" bind:tap="onRetry">重新加载</t-button>
      </view>

      <view class="section-card">
        <view class="section-head">
          <text class="section-title">基础统计</text>
          <t-tag theme="primary" variant="dark">近30天</t-tag>
        </view>

        <view wx:if="{{loading}}" class="skeleton-grid">
          <view wx:for="{{4}}" wx:key="index" class="skeleton-card skeleton-shimmer"></view>
        </view>

        <t-grid wx:else border="{{false}}" column="{{2}}" class="stats-grid">
          <t-grid-item text="累计订单" description="{{summaryCards.totalOrders}}" icon="order" />
          <t-grid-item text="累计GMV" description="{{summaryCards.totalGMV}}" icon="money-circle" />
          <t-grid-item text="活跃用户" description="{{summaryCards.activeUsers}}" icon="user" />
          <t-grid-item text="活跃商户" description="{{summaryCards.activeMerchants}}" icon="shop" />
        </t-grid>
      </view>

      <view class="section-card">
        <view class="section-head">
          <text class="section-title">实时状态</text>
          <t-tag theme="success" variant="dark">自动刷新</t-tag>
        </view>

        <view wx:if="{{loading}}" class="state-list">
          <view wx:for="{{3}}" wx:key="index" class="state-item skeleton-shimmer"></view>
        </view>

        <view wx:else class="state-list">
          <view wx:for="{{realtimeCards}}" wx:key="label" class="state-item">
            <view class="state-label-wrap">
              <view class="state-dot state-{{item.theme}}"></view>
              <text class="state-label">{{item.label}}</text>
            </view>
            <text class="state-value">{{item.value}}</text>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <text class="section-title">管理入口</text>
          <t-tag theme="warning" variant="dark">按角色开放</t-tag>
        </view>

        <t-grid border="{{false}}" column="{{2}}" class="actions-grid">
          <t-grid-item
            wx:for="{{actions}}"
            wx:key="id"
            text="{{item.title}}"
            description="{{item.desc}}"
            icon="{{item.icon}}"
            bind:click="onActionTap"
            data-id="{{item.id}}"
            data-url="{{item.url}}"
          />
        </t-grid>
      </view>

      <view wx:if="{{!loading && !error && !summaryCards.totalOrders}}" class="section-card status-wrap">
        <t-empty description="暂无统计数据" />
      </view>
    </view>
  </scroll-view>
</view>

