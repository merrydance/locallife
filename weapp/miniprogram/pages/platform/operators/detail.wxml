<custom-navbar title="运营商详情" show-back="{{true}}" show-location="{{false}}" bind:navheight="onNavHeight" />

<view
  class="detail-page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px"
>
  <scroll-view class="detail-scroll" scroll-y>
    <view class="detail-container">
      <view wx:if="{{loading}}" class="section-card">
        <view wx:for="{{4}}" wx:key="index" class="skeleton-item skeleton-shimmer"></view>
      </view>

      <view wx:elif="{{error}}" class="section-card status-wrap">
        <t-empty icon="error-circle" description="{{error}}">
          <t-button slot="action" theme="primary" bind:tap="onRetry">重试</t-button>
        </t-empty>
      </view>

      <view wx:elif="{{!detail}}" class="section-card status-wrap">
        <t-empty description="未找到运营商详情" />
      </view>

      <block wx:else>
        <view class="section-card">
          <view class="title-row">
            <text class="title">{{detail.name || ('运营商#' + detail.id)}}</text>
            <t-tag theme="{{detail.statusTheme}}" variant="light">{{detail.statusLabel}}</t-tag>
          </view>
          <view class="meta-row">
            <text class="meta-label">联系人</text>
            <text class="meta-value">{{detail.contact_name || '--'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">联系电话</text>
            <text class="meta-value">{{detail.contact_phone || '--'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">主要区县</text>
            <text class="meta-value">{{detail.region_name || '--'}}</text>
          </view>
        </view>

        <view class="section-card">
          <view class="section-title">运营概况</view>
          <view class="metric-grid">
            <view class="metric-item">
              <text class="metric-label">管理区县</text>
              <text class="metric-value">{{detail.regionText}}</text>
            </view>
            <view class="metric-item">
              <text class="metric-label">商户数量</text>
              <text class="metric-value">{{detail.merchantText}}</text>
            </view>
            <view class="metric-item">
              <text class="metric-label">近一个月订单</text>
              <text class="metric-value">{{detail.order_stats.last_month_orders}}</text>
            </view>
            <view class="metric-item">
              <text class="metric-label">近一个月流水</text>
              <text class="metric-value">{{detail.lastMonthRevenueText}}</text>
            </view>
          </view>
        </view>

        <view class="section-card">
          <view class="section-title">管理区县</view>
          <view wx:for="{{detail.regions}}" wx:key="region_id" class="meta-row">
            <text class="meta-label">{{item.region_name}}</text>
            <text class="meta-value">{{item.status}}</text>
          </view>
          <view wx:if="{{detail.regions.length === 0}}" class="empty-line">暂无区县</view>
        </view>

        <view class="section-card">
          <view class="section-title">服务水平</view>
          <view class="meta-row">
            <text class="meta-label">被投诉</text>
            <text class="meta-value">{{detail.complaintText}}</text>
          </view>
          <view wx:for="{{detail.categories}}" wx:key="category" class="meta-row">
            <text class="meta-label">{{item.category}}</text>
            <text class="meta-value">{{item.countText}}</text>
          </view>
          <view wx:if="{{detail.categories.length === 0}}" class="empty-line">暂无投诉分类</view>
        </view>

        <view wx:if="{{actionResultText}}" class="section-card action-result">
          <text class="action-result__title">{{actionResultText}}</text>
          <text class="action-result__note">{{actionResultNote}}</text>
        </view>

        <view wx:if="{{detail.can_suspend || detail.can_resume}}" class="section-card">
          <t-button
            theme="{{detail.can_suspend ? 'danger' : 'primary'}}"
            block
            loading="{{submitting}}"
            bind:tap="onToggleStatus"
          >{{detail.can_suspend ? '暂停运营商' : '恢复运营商'}}</t-button>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
