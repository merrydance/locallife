<custom-navbar title="运营商申请详情" show-back="{{true}}" show-location="{{false}}" bind:navheight="onNavHeight" />

<view class="detail-page" style="padding-top: {{navBarHeight}}px;">
  <scroll-view class="detail-scroll" scroll-y>
    <view class="detail-container">
      <view wx:if="{{loading}}" class="section-card">
        <view wx:for="{{4}}" wx:key="index" class="skeleton-item skeleton-shimmer"></view>
      </view>

      <view wx:elif="{{error}}" class="section-card status-wrap">
        <t-empty icon="error-circle" description="{{error}}">
          <t-button slot="action" theme="primary" shape="round" size="small" bind:tap="onRetry">重试</t-button>
        </t-empty>
      </view>

      <view wx:elif="{{!application}}" class="section-card status-wrap">
        <t-empty description="未找到申请详情" />
      </view>

      <block wx:else>
        <view class="section-card">
          <view class="title-row">
            <text class="title">{{application.name || application.legal_person_name || ('申请#' + application.id)}}</text>
            <t-tag theme="{{statusTheme}}" variant="dark">{{statusLabel}}</t-tag>
          </view>
          <view class="meta-row">
            <text class="meta-label">申请编号</text>
            <text class="meta-value">{{application.id}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">区域</text>
            <text class="meta-value">{{application.region_name || '-'}} ({{application.region_id}})</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">联系人</text>
            <text class="meta-value">{{application.contact_name || '-'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">联系电话</text>
            <text class="meta-value">{{application.contact_phone || '-'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">合同年限</text>
            <text class="meta-value">{{application.requested_contract_years || 0}} 年</text>
          </view>
        </view>

        <view class="section-card">
          <view class="section-title">企业资质</view>
          <view class="meta-row">
            <text class="meta-label">营业执照号</text>
            <text class="meta-value">{{application.business_license_number || '-'}}</text>
          </view>
          <view wx:if="{{application.business_license_url}}" class="image-row">
            <text class="meta-label">营业执照</text>
            <image
              class="cert-image"
              src="{{application.business_license_url}}"
              mode="aspectFill"
              lazy-load
              data-url="{{application.business_license_url}}"
              bind:tap="onPreviewImage"
            />
          </view>
        </view>

        <view class="section-card">
          <view class="section-title">身份信息</view>
          <view class="meta-row">
            <text class="meta-label">法人姓名</text>
            <text class="meta-value">{{application.legal_person_name || '-'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">法人证件号</text>
            <text class="meta-value">{{application.legal_person_id_number || '-'}}</text>
          </view>
          <view wx:if="{{application.id_card_front_url}}" class="image-row">
            <text class="meta-label">身份证人像面</text>
            <image
              class="cert-image"
              src="{{application.id_card_front_url}}"
              mode="aspectFill"
              lazy-load
              data-url="{{application.id_card_front_url}}"
              bind:tap="onPreviewImage"
            />
          </view>
          <view wx:if="{{application.id_card_back_url}}" class="image-row">
            <text class="meta-label">身份证国徽面</text>
            <image
              class="cert-image"
              src="{{application.id_card_back_url}}"
              mode="aspectFill"
              lazy-load
              data-url="{{application.id_card_back_url}}"
              bind:tap="onPreviewImage"
            />
          </view>
        </view>

        <view class="section-card">
          <view class="section-title">审核信息</view>
          <view class="meta-row">
            <text class="meta-label">提交时间</text>
            <text class="meta-value">{{application.submitted_at || application.created_at || '-'}}</text>
          </view>
          <view wx:if="{{application.reviewed_at}}" class="meta-row">
            <text class="meta-label">审核时间</text>
            <text class="meta-value">{{application.reviewed_at || '-'}}</text>
          </view>
          <view wx:if="{{application.status === 'rejected' && application.reject_reason}}" class="meta-row">
            <text class="meta-label">驳回原因</text>
            <text class="meta-value">{{application.reject_reason || '-'}}</text>
          </view>
        </view>

        <view wx:if="{{application.status === 'submitted'}}" class="section-card">
          <view class="section-title">审核操作</view>
          <view class="reject-input-wrap">
            <t-textarea
              value="{{rejectReason}}"
              placeholder="请输入驳回原因（必填）"
              maxlength="200"
              indicator
              bind:change="onRejectReasonChange"
            />
          </view>
          <view class="actions">
            <t-button
              theme="danger"
              shape="round"
              size="small"
              loading="{{submittingAction === 'reject'}}"
              disabled="{{submittingAction !== ''}}"
              bind:tap="onRejectTap"
            >驳回</t-button>
            <t-button
              theme="primary"
              shape="round"
              size="small"
              loading="{{submittingAction === 'approve'}}"
              disabled="{{submittingAction !== ''}}"
              bind:tap="onApproveTap"
              data-id="{{application.id}}"
            >通过</t-button>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
