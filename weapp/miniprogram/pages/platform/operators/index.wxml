<custom-navbar title="运营商管理" show-back="{{true}}" show-location="{{false}}" bind:navheight="onNavHeight" />

<view
  class="operators-page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px"
>
  <scroll-view
    class="list-scroll"
    scroll-y
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
  >
    <view class="operators-container">
      <view class="summary-card">
        <text class="summary-title">运营商总数</text>
        <text class="summary-value">{{total}}</text>
      </view>

      <view wx:if="{{loading}}" class="section-card">
        <view wx:for="{{3}}" wx:key="index" class="skeleton-item skeleton-shimmer"></view>
      </view>

      <view wx:if="{{error}}" class="section-card status-wrap">
        <t-empty icon="error-circle" description="{{error}}">
          <t-button slot="action" theme="primary" bind:tap="onRetry">重试</t-button>
        </t-empty>
      </view>

      <view wx:if="{{!loading && !error && operators.length === 0}}" class="section-card status-wrap">
        <t-empty description="暂无运营商" />
      </view>

      <view wx:for="{{operators}}" wx:key="id" class="section-card operator-card" bind:tap="onDetailTap" data-id="{{item.id}}">
        <view class="title-row">
          <view class="name">{{item.name || ('运营商#' + item.id)}}</view>
          <t-tag theme="{{item.statusTheme}}" variant="light">{{item.statusLabel}}</t-tag>
        </view>
        <view class="meta-row">
          <text class="meta-label">管理区县</text>
          <text class="meta-value">{{item.regionText}}</text>
        </view>
        <view class="meta-row">
          <text class="meta-label">商户数量</text>
          <text class="meta-value">{{item.merchantText}}</text>
        </view>
        <view class="meta-row">
          <text class="meta-label">被投诉</text>
          <text class="meta-value">{{item.complaintText}}</text>
        </view>
      </view>

      <view wx:if="{{!loading && !hasMore && operators.length > 0}}" class="no-more">没有更多了</view>
    </view>
  </scroll-view>
</view>
