<custom-navbar title="商户管控查询" show-back="{{true}}" show-location="{{false}}" bind:navheight="onNavHeight" />

<scroll-view
  scroll-y
  class="merchant-limitations-page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <view class="content-inner">
    <view class="section-card controls-card">
      <view class="section-head">
        <text class="section-title">查询条件</text>
        <t-tag theme="primary" variant="light" size="small">平台管理员</t-tag>
      </view>

      <t-input
        value="{{subMchId}}"
        type="number"
        maxlength="32"
        label="子商户号"
        placeholder="请输入微信子商户号"
        align="right"
        clearable
        bind:change="onSubMchIdChange"
      />

      <view class="controls-note">直接查询微信返回的受限功能与解脱路径。</view>

      <view class="controls-actions">
        <t-button theme="primary" shape="round" block loading="{{loading}}" bind:tap="onSubmit">查询管控情况</t-button>
      </view>
    </view>

    <view wx:if="{{error}}" class="section-card status-wrap">
      <t-empty icon="error-circle" description="{{error}}">
        <t-button slot="action" theme="primary" shape="round" size="small" loading="{{loading}}" bind:tap="onSubmit">重试</t-button>
      </t-empty>
    </view>

    <view wx:if="{{loading && !result && !error}}" class="section-card">
      <view wx:for="{{3}}" wx:key="index" class="skeleton-item skeleton-shimmer"></view>
    </view>

    <view wx:if="{{!loading && !error && !queried}}" class="section-card status-wrap">
      <t-empty description="输入子商户号后开始查询" />
    </view>

    <block wx:if="{{result}}">
      <view class="section-card">
        <view class="section-head">
          <text class="section-title">查询结果</text>
          <t-tag theme="{{result.statusTheme}}" variant="light" size="small">{{result.statusLabel}}</t-tag>
        </view>

        <view class="meta-list">
          <view class="meta-row">
            <text class="meta-label">子商户号</text>
            <view class="meta-value-wrap">
              <text class="meta-value meta-value--strong">{{result.mchid || '-'}}</text>
              <text class="copy-link" bindtap="onCopyTap" data-label="子商户号" data-value="{{result.mchid}}">复制</text>
            </view>
          </view>

          <view class="meta-row">
            <text class="meta-label">受限功能数</text>
            <text class="meta-value">{{result.limitedFunctionCount}}</text>
          </view>

          <view class="meta-row">
            <text class="meta-label">解脱路径数</text>
            <text class="meta-value">{{result.recoveryCount}}</text>
          </view>

          <view wx:if="{{result.other_limited_functions}}" class="meta-row meta-row--start">
            <text class="meta-label">其他限制</text>
            <text class="meta-value meta-value--multiline">{{result.other_limited_functions}}</text>
          </view>
        </view>

        <view wx:if="{{result.limitedFunctionCount > 0}}" class="chip-list">
          <t-tag
            wx:for="{{result.limited_functions}}"
            wx:key="*this"
            theme="warning"
            variant="light"
            size="small"
          >{{item}}</t-tag>
        </view>

        <view wx:if="{{result.limitedFunctionCount === 0 && !result.other_limited_functions}}" class="result-note">
          微信侧当前未返回受限功能。
        </view>
      </view>

      <view wx:if="{{result.recoveryCount > 0}}" class="section-card">
        <view class="section-head">
          <text class="section-title">解脱路径</text>
          <t-tag theme="warning" variant="light" size="small">{{result.recoveryCount}} 条</t-tag>
        </view>

        <view class="case-list">
          <view wx:for="{{result.recovery_specifications}}" wx:key="limitation_case_id" class="case-card">
            <view class="case-head">
              <text class="case-title">{{item.limitation_reason_type || item.limitation_case_id || '未命名限制'}}</text>
              <t-tag theme="default" variant="light" size="small">{{item.limitation_action_type || '待确认'}}</t-tag>
            </view>

            <view wx:if="{{item.limitation_reason}}" class="case-row">
              <text class="case-label">限制原因</text>
              <text class="case-value">{{item.limitation_reason}}</text>
            </view>

            <view wx:if="{{item.limitation_reason_describe}}" class="case-row">
              <text class="case-label">原因说明</text>
              <text class="case-value">{{item.limitation_reason_describe}}</text>
            </view>

            <view wx:if="{{item.recover_way}}" class="case-row">
              <text class="case-label">解脱方式</text>
              <text class="case-value">{{item.recover_way}}</text>
            </view>

            <view wx:if="{{item.recover_way_param}}" class="case-row">
              <text class="case-label">解脱参数</text>
              <view class="meta-value-wrap meta-value-wrap--top">
                <text class="case-value">{{item.recover_way_param}}</text>
                <text class="copy-link" bindtap="onCopyTap" data-label="解脱参数" data-value="{{item.recover_way_param}}">复制</text>
              </view>
            </view>

            <view wx:if="{{item.limitation_start_date}}" class="case-row">
              <text class="case-label">开始时间</text>
              <text class="case-value">{{item.limitation_start_date}}</text>
            </view>

            <view wx:if="{{item.limitation_date}}" class="case-row">
              <text class="case-label">管控时间</text>
              <text class="case-value">{{item.limitation_date}}</text>
            </view>

            <view wx:if="{{item.relate_limitations.length > 0}}" class="case-chip-group">
              <text class="case-label">关联限制</text>
              <view class="chip-list chip-list--compact">
                <t-tag
                  wx:for="{{item.relate_limitations}}"
                  wx:key="*this"
                  theme="default"
                  variant="light"
                  size="small"
                >{{item}}</t-tag>
              </view>
            </view>

            <view wx:if="{{item.other_relate_limitations}}" class="case-row">
              <text class="case-label">其他关联</text>
              <text class="case-value">{{item.other_relate_limitations}}</text>
            </view>

            <view wx:if="{{item.recover_help_url}}" class="case-row case-row--start">
              <text class="case-label">帮助链接</text>
              <view class="meta-value-wrap meta-value-wrap--top">
                <text class="case-value case-value--multiline">{{item.recover_help_url}}</text>
                <text class="copy-link" bindtap="onCopyTap" data-label="帮助链接" data-value="{{item.recover_help_url}}">复制</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{result.recoveryCount === 0}}" class="section-card status-wrap">
        <t-empty description="微信侧未返回解脱路径" />
      </view>
    </block>
  </view>
</scroll-view>