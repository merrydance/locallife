@import "../../../../styles/responsive.wxss";

.merchant-limitations-page {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

.content-inner {
  padding: var(--spacer-md);
}

.section-card {
  margin-bottom: var(--spacer-md);
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.controls-note {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.controls-actions {
  margin-top: var(--spacer-md);
}

.status-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.skeleton-item {
  height: 96rpx;
  margin-bottom: var(--spacer-sm);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-secondarycontainer);
}

.skeleton-item:last-child {
  margin-bottom: 0;
}

.meta-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.meta-row--start {
  align-items: flex-start;
}

.meta-label {
  width: 152rpx;
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.meta-value-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  min-width: 0;
}

.meta-value-wrap--top {
  align-items: flex-start;
}

.meta-value {
  flex: 1;
  text-align: right;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
}

.meta-value--strong {
  font-weight: 600;
}

.meta-value--multiline {
  line-height: 1.6;
}

.copy-link {
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  color: var(--td-brand-color);
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: var(--spacer-md);
}

.chip-list--compact {
  margin-top: var(--spacer-xs);
}

.result-note {
  margin-top: var(--spacer-md);
  font-size: var(--font-size-sm);
  color: var(--td-success-color-7);
}

.case-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.case-card {
  padding: var(--spacer-md);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-page);
}

.case-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.case-title {
  flex: 1;
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.case-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-top: var(--spacer-sm);
}

.case-row--start {
  align-items: flex-start;
}

.case-label {
  width: 152rpx;
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.case-value {
  flex: 1;
  text-align: right;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-primary);
}

.case-value--multiline {
  word-break: break-all;
}

.case-chip-group {
  margin-top: var(--spacer-sm);
}