.page-container {
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: var(--td-bg-color-page);
}

.category-scroll {
  height: calc(100vh - var(--page-shell-nav-height, 88px) - var(--spacer-sm));
}

.page-content {
  padding-top: 0;
  padding-bottom: calc(var(--spacer-lg) + var(--safe-area-bottom));
}

.state-block {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 0 var(--spacer-lg);
}

.notice-banner {
  margin-bottom: 0;
}

.notice-banner-operation {
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-brand-color);
  font-weight: 600;
}

.list-section {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: var(--spacer-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.list-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.list-heading {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.list-title {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.list-caption {
  font-size: var(--font-size-sm);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
}

.section-empty {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.category-chip-list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--spacer-sm);
}

.category-chip {
  max-width: 100%;
}

.category-chip-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  line-height: 1;
}

.category-chip-name {
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-icon-preview {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-secondarycontainer);
  font-size: 30rpx;
  line-height: 1;
}

.category-icon-preview--large {
  width: 72rpx;
  height: 72rpx;
  flex-basis: 72rpx;
  font-size: 44rpx;
}

.dialog-form {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.dialog-icon-preview {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-secondarycontainer);
}

.dialog-icon-copy {
  font-size: var(--font-size-sm);
  line-height: 1.5;
  color: var(--td-text-color-secondary);
}

.icon-picker {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: var(--spacer-xs);
}

.icon-picker-item {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--td-border-color);
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-container);
  font-size: 38rpx;
  line-height: 1;
}

.icon-picker-item--active {
  border-color: var(--td-brand-color);
  background: var(--td-brand-color-light);
}

@media (max-width: 420px) {
  .list-header {
    align-items: stretch;
    flex-direction: column;
  }
}
