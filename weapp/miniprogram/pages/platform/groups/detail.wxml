<custom-navbar title="集团申请详情" show-back="{{true}}" show-location="{{false}}" bind:navheight="onNavHeight" />

<view class="detail-page" style="padding-top: {{navBarHeight}}px;">
  <scroll-view class="detail-scroll" scroll-y>
    <view class="detail-container">
      <view wx:if="{{loading}}" class="section-card">
        <view wx:for="{{4}}" wx:key="index" class="skeleton-item skeleton-shimmer"></view>
      </view>

      <view wx:elif="{{error}}" class="section-card status-wrap">
        <t-empty icon="error-circle" description="{{error}}">
          <t-button slot="action" theme="primary" shape="round" size="small" bind:tap="onRetry">重试</t-button>
        </t-empty>
      </view>

      <view wx:elif="{{!application}}" class="section-card status-wrap">
        <t-empty description="未找到申请详情" />
      </view>

      <block wx:else>
        <view class="section-card">
          <view class="title-row">
            <text class="title">{{application.group_name || ('申请#' + application.id)}}</text>
            <t-tag theme="{{statusTheme}}" variant="dark">{{statusLabel}}</t-tag>
          </view>
          <view class="meta-row">
            <text class="meta-label">申请编号</text>
            <text class="meta-value">{{application.id}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">申请用户ID</text>
            <text class="meta-value">{{application.applicant_user_id}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">联系电话</text>
            <text class="meta-value">{{application.contact_phone || '-'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">区域ID</text>
            <text class="meta-value">{{application.region_id || '-'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">申请时间</text>
            <text class="meta-value">{{application.created_at || '-'}}</text>
          </view>
        </view>

        <view class="section-card">
          <view class="section-title">资质信息</view>
          <view class="meta-row">
            <text class="meta-label">营业执照号</text>
            <text class="meta-value">{{application.license_number || '-'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">注册地址</text>
            <text class="meta-value">{{application.address || '-'}}</text>
          </view>
          <view wx:if="{{licenseImageUrl}}" class="image-row">
            <text class="meta-label">营业执照</text>
            <image
              class="cert-image"
              src="{{licenseImageUrl}}"
              mode="aspectFill"
              lazy-load
              data-url="{{licenseImageUrl}}"
              bind:tap="onPreviewImage"
            />
          </view>
        </view>

        <view class="section-card">
          <view class="section-title">审核信息</view>
          <view wx:if="{{application.reviewed_at}}" class="meta-row">
            <text class="meta-label">审核时间</text>
            <text class="meta-value">{{application.reviewed_at}}</text>
          </view>
          <view wx:if="{{application.status === 'rejected' && application.reject_reason}}" class="meta-row">
            <text class="meta-label">驳回原因</text>
            <text class="meta-value">{{application.reject_reason}}</text>
          </view>
        </view>

        <view wx:if="{{application.status === 'submitted'}}" class="section-card">
          <view class="section-title">审核操作</view>
          <view class="actions">
            <t-button
              theme="danger"
              shape="round"
              size="small"
              loading="{{submittingAction === 'reject'}}"
              disabled="{{submittingAction !== ''}}"
              bind:tap="onRejectTap"
            >驳回</t-button>
            <t-button
              theme="primary"
              shape="round"
              size="small"
              loading="{{submittingAction === 'approve'}}"
              disabled="{{submittingAction !== ''}}"
              bind:tap="onApproveTap"
            >通过</t-button>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <t-dialog
    visible="{{showRejectDialog}}"
    title="驳回集团申请"
    confirm-btn="确认驳回"
    cancel-btn="取消"
    bind:confirm="onRejectConfirm"
    bind:cancel="onRejectCancel"
  >
    <view class="dialog-content">
      <view class="dialog-title">集团：{{application.group_name || ('申请#' + application.id)}}</view>
      <t-textarea
        value="{{rejectReason}}"
        placeholder="请输入驳回原因"
        maxlength="200"
        indicator
        bind:change="onRejectReasonChange"
      />
    </view>
  </t-dialog>
</view>
