/* Pages Order Detail */
.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
}

.loading {
  padding: 40rpx;
  text-align: center;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

.inline-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-md);
  padding: var(--spacer-sm) var(--spacer-md);
}

.inline-banner-danger {
  background: rgba(229, 57, 53, 0.08);
  color: var(--td-error-color);
}

.inline-banner-text {
  flex: 1;
  font-size: var(--font-size-sm);
  line-height: 1.6;
}

.inline-banner-action {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--td-brand-color);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 1. Status Header */
.status-header {
  background: var(--td-bg-color-container);
  padding: 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-left {
  display: flex;
  flex-direction: column;
}

.status-title {
  font-size: 44rpx; /* Display size */
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

/* Cards General */
.card {
  background: var(--td-bg-color-container);
  margin: 20rpx 24rpx;
  border-radius: var(--radius-md, 16rpx);
  overflow: hidden;
  box-shadow: var(--shadow-1);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--td-border-level-1-color);
  color: var(--td-text-color-primary);
}

/* 2. Action Card */
.action-card {
  padding: 24rpx 32rpx;
  background: var(--td-bg-color-container);
  border: 1rpx solid rgba(0,0,0,0.05);
}

.action-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-text {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

/* 3. Order Card (Merchant & Items) */
.order-card {
  padding: 0 0 24rpx 0;
}

.merchant-header {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.merchant-info {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.merchant-name {
  margin-right: 8rpx;
}

.hover-opacity {
  opacity: 0.7;
}

.item-list {
  padding: 24rpx 32rpx;
}

.order-item {
  display: flex;
  margin-bottom: 32rpx;
}

.order-item:last-child {
  margin-bottom: 0;
}

.item-img {
  flex-shrink: 0;
  margin-right: 20rpx;
  background-color: var(--td-bg-color-component);
}

.item-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-row-1 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
  line-height: 1.4;
  flex: 1;
  margin-right: 24rpx;
}

.item-price {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  font-weight: bold;
  font-family: 'DIN Alternate', sans-serif;
}

.item-row-2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-specs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-xs);
}

.item-qty {
  font-size: 26rpx;
  color: var(--td-text-color-placeholder);
}

/* Fees */
.fee-list {
  padding: 16rpx 32rpx;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  margin-bottom: 12rpx;
}

.price-group {
  display: flex;
  gap: 12rpx;
}

.discount-price {
  text-decoration: line-through;
  color: var(--td-text-color-disabled);
}

.highlight-red {
  color: var(--td-error-color);
}

.total-row {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
  padding: 16rpx 32rpx 0;
  font-size: 28rpx;
}

.total-label {
  margin-right: 12rpx;
  color: var(--td-text-color-primary);
  font-weight: bold;
}

.total-price {
  font-size: 40rpx;
  color: var(--td-text-color-primary);
  font-weight: bold;
  font-family: 'DIN Alternate', sans-serif;
}

/* Info Cards */
.address-note {
  text-align: right;
  width: 400rpx;
  white-space: normal !important;
  line-height: 1.4;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--td-bg-color-container);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.bottom-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.secondary-actions {
  display: flex;
  gap: 16rpx;
}

.primary-actions {
  display: flex;
  gap: 16rpx;
  margin-left: auto;
}

/* TDesign Button Overrides if needed */
.t-button--medium {
  font-weight: bold;
}

/* 骨架屏样式 */
.skeleton-container {
  padding: 24rpx;
}

.skeleton-bg {
  background: var(--td-bg-color-container);
}

.skeleton-rect {
  background-color: var(--td-bg-color-component);
  border-radius: 8rpx;
}

.skeleton-circle {
  background-color: var(--td-bg-color-component);
  border-radius: 50%;
}

.skeleton-row {
  background-color: var(--td-bg-color-component);
  border-radius: 8rpx;
}

.error-container {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: var(--td-bg-color-page);
}
