.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 100rpx 0;
}

.detail-content {
  padding-bottom: var(--spacer-xl);
}

/* 卡片通用样式 */
.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin: var(--spacer-sm) var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

/* 状态卡片 */
.status-card {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.status-header {
  display: flex;
  align-items: center;
  gap: var(--spacer-md);
}

.status-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xxs);
}

.status-text {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.status-time {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.status-chip {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-round);
  background: var(--td-brand-color-light);
  color: var(--td-brand-color);
  font-size: var(--font-size-xxs);
  font-weight: bold;
}

/* 模块标题 */
.section-title {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-md);
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

/* 商家部分 */
.merchant-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.merchant-name {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.address-text {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 500;
  margin-bottom: var(--spacer-xs);
  display: block;
}

.contact-info {
  display: flex;
  gap: var(--spacer-md);
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-sm) 0;
  font-size: var(--font-size-sm);
}

.info-row:first-child {
  padding-top: 0;
}

.info-row .label {
  color: var(--td-text-color-secondary);
}

.info-row .value {
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.value-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: var(--td-brand-color);
}

/* 商品清单 */
.item-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.item-row:last-child {
  border-bottom: none;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
}

.item-price {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.item-quantity {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

/* 费用明细 */
.cost-row {
  display: flex;
  justify-content: space-between;
  padding: var(--spacer-xs) 0;
  font-size: var(--font-size-sm);
}

.cost-row .label {
  color: var(--td-text-color-secondary);
}

.cost-row .value {
  color: var(--td-text-color-primary);
}

.cost-row .value.discount {
  color: var(--td-success-color);
}

.cost-row.total {
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
  margin-top: var(--spacer-sm);
  padding-top: var(--spacer-md);
}

.cost-row.total .label {
  font-weight: bold;
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
}

.cost-row.total .value {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-brand-color);
}

/* 时间线 */
.timeline {
  display: flex;
  flex-direction: column;
}

.timeline-row {
  display: flex;
  gap: var(--spacer-md);
  position: relative;
  padding-bottom: var(--spacer-lg);
}

.timeline-row:last-child {
  padding-bottom: 0;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 32rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-round);
  background: var(--td-bg-color-secondarycontainer);
  z-index: 2;
  margin-top: 12rpx;
}

.timeline-dot.done {
  background: var(--td-brand-color);
  box-shadow: 0 0 0 6rpx var(--td-brand-color-light);
}

.timeline-line {
  position: absolute;
  left: 15rpx;
  top: 28rpx;
  bottom: -15rpx;
  width: 2rpx;
  background: var(--td-bg-color-secondarycontainer);
  z-index: 1;
}

.timeline-row:last-child .timeline-line {
  display: none;
}

.timeline-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.timeline-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.timeline-title {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.timeline-time {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.timeline-desc {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacer-sm) var(--spacer-md);
  padding-bottom: calc(var(--spacer-sm) + env(safe-area-inset-bottom));
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-md);
  z-index: var(--z-index-fixed);
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.action-row {
  display: flex;
  gap: var(--spacer-sm);
}

.btn {
  flex: 1;
}
