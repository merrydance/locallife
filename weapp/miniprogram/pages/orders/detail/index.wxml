<custom-navbar title="订单详情" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: 240rpx;">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" class="loading" />

  <view wx:if="{{!loading && order}}" class="detail-content">
    <!-- 状态 -->
    <view class="status-card card">
      <view class="status-header">
        <t-icon name="{{order.status === 'cancelled' ? 'close-circle-filled' : 'check-circle-filled'}}" size="64rpx" color="var(--td-brand-color)" />
        <view class="status-meta">
          <text class="status-text">{{order.statusText}}</text>
          <text class="status-time">订单编号: {{order.orderNo}}</text>
        </view>
        <view wx:if="{{order.expectDeliverTime}}" class="status-chip">预计 {{order.expectDeliverTime}} 送达</view>
      </view>
    </view>

    <!-- 商家信息 -->
    <view class="merchant-section card">
      <view class="merchant-info">
        <view style="display: flex; align-items: center; gap: 8rpx;">
          <t-icon name="shop" size="32rpx" color="var(--td-text-color-primary)" />
          <text class="merchant-name">{{order.merchantName}}</text>
        </view>
        <t-button size="small" theme="primary" variant="outline" shape="round" icon="call" bindtap="onCallMerchant">联系商家</t-button>
      </view>
    </view>

    <!-- 配送/预订/堂食信息 -->
    <view class="info-module card">
      <view wx:if="{{order.type === 'takeout'}}">
        <view class="section-title">
          <t-icon name="location" size="32rpx" />
          <text>配送信息</text>
        </view>
        <text class="address-text">{{order.address}}</text>
        <view class="contact-info">
          <text>{{order.contactName}}</text>
          <text>{{order.contactPhone}}</text>
        </view>
      </view>

      <view wx:if="{{order.type === 'reservation'}}">
        <view class="section-title">
          <t-icon name="calendar" size="32rpx" />
          <text>预订信息</text>
        </view>
        <view class="info-row">
          <text class="label">预约时间</text>
          <text class="value">{{reservationInfo.reservation_date}} {{reservationInfo.reservation_time}}</text>
        </view>
        <view class="info-row">
          <text class="label">桌台/人数</text>
          <text class="value">{{reservationInfo.table_no || '--'}} / {{reservationInfo.guest_count}}人</text>
        </view>
        <view class="info-row">
          <text class="label">预约人</text>
          <text class="value">{{reservationInfo.contact_name}} {{reservationInfo.contact_phone}}</text>
        </view>
      </view>

      <view wx:if="{{order.type === 'dine_in'}}">
        <view class="section-title">
          <t-icon name="restaurant" size="32rpx" />
          <text>堂食信息</text>
        </view>
        <view class="info-row">
          <text class="label">用餐桌台</text>
          <text class="value">{{order.tableId ? ('#' + order.tableId) : '店内用餐'}}</text>
        </view>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="items-section card">
      <view class="section-title">
        <t-icon name="view-list" size="32rpx" />
        <text>商品清单</text>
      </view>
      <view wx:for="{{order.items}}" wx:key="id" class="item-row">
        <t-image class="item-image" src="{{item.imageUrl}}" mode="aspectFill" lazy />
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">¥{{item.unitPriceDisplay}}</text>
        </view>
        <text class="item-quantity">x{{item.quantity}}</text>
      </view>
    </view>

    <!-- 费用明细 -->
    <view class="cost-section card">
      <view class="cost-row">
        <text class="label">商品金额</text>
        <text class="value">¥{{order.subtotalDisplay}}</text>
      </view>
      <view wx:if="{{order.type === 'takeout'}}" class="cost-row">
        <text class="label">配送费</text>
        <text class="value">¥{{order.deliveryFeeDisplay}}</text>
      </view>
      <view wx:if="{{order.discountAmount > 0}}" class="cost-row">
        <text class="label">优惠</text>
        <text class="value discount">-¥{{order.discountAmountDisplay}}</text>
      </view>
      <view class="cost-row total">
        <text class="label">实付金额</text>
        <text class="value">¥{{order.payableAmountDisplay}}</text>
      </view>
    </view>

    <!-- 订单元数据 -->
    <view class="metadata-section card">
      <view class="info-row">
        <text class="label">下单时间</text>
        <text class="value">{{order.createTime}}</text>
      </view>
      <view class="info-row link-row" bindtap="onViewPayment">
        <text class="label">支付详情</text>
        <view class="value-link">
          <text>点击查看</text>
          <t-icon name="chevron-right" size="32rpx" />
        </view>
      </view>
    </view>

    <!-- 订单进度 (Timeline) -->
    <view wx:if="{{order.timeline && order.timeline.length > 0}}" class="timeline-section card">
      <view class="section-title">
        <t-icon name="Steps" size="32rpx" />
        <text>订单进度</text>
      </view>
      <view class="timeline">
        <view class="timeline-row" wx:for="{{order.timeline}}" wx:key="title">
          <view class="timeline-left">
            <view class="timeline-dot {{item.done ? 'done' : ''}}" />
            <view class="timeline-line" />
          </view>
          <view class="timeline-body">
            <view class="timeline-head">
              <view class="timeline-title">{{item.title}}</view>
              <view class="timeline-time">{{item.time}}</view>
            </view>
            <view class="timeline-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 底部操作栏 -->
<view wx:if="{{!loading && order}}" class="bottom-bar">
  <view wx:if="{{showPayButton || showCancelButton}}" class="action-row">
    <t-button wx:if="{{showCancelButton}}" class="btn" variant="outline" theme="primary" shape="round" block bindtap="onCancelOrder">取消订单</t-button>
    <t-button wx:if="{{showPayButton}}" class="btn" theme="primary" shape="round" block bindtap="onPayOrder">去支付</t-button>
  </view>

  <view wx:if="{{showConfirmButton || showTrackingButton}}" class="action-row">
    <t-button wx:if="{{showTrackingButton}}" class="btn" variant="outline" theme="primary" shape="round" block bindtap="onViewTracking">查看物流</t-button>
    <t-button wx:if="{{showConfirmButton}}" class="btn" theme="primary" shape="round" block bindtap="onConfirmReceipt">确认收货</t-button>
  </view>

  <view wx:if="{{showUrgeButton}}" class="action-row">
    <t-button class="btn" variant="outline" theme="primary" shape="round" block bindtap="onUrgeOrder" disabled="{{urgeCountdown > 0}}">
      {{urgeCountdown > 0 ? urgeCountdown + 's后可重新催单' : '催单'}}
    </t-button>
  </view>

  <view wx:if="{{order.status === 'completed'}}" class="action-row">
    <t-button class="btn" variant="outline" theme="primary" shape="round" block bindtap="onReview">评价订单</t-button>
    <t-button class="btn" theme="primary" shape="round" block bindtap="onReorder">再来一单</t-button>
  </view>
</view>
