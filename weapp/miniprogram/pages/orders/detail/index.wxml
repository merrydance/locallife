<custom-navbar title="订单详情" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 120rpx;"
>
  <!-- 1. 错误状态 -->
  <view wx:if="{{isError}}" class="error-container">
    <t-empty icon="info-circle" description="{{errorMsg}}" />
    <t-button theme="primary" size="small" bindtap="loadOrderDetail" style="margin-top: 24rpx;" shape="round">重试</t-button>
  </view>

  <!-- 2. 骨架屏加载 (App Shell + Skeleton) -->
  <view wx:elif="{{loading && !order}}" class="skeleton-container">
    <!-- Status Header Skeleton -->
    <view class="status-header skeleton-bg">
       <view class="status-left">
         <view class="skeleton-rect" style="width: 200rpx; height: 50rpx; margin-bottom: 16rpx;"></view>
         <view class="skeleton-rect" style="width: 400rpx; height: 32rpx;"></view>
       </view>
       <view class="skeleton-circle" style="width: 56rpx; height: 56rpx;"></view>
    </view>
    
    <!-- Action Skeleton -->
    <view class="action-card card skeleton-bg" style="height: 140rpx;"></view>

    <!-- Merchant/Items Skeleton -->
    <view class="order-card card skeleton-bg" style="padding: 24rpx;">
       <view class="skeleton-rect" style="width: 300rpx; height: 40rpx; margin-bottom: 32rpx;"></view>
       <list-skeleton wx:for="{{[1,2]}}" wx:key="*this" showAvatar="{{true}}" />
       <view class="total-row" style="margin-top: 20rpx; justify-content: flex-end;">
          <view class="skeleton-rect" style="width: 150rpx; height: 40rpx;"></view>
       </view>
    </view>

    <!-- Info Card Skeleton -->
    <view class="info-card card skeleton-bg">
        <view class="skeleton-rect" style="width: 120rpx; height: 36rpx; margin-bottom: 24rpx;"></view>
        <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-rect" style="width: 100%; height: 60rpx; margin-bottom: 16rpx;"></view>
    </view>
  </view>

  <!-- 3. 正常内容 -->
  <view wx:if="{{order}}" class="detail-content animate-fade-in">
  <view wx:if="{{refreshErrorMessage}}" class="inline-banner inline-banner-danger">
      <text class="inline-banner-text">{{refreshErrorMessage}}</text>
      <text class="inline-banner-action" bindtap="onRetryRefresh">重新同步</text>
    </view>

    <view wx:if="{{cancelRefundExpected && (cancelRefundPending || cancelRefundId)}}" class="inline-banner inline-banner-warning">
      <text class="inline-banner-text">{{cancelRefundStatusText}}：{{cancelRefundHint}}</text>
      <text wx:if="{{cancelRefundActionText && cancelRefundId}}" class="inline-banner-action" bindtap="onViewCancelRefundDetail">{{cancelRefundActionText}}</text>
    </view>

    <!-- 顶部状态区 -->
    <view class="status-header">
      <view class="status-left">
        <view class="status-title">{{order.statusText}}</view>
        <view class="status-desc">{{statusHeaderDesc}}</view>
      </view>
      <t-icon name="{{statusHeaderIcon}}" size="56rpx" color="#333" />
    </view>

    <!-- 操作引导区 (如去支付/物流) -->
    <view wx:if="{{showPayButton || showTrackingButton}}" class="action-card card">
       <view class="action-content">
          <view class="action-text">
            <text wx:if="{{showPayButton}}">订单等待支付，请在15分钟内完成</text>
            <text wx:if="{{showTrackingButton}}">骑手正在为您代取中</text>
          </view>
          <t-button wx:if="{{showPayButton}}" theme="primary" size="small" shape="round" loading="{{paying}}" disabled="{{paying}}" bindtap="onPayOrder">立即支付</t-button>
          <t-button wx:if="{{showTrackingButton}}" size="small" shape="round" bindtap="onViewTracking">查看进度</t-button>
       </view>
    </view>

    <!-- 打包自取：取餐码展示 -->
    <view wx:if="{{order.type === 'takeaway' && orderDTO.pickup_code_masked}}" class="pickup-card card" style="text-align: center; padding: 40rpx 0;">
      <view style="font-size: 28rpx; color: #666; margin-bottom: 16rpx;">取餐码</view>
      <view style="font-size: 64rpx; font-weight: bold; color: var(--brand-primary, #FF6B00);">{{orderDTO.pickup_code_masked}}</view>
    </view>

    <!-- 商品明细卡片 -->
    <view class="order-card card">
      <!-- 商户头 -->
      <view class="merchant-header" bindtap="onEnterMerchant" data-id="{{order.merchantId}}" hover-class="hover-opacity">
        <view class="merchant-info">
           <text class="merchant-name">{{order.merchantName}}</text>
           <t-icon name="chevron-right" size="32rpx" color="#999" />
        </view>
        <t-icon name="call" size="40rpx" catchtap="onCallMerchant" color="var(--td-brand-color)" />
      </view>
      
      <t-divider />

      <!-- 商品列表 -->
      <view class="item-list">
        <view wx:for="{{order.items}}" wx:key="id" class="order-item">
          <t-image src="{{item.imageUrl}}" mode="aspectFill" width="112rpx" height="112rpx" shape="round" class="item-img" />
          <view class="item-main">
            <view class="item-row-1">
              <view class="item-name">{{item.name}}</view>
              <view class="item-price">{{item.unitPriceDisplay}}</view>
            </view>
            <view class="item-row-2">
              <view class="item-specs">
                <t-tag wx:for="{{item.customizations}}" wx:key="*this" wx:for-item="cust" size="extra-small" variant="dark" theme="default" shape="round">{{cust}}</t-tag>
              </view>
              <view class="item-qty">x{{item.quantity}}</view>
            </view>
          </view>
        </view>
      </view>

      <t-divider dashed />

      <!-- 费用详情 -->
      <view class="fee-list">
        <view class="fee-row" wx:if="{{order.type === 'takeout'}}">
           <text>代取费</text>
           <view class="price-group">
             <text wx:if="{{order.deliveryFeeDiscount}}" class="discount-price">{{order.deliveryFeeDiscountDisplay}}</text>
             <text>{{order.deliveryFeeDisplay}}</text>
           </view>
        </view>
        <view class="fee-row" wx:if="{{order.discountAmount > 0}}">
           <text>优惠合计</text>
           <text class="highlight-red">{{order.discountAmountDisplay}}</text>
        </view>
      </view>

      <view class="total-row">
         <text class="total-label">实付</text>
         <text class="total-price">{{order.payableAmountDisplay}}</text>
      </view>
    </view>

    <!-- 代取/预订信息卡片 -->
    <view class="info-card card">
      <view class="card-title">代取信息</view>
      
      <t-cell-group>
        <block wx:if="{{order.type === 'takeout'}}">
          <t-cell title="送达地址" note="{{order.address}}" align="top" t-class-note="address-note" />
          <t-cell title="联系人" note="{{order.contactName}} {{order.contactPhone}}" />
          <t-cell title="代取时间" note="{{order.expectDeliverTime || '立即代取'}}" />
        </block>

        <block wx:if="{{order.type === 'reservation'}}">
           <t-cell title="预订桌台" note="{{reservationInfo.table_no || '待分配'}}" />
           <t-cell title="预订时间" note="{{reservationInfo.reservation_date}} {{reservationInfo.reservation_time}}" />
           <t-cell title="预订人数" note="{{reservationInfo.guest_count}}人" />
           <t-cell title="预订人" note="{{reservationInfo.contact_name}} {{reservationInfo.contact_phone}}" />
        </block>

         <block wx:if="{{order.type === 'dine_in'}}">
           <t-cell title="就餐桌号" note="#{{order.tableId || '--'}}" />
           <t-cell title="就餐人数" note="{{order.guestCount || '--'}}人" />
         </block>
      </t-cell-group>
    </view>

    <!-- 订单信息卡片 -->
    <view class="info-card card">
      <view class="card-title">订单信息</view>
      <t-cell-group>
        <t-cell title="订单号码" note="{{order.orderNo}}" hover arrow bindtap="onCopy" data-text="{{order.orderNo}}" />
        <t-cell title="下单时间" note="{{order.createTime}}" />
        <t-cell title="支付方式" note="{{order.paymentMethod || '在线支付'}}" />
        <t-cell wx:if="{{order.notes}}" title="备注" note="{{order.notes}}" align="top" />
      </t-cell-group>
    </view>
  </view>
</view>

<!-- 底部固定操作栏 -->
<view wx:if="{{!loading && order}}" class="bottom-bar">
   <scroll-view class="bottom-actions" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="bottom-actions-row">
      <!-- 辅助按钮 -->
      <view class="secondary-actions">
         <t-button wx:if="{{showCancelButton}}" class="bottom-action-button" size="medium" shape="round" bindtap="onCancelOrder">取消订单</t-button>
         <t-button wx:if="{{showContactButton}}" class="bottom-action-button" size="medium" icon="chat" shape="round" bindtap="onContact">联系客服</t-button>
        <t-button wx:if="{{showFoodSafetyButton}}" class="bottom-action-button" size="medium" icon="error-circle" shape="round" bindtap="onReportFoodSafety">食安反馈</t-button>
      </view>

      <!-- 主要按钮 -->
      <view class="primary-actions">
         <t-button wx:if="{{showPayButton}}" class="bottom-action-button" theme="primary" size="medium" shape="round" loading="{{paying}}" disabled="{{paying}}" bindtap="onPayOrder">去支付</t-button>
         <t-button wx:if="{{showUrgeButton}}" class="bottom-action-button" theme="primary" size="medium" shape="round" bindtap="onUrgeOrder" disabled="{{urgeCountdown > 0}}">{{urgeCountdown > 0 ? urgeCountdown + 's' : '催单'}}</t-button>
         <t-button wx:if="{{showConfirmButton}}" class="bottom-action-button" theme="primary" size="medium" shape="round" bindtap="onConfirmReceipt">确认收货</t-button>
        <t-button wx:if="{{showPickupConfirmButton}}" class="bottom-action-button" theme="primary" size="medium" shape="round" bindtap="onConfirmReceipt">我已取餐</t-button>
         <t-button wx:if="{{showReviewButton}}" class="bottom-action-button" theme="primary" size="medium" shape="round" bindtap="onReview">{{isReviewed ? '查看评价' : '发表评价'}}</t-button>
        <t-button wx:if="{{showReorderButton}}" class="bottom-action-button" theme="primary" size="medium" shape="round" bindtap="onReorder">再来一单</t-button>
      </view>
    </view>
   </scroll-view>
  <t-toast id="t-toast" />
</view>

<t-dialog
  visible="{{showCancelDialog}}"
  title="取消订单"
  confirm-btn="{{ { content: cancelSubmitting ? '提交中...' : '确认取消', theme: 'danger', loading: cancelSubmitting } }}"
  cancel-btn="暂不取消"
  bind:confirm="confirmCancelOrder"
  bind:cancel="onCloseCancelDialog"
>
  <view slot="content" class="dialog-content">
    <view class="dialog-tips">{{cancelRefundExpected ? '已支付订单取消后，退款会异步处理并原路返回。' : '取消后订单会立即关闭。'}}</view>
    <t-radio-group value="{{cancelReason}}" bind:change="onCancelReasonChange">
      <t-radio wx:for="{{cancelReasons}}" wx:key="*this" value="{{item}}" label="{{item}}" />
    </t-radio-group>
  </view>
</t-dialog>
