<custom-navbar title="配送追踪" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page" style="padding-top: {{navBarHeight}}px;">
  <!-- 1. 错误状态 -->
  <view wx:if="{{isError}}" class="error-container">
    <t-empty icon="info-circle" description="{{errorMsg}}" />
    <t-button theme="primary" variant="outline" size="small" bindtap="loadDeliveryData" style="margin-top: 24rpx;">重试</t-button>
  </view>

  <!-- 2. 骨架屏加载 -->
  <view wx:elif="{{loading && !delivery}}" class="skeleton-container">
    <!-- Map Skeleton -->
    <view class="hero-card skeleton-bg" style="height: 500rpx; background: #e0e0e0;"></view>
    
    <!-- Status Skeleton -->
    <view class="status-card skeleton-bg" style="margin-top: -60rpx; position: relative; z-index: 1;">
       <view class="skeleton-rect" style="width: 200rpx; height: 48rpx; margin-bottom: 16rpx;"></view>
       <view class="skeleton-rect" style="width: 350rpx; height: 32rpx;"></view>
    </view>
    
    <!-- Rider Skeleton -->
    <view class="rider-card skeleton-bg">
       <view style="display: flex; align-items: center;">
          <view class="skeleton-circle" style="width: 80rpx; height: 80rpx; margin-right: 20rpx;"></view>
          <view style="flex: 1;">
             <view class="skeleton-rect" style="width: 150rpx; height: 32rpx; margin-bottom: 12rpx;"></view>
             <view class="skeleton-rect" style="width: 200rpx; height: 28rpx;"></view>
          </view>
       </view>
    </view>
    
    <!-- Progress Skeleton -->
    <view class="progress-card skeleton-bg">
        <view class="skeleton-rect" style="width: 120rpx; height: 36rpx; margin-bottom: 24rpx;"></view>
        <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-rect" style="width: 100%; height: 80rpx; margin-bottom: 24rpx;"></view>
    </view>
  </view>

  <!-- 3. 正常内容 -->
  <block wx:elif="{{delivery}}">
    <!-- 地图 -->
    <view class="hero-card">
      <map
        id="routeMap"
        class="hero-map"
        longitude="{{mapCenter.longitude}}"
        latitude="{{mapCenter.latitude}}"
        scale="{{scale}}"
        markers="{{markers}}"
        polyline="{{polyline}}"
        include-points="{{includePoints}}"
        show-location
        enable-3D
        enable-zoom
        enable-scroll
      />
    </view>

    <!-- 配送状态 -->
    <view class="status-card animate-slide-up">
      <view class="status-main">
        <t-icon name="delivery" size="48rpx" color="#1d63ff" />
        <view class="status-text">{{deliveryStatusText}}</view>
      </view>
      <view class="eta">预计 {{estimatedDeliveryTime}} 送达</view>
    </view>

    <!-- 骑手信息 -->
    <view class="rider-card animate-slide-up" wx:if="{{riderPhone}}" style="animation-delay: 0.1s;">
      <view class="rider-info">
        <image class="avatar" src="/assets/rider.png" mode="aspectFill" />
        <view>
          <view class="rider-name">{{riderName}}</view>
          <view class="rider-desc">{{riderPhoneDisplay}}</view>
        </view>
      </view>
      <view class="rider-actions">
        <button class="primary" bindtap="onCallRider">联系骑手</button>
      </view>
    </view>

    <!-- 配送进度 -->
    <view class="progress-card animate-slide-up" style="animation-delay: 0.2s;">
      <view class="card-title">配送进度</view>
      <view class="progress-list">
        <view 
          wx:for="{{progress}}" 
          wx:key="title" 
          class="progress-item {{item.done ? 'done' : ''}} {{item.active ? 'active' : ''}}"
        >
          <view class="progress-dot"></view>
          <view class="progress-line" wx:if="{{index < progress.length - 1}}"></view>
          <view class="progress-content">
            <view class="progress-title">{{item.title}}</view>
            <view class="progress-time" wx:if="{{item.time}}">{{item.time}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 配送地址 -->
    <view class="address-card animate-slide-up" style="animation-delay: 0.3s;">
      <view class="address-row">
        <view class="address-icon merchant"></view>
        <view class="address-info">
          <view class="address-label">取餐地址</view>
          <view class="address-text">{{delivery.pickup_address}}</view>
        </view>
      </view>
      <view class="address-row">
        <view class="address-icon customer"></view>
        <view class="address-info">
          <view class="address-label">送餐地址</view>
          <view class="address-text">{{delivery.delivery_address}}</view>
        </view>
      </view>
    </view>

    <!-- 刷新按钮 -->
    <view class="refresh-btn" bindtap="onRefresh">
      <t-icon name="refresh" size="32rpx" />
      <text>刷新位置</text>
    </view>
  </block>

  <!-- 无配送信息 -->
  <view wx:elif="{{!loading && !delivery}}" class="empty">
    <t-empty description="暂无配送信息" />
  </view>
</view>
