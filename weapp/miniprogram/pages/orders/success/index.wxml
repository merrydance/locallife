<custom-navbar title="{{navTitle}}" showBack="{{false}}" />

<view class="container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view class="success-wrap">
    <t-result
      theme="{{resultTheme}}"
      title="{{successTitle}}"
      description="{{successDescription}}"
    />

    <view class="status-note" wx:if="{{statusNote}}">
      <text class="status-note-text">{{statusNote}}</text>
    </view>

    <view class="order-info-card">
      <view class="info-item">
        <text class="label">支付金额</text>
        <text class="value price">¥{{amount}}</text>
      </view>
      <view class="info-item">
        <text class="label">{{businessType === 'reservation' ? '预订编号' : '订单编号'}}</text>
        <text class="value">{{orderNo}}</text>
      </view>
      <view class="info-item" wx:if="{{businessType === 'reservation' && statusText}}">
        <text class="label">当前状态</text>
        <text class="value">{{statusText}}</text>
      </view>
    </view>

    <view class="action-btns">
      <t-button theme="primary" block size="large" shape="round" loading="{{stateLoading || refreshing}}" bindtap="onPrimaryAction">{{primaryButtonText}}</t-button>
      <t-button theme="default" block size="large" shape="round" bindtap="onSecondaryAction" style="margin-top: 32rpx;">{{secondaryButtonText}}</t-button>
    </view>
  </view>

  <view class="recommend-section">
     <view class="section-title">{{businessType === 'reservation' ? '结果说明' : '可能感兴趣'}}</view>
     <view class="recommend-tips">{{hintText}}</view>
  </view>
</view>
