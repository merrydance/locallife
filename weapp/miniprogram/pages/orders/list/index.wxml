<custom-navbar title="{{pageTitle}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page" style="padding-top: {{navBarHeight}}px">
  <!-- 顶部状态栏 -->
  <view class="tabs-wrapper">
    <t-tabs value="{{currentStatus}}" bind:change="onStatusChange" theme="tag" space-evenly="{{false}}" split="{{false}}">
      <t-tab-panel wx:for="{{statusTabs}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" />
    </t-tabs>
    <view wx:if="{{currentStatus === 'pending' && pendingPayableCount > 1}}" class="batch-toolbar">
      <t-button size="small" variant="outline" shape="round" bindtap="onToggleSelectAllPending">
        {{selectedPayCount === pendingPayableCount ? '取消全选' : '全选待支付'}}
      </t-button>
      <text class="batch-tip">已选{{selectedPayCount}}单</text>
      <t-button size="small" theme="primary" shape="round" bindtap="onBatchPay" disabled="{{selectedPayCount === 0 || paying}}">
        合并支付
      </t-button>
    </view>
  </view>

  <!-- 列表内容 -->
  <view class="order-list">
    <!-- 1. 错误状态 -->
    <view wx:if="{{isError}}" class="error-container">
      <t-empty icon="info-circle" description="{{errorMsg}}" />
      <t-button theme="primary" variant="outline" size="small" bindtap="loadOrders" data-retry="true" style="margin-top: 24rpx;" shape="round">重试</t-button>
    </view>

    <!-- 2. 骨架屏加载 (App Shell + Skeleton) -->
    <view wx:elif="{{loading && orders.length === 0}}">
      <list-skeleton wx:for="{{[1,2,3,4,5]}}" wx:key="*this" showAvatar="{{false}}" />
    </view>

    <!-- 3. 正常数据 -->
    <block wx:else>
      <!-- 空状态 -->
      <view wx:if="{{orders.length === 0}}" class="empty-state">
        <t-empty icon="order-adjustment" description="暂无相关订单" />
      </view>

      <!-- 订单卡片 -->
      <view class="order-card" wx:for="{{orders}}" wx:key="uniqueId" bindtap="onViewOrder" data-id="{{item.id}}" hover-class="order-card-hover">
        <!-- 头部：商户信息 + 状态 -->
        <view class="card-header">
          <view class="merchant-info">
            <text class="merchant-name">{{item.merchantName}}</text>
            <t-icon name="chevron-right" size="32rpx" color="#999" />
          </view>
          <view class="status-tag {{item.statusClass}}">{{item.statusLabel}}</view>
        </view>

        <!-- 内容区：商品预览 -->
        <view class="card-content">
          <!-- 单商品展示 -->
          <view wx:if="{{item.previewItems.length === 1}}" class="single-item">
            <t-image src="{{item.previewItems[0].imageUrl}}" mode="aspectFill" width="140rpx" height="140rpx" shape="round" class="item-img" />
            <view class="item-details">
              <view class="item-name">{{item.previewItems[0].dishName}}</view>
              <!-- 预留规格展示 -->
              <!-- <view class="item-specs">具体规格</view> -->
            </view>
            <view class="item-qty">x{{item.previewItems[0].quantity}}</view>
          </view>

          <!-- 多商品展示 -->
          <view wx:else class="multi-items">
            <scroll-view scroll-x class="item-scroll" enable-flex catchtap="preventBubble">
              <view class="scroll-inner">
                <view wx:for="{{item.previewItems}}" wx:for-item="dish" wx:key="dishId" class="scroll-item">
                  <t-image src="{{dish.imageUrl}}" mode="aspectFill" width="140rpx" height="140rpx" shape="round" />
                  <view class="item-sub-name">{{dish.dishName}}</view>
                </view>
              </view>
            </scroll-view>
            <view class="item-summary">
              <view class="summary-price">
                 <text class="price-num">{{item.totalDisplay}}</text>
              </view>
              <view class="summary-count">共{{item.itemCount}}件</view>
            </view>
          </view>
        </view>

        <!-- 底部：结算信息 & 操作按钮 -->
        <view class="card-footer">
          <!-- 单商品的结算信息因为布局不同，在这里统一补齐总价显示 -->
          <view wx:if="{{item.previewItems.length === 1}}" class="footer-price">
             <text class="count-label">共{{item.itemCount}}件</text>
             <text class="total-label">合计</text>
             <text class="total-val">{{item.totalDisplay}}</text>
          </view>
          <view wx:else></view> <!-- 占位撑开 -->

          <view class="footer-actions" catchtap="preventBubble">
            <t-button wx:if="{{item.canCancel}}" size="small" variant="outline" shape="round" catchtap="onCancelOrder" data-id="{{item.id}}" t-class="action-btn">取消订单</t-button>

            <t-button wx:if="{{orderType === 'dine_in' || orderType === 'reservation'}}" size="small" variant="outline" icon="call" shape="round" catchtap="onCallMerchant" data-phone="{{item.merchantPhone}}" t-class="action-btn">联系商家</t-button>

            <t-button wx:if="{{item.canPay && currentStatus === 'pending' && pendingPayableCount > 1}}" size="small" variant="outline" shape="round" catchtap="onTogglePaySelect" data-id="{{item.id}}" t-class="action-btn">
              {{selectedPayMap[item.id] ? '已选' : '选择'}}
            </t-button>
            
            <t-button wx:if="{{item.canPay}}" size="small" theme="primary" shape="round" catchtap="onPayOrder" data-id="{{item.id}}" t-class="action-btn">去支付</t-button>
            
            <t-button wx:if="{{item.canReorder}}" size="small" variant="outline" shape="round" catchtap="onReorder" data-id="{{item.id}}" t-class="action-btn">再来一单</t-button>
          </view>
        </view>
      </view>
      
      <!-- 加载更多提示 (Only show when loading more) -->
       <view class="loading-footer" wx:if="{{loading && orders.length > 0}}">
        <t-loading theme="circular" size="40rpx" text="加载中..." />
      </view>
      <view class="loading-footer" wx:elif="{{!hasMore && orders.length > 0}}">
        <view class="no-more">没有更多了</view>
      </view>
    </block>
  </view>
</view>
