@import '../../../styles/customer.wxss';

/* Pages Order List */
.page {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

.tabs-wrapper {
  background: var(--td-bg-color-container);
  position: sticky;
  top: 0;
  z-index: 100;
  padding-bottom: 8rpx;
}

.batch-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 16rpx;
}

.batch-tip {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.order-list {
  padding-top: var(--spacer-md);
}

.inline-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: 24rpx;
  border-radius: var(--radius-md);
  padding: var(--spacer-sm) var(--spacer-md);
}

.inline-banner-danger {
  background: rgba(229, 57, 53, 0.08);
  color: var(--td-error-color);
}

.inline-banner-text {
  flex: 1;
  font-size: var(--font-size-sm);
  line-height: 1.6;
}

.inline-banner-action {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--td-brand-color);
}

.empty-state {
  margin-top: 120rpx;
}

/* Order Card */
.order-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: opacity 0.16s ease;
}

.order-card-main {
  border-radius: var(--radius-sm);
}

.order-card-hover {
  opacity: 0.72;
}

/* Header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.merchant-info {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.merchant-link {
  max-width: 70%;
  transition: opacity 0.16s ease;
}

.merchant-info-hover {
  opacity: 0.72;
}

.merchant-name {
  margin-right: 8rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: var(--font-size-xs);
  font-weight: 500;
}

.status-tag.class-pending { color: var(--td-brand-color); background: var(--td-brand-color-light); }
.status-tag.class-preparing { color: var(--td-success-color); background: var(--td-success-color-light); }
.status-tag.class-ready { color: var(--td-brand-color-9); background: var(--td-brand-color-1); }
.status-tag.class-delivering { color: var(--td-brand-color-9); background: var(--td-brand-color-1); }
.status-tag.class-completed { color: var(--td-text-color-placeholder); background: var(--td-bg-color-secondarycontainer); }
.status-tag.class-cancelled { color: var(--td-text-color-disabled); background: var(--td-bg-color-secondarycontainer); }

/* Content: Compact Meta */
.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.meta-info {
  flex: 1;
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meta-highlight {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-time {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.meta-total {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  font-family: 'DIN Alternate', sans-serif;
  white-space: nowrap;
}

/* Footer */
.card-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.footer-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 26rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 24rpx !important;
}

.loading-footer {
  padding: 32rpx 0;
  text-align: center;
}

.no-more {
  color: var(--td-text-color-disabled);
  font-size: 24rpx;
}

.error-container {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: var(--td-bg-color-page);
}
