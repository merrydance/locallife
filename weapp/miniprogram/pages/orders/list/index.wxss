.page {
  height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 0 64rpx;
  background: #f2f3f7;
}

.tabs-container {
  padding: 0 0 16rpx;
}

.order-list {
  padding: 0 24rpx 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.merchant-block {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.merchant {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2430;
}

.order-id {
  font-size: 24rpx;
  color: #9ba3b4;
}

.status-pill {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  min-width: 120rpx;
  text-align: center;
}

.status-pill.pending {
  background: #ffe5cc;
  color: #c25a00;
}

.status-pill.preparing {
  background: #e7f0ff;
  color: #0f5ac1;
}

.status-pill.ready {
  background: #fff4d6;
  color: #a06a00;
}

.status-pill.delivering {
  background: #e8f7ff;
  color: #0d74b8;
}

.status-pill.completed {
  background: #e9f7ef;
  color: #0f7a3d;
}

.status-pill.cancelled {
  background: #f2f3f5;
  color: #7a8190;
}

.status-hint {
  margin-bottom: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f6f8ff;
  color: #31394b;
  font-size: 26rpx;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef1ff;
  color: #4a5fe0;
  font-size: 22rpx;
}

.preview-list {
  border-top: 1rpx dashed #edf0fb;
  border-bottom: 1rpx dashed #edf0fb;
  padding: 14rpx 0;
  margin-bottom: 12rpx;
}

.preview-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.item-thumb {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  background: #f0f2fb;
}

.name {
  flex: 1;
  font-size: 26rpx;
  color: #1f2430;
}

.count {
  font-size: 24rpx;
  color: #9aa4c2;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 6rpx;
  margin-bottom: 18rpx;
  color: #6b7384;
  font-size: 26rpx;
}

.total {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2430;
}

.btn-row {
  display: flex;
  justify-content: center;
}

.primary-btn {
  width: 100%;
  height: 86rpx;
  border-radius: 999rpx;
  border: none;
  background: #e9ecf9;
  color: #1f2430;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-btn::after {
  border: none;
}

.empty {
  padding-top: 200rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
}

.loading-footer {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.no-more {
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

/* 骨架屏 */
.skeleton-container {
  padding: 48rpx 32rpx;
}

.card.skeleton {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.skeleton-line {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

@keyframes loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
