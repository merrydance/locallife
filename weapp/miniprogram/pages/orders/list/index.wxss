/* Pages Order List */
.page {
  background-color: var(--td-bg-color-page, #f6f6f6);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabs-wrapper {
  background: var(--td-bg-color-container, #fff);
  position: sticky;
  top: 0;
  z-index: 100;
  padding-bottom: 8rpx;
}

.batch-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx 16rpx;
}

.batch-tip {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #666);
}

.order-list {
  padding: 24rpx;
}

.empty-state {
  margin-top: 120rpx;
}

/* Order Card */
.order-card {
  background: var(--td-bg-color-container, #fff);
  border-radius: var(--radius-md, 16rpx);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}

.order-card-hover {
  transform: scale(0.99);
  background-color: #fafafa;
}

/* Header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.merchant-info {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.merchant-name {
  margin-right: 8rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 26rpx;
  font-weight: 500;
}

.status-tag.class-pending { color: var(--td-brand-color, #FF6B58); }
.status-tag.class-preparing { color: #2ba471; } 
.status-tag.class-delivering { color: #0052d9; }
.status-tag.class-completed { color: #999; }
.status-tag.class-cancelled { color: #bbb; }

/* Content: Single Item */
.single-item {
  display: flex;
  margin-bottom: 20rpx;
}

.item-img {
  flex-shrink: 0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
}

.item-details {
  flex: 1;
  margin-left: 16rpx;
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-specs {
  font-size: 24rpx;
  color: #999;
}

.item-qty {
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
}

/* Content: Multi Items */
.multi-items {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-scroll {
  flex: 1;
  white-space: nowrap;
  margin-right: 24rpx;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
}

.scroll-item {
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
}

.item-sub-name {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.item-summary {
  text-align: right;
  min-width: 120rpx;
}

.summary-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.summary-count {
  font-size: 24rpx;
  color: #999;
}

/* Footer */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 12rpx;
  /* border-top: 1rpx solid #f5f5f5; optional */
}

.footer-price {
  font-size: 26rpx;
  color: #333;
  display: flex;
  align-items: baseline;
}

.count-label {
  color: #999;
  margin-right: 12rpx;
}

.total-label {
  margin-right: 4rpx;
  font-weight: bold;
}

.total-val {
  font-size: 32rpx;
  font-weight: bold;
  font-family: 'DIN Alternate', sans-serif; /* Number font */
}

.footer-actions {
  display: flex;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
}

.action-btn {
  font-size: 26rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 24rpx !important;
}

.loading-footer {
  padding: 32rpx 0;
  text-align: center;
}

.no-more {
  color: #bbb;
  font-size: 24rpx;
}

.error-container {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: var(--td-bg-color-page);
}
