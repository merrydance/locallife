/* 预订页面 - 严格遵循 Design System $v1.0 */

.page-scroll {
  background-color: var(--td-bg-color-page);
  box-sizing: border-box;
}

/* 顶部栏：搜索 + 过滤 */
.top-bar {
  display: flex;
  align-items: center;
  padding: 0 var(--spacer-md) var(--spacer-sm);
  background: var(--td-bg-color-page);
  gap: var(--spacer-sm);
  position: sticky;
  top: 0;
  z-index: var(--z-index-sticky);
}

.filter-btn-new {
  flex-shrink: 0;
}

.search-box {
  flex: 1;
}

/* 选项卡区域 */
.tabs-section {
  background: var(--td-bg-color-page);
  margin-bottom: var(--spacer-xs);
}

/* 内容列表区域 */
.content-section {
  display: flex;
  flex-direction: column;
  padding: var(--spacer-sm) var(--spacer-md) var(--spacer-lg);
  gap: var(--spacer-sm);
}

.loading-more {
  display: flex;
  justify-content: center;
  padding: var(--spacer-lg) 0;
  color: var(--td-text-color-secondary);
}

.no-more {
  text-align: center;
  padding: var(--spacer-lg) 0;
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-sm);
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md) 0;
}

/* 筛选侧边栏 (Drawer) */
.filter-drawer {
  width: 620rpx;
  height: 100vh;
  background: var(--td-bg-color-container);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-md) var(--spacer-lg);
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
  flex-shrink: 0;
}

.drawer-title {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.drawer-content {
  flex: 1;
  padding: var(--spacer-lg) var(--spacer-md);
}

.filter-group {
  margin-bottom: var(--spacer-lg);
}

.group-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

/* 侧边栏底部按钮 */
.drawer-footer {
  display: flex;
  gap: var(--spacer-md);
  padding: var(--spacer-md) var(--spacer-md) calc(var(--spacer-md) + var(--safe-area-bottom));
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
  flex-shrink: 0;
  background: var(--td-bg-color-container);
}

.drawer-footer .t-button {
  flex: 1;
}
