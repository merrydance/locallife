<custom-navbar title="包间详情" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: 140rpx;">
  <block wx:if="{{loading}}">
     <view style="padding: 24rpx;">
       <card-skeleton wx:for="{{[1,2,3]}}" wx:key="*this" />
     </view>
  </block>

  <view wx:elif="{{isError}}" class="error-container" style="padding-top: 200rpx; display: flex; flex-direction: column; align-items: center; gap: 32rpx;">
     <t-empty icon="error-circle" description="{{errorMessage}}" />
     <t-button theme="primary" size="medium" bindtap="onRetry" shape="round" variant="outline">重试</t-button>
  </view>

  <view wx:elif="{{room}}" class="content-view">
    <!-- 轮播图卡片 -->
    <view class="swiper-container">
      <t-swiper 
        wx:if="{{room.images.length > 0}}"
        list="{{room.images}}"
        autoplay="{{true}}"
        duration="{{300}}"
        interval="{{3000}}"
        navigation="{{ { type: 'dots' } }}"
        height="{{480}}"
      />
    </view>

    <!-- 基本信息卡片 -->
    <view class="info-section card">
      <view class="header-row">
        <text class="room-name">{{room.name}}</text>
        <t-tag theme="success" variant="light" shape="round">可预订</t-tag>
      </view>
      <view class="detail-row">
        <text class="label">最高容纳</text>
        <text class="value">{{room.capacity}} 人</text>
      </view>
      <view class="detail-row">
        <text class="label">最低消费</text>
        <text class="value price">¥{{room.minSpendDisplay}}</text>
      </view>
      <view class="detail-row">
        <text class="label">预约保证金</text>
        <text class="value">¥{{room.depositDisplay}}</text>
      </view>
    </view>

    <!-- 设施服务卡片 -->
    <view class="facilities-section card" wx:if="{{room.facilities.length > 0}}">
      <view class="section-title">
        <t-icon name="service" size="36rpx" />
        <text>设施服务</text>
      </view>
      <view class="facilities-grid">
        <view wx:for="{{room.facilities}}" wx:key="*this" class="facility-item">
          <t-icon name="check-circle" size="40rpx" color="var(--td-success-color)" />
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 预约详情卡片 -->
    <view class="calendar-section card">
      <view class="section-title">
        <t-icon name="calendar" size="36rpx" />
        <text>预订档期</text>
        <text class="month-label">{{currentMonth}}</text>
      </view>
      
      <t-loading wx:if="{{loadingDates}}" theme="circular" size="32rpx" />
      
      <view class="calendar-grid" wx:if="{{!loadingDates && calendarDays.length > 0}}">
        <!-- 日历表头 -->
        <view class="calendar-header">
          <view class="header-cell empty"></view>
          <view class="header-cell" wx:for="{{calendarDays}}" wx:key="date">
            <text class="day-label">{{item.dayLabel}}</text>
            <text class="date-num">{{item.dateNum}}</text>
          </view>
        </view>
        
        <!-- 午餐排期 -->
        <view class="calendar-row">
          <view class="row-label">午餐</view>
          <view 
            class="calendar-cell" 
            wx:for="{{calendarDays}}" 
            wx:key="date"
            bindtap="onCellTap"
            data-date="{{item.date}}"
            data-type="lunch"
            data-available="{{item.lunchAvailable}}"
          >
            <t-icon 
              name="{{item.lunchAvailable ? 'check-circle-filled' : 'close-circle-filled'}}" 
              size="40rpx" 
              color="{{item.lunchAvailable ? 'var(--td-success-color)' : 'var(--td-error-color)'}}" 
            />
          </view>
        </view>
        
        <!-- 晚餐排期 -->
        <view class="calendar-row">
          <view class="row-label">晚餐</view>
          <view 
            class="calendar-cell" 
            wx:for="{{calendarDays}}" 
            wx:key="date"
            bindtap="onCellTap"
            data-date="{{item.date}}"
            data-type="dinner"
            data-available="{{item.dinnerAvailable}}"
          >
            <t-icon 
              name="{{item.dinnerAvailable ? 'check-circle-filled' : 'close-circle-filled'}}" 
              size="40rpx" 
              color="{{item.dinnerAvailable ? 'var(--td-success-color)' : 'var(--td-error-color)'}}" 
            />
          </view>
        </view>
      </view>
      
      <!-- 预定状态图例 -->
      <view class="legend">
        <view class="legend-item">
          <t-icon name="check-circle-filled" size="28rpx" color="var(--td-success-color)" />
          <text>可预订</text>
        </view>
        <view class="legend-item">
          <t-icon name="close-circle-filled" size="28rpx" color="var(--td-error-color)" />
          <text>已约满</text>
        </view>
      </view>
    </view>

    <!-- 包间详述卡片 -->
    <view class="desc-section card" wx:if="{{room.description}}">
      <view class="section-title">
        <t-icon name="info-circle" size="36rpx" />
        <text>包间介绍</text>
      </view>
      <text class="desc-text">{{room.description}}</text>
    </view>
  </view>
</view>

<!-- 底部操作栏 -->
<view wx:if="{{!loading && !isError && room}}" class="bottom-bar">
  <t-button block theme="primary" size="large" shape="round" bindtap="onBook">立即预订包间</t-button>
</view>
