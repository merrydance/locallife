@import '../../../styles/customer.wxss';

.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

/* 轮播图容器 */
.swiper-container {
  margin: var(--spacer-md);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.swiper {
  width: 100%;
  height: 480rpx;
}

/* 卡片通用样式 */
.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.info-section {
  display: flex;
  flex-direction: column;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-md);
}

.header-row-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.share-btn-reset {
  padding: 0;
  margin: 0;
  line-height: normal;
  background: none;
  border: none;
  overflow: visible;
}

.share-btn-reset::after {
  border: none;
}

.share-icon-box {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--td-brand-color-light);
  border-radius: var(--radius-round);
}

.room-name {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-sm) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.detail-row:last-child {
  border-bottom: none;
}

.label {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
}

.value {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.value.price {
  color: var(--td-brand-color);
  font-weight: bold;
  font-size: var(--font-size-heading);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-md);
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

/* 设施服务 */
.facilities-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacer-sm);
}

.facility-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-xs);
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-secondary);
  text-align: center;
}

/* 日历区块 */
.month-label {
  font-size: var(--font-size-xs);
  font-weight: normal;
  color: var(--td-text-color-placeholder);
  margin-left: auto;
}

.calendar-grid {
  background: var(--td-bg-color-secondarycontainer);
  border-radius: var(--radius-sm);
  padding: var(--spacer-sm);
  margin-top: var(--spacer-sm);
}

.calendar-header {
  display: flex;
  padding-bottom: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
  border-bottom: 2rpx solid var(--td-bg-color-container);
}

.header-cell {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-cell.empty {
  width: 80rpx;
  flex: none;
}

.day-label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.date-num {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-top: 4rpx;
}

.calendar-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacer-xs);
}

.calendar-row:last-child {
  margin-bottom: 0;
}

.row-label {
  width: 80rpx;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  text-align: center;
  font-weight: 500;
}

.calendar-cell {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--spacer-sm) 0;
}

.legend {
  display: flex;
  justify-content: center;
  gap: var(--spacer-xl);
  margin-top: var(--spacer-lg);
  padding-top: var(--spacer-md);
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

/* 描述 */
.desc-text {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacer-sm) var(--spacer-md);
  padding-bottom: calc(var(--spacer-sm) + env(safe-area-inset-bottom));
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-md);
  z-index: var(--z-index-fixed);
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
}

