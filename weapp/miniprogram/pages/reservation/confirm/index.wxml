<custom-navbar title="确认预定" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 120rpx;">
  <!-- 房间信息 -->
  <view class="room-info">
    <text class="room-name">{{roomName}}</text>
    <text class="room-capacity">可容纳{{capacity}}人</text>
  </view>

  <!-- 预定表单 -->
  <view class="form-section">
    <t-cell-group title="预定信息">
      <t-cell title="日期" arrow hover note="{{form.date || '请选择日期'}}" bindtap="showDatePicker" />
      <t-cell 
        title="预计到店时间" 
        arrow 
        hover 
        note="{{loadingSlots ? '加载中...' : (selectedTimeLabel || '请选择时间')}}" 
        bindtap="showTimePicker"
        disabled="{{loadingSlots || availableTimeSlots.length === 0}}"
      />
      <t-cell title="人数">
        <t-stepper value="{{form.guestCount}}" min="1" max="{{capacity}}" bind:change="onGuestCountChange" slot="note" />
      </t-cell>
    </t-cell-group>

    <t-cell-group title="联系人信息" style="margin-top: 24rpx;">
      <t-input label="姓名" placeholder="请输入姓名" value="{{form.name}}" data-field="name" bindchange="onInputChange" />
      <t-input label="手机号" placeholder="请输入手机号" type="number" value="{{form.phone}}" data-field="phone" bindchange="onInputChange" />
      <t-input label="备注" placeholder="如有特殊需求请备注" value="{{form.remark}}" data-field="remark" bindchange="onInputChange" />
    </t-cell-group>

    <view class="task-summary-card">
      <view class="task-summary-title">当前步骤</view>
      <view class="task-summary-row">
        <text class="task-summary-label">本步将完成</text>
        <text class="task-summary-value">{{paymentMode === 'deposit' ? '提交预订并拉起定金支付' : '提交预订并进入点菜页'}}</text>
      </view>
      <view class="task-summary-row">
        <text class="task-summary-label">下一步</text>
        <text class="task-summary-desc">{{paymentMode === 'deposit' ? '支付结果会继续由结果页和预订详情页承接' : '进入点菜页后再确认菜品和后续支付'}}</text>
      </view>
    </view>
  </view>

    <view class="price-section">
      <view class="price-row">
        <text class="price-row-label">{{paymentMode === 'deposit' ? '应付定金' : '本步费用'}}</text>
        <text class="price-row-value">{{paymentMode === 'deposit' ? '¥' + depositDisplay : '无需支付'}}</text>
      </view>
      <view class="price-row" wx:if="{{paymentMode === 'deposit'}}">
        <text class="price-row-label">支付方式</text>
        <text class="price-row-value">提交后拉起微信支付</text>
      </view>
    </view>

  <!-- 支付提示 -->
  <view class="payment-tip">
    <t-icon name="info-circle" size="32rpx" color="#999" />
    <text>{{paymentMode === 'deposit' ? '提交预订后需在30分钟内完成支付，否则预订将自动取消。' : '本页只负责提交预订并进入点菜，后续金额和支付以点菜链路为准。'}}</text>
  </view>
</view>

<!-- 底部提交栏 -->
<view class="bottom-bar">
  <t-button theme="primary" size="large" block loading="{{submitting}}" bindtap="onSubmit" shape="round">
    {{paymentMode === 'deposit' ? '提交预订并支付定金' : '提交预订并去点菜'}}
  </t-button>
</view>

<!-- 日期选择器 -->
<t-date-time-picker
  title="选择日期"
  visible="{{dateVisible}}"
  mode="date"
  defaultValue="{{form.date}}"
  format="YYYY-MM-DD"
  bindchange="onDateConfirm"
  bindcancel="hideDatePicker"
  start="{{minDate}}"
/>

<!-- 时间选择器（可用时段列表） -->
<t-picker
  visible="{{timePickerVisible}}"
  value="{{[0]}}"
  title="选择时段"
  cancelBtn="取消"
  confirmBtn="确定"
  bindconfirm="onTimeSelect"
  bindcancel="hideTimePicker"
>
  <t-picker-item options="{{availableTimeSlots}}" />
</t-picker>
