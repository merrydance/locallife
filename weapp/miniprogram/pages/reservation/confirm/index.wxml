<custom-navbar title="确认预定" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: 120rpx;">
  <!-- 房间信息 -->
  <view class="room-info">
    <text class="room-name">{{roomName}}</text>
    <text class="room-capacity">可容纳{{capacity}}人</text>
  </view>

  <!-- 预定表单 -->
  <view class="form-section">
    <t-cell-group title="预定信息">
      <t-cell title="日期" arrow hover note="{{form.date || '请选择日期'}}" bindtap="showDatePicker" />
      <t-cell 
        title="预计到店时间" 
        arrow 
        hover 
        note="{{loadingSlots ? '加载中...' : (selectedTimeLabel || '请选择时间')}}" 
        bindtap="showTimePicker"
        disabled="{{loadingSlots || availableTimeSlots.length === 0}}"
      />
      <t-cell title="人数">
        <t-stepper value="{{form.guestCount}}" min="1" max="{{capacity}}" bind:change="onGuestCountChange" slot="note" />
      </t-cell>
    </t-cell-group>

    <t-cell-group title="联系人信息" style="margin-top: 24rpx;">
      <t-input label="姓名" placeholder="请输入姓名" value="{{form.name}}" data-field="name" bindchange="onInputChange" />
      <t-input label="手机号" placeholder="请输入手机号" type="number" value="{{form.phone}}" data-field="phone" bindchange="onInputChange" />
      <t-input label="备注" placeholder="如有特殊需求请备注" value="{{form.remark}}" data-field="remark" bindchange="onInputChange" />
    </t-cell-group>

    <!-- 支付方式选择 (仅当需要支付定金或全款时展示) -->
    <t-cell-group title="支付方式" style="margin-top: 24rpx;" wx:if="{{paymentMode !== 'none'}}">
      <view class="payment-selector">
        <t-radio-group value="{{selectedPaymentMethod}}" bind:change="onSelectedPaymentMethodChange">
          <t-radio value="wechat" label="微信支付" icon="circle">
            <t-icon name="logo-wechat" size="40rpx" color="#07C160" slot="icon" />
          </t-radio>
          <t-radio value="balance" label="余额支付" icon="circle" disabled="{{memberBalance <= 0}}">
            <view slot="label" style="display: flex; flex-direction: column;">
              <view style="display: flex; align-items: center; gap: 8rpx;">
                <text>余额支付</text>
                <t-tag wx:if="{{memberBalance > 0 && memberBalance < (paymentMode === 'deposit' ? deposit : 0)}}" size="extra-small" theme="warning" variant="light">余额不足以全抵</t-tag>
              </view>
              <text class="balance-note" wx:if="{{memberBalanceDisplay}}">可用余额: ¥{{memberBalanceDisplay}}</text>
              <text class="balance-note" wx:else>未加入会员或无余额</text>
            </view>
            <t-icon name="wallet" size="40rpx" color="{{memberBalance <= 0 ? '#ccc' : '#FF6B00'}}" slot="icon" />
          </t-radio>
        </t-radio-group>
      </view>
    </t-cell-group>

    <!-- 商户优惠活动 -->
    <view style="margin: 24rpx;">
      <merchant-promos 
        merchantId="{{merchantId}}"
        membershipId="{{membershipId}}"
        currentBalance="{{memberBalance}}"
        orderTotal="{{calculation.total_amount}}"
        bind:recharged="onRecharged"
        bind:voucherClaimed="onVoucherClaimed"
      />
    </view>
  </view>

    <!-- 费用明细 -->
    <view class="price-section" wx:if="{{paymentMode !== 'none'}}">
      <view class="price-row">
        <text class="price-row-label">预计金额 ({{paymentMode === 'deposit' ? '定金' : '全款'}})</text>
        <text class="price-row-value">¥{{paymentMode === 'deposit' ? depositDisplay : calculation.subtotalDisplay}}</text>
      </view>
      
      <!-- 优惠明细 -->
      <view class="price-row" wx:for="{{calculation.ladder_promotions || []}}" wx:key="rule_id">
        <text class="price-row-discount-label" wx:if="{{item.current_hit}}">{{item.name}}（已满¥{{item.thresholdDisplay}}）</text>
        <text class="price-row-discount-label" wx:else>{{item.name}}（还差¥{{item.missingNeedDisplay}}）</text>
        <text class="price-row-discount-value">可减¥{{item.discountDisplay}}</text>
      </view>
      <view class="price-row" wx:for="{{calculation.applied_promotions || []}}" wx:key="title">
        <text class="price-row-label highlight-red">{{item.title}}</text>
        <text class="price-row-value highlight-red">-¥{{item.amountDisplay}}</text>
      </view>
      <view class="price-row" wx:for="{{calculation.voucher_trials || []}}" wx:key="voucher_id">
        <text class="price-row-discount-label">券试算：{{item.voucher_name}}（减¥{{item.amountDisplay}}）</text>
        <text class="price-row-discount-value">试算后¥{{item.trialPayableDisplay}}</text>
      </view>
      <view class="price-row" wx:if="{{calculation.payment_assessment && calculation.payment_assessment.payment_hint}}">
        <text class="price-row-label">支付提示</text>
        <text class="price-row-value">{{calculation.payment_assessment.payment_hint}}</text>
      </view>

      <view class="price-row price-row-total">
        <text class="price-row-total-label">最终应付</text>
        <text class="price-row-total-value">¥{{calculation.totalDisplay}}</text>
      </view>
    </view>

  <!-- 支付提示 -->
  <view class="payment-tip">
    <t-icon name="info-circle" size="32rpx" color="#999" />
    <text>提交预定后需在30分钟内完成支付，否则预定将自动取消。</text>
  </view>
</view>

<!-- 底部提交栏 -->
<view class="bottom-bar">
  <t-button theme="primary" size="large" block loading="{{submitting}}" bindtap="onSubmit" shape="round">
    {{paymentMode === 'deposit' ? '确认预定 (¥' + calculation.totalDisplay + ')' : '下一步：选择菜品'}}
  </t-button>
</view>

<!-- 日期选择器 -->
<t-date-time-picker
  title="选择日期"
  visible="{{dateVisible}}"
  mode="date"
  defaultValue="{{form.date}}"
  format="YYYY-MM-DD"
  bindchange="onDateConfirm"
  bindcancel="hideDatePicker"
  start="{{minDate}}"
/>

<!-- 时间选择器（可用时段列表） -->
<t-picker
  visible="{{timePickerVisible}}"
  value="{{[0]}}"
  title="选择时段"
  cancelBtn="取消"
  confirmBtn="确定"
  bindconfirm="onTimeSelect"
  bindcancel="hideTimePicker"
>
  <t-picker-item options="{{availableTimeSlots}}" />
</t-picker>
