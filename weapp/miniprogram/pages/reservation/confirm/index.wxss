@import '../../../styles/customer.wxss';

.page-container {
  min-height: 100vh;
  background: #F6F6F6;
}

.room-info {
  background: #fff;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.room-capacity {
  font-size: 28rpx;
  color: #666;
}

.form-section {
  margin-bottom: 24rpx;
}

.task-summary-card {
  margin: 24rpx;
  background: var(--td-bg-color-container, #fff);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.task-summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.task-summary-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.task-summary-row:last-child {
  margin-bottom: 0;
}

.task-summary-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.task-summary-value,
.task-summary-desc {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  text-align: right;
}

.payment-tip {
  padding: 24rpx;
  display: flex;
  gap: 12rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.08);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.mode-selector {
  padding: 24rpx;
}

/* weapp-gate allow-tdesign-internal-class: 预订确认页单选组需要纵向编排，待抽成统一选项卡片组件后移除 */
.mode-selector .t-radio-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 收紧分组标题与内容的间距，优化视觉层级 */
/* weapp-gate allow-tdesign-internal-class: 预订确认页需压缩 cell-group 标题节距，待统一卡片分组头部后移除 */
.t-cell-group__title {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f7f7f7;
}

/* weapp-gate allow-tdesign-internal-class: 预订确认页需压缩 cell-group 内容包裹间距，待统一卡片分组头部后移除 */
.t-cell-group__wrapper {
  margin-top: 0;
}

/* ========== P1-6: 费用明细卡片 ========== */
.price-section {
  margin: 24rpx;
  background: var(--td-bg-color-container, #fff);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.price-row:last-child {
  margin-bottom: 0;
}

.price-row-label {
  color: var(--td-text-color-secondary, #666);
}

.price-row-value {
  color: var(--td-text-color-primary, #333);
  font-weight: 500;
}

