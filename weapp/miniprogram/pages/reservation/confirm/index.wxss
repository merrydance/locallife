.page-container {
  min-height: 100vh;
  background: #F6F6F6;
}

.room-info {
  background: #fff;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.room-capacity {
  font-size: 28rpx;
  color: #666;
}

.form-section {
  margin-bottom: 24rpx;
}

.payment-tip {
  padding: 24rpx;
  display: flex;
  gap: 12rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.08);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.mode-selector {
  padding: 24rpx;
}

.mode-selector .t-radio-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 收紧分组标题与内容的间距，优化视觉层级 */
.t-cell-group__title {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f7f7f7;
}

.t-cell-group__wrapper {
  margin-top: 0;
}

/* ========== P1-6: 费用明细卡片 ========== */
.price-section {
  margin: 24rpx;
  background: var(--td-bg-color-container, #fff);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.price-row:last-child {
  margin-bottom: 0;
}

.price-row-label {
  color: var(--td-text-color-secondary, #666);
}

.price-row-value {
  color: var(--td-text-color-primary, #333);
  font-weight: 500;
}

.price-row-discount-label {
  color: var(--td-text-color-secondary, #666);
}

.price-row-discount-value {
  color: var(--td-text-color-secondary, #666);
}

.price-row-total {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer, #eee);
}

.price-row-total-label {
  font-weight: bold;
  color: var(--td-text-color-primary, #333);
  font-size: 30rpx;
}

.price-row-total-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--td-error-color, #E34D59);
}

.payment-selector {
  padding: 16rpx 24rpx;
}

