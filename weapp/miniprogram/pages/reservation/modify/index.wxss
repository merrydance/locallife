@import '../../../styles/customer.wxss';

.page-container {
  min-height: 100vh;
  background: #f6f6f6;
}


.content {
  padding: 16rpx 24rpx 0;
}

.section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #333;
}

.info-row .label {
  color: #777;
}

.dishes-container {
  display: flex;
  min-height: 420rpx;
}

.category-sidebar {
  width: 180rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 8rpx 0;
}

.category-item {
  padding: 18rpx 16rpx;
  font-size: 26rpx;
  color: #666;
}

.category-item.active {
  background: #fff;
  color: #1f7aec;
  font-weight: 700;
}

.dishes-list {
  flex: 1;
  padding-left: 16rpx;
  max-height: 520rpx;
}

.dish-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.dish-row:last-child {
  border-bottom: none;
}

.dish-img {
  width: 90rpx;
  height: 90rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d2750;
}

.dish-desc {
  font-size: 24rpx;
  color: #7a7f8c;
}

.dish-price {
  font-size: 26rpx;
  color: #ff7a1a;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-row:last-child {
  border-bottom: none;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-name {
  font-size: 26rpx;
  color: #1d2750;
  font-weight: 600;
}

.item-price {
  font-size: 24rpx;
  color: #7a7f8c;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty {
  min-width: 36rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.summary {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #333;
}

.summary-amount {
  font-weight: 700;
  color: #1f7aec;
}
