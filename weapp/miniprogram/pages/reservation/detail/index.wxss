/* Pages Reservation Detail */
.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page, #f6f6f6);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.loading {
  padding: 40rpx;
  text-align: center;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Status Header */
.status-header {
  background: #fff;
  padding: 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-left {
  display: flex;
  flex-direction: column;
}

.status-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #666;
}

/* Card General */
.card {
  background: var(--td-bg-color-container, #fff);
  margin: 20rpx 24rpx;
  border-radius: var(--radius-md, 16rpx);
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  color: #333;
}

/* Merchant Info */
.info-card {
  padding: 0;
}

.merchant-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
}

.merchant-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.merchant-address {
  font-size: 24rpx;
  color: #999;
}

.contact-actions {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}

/* Order Items */
.order-card {
  padding-bottom: 24rpx;
}

.item-list {
  padding: 24rpx 32rpx;
}

.order-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.order-item:last-child {
  margin-bottom: 0;
}

.item-img {
  margin-right: 20rpx;
  background: #f9f9f9;
  flex-shrink: 0;
}

.item-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 96rpx;
  padding: 4rpx 0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  display: flex;
  gap: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.item-price {
  font-weight: bold;
  color: #333;
}

.item-total {
   font-size: 28rpx;
   font-weight: bold;
   color: #333;
   margin-left: 20rpx;
}

.total-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 16rpx 32rpx 0;
}

.total-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
  font-weight: bold;
}

.total-price {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  font-family: 'DIN Alternate', sans-serif;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.bottom-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.secondary-actions {
  display: flex;
  gap: 16rpx;
}

.primary-actions {
  display: flex;
  gap: 16rpx;
  margin-left: auto;
}

/* Dialog */
.dialog-content {
  padding: 20rpx 0;
}
