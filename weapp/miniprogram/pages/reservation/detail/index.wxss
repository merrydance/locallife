.page {
  min-height: 100vh;
  background: #f6f6f6;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.detail-content {
  padding: 16rpx 24rpx 0;
}

.status-card {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.status-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.status-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2b2f36;
}

.status-time {
  font-size: 24rpx;
  color: #777;
}

.status-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ffece6;
  color: #ff5a3c;
  font-size: 22rpx;
  font-weight: 600;
}

.section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  align-items: center;
}

.row.space {
  justify-content: space-between;
  gap: 16rpx;
}

.col {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d2750;
}

.merchant-address,
.merchant-phone {
  font-size: 26rpx;
  color: #57618c;
  line-height: 1.4;
  word-break: break-all;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  color: #777;
}

.info-row .value {
  color: #333;
  text-align: right;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-row {
  display: flex;
  gap: 12rpx;
}

.btn {
  flex: 1;
  border-radius: 16rpx;
}

.btn.primary {
  background: linear-gradient(120deg, #ff9f45, #ff7a1a);
  color: #fff;
  border: none;
}

.btn.ghost {
  background: #fff;
  color: #2b2f36;
  border: 1rpx solid #e5e7eb;
}

.dish-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.dish-row:last-child {
  border-bottom: none;
}

.dish-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d2750;
}

.dish-meta {
  font-size: 24rpx;
  color: #7a7f8c;
}

.dish-total {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f7aec;
}
