<custom-navbar title="扫码点餐" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <!-- 1. 加载状态 -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <t-skeleton theme="paragraph" animation="gradient" />
    <t-skeleton theme="paragraph" animation="gradient" style="margin-top: 32rpx;" />
  </view>

  <block wx:else>
    <!-- 2. 错误状态 -->
    <view wx:if="{{error}}" class="error-wrap">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" variant="outline" bindtap="rescan">重新扫码</t-button>
      </t-empty>
    </view>

    <!-- 3. 主界面 -->
    <view wx:else class="content-animate">
      <!-- 商户信息卡片 -->
      <view class="merchant-card">
        <image class="merchant-cover" src="{{merchantInfo.cover_image || '/assets/images/merchant_default_cover.jpg'}}" mode="aspectFill" />
        <view class="merchant-info">
          <t-avatar image="{{merchantInfo.logo_url}}" size="large" class="merchant-logo" />
          <view class="merchant-detail">
            <view class="merchant-name">{{merchantInfo.name}}</view>
            <view class="merchant-tags">
              <view class="tag">支持外卖</view>
              <view class="tag">支持预订</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 桌台核心操作区 -->
      <view class="table-action-card">
        <view class="table-header">
          <t-icon name="root-list" size="48rpx" color="var(--td-brand-color)" />
          <view class="table-no-box">
            <text class="table-label">当前桌号</text>
            <text class="table-no">{{tableInfo.table_no}}</text>
          </view>
          <view class="table-status {{tableInfo.status === 'occupied' ? 'is-occupied' : 'is-idle'}}">
            {{tableInfo.status === 'occupied' ? '占用中' : '空闲'}}
          </view>
        </view>

        <view class="tips">
          <t-icon name="info-circle" size="32rpx" />
          <text>确认桌号无误后，点击下方按钮开始点餐</text>
        </view>

        <t-button block size="large" theme="primary" shape="round" t-class="btn-start" bindtap="startDining">
          开始点餐
        </t-button>

        <view class="secondary-actions">
          <view class="action-item" bindtap="goToTakeout">
            <t-icon name="order-adjustment-column" size="40rpx" />
            <text>改点外卖</text>
          </view>
          <t-divider layout="vertical" />
          <view class="action-item" bindtap="goToReservation">
            <t-icon name="calendar" size="40rpx" />
            <text>预订包间</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 换桌确认弹窗 -->
  <t-dialog
    visible="{{showTransferDialog}}"
    title="检测到已有订单"
    confirm-btn="{{ { content: '确认换桌', variant: 'base', loading: transferSubmitting } }}"
    cancel-btn="取消"
    bind:confirm="confirmTransfer"
    bind:cancel="cancelTransfer"
  >
    <view slot="content" class="dialog-content">
      <view class="dialog-text">
        您在 <text class="highlight">{{activeSession.table_no}}号桌</text> 有进行中的订单，是否将订单转至当前 <text class="highlight">{{tableInfo.table_no}}号桌</text>？
      </view>
      <t-input
        wx:if="{{!activeSession.reservation_id}}"
        label="桌台验证码"
        placeholder="请输入当前桌台码"
        value="{{transferCode}}"
        bind:change="onTransferCodeInput"
        borderless
        class="transfer-input"
      />
    </view>
  </t-dialog>
</view>