.page-container {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.skeleton-wrap {
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.error-wrap {
  margin-top: 100rpx;
}

.content-animate {
  animation: slideUp 0.5s ease-out;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 商户卡片 */
.merchant-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}

.merchant-cover {
  width: 100%;
  height: 240rpx;
  background-color: #f5f5f5;
}

.merchant-info {
  display: flex;
  padding: 0 32rpx 32rpx;
  margin-top: -40rpx;
  align-items: flex-end;
}

.merchant-logo {
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.merchant-detail {
  margin-left: 24rpx;
  padding-bottom: 8rpx;
}

.merchant-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 12rpx;
}

.merchant-tags {
  display: flex;
  gap: 12rpx;
}

/* 桌台操作区 */
.table-action-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.table-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 48rpx;
}

.table-no-box {
  flex: 1;
  margin-left: 24rpx;
}

.table-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  display: block;
}

.table-no {
  font-size: 60rpx;
  font-weight: bold;
  font-family: 'Outfit', sans-serif;
  color: var(--td-text-color-primary);
}

.table-status {
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.is-idle {
  background: var(--td-success-color-light);
  color: var(--td-success-color);
}

.is-occupied {
  background: var(--td-warning-color-light);
  color: var(--td-warning-color);
}

.tips {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
  margin-bottom: 48rpx;
  justify-content: center;
}

.btn-start {
  height: 96rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 8rpx 16rpx rgba(0, 82, 217, 0.2);
}

.secondary-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  gap: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
}

/* 弹窗样式 */
.dialog-content {
  padding: 32rpx 0;
}

.dialog-text {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  line-height: 1.6;
}

.highlight {
  color: var(--td-brand-color);
  font-weight: 600;
}

.transfer-input {
  margin-top: 24rpx !important;
  background-color: var(--td-bg-color-container) !important;
  border-radius: 8rpx;
}
