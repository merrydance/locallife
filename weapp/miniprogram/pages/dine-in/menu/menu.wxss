.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 加载容器居中 */
.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 100rpx 0;
}

.error-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 120rpx 48rpx;
  text-align: center;
  color: #333;
}

.error-title {
  font-size: 32rpx;
  font-weight: 700;
}

.error-message {
  font-size: 28rpx;
  color: #666;
}

.content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-left: var(--spacer-md);
  padding-right: var(--spacer-md);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 桌台信息 */
.table-info {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.info-row {
  display: flex;
  align-items: center;
  flex: 1;
}

.call-btn {
  margin-left: auto;
}

.info-row .label {
  font-size: 28rpx;
  color: #666;
}

.info-row .value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b35;
}

/* 菜单区域 */
.dishes-container {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.category-sidebar {
  width: 180rpx;
  background: #f8f8f8;
  height: 100%;
}

.category-item {
  padding: 32rpx 20rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  position: relative;
}

.category-item.active {
  background: #fff;
  color: #333;
  font-weight: bold;
}

.category-indicator {
  position: absolute;
  left: 0;
  top: 30%;
  height: 40%;
  width: 8rpx;
  background: #ff6b35;
  border-radius: 0 4rpx 4rpx 0;
}

/* 菜品列表 */
.dishes-list {
  flex: 1;
  background: #fff;
  padding: 0 24rpx;
}

.dish-item {
  display: flex;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.dish-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.dish-price-row {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.price-box {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e34d59;
}

.dish-member-price {
  font-size: 22rpx;
  color: #ff6b35;
  background: rgba(255, 107, 53, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

/* 菜品控制区 */
.dish-card-controls {
  display: flex;
  align-items: center;
}

.customize-btn-wrapper {
  position: relative;
}

.stepper-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stepper-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-text {
  font-size: 30rpx;
  color: #333;
  min-width: 40rpx;
  text-align: center;
  font-weight: 500;
}

.cart-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  background: #e34d59;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  border: 2rpx solid #fff;
  z-index: 10;
}

/* 购物车弹窗样式 */
.cart-modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.cart-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.cart-title {
  font-size: 32rpx;
  font-weight: bold;
}

.clear-cart {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #999;
}

.cart-items-scroll {
  flex: 1;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.cart-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  box-sizing: border-box;
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
  background: #f5f5f5;
  flex-shrink: 0;
}

.cart-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cart-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #e34d59;
  flex-shrink: 0;
}

.item-spec {
  font-size: 24rpx;
  color: #888;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.item-stepper .qty {
  font-size: 30rpx;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
}

/* 定制 Drawer 样式 */
.custom-drawer {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.drawer-title {
  font-size: 36rpx;
  font-weight: bold;
}

.drawer-content {
  flex: 1;
  overflow-y: auto;
}

.spec-group {
  margin-bottom: 32rpx;
}

.group-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  --td-tag-font-size: 26rpx;
  --td-tag-padding: 12rpx 24rpx;
}

.spec-item.active {
  --td-tag-bg-color: rgba(255, 107, 53, 0.1);
  --td-tag-text-color: #ff6b35;
  --td-tag-border-color: #ff6b35;
}

.cart-footer {
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-top: 1rpx solid #eee;
  box-sizing: border-box;
}

.cart-total-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-shrink: 0;
  min-width: 220rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666;
}

.total-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #e34d59;
}

.checkout-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

/* 详情弹窗 */
.dish-detail-popup {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.detail-image {
  width: 100%;
  height: 450rpx;
}

.detail-info {
  padding: 32rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
}

.detail-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 32rpx;
  display: block;
}

.detail-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}



/* Skeleton Styles */
.skeleton-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.skeleton-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.skeleton-sidebar {
  width: 180rpx;
  background: #f8f8f8;
  padding-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.skeleton-tab {
  width: 140rpx;
  height: 60rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
}

.skeleton-content {
  flex: 1;
  padding: 24rpx;
  background: #fff;
}

.skeleton-dish-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.skeleton-dish-img {
  width: 160rpx;
  height: 160rpx;
  background: #e0e0e0;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.skeleton-dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-top: 8rpx;
}

.skeleton-line {
  height: 32rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
}

.skeleton-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e0e0e0;
  align-self: flex-end;
  margin-bottom: 8rpx;
}

.w-40 { width: 40%; }
.w-60 { width: 60%; }
.w-30 { width: 30%; }
.mt-20 { margin-top: 20rpx; }

.skeleton-animate {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}
