@import "../../../styles/dine-in-menu-overlays.wxss";
@import "../../../styles/dine-in-menu-skeleton.wxss";

.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 加载容器居中 */
.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 100rpx 0;
}

.error-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 120rpx 48rpx;
  text-align: center;
  color: #333;
}

.error-title {
  font-size: 32rpx;
  font-weight: 700;
}

.error-message {
  font-size: 28rpx;
  color: #666;
}

.content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-left: var(--spacer-md);
  padding-right: var(--spacer-md);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 桌台信息 */
.table-info {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.info-row {
  display: flex;
  align-items: center;
  flex: 1;
}

.call-btn {
  margin-left: auto;
}

.info-row .label {
  font-size: 28rpx;
  color: #666;
}

.info-row .value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b35;
}

/* 菜单区域 */
.dishes-container {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.category-sidebar {
  width: 180rpx;
  background: #f8f8f8;
  height: 100%;
}

.category-item {
  padding: 32rpx 20rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  position: relative;
}

.category-item.active {
  background: #fff;
  color: #333;
  font-weight: bold;
}

.category-indicator {
  position: absolute;
  left: 0;
  top: 30%;
  height: 40%;
  width: 8rpx;
  background: #ff6b35;
  border-radius: 0 4rpx 4rpx 0;
}

/* 菜品列表 */
.dishes-list {
  flex: 1;
  background: #fff;
  padding: 0 24rpx;
}

.dish-item {
  display: flex;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.dish-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.dish-price-row {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.price-box {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e34d59;
}

.dish-member-price {
  font-size: 22rpx;
  color: #ff6b35;
  background: rgba(255, 107, 53, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

/* 菜品控制区 */
.dish-card-controls {
  display: flex;
  align-items: center;
}

.customize-btn-wrapper {
  position: relative;
}

.stepper-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stepper-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-text {
  font-size: 30rpx;
  color: #333;
  min-width: 40rpx;
  text-align: center;
  font-weight: 500;
}

.cart-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  background: #e34d59;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  border: 2rpx solid #fff;
  z-index: 10;
}
