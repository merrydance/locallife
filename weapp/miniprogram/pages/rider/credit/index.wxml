<custom-navbar title="高值单资格" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" class="loading" />

  <view wx:elif="{{errorMessage}}" class="state-shell">
    <t-empty icon="error-circle" description="{{errorMessage}}" />
    <t-button theme="primary" shape="round" bindtap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="content">
    <!-- 信用卡片 -->
    <view class="credit-card">
      <view class="card-header">
        <view class="score-info">
          <text class="score-value">{{score}}</text>
          <text class="score-label">当前高值单资格分</text>
          <text class="rider-name" wx:if="{{riderName}}">{{riderName}}</text>
        </view>
        <t-tag size="small" variant="dark" theme="{{qualificationTheme}}" shape="round" class="level-tag">{{qualificationLabel}}</t-tag>
      </view>
      <view class="progress-bar">
        <view class="progress {{score >= 0 ? 'progress-pass' : 'progress-risk'}}" style="width: {{score >= 0 ? (score > 100 ? 100 : score) : 12}}%"></view>
      </view>
      <text class="level-desc">{{qualificationDesc}}</text>
    </view>

    <!-- 核心指标 -->
    <view class="section">
      <view class="section-title">资格摘要</view>
      <view class="metrics-grid">
        <view wx:for="{{summary}}" wx:key="label" class="metric-item metric-{{item.tone}}">
          <text class="metric-value">{{item.value}}</text>
          <text class="metric-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 奖惩记录 -->
    <view class="section">
      <view class="section-header">
        <view class="section-title">资格变更记录</view>
        <view class="section-subtitle">共 {{total}} 条</view>
      </view>

      <view class="history-list" wx:if="{{history.length > 0}}">
        <view wx:for="{{history}}" wx:key="id" class="history-item">
          <view class="item-left">
            <view class="item-topline">
              <text class="item-reason">{{item.title}}</text>
              <t-tag size="small" variant="light" theme="default">{{item.tagText}}</t-tag>
            </view>
            <text class="item-subtitle">{{item.subtitle}}</text>
            <text class="item-time">{{item.created_at}}</text>
          </view>
          <text class="item-amount {{item.type}}">
            {{item.amount}}
          </text>
        </view>
      </view>

      <view wx:elif="{{!loading}}" class="inner-empty">
        <t-empty icon="calendar" description="暂时没有资格变更记录" />
      </view>

      <view wx:if="{{loadingMore}}" class="loading-more">
        <t-loading theme="dots" size="32rpx" />
      </view>
    </view>
  </view>
</view>
