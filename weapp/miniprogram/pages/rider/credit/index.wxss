.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.content {
  padding: 24rpx;
}

.credit-card {
  background: linear-gradient(135deg, var(--td-brand-color-9) 0%, var(--td-success-color) 100%);
  border-radius: var(--radius-md);
  padding: 48rpx;
  color: var(--td-text-color-anti);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.score-info {
  display: flex;
  flex-direction: column;
}

.score-value {
  font-size: 80rpx;
  font-weight: bold;
  line-height: 1;
  margin-bottom: 8rpx;
}

.score-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.level-tag {
  background: rgba(255, 255, 255, 0.2);
  font-size: 26rpx;
  color: var(--td-text-color-anti);
  font-weight: bold;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: var(--td-text-color-anti);
  border-radius: 6rpx;
}

.level-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.section {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 24rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.metric-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.metric-label {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--td-border-level-1-color);
}

.history-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-reason {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.item-time {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

.item-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.item-amount.positive { color: var(--td-success-color); }
.item-amount.negative { color: var(--td-error-color); }
