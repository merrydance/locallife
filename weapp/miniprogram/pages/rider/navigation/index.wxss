.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.loading-box,
.error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-md);
  padding: 160rpx var(--spacer-md);
}

.navigation-map {
  width: 100%;
  height: calc(100vh - 420rpx);
}

.panel-sheet {
  position: fixed;
  left: var(--spacer-md);
  right: var(--spacer-md);
  bottom: calc(var(--spacer-sm) + env(safe-area-inset-bottom));
  padding: var(--spacer-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--td-component-border);
  box-shadow: var(--shadow-sm);
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.panel-address {
  margin-top: 8rpx;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.panel-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.pending-strip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: var(--spacer-sm);
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  background: var(--td-warning-color-light);
  color: var(--td-warning-color-7);
  font-size: var(--font-size-xs);
}

.primary-action-row {
  margin-top: var(--spacer-md);
}

.secondary-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: var(--spacer-sm);
}