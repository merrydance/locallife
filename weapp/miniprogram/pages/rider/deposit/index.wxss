/* 骑手钱包样式 */

.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
}

.state-shell,
.inline-state-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 80rpx var(--spacer-md);
}

.wallet-card {
  margin: var(--spacer-md);
  padding: 48rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.balance-main {
  text-align: center;
  margin-bottom: 48rpx;
}

.balance-main .label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-placeholder);
  margin-bottom: 12rpx;
  display: block;
}

.balance-main .value {
  font-size: 64rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.balance-sub {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid var(--td-border-level-1-color);
  border-bottom: 1rpx solid var(--td-border-level-1-color);
  margin-bottom: 48rpx;
}

.balance-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--td-border-level-1-color);
}

.sub-item {
  flex: 1;
  text-align: center;
  min-width: 0;
}

.sub-label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  margin-bottom: 4rpx;
  display: block;
}

.sub-value {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-secondary);
}

.wallet-actions {
  display: flex;
  gap: 24rpx;
}

.wallet-tip {
  margin: 0 0 24rpx;
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  line-height: 1.6;
}

.wallet-tip-secondary {
  color: var(--td-text-color-secondary);
}

.notice-banner {
  margin: 0 0 24rpx;
}

/* 历史列表 */
.history-section {
  padding: var(--spacer-md);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.section-header {
  margin-bottom: var(--spacer-md);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.history-item {
  background: #FFFFFF;
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  margin-bottom: var(--spacer-sm);
}

.item-icon {
  margin-right: 24rpx;
}

.item-info {
  flex: 1;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.item-title {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-primary);
  margin-bottom: 4rpx;
}

.item-time {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.item-remark {
  margin-top: 8rpx;
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

.item-amount {
  font-size: var(--font-size-heading);
  font-weight: bold;
}

.item-amount.positive {
  color: var(--td-success-color);
}

.item-amount.negative {
  color: var(--td-text-color-primary);
}

.load-more-tip {
  text-align: center;
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  padding: 40rpx 0;
}

.error-tip {
  color: var(--td-error-color);
}

/* 弹窗内容 */
.dialog-content {
  padding-top: 24rpx;
}

.amount-input {
  background: var(--td-bg-color-page);
  border-radius: var(--radius-sm);
  padding: 0 16rpx !important;
}

.dialog-tips {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  margin-top: 16rpx;
  padding: 0 16rpx;
}
