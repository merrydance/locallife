<custom-navbar title="押金账户" showBack="{{true}}" />

<view
  class="deposit-page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px;"
>
  <scroll-view 
    scroll-y 
    class="deposit-scroll"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onReachBottom"
  >
    <view wx:if="{{accountError && !loading}}" class="state-shell">
      <t-empty icon="error-circle" description="{{accountError}}" />
      <t-button theme="primary" bindtap="onRetryPage">重新加载</t-button>
    </view>

    <block wx:else>
      <!-- 1. 余额总览卡片 -->
      <view class="wallet-card">
        <view class="balance-main">
          <text class="label">可用押金 (元)</text>
          <view class="value">¥{{availableDepositDisplay}}</view>
        </view>
        
        <view class="balance-sub">
          <view class="sub-item">
            <text class="sub-label">押金总额</text>
            <text class="sub-value">¥{{totalDepositDisplay}}</text>
          </view>
          <view class="balance-divider"></view>
          <view class="sub-item">
            <text class="sub-label">代取冻结</text>
            <text class="sub-value">¥{{deliveryFrozenDepositDisplay}}</text>
          </view>
          <view class="balance-divider"></view>
          <view class="sub-item">
            <text class="sub-label">提现处理中</text>
            <text class="sub-value">¥{{withdrawalProcessingAmountDisplay}}</text>
          </view>
        </view>

        <view wx:if="{{hasPendingRecharge}}" class="status-card-inline status-card-inline--pending">
          <view class="status-card-inline__header">
            <view>
              <view class="status-card-inline__title">{{pendingRechargeTitle}}</view>
              <view class="status-card-inline__desc">{{pendingRechargeDescription}}</view>
            </view>
            <view class="status-card-inline__amount">{{pendingRechargeAmountDisplay}}</view>
          </view>
          <view class="status-card-inline__actions">
            <t-button size="small" theme="primary" variant="outline" bindtap="onViewPendingRechargeDetail">查看进度</t-button>
            <t-button size="small" theme="primary" bindtap="onContinuePendingRecharge" loading="{{syncingPendingRecharge}}" disabled="{{syncingPendingRecharge || rechargeSubmitting}}">继续支付</t-button>
          </view>
        </view>

        <view wx:if="{{hasPendingWithdrawal}}" class="status-card-inline status-card-inline--withdrawal status-card-inline--{{pendingWithdrawalPanelTheme}}">
          <view class="status-card-inline__header">
            <view class="status-card-inline__main">
              <view class="status-card-inline__title-row">
                <view class="status-card-inline__title">{{pendingWithdrawalTitle}}</view>
                <t-tag size="small" theme="{{pendingWithdrawalTagTheme}}" variant="light">{{pendingWithdrawalStatusText}}</t-tag>
              </view>
              <view class="status-card-inline__desc">{{pendingWithdrawalDescription}}</view>
            </view>
            <view class="status-card-inline__amount">{{pendingWithdrawalAmountDisplay}}</view>
          </view>
          <view wx:if="{{pendingWithdrawalCanRefresh}}" class="status-card-inline__actions">
            <t-button size="small" theme="primary" variant="outline" bindtap="onRefreshPendingWithdrawal" loading="{{syncingPendingWithdrawal}}" disabled="{{syncingPendingWithdrawal}}">刷新状态</t-button>
          </view>
        </view>

        <view wx:if="{{actionFeedbackMessage}}" class="status-card-inline status-card-inline--feedback status-card-inline--{{actionFeedbackTheme}}">
          <view class="status-card-inline__title">{{actionFeedbackTheme === 'success' ? '状态已更新' : '请继续关注结果'}}</view>
          <view class="status-card-inline__desc">{{actionFeedbackMessage}}</view>
        </view>

        <view class="wallet-actions">
          <t-button block theme="primary" bindtap="onShowRecharge">充值押金</t-button>
          <t-button block theme="primary" variant="outline" disabled="{{!canWithdraw}}" bindtap="onShowWithdraw">申请提现</t-button>
        </view>
      </view>

      <!-- 2. 交易记录列表 -->
      <view class="history-section">
        <view class="section-header">
          <text class="section-title">账单明细</text>
        </view>

        <t-loading wx:if="{{loading && transactions.length === 0}}" theme="circular" size="40rpx" class="loading" />

        <view wx:elif="{{listError && transactions.length === 0}}" class="inline-state-card">
          <t-empty icon="error-circle" description="{{listError}}" />
          <t-button theme="primary" bindtap="onRetryTransactions">重新加载账单</t-button>
        </view>

        <view class="history-list" wx:elif="{{transactions.length > 0}}">
          <view class="history-item" wx:for="{{transactions}}" wx:key="id">
            <view class="item-icon">
              <t-icon 
                name="{{item.icon_name}}" 
                color="{{item.icon_color}}"
                size="48rpx"
              />
            </view>
            <view class="item-info">
              <view class="item-header">
                <view class="item-title">{{item.display_type_text}}</view>
                <t-tag size="small" theme="{{item.status_theme}}" variant="light">{{item.status_text}}</t-tag>
              </view>
              <view class="item-time">{{item.display_time}}</view>
              <view wx:if="{{item.display_remark}}" class="item-remark">{{item.display_remark}}</view>
            </view>
            <view class="item-amount {{item.display_amount_class}}">
              {{item.display_amount_text}}
            </view>
          </view>

          <view wx:if="{{listError}}" class="load-more-tip error-tip" bindtap="onRetryTransactions">{{listError}}，点击重试</view>
          <view wx:elif="{{loadingMore}}" class="load-more-tip">正在加载更多...</view>
          <view wx:elif="{{!hasMore}}" class="load-more-tip">没有更多记录了</view>
        </view>

        <t-empty wx:else icon="info-circle" description="暂无收支明细" />
      </view>
    </block>
  </scroll-view>

  <!-- 充值弹窗 -->
  <t-dialog
    visible="{{isRechargeVisible}}"
    title="押金充值"
    confirm-btn="{{ {content: rechargeSubmitting ? '提交中...' : '立即支付', variant: 'base', theme: 'primary'} }}"
    cancel-btn="取消"
    bind:confirm="confirmRecharge"
    bind:cancel="onCloseRechargeDialog"
  >
    <view slot="content" class="dialog-content">
      <t-input
        placeholder="如 100.00"
        type="digit"
        label="金额(元)"
        value="{{rechargeAmount}}"
        data-field="rechargeAmount"
        bind:change="onInputAmount"
        t-class="amount-input"
      />
      <view class="dialog-tips">上线前需满足对应运营区域押金要求</view>
    </view>
  </t-dialog>

  <t-toast id="t-toast" />

  <t-dialog
    visible="{{isWithdrawVisible}}"
    title="押金提现"
    confirm-btn="{{ {content: withdrawSubmitting ? '提交中...' : '确认提现', variant: 'base', theme: 'primary'} }}"
    cancel-btn="取消"
    bind:confirm="confirmWithdraw"
    bind:cancel="onCloseWithdrawDialog"
  >
    <view slot="content" class="dialog-content">
      <t-input
        placeholder="如 100.00"
        type="digit"
        label="金额(元)"
        value="{{withdrawAmount}}"
        data-field="withdrawAmount"
        bind:change="onInputAmount"
        t-class="amount-input"
      />
      <view wx:if="{{withdrawErrorMessage}}" class="dialog-error-message">{{withdrawErrorMessage}}</view>
      <view class="dialog-tips">最低提现 1.00 元，需无代取冻结和处理中提现。</view>
    </view>
  </t-dialog>
</view>
