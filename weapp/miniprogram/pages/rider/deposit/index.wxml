<custom-navbar title="押金账户" showBack="{{true}}" />

<scroll-view 
  scroll-y 
  class="page-container" 
  style="padding-top: {{navBarHeight}}px;"
  bindscrolltolower="onReachBottom"
>
  <!-- 1. 余额总览卡片 -->
  <view class="wallet-card">
    <view class="balance-main">
      <text class="label">可用押金 (元)</text>
      <view class="value">¥{{availableDeposit / 100}}</view>
    </view>
    
    <view class="balance-sub">
      <view class="sub-item">
        <text class="sub-label">押金总额</text>
        <text class="sub-value">¥{{totalDeposit / 100}}</text>
      </view>
      <view class="balance-divider"></view>
      <view class="sub-item">
        <text class="sub-label">冻结押金</text>
        <text class="sub-value">¥{{frozenDeposit / 100}}</text>
      </view>
    </view>

    <view class="wallet-tip">配送分账资金将直接进入微信零钱，本页仅展示押金与账单记录</view>

    <view class="wallet-actions">
      <t-button block theme="primary" shape="round" bindtap="onShowRecharge">充值押金</t-button>
    </view>
  </view>

  <!-- 2. 交易记录列表 -->
  <view class="history-section">
    <view class="section-header">
      <text class="section-title">账单明细</text>
    </view>

    <view class="history-list" wx:if="{{transactions.length > 0}}">
      <view class="history-item" wx:for="{{transactions}}" wx:key="id">
        <view class="item-icon">
          <t-icon 
            name="{{item.type === 'deposit' ? 'add-circle' : 'remove-circle'}}" 
            color="{{item.type === 'deposit' ? 'var(--td-success-color)' : 'var(--td-text-color-primary)'}}"
            size="48rpx"
          />
        </view>
        <view class="item-info">
          <view class="item-title">{{getTransactionTypeText(item.type)}}</view>
          <view class="item-time">{{item.created_at}}</view>
        </view>
        <view class="item-amount {{getTransactionAmountClass(item.amount, item.type)}}">
          {{formatTransactionAmount(item.amount, item.type)}}
        </view>
      </view>
      <view class="load-more-tip" wx:if="{{!hasMore}}">没有更多记录了</view>
    </view>
    <t-empty wx:else icon="info-circle" description="暂无收支明细" />
  </view>
</scroll-view>

<!-- 充值弹窗 -->
<t-dialog
  visible="{{isRechargeVisible}}"
  title="押金充值"
  confirm-btn="{{ {content: '立即支付', variant: 'base', theme: 'primary'} }}"
  cancel-btn="取消"
  bind:confirm="confirmRecharge"
  bind:cancel="onCloseDialog"
>
  <view slot="content" class="dialog-content">
    <t-input
      placeholder="请输入充值金额"
      type="digit"
      label="金额(元)"
      value="{{rechargeAmount}}"
      data-field="rechargeAmount"
      bind:change="onInputAmount"
      t-class="amount-input"
    />
    <view class="dialog-tips">上线需保持押金不少于 100.00 元</view>
  </view>
</t-dialog>
