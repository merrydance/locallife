/* 骑手调度中心 - 严格遵循 DESIGN_SYSTEM.md */

.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  display: flex;
  flex-direction: column;
}

/* 1. 骑手概览卡片 */
.stats-card {
  margin: var(--spacer-md);
  padding: var(--spacer-md);
  background: linear-gradient(135deg, var(--td-brand-color) 0%, #FF8A7A 100%);
  border-radius: var(--radius-lg);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 88, 0.2);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-lg);
}

.rider-profile {
  display: flex;
  align-items: center;
}

.rider-name {
  font-size: var(--font-size-heading);
  font-weight: 600;
  margin: 0 var(--spacer-sm);
}

.wallet-entry {
  display: flex;
  align-items: center;
  font-size: var(--font-size-sm);
  background: rgba(255, 255, 255, 0.15);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-round);
}

.stats-grid {
  display: flex;
  align-items: center;
  padding: var(--spacer-xs) 0;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: var(--font-size-display);
  font-weight: bold;
  line-height: 1.2;
}

.stats-label {
  font-size: var(--font-size-xxs);
  opacity: 0.8;
  margin-top: 8rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 2. 上线状态条 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-sm) var(--spacer-md);
  margin: 0 var(--spacer-md) var(--spacer-md);
  background: #FFFFFF;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.status-bar.is-online {
  border-left: 8rpx solid var(--td-success-color);
}

.status-bar.is-offline {
  border-left: 8rpx solid var(--td-text-color-placeholder);
}

.status-info {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: var(--spacer-sm);
  background: var(--td-text-color-placeholder);
}

.is-online .status-dot {
  background: var(--td-success-color);
  box-shadow: 0 0 12rpx var(--td-success-color);
  animation: pulse 2s infinite;
}

.status-text {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-primary);
}

@keyframes pulse {
  0% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
  100% { opacity: 1; transform: scale(1); }
}

/* 3. 标签与列表 */
.tabs-container {
  --td-tab-item-active-color: var(--td-brand-color);
  --td-tab-track-color: var(--td-brand-color);
  background: transparent !important;
}

.tab-content {
  padding: var(--spacer-sm) var(--spacer-md) env(safe-area-inset-bottom);
}

/* 订单卡片通用样式 */
.order-card {
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-md);
  padding-bottom: var(--spacer-sm);
  border-bottom: 1rpx dashed var(--td-border-level-1-color);
}

.distance-info {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.order-no {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.order-route {
  position: relative;
  margin-bottom: var(--spacer-md);
}

.route-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.route-item:last-child {
  margin-bottom: 0;
}

.marker {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.pickup .marker {
  background: #FFA000;
}

.delivery .marker {
  background: var(--td-success-color);
}

.route-item.finished {
  opacity: 0.5;
}

.addr-box {
  margin-left: var(--spacer-md);
  flex: 1;
}

.addr-name {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 4rpx;
}

.addr-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.route-line {
  position: absolute;
  left: 20rpx;
  top: 40rpx;
  bottom: 40rpx;
  width: 2rpx;
  background: #EEEEEE;
  z-index: 0;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--spacer-md);
  padding-top: var(--spacer-sm);
  border-top: 1rpx solid var(--td-border-level-1-color);
}

.time-limit {
  display: flex;
  align-items: center;
  font-size: var(--font-size-xs);
  color: var(--td-brand-color);
}

.time-limit t-icon {
  margin-right: 8rpx;
}

.earnings {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.price {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-brand-color);
}

.footer-safe {
  height: calc(40rpx + env(safe-area-inset-bottom));
}

/* 4. 新订单提醒栏 */
.new-orders-bar {
  padding: 0 var(--spacer-md) var(--spacer-md);
  margin-top: -10rpx; /* 向上偏移一点 */
  animation: slideDown 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.bar-inner {
  background: linear-gradient(90deg, #00BFA5 0%, #00897B 100%);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 191, 165, 0.3);
}

.bar-text {
  flex: 1;
  font-size: var(--font-size-sm);
  font-weight: 500;
  margin-left: 12rpx;
}

.refresh-btn {
  font-size: var(--font-size-xs);
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
}

.refresh-btn t-icon {
  margin-left: 6rpx;
  animation: rotate 2s linear infinite;
  animation-play-state: paused;
}

.new-orders-bar:active .refresh-btn t-icon {
  animation-play-state: running;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
