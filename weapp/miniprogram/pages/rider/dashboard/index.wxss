/* 骑手调度中心 - 严格遵循 .github/standards/weapp/DESIGN_SYSTEM.md */

.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  display: flex;
  flex-direction: column;
}

/* 1. 骑手概览卡片 */
.rider-header-card {
  margin: var(--spacer-md);
  padding: var(--spacer-md);
  background: linear-gradient(135deg, var(--td-brand-color) 0%, var(--td-brand-color-6) 100%);
  border-radius: var(--radius-lg);
  color: var(--td-text-color-anti);
  box-shadow: var(--shadow-md);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-lg);
}

.rider-profile {
  display: flex;
  align-items: center;
}

.rider-name {
  font-size: var(--font-size-heading);
  font-weight: 600;
  margin: 0 var(--spacer-sm);
}

.credit-tag {
  font-size: 20rpx;
  color: var(--td-text-color-anti);
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  margin-left: 12rpx;
  backdrop-filter: blur(4px);
}

.wallet-entry {
  display: flex;
  align-items: center;
  font-size: var(--font-size-sm);
  background: rgba(255, 255, 255, 0.15);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-round);
}

.stats-grid {
  display: flex;
  align-items: center;
  padding: var(--spacer-xs) 0;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: var(--font-size-display);
  font-weight: bold;
  line-height: 1.2;
}

.stats-label {
  font-size: var(--font-size-xxs);
  opacity: 0.8;
  margin-top: 8rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 2. 上线状态条 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-sm) var(--spacer-md);
  margin: 0 var(--spacer-md) var(--spacer-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.status-bar.is-online {
  border-left: 8rpx solid var(--td-success-color);
}

.status-bar.is-offline {
  border-left: 8rpx solid var(--td-text-color-placeholder);
}

.status-info {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: var(--spacer-sm);
  background: var(--td-text-color-placeholder);
}

.is-online .status-dot {
  background: var(--td-success-color);
  box-shadow: 0 0 12rpx var(--td-success-color);
  animation: pulse 2s infinite;
}

.status-text {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-primary);
}

@keyframes pulse {
  0% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
  100% { opacity: 1; transform: scale(1); }
}

/* 3. 标签与列表 */
/* 骨架屏样式 */
.skeleton-card {
  min-height: 300rpx;
  background: var(--td-bg-color-container);
  padding: 30rpx;
  position: relative;
  overflow: hidden;
}

.skeleton-header, 
.skeleton-content, 
.skeleton-footer {
  background: linear-gradient(90deg, var(--td-bg-color-secondarycontainer) 25%, var(--td-bg-color-page) 37%, var(--td-bg-color-secondarycontainer) 63%);
  background-size: 400% 100%;
  animation: shimmer 1.4s ease infinite;
  border-radius: 8rpx;
}

.skeleton-header {
  height: 48rpx;
  width: 40%;
  margin-bottom: 30rpx;
}

.skeleton-content {
  height: 120rpx;
  width: 100%;
  margin-bottom: 30rpx;
}

.skeleton-footer {
  height: 60rpx;
  width: 100%;
}

@keyframes shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

.tabs-container {
  --td-tab-item-active-color: var(--td-brand-color);
  --td-tab-track-color: var(--td-brand-color);
  background: transparent !important;
}

.tab-content {
  padding: var(--spacer-sm) var(--spacer-md) env(safe-area-inset-bottom);
}

/* 订单卡片通用样式 */
.order-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--td-border-level-1-color);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacer-md);
}

.earnings-box {
  display: flex;
  flex-direction: column;
}

.earnings-box .label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-secondary);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.earnings-box .value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--td-brand-color);
  line-height: 1;
  margin-top: 4rpx;
}

.tags-group {
  display: flex;
  gap: 8rpx;
}

.order-route {
  position: relative;
  margin: 32rpx 0;
}

.route-item {
  display: flex;
  align-items: flex-start;
  position: relative;
}

.marker-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
  border: 4rpx solid #FFF;
}

.marker-dot.orange { background: #FFA000; box-shadow: 0 0 8rpx rgba(255, 160, 0, 0.4); }
.marker-dot.green { background: var(--td-success-color); box-shadow: 0 0 8rpx rgba(0, 137, 123, 0.4); }

.addr-box {
  flex: 1;
  margin-left: 24rpx;
  padding-right: 20rpx;
}

.addr-name {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
  line-height: 1.4;
}

.addr-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  margin-top: 4rpx;
}

.distance-tag, .arrival-time {
  text-align: right;
  flex-shrink: 0;
}

.distance-tag {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
  background: var(--td-bg-color-page);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  height: fit-content;
}

.arrival-time {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.time-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.time-group:not(:last-child) {
  margin-bottom: 12rpx;
}

.arrival-time .label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  line-height: 1.2;
}

.arrival-time .time {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--td-text-color-primary);
  line-height: 1.4;
}

.arrival-time .time.urgent {
  color: var(--td-error-color);
}

.route-divider {
  padding: 8rpx 0 8rpx 7rpx;
}

.route-divider .line {
  width: 2rpx;
  height: 40rpx;
  background: repeating-linear-gradient(to bottom, #ddd 0, #ddd 4rpx, transparent 4rpx, transparent 8rpx);
}

.route-divider .mid-dist {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
  margin-left: 24rpx;
  margin-top: -30rpx;
  padding-bottom: 24rpx;
}

.order-footer {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* Task Card Specific */
.status-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-count {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.action-icons {
  display: flex;
  align-items: center;
  padding-left: 20rpx;
}

.earnings-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx dashed #EEEEEE;
  margin-bottom: 16rpx;
}

.earnings-info .label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.earnings-info .price {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--td-brand-color);
  font-family: 'DIN Alternate', sans-serif;
}

.action-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-left: auto;
}

.action-icon {
  color: var(--td-text-color-placeholder);
  padding: 10rpx;
}

.chat-btn {
  --td-button-text-color: var(--td-brand-color);
  padding: 0 !important;
  margin-right: -10rpx;
}

.order-notes {
  margin-top: 24rpx;
  background: #F8F8F8;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
}

.notes-label {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
  font-weight: 500;
}

.notes-content {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  margin-top: 4rpx;
  display: block;
  word-break: break-all;
}

.notes-content.no-notes {
  color: var(--td-text-color-placeholder);
  font-style: italic;
}

/* 菜品清单样式 */
.order-items-list {
  margin-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 16rpx;
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dish-name {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.dish-qty {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.item-count.no-data {
  color: var(--td-text-color-placeholder);
  font-size: 20rpx;
  background: #F0F0F0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.order-footer {
  margin-top: 16rpx;
}

.action-btns {
  width: 100%;
}

.action-btns .step-btn {
  margin-top: 16rpx;
}

.contact-text {
  font-weight: 500;
  color: var(--td-brand-color);
}

.addr-desc {
  display: flex;
  align-items: center;
}

.deadline-bar {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  background: var(--td-bg-color-page);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-sm);
}

.deadline-bar .deadline-icon {
  margin-right: 8rpx;
}

.deadline-bar.urgent {
  color: var(--td-error-color);
  background: var(--td-error-color-light);
  font-weight: 600;
}

.task-card.is-overdue {
  border: 1rpx solid var(--td-error-color-light);
  background: var(--td-error-color-light);
}

.footer-safe {
  height: calc(40rpx + env(safe-area-inset-bottom));
}

/* 4. 新订单提醒栏 */
.new-orders-bar {
  padding: 0 var(--spacer-md) var(--spacer-md);
  margin-top: -10rpx; /* 向上偏移一点 */
  animation: slideDown 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.bar-inner {
  background: linear-gradient(90deg, #00BFA5 0%, #00897B 100%);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 191, 165, 0.3);
}

.bar-text {
  flex: 1;
  font-size: var(--font-size-sm);
  font-weight: 500;
  margin-left: 12rpx;
}

.refresh-btn {
  font-size: var(--font-size-xs);
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
}

.refresh-btn .refresh-icon {
  margin-left: 6rpx;
  animation: rotate 2s linear infinite;
  animation-play-state: paused;
}

.new-orders-bar:active .refresh-btn .refresh-icon {
  animation-play-state: running;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
