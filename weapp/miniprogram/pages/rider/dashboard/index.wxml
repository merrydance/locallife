<custom-navbar title="骑手调度中心" showBack="{{true}}" />

<scroll-view 
  scroll-y 
  enable-back-to-top 
  class="page-container" 
  style="padding-top: {{navBarHeight}}px;"
  refresher-enabled="{{true}}"
  refresher-triggered="{{isRefresherTriggered}}"
  bindrefresherrefresh="onPullDownRefresh"
>
  <!-- 1. 骑手概览卡片 (Stats Card) -->
  <view class="stats-card">
    <view class="stats-header">
      <view class="rider-profile">
        <t-icon name="user-circle" size="48rpx" color="rgba(255,255,255,0.8)" />
        <view class="rider-name">{{riderInfo.real_name || '骑手用户'}}</view>
        <t-tag variant="light-outline" size="extra-small" theme="primary" wx:if="{{riderInfo.credit_score}}">
          信用: {{riderInfo.credit_score}}
        </t-tag>
      </view>
      <view class="wallet-entry" bindtap="onGoToWallet">
        <text>我的钱包</text>
        <t-icon name="chevron-right" size="32rpx" />
      </view>
    </view>
    
    <view class="stats-grid">
      <view class="stats-item">
        <view class="stats-value">¥{{stats.todayEarnings / 100 || '0.00'}}</view>
        <view class="stats-label">今日预计(元)</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <view class="stats-value">{{stats.todayCount || 0}}</view>
        <view class="stats-label">今日结单</view>
      </view>
    </view>
  </view>

  <!-- 2. 上线开关 (Sticky Status) -->
  <t-sticky offset-top="{{navBarHeight}}">
    <view class="status-bar {{isOnline ? 'is-online' : 'is-offline'}}">
      <view class="status-info">
        <view class="status-dot"></view>
        <text class="status-text">{{isOnline ? '接单服务中...' : '当前休息中'}}</text>
      </view>
      <view class="status-switch">
        <t-switch 
          value="{{isOnline}}" 
          bind:change="onToggleOnline" 
          colors="{{['#00897B', 'var(--td-bg-color-component)']}}"
        />
      </view>
    </view>
  </t-sticky>

  <!-- 3. 任务分类 (Tabs) -->
  <view class="content-section">
    <!-- 📢 新单实时提醒栏 (差量刷新提示) -->
    <view class="new-orders-bar" wx:if="{{newOrdersCount > 0}}" bindtap="onRefreshHall">
      <view class="bar-inner">
        <t-icon name="notification" size="32rpx" color="#fff" />
        <text class="bar-text">附近有 {{newOrdersCount}} 个新订单加入大厅</text>
        <view class="refresh-btn"> 点击刷新 <t-icon name="refresh" size="28rpx" /> </view>
      </view>
    </view>

    <t-tabs 
      value="{{activeTab}}" 
      bind:change="onTabChange" 
      sticky 
      stickyProps="{{ {offsetTop: navBarHeight + 44} }}"
      t-class="tabs-container"
    >
      <t-tab-panel label="抢单大厅" value="hall">
        <view class="tab-content">
          <!-- Hall Orders -->
          <block wx:if="{{recommendOrders.length > 0}}">
            <view 
              class="order-card grab-card" 
              wx:for="{{recommendOrders}}" 
              wx:key="order_id"
              bindtap="onGoToDetail"
              data-order-id="{{item.order_id}}"
            >
              <view class="order-header">
                <t-tag theme="warning" variant="light-outline" size="small">预计收入 ¥{{item.delivery_fee / 100}}</t-tag>
                <view class="distance-info">距您 {{item.distance_to_pickup}}m</view>
              </view>
              
              <view class="order-route">
                <view class="route-item pickup">
                  <view class="marker">取</view>
                  <view class="addr-box">
                    <view class="addr-name">{{item.merchant_name || '商户名称详情'}}</view>
                    <view class="addr-desc">{{item.merchant_address || '点击查看详情位置'}}</view>
                  </view>
                </view>
                <view class="route-line"></view>
                <view class="route-item delivery">
                  <view class="marker">送</view>
                  <view class="addr-box">
                    <view class="addr-name">{{item.customer_address || '订单送达地址'}}</view>
                    <view class="addr-desc">距离商家 {{item.distance}}m</view>
                  </view>
                </view>
              </view>

              <view class="order-footer">
                <view class="time-limit">
                  <t-icon name="time" size="32rpx" />
                  <text>预计 {{item.estimated_minutes}}分钟 送达</text>
                </view>
                <t-button 
                  theme="primary" 
                  size="small" 
                  shape="round" 
                  catchtap="onGrabOrder" 
                  data-order-id="{{item.order_id}}"
                >立即抢单</t-button>
              </view>
            </view>
          </block>
          <t-empty 
            wx:else 
            icon="info-circle" 
            description="{{isOnline ? '附近暂无可接订单' : '请先上线后再刷新订单'}}" 
          />
        </view>
      </t-tab-panel>

      <t-tab-panel label="我的任务" value="my">
        <view class="tab-content">
          <block wx:if="{{activeDeliveries.length > 0}}">
             <view 
              class="order-card task-card" 
              wx:for="{{activeDeliveries}}" 
              wx:key="id"
              bindtap="onGoToDetail"
              data-order-id="{{item.order_id}}"
            >
              <view class="order-header">
                <t-tag theme="primary" variant="dark" size="small">
                  {{item.status === 'assigned' ? '前往取餐' : (item.status === 'start_pickup' ? '取餐中' : (item.status === 'picked_up' ? '正在配送' : '配送中'))}}
                </t-tag>
                <view class="order-no">单号: {{item.order_id}}</view>
              </view>

              <view class="order-route">
                 <view class="route-item pickup {{item.status === 'picked_up' ? 'finished' : ''}}">
                  <view class="marker">取</view>
                  <view class="addr-box">
                    <view class="addr-name">{{item.pickup_address}}</view>
                  </view>
                </view>
                <view class="route-item delivery">
                  <view class="marker">送</view>
                  <view class="addr-box">
                    <view class="addr-name">{{item.delivery_address}}</view>
                  </view>
                </view>
              </view>

              <view class="order-footer">
                <view class="earnings">预计收入: <text class="price">¥{{item.rider_earnings / 100}}</text></view>
                <t-button theme="primary" size="small" variant="outline" shape="round">查看详情</t-button>
              </view>
            </view>
          </block>
          <t-empty wx:else icon="order-adjustment" description="暂无进行中的配送任务" />
        </view>
      </t-tab-panel>
    </t-tabs>
  </view>
  
  <view class="footer-safe"></view>
</scroll-view>
