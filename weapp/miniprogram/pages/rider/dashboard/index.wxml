<custom-navbar title="骑手工作台" showBack="{{true}}" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{loading && !riderInfo}}" class="page-state-card">
    <t-loading theme="circular" size="40rpx" text="加载中..." layout="vertical" />
  </view>

  <view wx:elif="{{initError && !riderInfo}}" class="page-state-card">
    <t-empty icon="error-circle" description="{{initError}}" />
    <t-button wx:if="{{initErrorCanRetry}}" theme="primary" bindtap="onRetryLoad">重试</t-button>
  </view>

  <block wx:else>
    <view wx:if="{{dashboardInlineError}}" class="inline-sync-state">
      <t-icon name="error-circle" size="32rpx" />
      <text class="inline-sync-state__text">{{dashboardInlineError}}</text>
      <t-button wx:if="{{initErrorCanRetry}}" size="small" theme="primary" variant="text" bindtap="onRetryLoad">重试</t-button>
    </view>

    <view class="workbench-summary-card">
      <view class="workbench-status-row">
        <view class="workbench-rider-main">
          <t-icon name="user-circle" size="44rpx" />
          <view class="workbench-rider-text">
            <text class="workbench-rider-name">{{riderInfo.real_name || '骑手用户'}}</text>
            <text class="workbench-rider-sub">信用分 {{riderInfo.credit_score || 100}}</text>
          </view>
        </view>
        <t-tag size="small" theme="{{onlineStatusTheme}}" variant="light">{{onlineStatusLabel}}</t-tag>
      </view>

      <view class="workbench-metrics-grid">
        <view wx:for="{{workbench.metrics}}" wx:key="key" class="workbench-metric-item">
          <text class="workbench-metric-label">{{item.label}}</text>
          <text class="workbench-metric-value">{{item.value}}</text>
          <text class="workbench-metric-note">{{item.note}}</text>
        </view>
      </view>

      <view class="workbench-risk-grid">
        <view wx:for="{{workbench.risks}}" wx:key="key" class="workbench-risk-item {{item.highlightClass}}" bindtap="onWorkbenchRiskTap" data-key="{{item.key}}">
          <text class="workbench-risk-label">{{item.label}}</text>
          <text class="workbench-risk-value">{{item.value}}</text>
          <text class="workbench-risk-note">{{item.note}}</text>
          <text wx:if="{{item.actionText}}" class="workbench-risk-action">{{item.actionText}}</text>
        </view>
      </view>
    </view>

    <t-sticky offsetTop="{{navBarHeight}}">
      <view class="status-bar-container">
        <view class="status-bar {{isOnline ? 'is-online' : 'is-offline'}}">
          <view class="status-info">
            <view class="status-dot"></view>
            <text class="status-text">{{statusText}}</text>
          </view>
          <t-switch
            value="{{isOnline}}"
            loading="{{onlineSwitchLoading}}"
            disabled="{{onlineSwitchLoading}}"
            bind:change="onToggleOnline"
            colors="{{['#00897B', 'var(--td-bg-color-component)']}}"
          />
        </view>
      </view>
    </t-sticky>

    <view wx:if="{{showSettlementReminder}}" class="inline-sync-state">
      <t-icon name="error-circle-filled" size="32rpx" />
      <text class="inline-sync-state__text">{{settlementReminderText}}</text>
      <t-button theme="primary" variant="text" size="small" bindtap="onGoToSettlementAccount">去开通</t-button>
    </view>

    <view wx:if="{{showDepositReminder}}" class="inline-sync-state">
      <t-icon name="error-circle-filled" size="32rpx" />
      <text class="inline-sync-state__text">{{depositReminderText}}</text>
      <t-button theme="primary" variant="text" size="small" bindtap="onGoToDeposit">去充值</t-button>
    </view>

    <view class="content-section">
      <view class="hall-entry-card" bindtap="onGoToHall">
        <view class="hall-entry-main">
          <view class="hall-entry-icon">
            <t-icon name="order-adjustment" size="42rpx" />
          </view>
          <view class="hall-entry-text">
            <text class="hall-entry-title">接单大厅</text>
            <text class="hall-entry-meta">{{workbench.availableOrderCount || 0}} 个可接订单</text>
          </view>
        </view>
        <view class="hall-entry-action">
          <t-tag wx:if="{{newOrdersCount > 0}}" theme="success" variant="light" size="small">新单 {{newOrdersCount}}</t-tag>
          <t-button theme="primary" size="small" catchtap="onGoToHall">进入</t-button>
        </view>
      </view>

      <view class="current-mission-card" wx:if="{{currentDelivery}}">
        <view class="current-mission-header">
          <view class="current-mission-title">当前任务</view>
          <t-tag theme="{{currentDelivery.status_tag_theme}}" variant="dark" size="small">{{currentDelivery.status_desc}}</t-tag>
        </view>

        <view class="current-mission-route">
          <view class="current-mission-point">
            <view class="marker-dot orange"></view>
            <view class="current-mission-body">
              <text class="current-mission-name">{{currentDelivery.merchant_name || currentDelivery.pickup_address}}</text>
              <text class="current-mission-address">{{currentDelivery.pickup_address}}</text>
            </view>
          </view>
          <view class="current-mission-divider"></view>
          <view class="current-mission-point">
            <view class="marker-dot green"></view>
            <view class="current-mission-body">
              <text class="current-mission-name">{{currentDelivery.delivery_contact || '顾客'}}</text>
              <text class="current-mission-address">{{currentDelivery.delivery_address}}</text>
            </view>
          </view>
        </view>

        <view class="current-mission-meta">
          <view class="current-mission-meta-item">
            <text class="meta-label">时限</text>
            <text class="meta-value">{{currentDelivery.deadline_desc || '尽快送达'}}</text>
          </view>
        </view>

        <view class="current-mission-actions">
          <t-button theme="primary" variant="outline" bindtap="onGoToDetail" data-order-id="{{currentDelivery.order_id}}">查看详情</t-button>
          <t-button theme="primary" bindtap="onGoToNavigation" data-order-id="{{currentDelivery.order_id}}">进入导航</t-button>
        </view>
      </view>

      <view class="tool-shortcuts">
        <view class="tool-shortcut" bindtap="onGoToIncome">
          <t-icon name="money" size="34rpx" />
          <text>结算账本</text>
        </view>
        <view class="tool-shortcut" bindtap="onGoToDeposit">
          <t-icon name="certificate" size="34rpx" />
          <text>押金保障</text>
        </view>
        <view class="tool-shortcut" bindtap="onGoToHistory">
          <t-icon name="task-checked" size="34rpx" />
          <text>历史任务</text>
        </view>
        <view class="tool-shortcut" bindtap="onGoToClaims">
          <t-icon name="service" size="34rpx" />
          <text>索赔申诉</text>
        </view>
      </view>
    </view>
  </block>
</view>
