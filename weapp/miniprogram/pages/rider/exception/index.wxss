.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-area {
  flex: 1;
  overflow: hidden;
}

.state-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 120rpx 40rpx;
}

.form-wrapper {
  padding: 30rpx;
  animation: fadeIn 0.4s ease-out forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 各组样式 */
.card-group {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.group-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.group-title t-icon {
  margin-right: 12rpx;
  color: var(--td-brand-color);
}

.notice-card,
.success-card {
  background: #fffaf5;
}

.notice-block {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  font-size: var(--font-size-sm);
  color: #666;
  line-height: 1.6;
}

.submitted-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: var(--font-size-sm);
}

.submitted-label {
  color: #999;
}

.submitted-value {
  color: #333;
  font-weight: 600;
}

.submitted-desc {
  margin-top: 12rpx;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: #333;
}

/* 订单选择器 */
.order-scroll {
  white-space: nowrap;
  width: 100%;
}

.order-card {
  display: inline-block;
  width: 400rpx;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: var(--radius-md);
  margin-right: 20rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.2s ease;
}

.order-card.active {
  background: #fff9f8;
  border-color: var(--td-brand-color);
  box-shadow: 0 4rpx 12rpx rgba(234, 68, 53, 0.1);
}

.order-no {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.order-merchant {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
}

.active-dot {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 12rpx;
  height: 12rpx;
  background: var(--td-brand-color);
  border-radius: 50%;
}

.empty-orders {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 24rpx;
}

/* 类型网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
  background: #f9f9f9;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #fff9f8;
  border-color: var(--td-brand-color);
  color: var(--td-brand-color);
}

.type-icon-box {
  margin-bottom: 12rpx;
  transition: transform 0.3s ease;
}

.type-item.active .type-icon-box {
  transform: scale(1.1);
}

.type-item text {
  font-size: 24rpx;
}

/* 文本域 */
.custom-textarea {
  --td-textarea-background-color: #f9f9f9;
  border-radius: var(--radius-md);
}

/* 提交部 */
.submit-footer {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.notice {
  text-align: center;
  font-size: var(--font-size-xs);
  color: #999;
  margin-top: 24rpx;
}
