<custom-navbar title="异常报备" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <scroll-view 
    scroll-y 
    class="scroll-area"
    refresher-enabled="{{true}}"
    refresher-triggered="{{loading}}"
    bindrefresherrefresh="onRefresh"
  >
    <view wx:if="{{errorMessage && !loading}}" class="state-shell">
      <t-empty icon="error-circle" description="{{errorMessage}}" />
      <t-button theme="primary" shape="round" bindtap="onRefresh">重新加载</t-button>
    </view>

    <view wx:else class="form-wrapper show">
      <view class="card-group notice-card">
        <view class="group-title">
          <t-icon name="info-circle" size="32rpx" /> 处理说明
        </view>
        <view class="notice-block">
          <text>本页仅提交配送异常。异常后进入索赔、追偿或申诉处理时，请前往“索赔与申诉”页查看。</text>
          <text>如遇商户闭店、车辆故障等未单列场景，请选择“其他原因”并在描述里写明现场情况。</text>
          <t-button theme="primary" variant="outline" shape="round" size="small" bindtap="onGoToClaims">查看索赔与申诉</t-button>
        </view>
      </view>

      <view class="card-group">
        <view class="group-title">
          <t-icon name="assignment" size="32rpx" /> 相关订单
        </view>
        <view class="order-selector-box">
          <scroll-view scroll-x class="order-scroll">
            <view 
              class="order-card {{formData.orderId === item.order_id ? 'active' : ''}}" 
              wx:for="{{activeOrders}}" 
              wx:key="order_id"
              bindtap="onSelectOrder"
              data-id="{{item.order_id}}"
            >
              <view class="order-no">单号: {{item.order_id}}</view>
              <view class="order-merchant">{{item.merchant_name || '未知商户'}}</view>
              <view class="active-dot" wx:if="{{formData.orderId === item.order_id}}"></view>
            </view>
            <view wx:if="{{activeOrders.length === 0}}" class="empty-orders">
              <t-icon name="info-circle" size="40rpx" color="#999" />
              <text>当前暂无可报备配送单</text>
            </view>
          </scroll-view>
        </view>
      </view>

      <view class="card-group">
        <view class="group-title">
          <t-icon name="view-module" size="32rpx" /> 异常类型
        </view>
        <view class="type-grid">
          <view 
            class="type-item {{formData.type === item.value ? 'active' : ''}}"
            wx:for="{{typeOptions}}"
            wx:key="value"
            bindtap="onTypeSelect"
            data-value="{{item.value}}"
          >
            <view class="type-icon-box">
               <t-icon name="{{item.icon || 'error'}}" size="48rpx" />
            </view>
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <view class="card-group">
        <view class="group-title">
          <t-icon name="edit-1" size="32rpx" /> 详情描述
        </view>
        <view class="textarea-box">
          <t-textarea 
            placeholder="请详细描述现场情况，方便平台核实及后续申诉（如：客户电话关机、商家闭店等）" 
            disable-default-padding
            maxlength="300" 
            indicator
            value="{{formData.description}}"
            bind:change="onDescriptionChange"
            t-class="custom-textarea"
          />
        </view>
      </view>

      <view class="submit-footer">
        <t-button 
          theme="primary" 
          size="large" 
          block 
          shape="round" 
          bindtap="onSubmit"
          loading="{{submitting}}"
          disabled="{{!formData.orderId || !formData.description}}"
        >立即上报</t-button>
        <view class="notice">上报后，平台将在2小时内完成初审</view>
      </view>

      <view class="card-group success-card" wx:if="{{lastSubmittedReport}}">
        <view class="group-title">
          <t-icon name="check-circle" size="32rpx" /> 最近一次提交
        </view>
        <view class="submitted-row">
          <text class="submitted-label">关联订单</text>
          <text class="submitted-value">#{{lastSubmittedReport.orderId}}</text>
        </view>
        <view class="submitted-row">
          <text class="submitted-label">异常类型</text>
          <text class="submitted-value">{{lastSubmittedReport.typeLabel}}</text>
        </view>
        <view class="submitted-desc">{{lastSubmittedReport.description}}</view>
      </view>

      <view class="card-group" wx:if="{{activeOrders.length === 0 && !loading}}">
        <t-empty icon="info-circle" description="当前暂无可报备配送单" />
      </view>
    </view>
  </scroll-view>
</view>
