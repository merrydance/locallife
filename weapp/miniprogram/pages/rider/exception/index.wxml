<custom-navbar title="异常报备" showBack="{{true}}" />

<scroll-view 
  scroll-y 
  class="page-container" 
  style="padding-top: {{navBarHeight}}px; padding-bottom: 120rpx;"
>
  <view class="content" wx:if="{{!showForm}}">
    <!-- 1. 历史记录 -->
    <view class="section-title">报备记录</view>
    <view class="history-list" wx:if="{{historyApps.length > 0}}">
      <view class="history-card" wx:for="{{historyApps}}" wx:key="id">
        <view class="card-header">
          <t-tag size="small" theme="{{item.status === 'resolved' ? 'success' : (item.status === 'dismissed' ? 'default' : 'warning')}}" variant="light-outline">
            {{item.status === 'resolved' ? '已处理' : (item.status === 'dismissed' ? '已驳回' : '处理中')}}
          </t-tag>
          <text class="time">{{item.created_at}}</text>
        </view>
        <view class="card-body">
          <view class="type">类型：{{item.exception_type}}</view>
          <view class="desc">{{item.description}}</view>
        </view>
        <view class="card-footer" wx:if="{{item.result}}">
          反馈：{{item.result}}
        </view>
      </view>
    </view>
    <t-empty wx:else icon="info-circle" description="暂无报备记录" />

    <!-- 底部悬浮按钮 -->
    <view class="fab-btn" bindtap="onOpenForm">
      <t-icon name="add" size="48rpx" color="#fff" />
    </view>
  </view>

  <!-- 2. 新增报备表单 -->
  <view class="form-container" wx:else>
    <view class="form-header">
      <text class="form-title">新增异常报备</text>
      <t-icon name="close" size="40rpx" bindtap="onCloseForm" />
    </view>

    <view class="form-section">
      <view class="label">选择关联订单 <text class="required">*</text></view>
      <scroll-view scroll-x class="order-selector">
        <view 
          class="order-chip {{formData.orderId === item.order_id ? 'active' : ''}}" 
          wx:for="{{activeOrders}}" 
          wx:key="order_id"
          bindtap="onSelectOrder"
          data-id="{{item.order_id}}"
        >
          单号: {{item.order_id}}
        </view>
        <view wx:if="{{activeOrders.length === 0}}" class="no-orders-tip">暂无进行中的订单</view>
      </scroll-view>
    </view>

    <view class="form-section">
      <view class="label">异常类型 <text class="required">*</text></view>
      <t-radio-group value="{{formData.type}}" bind:change="onTypeChange" t-class="radio-group-custom">
        <t-radio 
          wx:for="{{typeOptions}}" 
          wx:key="value" 
          value="{{item.value}}" 
          label="{{item.label}}" 
          icon="dot"
        />
      </t-radio-group>
    </view>

    <view class="form-section">
      <view class="label">详情描述 <text class="required">*</text></view>
      <t-textarea 
        placeholder="请详细描述现场情况，方便客服核实..." 
        bordered 
        maxlength="200" 
        indicator
        value="{{formData.description}}"
        bind:change="onDescriptionChange"
      />
    </view>

    <view class="form-actions">
      <t-button theme="primary" size="large" block shape="round" bindtap="onSubmit">提交上报</t-button>
    </view>
  </view>
</scroll-view>
