<custom-navbar title="配送详情" showBack="{{true}}" />

<scroll-view 
  scroll-y 
  class="page-container" 
  style="padding-top: {{navBarHeight}}px; padding-bottom: 200rpx;"
>
  <view class="loading-box" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" text="正在加载详情..." />
  </view>

  <view class="content">
    <!-- 1. 进度追踪 (Shell stays even when data is missing) -->
    <view class="detail-card steps-card">
      <t-steps current="{{currentStep}}" readonly t-class="custom-steps">
        <t-step-item 
          wx:for="{{statusSteps}}" 
          wx:key="status" 
          title="{{item.title}}" 
        />
      </t-steps>
    </view>

    <!-- 2. 异常状态展示 (Only shows if not loading AND no data) -->
    <view class="error-placeholder" wx:if="{{!loading && !delivery}}">
      <t-empty icon="info-circle" description="{{errorMessage || '订单不存在或已被接走'}}" />
      <t-button theme="primary" variant="outline" shape="round" block size="large" bindtap="onRetry" style="margin-top: 24rpx;">
        重试加载
      </t-button>
      <t-button theme="primary" shape="round" block size="large" bindtap="onBack" style="margin-top: 40rpx;">
        返回大厅
      </t-button>
    </view>

    <!-- 3. 正常业务数据占位/展示 -->
    <block wx:if="{{delivery}}">
      <!-- 收入与时间 -->
      <view class="detail-card income-card">
        <view class="info-item">
          <text class="label">预计收益</text>
          <view class="value price">¥{{delivery.rider_earnings / 100 || '--'}}</view>
        </view>
        <t-divider layout="vertical" />
        <view class="info-item">
          <text class="label">送达时限</text>
          <view class="value">{{delivery.deadline_desc || '尽快送达'}}</view>
        </view>
      </view>

      <!-- 取餐与送餐地址 -->
      <view class="detail-card route-card">
        <view class="location-box pickup">
          <view class="marker orange">取</view>
          <view class="info">
            <view class="title-row">
              <text class="name">{{delivery.merchant_name || delivery.pickup_address}}</text>
              <view class="action-group">
                <view
                  class="icon-action"
                  catchtap="onOpenLocation"
                  data-latitude="{{delivery.pickup_latitude}}"
                  data-longitude="{{delivery.pickup_longitude}}"
                  data-name="{{delivery.merchant_name || '取货点'}}"
                  data-address="{{delivery.pickup_address}}"
                  data-label="到店导航"
                >
                  <t-icon name="map-location" size="44rpx" color="var(--td-brand-color)" />
                </view>
                <view class="icon-action" wx:if="{{delivery.pickup_phone}}" catchtap="onCallPhone" data-phone="{{delivery.pickup_phone}}">
                  <t-icon name="call" size="44rpx" color="var(--td-brand-color)" />
                </view>
              </view>
            </view>
            <view class="contact-sub">
              <text class="address-text">{{delivery.pickup_address}}</text>
            </view>
          </view>
        </view>
        
        <view class="route-line-detail"></view>
        
        <view class="location-box delivery">
          <view class="marker green">送</view>
          <view class="info">
            <view class="title-row">
              <text class="name">{{delivery.delivery_address}}</text>
              <view class="action-group">
                <view
                  class="icon-action"
                  catchtap="onOpenLocation"
                  data-latitude="{{delivery.delivery_latitude}}"
                  data-longitude="{{delivery.delivery_longitude}}"
                  data-name="{{delivery.delivery_contact || '送达点'}}"
                  data-address="{{delivery.delivery_address}}"
                  data-label="送达导航"
                >
                  <t-icon name="map-location" size="44rpx" color="var(--td-brand-color)" />
                </view>
                <view class="icon-action" wx:if="{{delivery.delivery_phone}}" catchtap="onCallPhone" data-phone="{{delivery.delivery_phone}}">
                  <t-icon name="call" size="44rpx" color="var(--td-brand-color)" />
                </view>
              </view>
            </view>
             <view class="contact-sub">
              <text>{{delivery.delivery_contact || '客户'}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 商品清单 -->
      <view class="detail-card items-card" wx:if="{{delivery.items && delivery.items.length > 0}}">
        <view class="card-title">商品清单 (共{{delivery.item_count}}件)</view>
        <view class="item-list">
          <view class="item-row" wx:for="{{delivery.items}}" wx:key="name">
            <text class="dish-name">{{item.name}}</text>
            <text class="dish-qty">x {{item.quantity}}</text>
          </view>
        </view>
      </view>

      <!-- 订单信息 -->
      <view class="detail-card info-section">
        <t-cell-group borderless>
          <t-cell title="订单单号" note="{{orderId}}" />
          <t-cell title="备注" note="{{delivery.notes}}" wx:if="{{delivery.notes}}" />
          <t-cell title="下单时间" note="{{delivery.created_at}}" />
        </t-cell-group>
      </view>

      <view class="support-actions">
        <view class="support-entry" bindtap="onOpenDelayReport">
          <t-icon name="time" size="32rpx" />
          <text>预计会延时？先报备</text>
        </view>
        <view class="support-entry" bindtap="onReportException">
          <t-icon name="error-circle" size="32rpx" />
          <text>配送遇到问题？去报备</text>
        </view>
      </view>
    </block>
  </view>
</scroll-view>

<t-popup visible="{{showDelayReport}}" placement="bottom">
  <view class="delay-sheet">
    <view class="delay-sheet-title">配送延时报备</view>
    <text class="delay-sheet-desc">提前报备后，平台可以同步顾客和商户，减少后续争议。</text>

    <view class="delay-group">
      <text class="delay-label">常用原因</text>
      <view class="delay-chip-row">
        <view
          wx:for="{{delayReasonTemplates}}"
          wx:key="label"
          class="delay-chip"
          data-reason="{{item.reason}}"
          data-minutes="{{item.expectedMinutes}}"
          bindtap="onSelectDelayTemplate"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="delay-group">
      <text class="delay-label">预计延时</text>
      <view class="delay-chip-row">
        <view
          wx:for="{{delayMinuteOptions}}"
          wx:key="*this"
          class="delay-chip {{delayForm.expectedMinutes === item ? 'is-active' : ''}}"
          data-minutes="{{item}}"
          bindtap="onSelectDelayMinutes"
        >{{item}} 分钟</view>
      </view>
    </view>

    <view class="delay-group">
      <text class="delay-label">延时说明</text>
      <t-textarea
        value="{{delayForm.reason}}"
        placeholder="请说明延时原因，平台会据此同步各方。"
        maxlength="300"
        indicator
        bindchange="onDelayReasonChange"
      />
    </view>

    <view class="delay-sheet-actions">
      <t-button theme="default" variant="outline" shape="round" bindtap="onCloseDelayReport" disabled="{{delaySubmitting}}">取消</t-button>
      <t-button theme="primary" shape="round" loading="{{delaySubmitting}}" bindtap="onSubmitDelayReport">提交报备</t-button>
    </view>
  </view>
</t-popup>

<!-- 底部固定操作按钮 -->
<view class="bottom-action" wx:if="{{delivery && delivery.can_update_status}}">
  <t-button 
    theme="primary" 
    size="large" 
    block 
    shape="round" 
    bindtap="onUpdateStatus"
  >
    {{delivery.action_label}}
  </t-button>
</view>
