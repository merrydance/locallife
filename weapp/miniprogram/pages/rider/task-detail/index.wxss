.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
}

.loading-box {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.error-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  margin-top: 24rpx;
}

.content {
  padding: 0;
}

.detail-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  border: 1rpx solid var(--td-border-level-1-color);
}

.sync-warning-card {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  margin-bottom: var(--spacer-md);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
  color: var(--td-text-color-primary);
  font-size: var(--font-size-xs);
  line-height: 1.5;
}

.sync-warning-card text {
  flex: 1;
  min-width: 0;
}

/* 进度追踪 */
.steps-card {
  padding: 40rpx var(--spacer-md);
}

.custom-steps {
  --td-step-item-active-color: var(--td-brand-color);
  --td-step-item-finish-color: var(--td-success-color);
}

/* 收入卡片 */
.income-card {
  display: flex;
  align-items: center;
}

.income-card .info-item {
  flex: 1;
  text-align: center;
}

.income-card .label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  margin-bottom: 8rpx;
  display: block;
}

.income-card .value {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.income-card .price {
  color: var(--td-brand-color);
  font-size: 40rpx;
}

/* 路线卡片 */
.route-card {
  position: relative;
  padding: 40rpx var(--spacer-md);
}

.location-box {
  display: flex;
  align-items: flex-start;
}

.location-box .marker {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  color: #FFFFFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.pickup .marker {
  background: #FFA000;
}

.delivery .marker {
  background: var(--td-success-color);
}

.location-box .info {
  margin-left: 24rpx;
  flex: 1;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.action-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 16rpx;
}

.icon-action {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
}

.title-row .name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
  line-height: 1.4;
  flex: 1;
  margin-right: 20rpx;
}

.contact-sub {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.address-text {
  display: block;
  line-height: 1.5;
}

.contact-sub .phone {
  margin-left: 16rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.route-line-detail {
  width: 2rpx;
  height: 80rpx;
  background: #EEEEEE;
  margin: 10rpx 0 10rpx 23rpx;
}

.location-card {
  padding: var(--spacer-md);
}

.location-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.location-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.delivery-map {
  width: 100%;
  height: 320rpx;
  margin-top: var(--spacer-md);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.location-meta-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: var(--spacer-sm);
}

.location-meta-primary {
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--td-text-color-primary);
}

.location-meta-secondary {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.location-pending {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: var(--spacer-sm);
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--td-warning-color-light);
  color: var(--td-warning-color-7);
  font-size: var(--font-size-xs);
}

.location-actions {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
}

.location-actions-main {
  display: flex;
  gap: 16rpx;
}

/* 详情信息 */
.info-section {
  padding: 0;
  overflow: hidden;
}

.order-no-box {
  display: flex;
  align-items: center;
  color: var(--td-text-color-secondary);
}

.detail-actions {
  margin-top: var(--spacer-md);
  padding-bottom: var(--spacer-md);
}

/* 商品清单 */
.items-card .card-title {
  font-size: var(--font-size-base);
  font-weight: bold;
  margin-bottom: 24rpx;
  color: var(--td-text-color-primary);
}

.item-list {
  background: #F9F9F9;
  border-radius: var(--radius-sm);
  padding: 20rpx;
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-row:last-child {
  margin-bottom: 0;
}

.dish-name {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
}

.dish-qty {
  font-size: var(--font-size-sm);
  color: var(--td-brand-color);
  font-weight: bold;
}

