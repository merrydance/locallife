/* 配送详情样式 - 高级感与功能性结合 */

.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
}

.loading-box {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.content {
  padding: var(--spacer-md);
}

.detail-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

/* 进度追踪 */
.steps-card {
  padding: 40rpx var(--spacer-md);
}

.custom-steps {
  --td-step-item-active-color: var(--td-brand-color);
  --td-step-item-finish-color: var(--td-success-color);
}

/* 收入卡片 */
.income-card {
  display: flex;
  align-items: center;
}

.income-card .info-item {
  flex: 1;
  text-align: center;
}

.income-card .label {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  margin-bottom: 8rpx;
  display: block;
}

.income-card .value {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.income-card .price {
  color: var(--td-brand-color);
  font-size: 40rpx;
}

/* 路线卡片 */
.route-card {
  position: relative;
  padding: 40rpx var(--spacer-md);
}

.location-box {
  display: flex;
  align-items: flex-start;
}

.location-box .marker {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  color: #FFFFFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.pickup .marker {
  background: #FFA000;
}

.delivery .marker {
  background: var(--td-success-color);
}

.location-box .info {
  margin-left: 24rpx;
  flex: 1;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.title-row .name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
  line-height: 1.4;
  flex: 1;
  margin-right: 20rpx;
}

.contact-sub {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.contact-sub .phone {
  margin-left: 16rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.route-line-detail {
  width: 2rpx;
  height: 80rpx;
  background: #EEEEEE;
  margin: 10rpx 0 10rpx 23rpx;
}

/* 详情信息 */
.info-section {
  padding: 0;
  overflow: hidden;
}

.order-no-box {
  display: flex;
  align-items: center;
  color: var(--td-text-color-secondary);
}

/* 异常入口 */
.exception-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacer-md);
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-sm);
}

.exception-entry t-icon {
  margin-right: 12rpx;
}

/* 底部按钮 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}
