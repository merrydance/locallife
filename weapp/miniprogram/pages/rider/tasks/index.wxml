<custom-navbar title="配送历史" showBack="{{true}}" />

<scroll-view 
  scroll-y 
  class="page-container" 
  style="padding-top: {{navBarHeight}}px;"
  bindscrolltolower="onReachBottom"
>
  <!-- 历史概览 -->
  <view class="history-summary">
    <view class="summary-item">
      <view class="val">{{totalCount}}</view>
      <view class="lab">累计完成</view>
    </view>
    <t-divider layout="vertical" />
    <view class="summary-item">
      <view class="val">¥{{totalEarnings / 100}}</view>
      <view class="lab">累计收益</view>
    </view>
  </view>

  <!-- 历史列表 -->
  <view class="history-list" wx:if="{{deliveries.length > 0}}">
    <view 
      class="history-card" 
      wx:for="{{deliveries}}" 
      wx:key="id"
      bindtap="onGoToDetail"
      data-order-id="{{item.order_id}}"
    >
      <view class="card-header">
        <text class="date">{{item.completed_at || item.created_at}}</text>
        <t-tag theme="success" variant="light-outline" size="extra-small">已送达</t-tag>
      </view>
      
      <view class="card-body">
        <view class="route-info">
          <view class="address"><t-icon name="location" size="32rpx" /> {{item.pickup_address}}</view>
          <view class="arrow"><t-icon name="arrow-down-rectangle" size="24rpx" /></view>
          <view class="address"><t-icon name="map-location" size="32rpx" /> {{item.delivery_address}}</view>
        </view>
      </view>

      <view class="card-footer">
        <text class="order-no">订单: {{item.order_id}}</text>
        <view class="income">+¥{{item.rider_earnings / 100}}</view>
      </view>
    </view>
    
    <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." />
    <view class="no-more" wx:if="{{!hasMore}}">到底啦，仅显示最近半年的记录</view>
  </view>
  
  <t-empty wx:else icon="order-adjustment" description="暂无历史纪录" />
</scroll-view>
