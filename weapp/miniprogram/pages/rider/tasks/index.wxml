<custom-navbar title="代取历史" showBack="{{true}}" bind:navheight="onNavHeight" />

<scroll-view 
  scroll-y 
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" 
  style="--page-shell-nav-height: {{navBarHeight}}px;"
  bindscrolltolower="onReachBottom"
>
  <view class="history-filter">
    <view class="date-filter-main" bindtap="onOpenRangePicker">
      <t-icon name="calendar" size="34rpx" />
      <view class="date-filter-text">
        <text class="date-filter-label">日期范围</text>
        <text class="date-filter-value">{{dateRangeLabel}}</text>
      </view>
      <t-icon name="chevron-right" size="32rpx" />
    </view>
    <t-button wx:if="{{hasDateRange}}" size="small" theme="default" variant="outline" bindtap="onClearDateRange">全部</t-button>
  </view>

  <view wx:if="{{loading && deliveries.length === 0}}" class="history-loading">
    <t-loading theme="circular" size="40rpx" text="正在加载历史任务..." />
  </view>

  <view wx:elif="{{errorMessage && deliveries.length === 0}}" class="history-error card-state">
    <t-empty icon="error-circle" description="{{errorMessage}}" />
    <t-button theme="primary" bindtap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
  <view wx:if="{{refreshErrorMessage}}" class="history-sync-state">
    <t-icon name="error-circle" size="30rpx" />
    <text>{{refreshErrorMessage}}</text>
    <t-button theme="primary" variant="text" size="small" bindtap="onRetry">重试</t-button>
  </view>

  <view class="history-count-row">
    <text>{{totalCount}} 条任务</text>
  </view>

  <!-- 历史列表 -->
  <view class="history-list" wx:if="{{deliveries.length > 0}}">
    <view 
      class="history-card" 
      wx:for="{{deliveries}}" 
      wx:key="id"
      bindtap="onGoToDetail"
      data-order-id="{{item.order_id}}"
    >
      <view class="card-header">
        <text class="date">{{item.display_time || '--'}}</text>
        <t-tag theme="{{item.status_theme}}" variant="dark" size="extra-small">{{item.status_text}}</t-tag>
      </view>
      
      <view class="card-body">
        <view class="route-info">
          <view class="address-row">
            <view class="address"><t-icon name="location" size="32rpx" /> {{item.pickup_address}}</view>
            <view
              class="nav-action"
              catchtap="onOpenLocation"
              data-latitude="{{item.pickup_latitude}}"
              data-longitude="{{item.pickup_longitude}}"
              data-name="{{item.merchant_name || '取货点'}}"
              data-address="{{item.pickup_address}}"
              data-label="到店导航"
            >
              <t-icon name="map-location" size="34rpx" />
            </view>
          </view>
          <view class="arrow"><t-icon name="arrow-down-rectangle" size="24rpx" /></view>
          <view class="address-row">
            <view class="address"><t-icon name="map-location" size="32rpx" /> {{item.delivery_address}}</view>
            <view
              class="nav-action"
              catchtap="onOpenLocation"
              data-latitude="{{item.delivery_latitude}}"
              data-longitude="{{item.delivery_longitude}}"
              data-name="{{item.delivery_contact || '送达点'}}"
              data-address="{{item.delivery_address}}"
              data-label="送达导航"
            >
              <t-icon name="map-location" size="34rpx" />
            </view>
          </view>
        </view>
      </view>

      <view class="card-footer">
        <text class="order-no">订单: {{item.order_id}}</text>
        <view class="income">{{item.income_view.summaryText}}</view>
      </view>
    </view>
    
    <t-loading wx:if="{{loadingMore}}" theme="circular" size="40rpx" text="加载中..." />
    <view class="card-state load-more-state" wx:if="{{loadMoreError}}">
      <text class="load-more-error">{{loadMoreError}}</text>
      <t-button theme="primary" variant="outline" bindtap="onRetryLoadMore">重试加载更多</t-button>
    </view>
    <view class="no-more" wx:if="{{!hasMore && !loadMoreError}}">没有更多任务了</view>
  </view>
  
  <t-empty wx:else icon="order-adjustment" description="暂无历史任务" />
  </block>

  <t-calendar
    title="选择日期范围"
    type="range"
    visible="{{rangePickerVisible}}"
    value="{{rangePickerValue}}"
    minDate="{{rangePickerMinDate}}"
    maxDate="{{rangePickerMaxDate}}"
    confirmBtn="确定"
    bind:confirm="onConfirmRangePicker"
    bind:close="onCloseRangePicker"
  />
</scroll-view>
