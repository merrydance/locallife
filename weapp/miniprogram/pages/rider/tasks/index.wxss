/* 配送历史样式 */

.page-container {
  background: var(--td-bg-color-page);
  min-height: 100vh;
}

.history-loading,
.card-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 24rpx;
}

.history-summary {
  display: flex;
  background: #FFFFFF;
  padding: 40rpx;
  align-items: center;
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-item .val {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.summary-item .lab {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.history-list {
  padding: 0;
}

.history-card {
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-sm);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-md);
}

.card-header .date {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.route-info {
  margin-bottom: var(--spacer-md);
}

.address-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.address {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  display: flex;
  align-items: center;
  flex: 1;
}

.address t-icon {
  margin-right: 12rpx;
  color: var(--td-text-color-placeholder);
}

.arrow {
  padding: 8rpx 0 8rpx 36rpx;
  color: var(--td-border-level-1-color);
}

.nav-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-round);
  background: var(--td-bg-color-secondarycontainer);
  border: 1rpx solid var(--td-component-border);
  color: var(--td-brand-color);
  flex-shrink: 0;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--spacer-sm);
  border-top: 1rpx solid var(--td-border-level-1-color);
}

.order-no {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.income {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-success-color);
}

.no-more {
  text-align: center;
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  padding: 40rpx 0;
}

.load-more-state {
  padding: 32rpx 24rpx 48rpx;
}

.load-more-error {
  font-size: var(--font-size-xs);
  color: var(--td-error-color);
  line-height: 1.6;
}
