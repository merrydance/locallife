<custom-navbar title="索赔与申诉" showBack="{{true}}" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{initialLoading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载索赔与申诉中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="state-block">
    <t-empty description="{{initialErrorMessage || '索赔与申诉加载失败，请重试'}}" />
    <t-button theme="primary" bindtap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view wx:if="{{refreshErrorMessage}}" class="sync-state">
      <t-icon name="error-circle" size="32rpx" />
      <text class="sync-state__text">{{refreshErrorMessage}}</text>
      <t-button size="small" theme="primary" variant="text" icon="refresh" bindtap="onRetryRefresh">重试</t-button>
    </view>

    <view class="summary-grid">
      <view class="summary-card accent-total">
        <text class="summary-label">全部索赔</text>
        <text class="summary-value">{{summary.total}}</text>
      </view>
      <view class="summary-card accent-pending">
        <text class="summary-label">待处理</text>
        <text class="summary-value">{{summary.pendingAction}}</text>
      </view>
      <view class="summary-card accent-appealed">
        <text class="summary-label">申诉中</text>
        <text class="summary-value">{{summary.appealed}}</text>
      </view>
      <view class="summary-card accent-closed">
        <text class="summary-label">已结案</text>
        <text class="summary-value">{{summary.closed}}</text>
      </view>
    </view>

    <t-tabs value="{{sectionTab}}" bind:change="onSectionTabChange" t-class="claims-tabs">
      <t-tab-panel label="索赔记录" value="claims"><view /></t-tab-panel>
      <t-tab-panel label="我的申诉" value="appeals"><view /></t-tab-panel>
    </t-tabs>

    <block wx:if="{{sectionTab === 'claims'}}">
      <t-tabs value="{{bucketTab}}" bind:change="onBucketTabChange" t-class="claims-tabs sub-tabs">
        <t-tab-panel label="全部" value="all"><view /></t-tab-panel>
        <t-tab-panel label="待处理" value="pending_action"><view /></t-tab-panel>
        <t-tab-panel label="申诉中" value="appealed"><view /></t-tab-panel>
        <t-tab-panel label="已结案" value="closed"><view /></t-tab-panel>
      </t-tabs>

      <view wx:if="{{loading && !claims.length}}" class="state-block state-block-compact">
        <t-loading theme="circular" size="40rpx" text="刷新索赔中..." vertical />
      </view>

      <view wx:elif="{{!loading && claims.length === 0}}" class="empty-wrap">
        <t-empty description="当前筛选下暂无索赔记录" />
      </view>

      <view wx:else class="claims-list">
        <view wx:for="{{claims}}" wx:key="id" class="claim-card" data-claim-id="{{item.id}}" bindtap="onViewClaimDetail">
          <view class="card-header">
            <view class="left">
              <text class="order-no">订单 {{item.orderNo}}</text>
              <t-tag size="small" theme="{{item.claimTypeTheme}}" variant="dark">{{item.claimTypeLabel}}</t-tag>
            </view>
            <t-tag size="small" theme="{{item.statusTheme}}" variant="dark">{{item.statusLabel}}</t-tag>
          </view>

          <view class="status-strip">
            <t-tag size="small" theme="{{item.appealStatusTheme}}" variant="light">{{item.appealStatusLabel}}</t-tag>
            <t-tag size="small" theme="{{item.recoveryStatusTheme}}" variant="light">{{item.recoveryStatusLabel}}</t-tag>
          </view>

          <view class="row">
            <text class="label">索赔金额</text>
            <text class="value">{{item.claimAmountText}}</text>
          </view>
          <view class="row">
            <text class="label">批准金额</text>
            <text class="value">{{item.approvedAmountText}}</text>
          </view>
          <view class="row">
            <text class="label">提交时间</text>
            <text class="value">{{item.createdAtLabel}}</text>
          </view>

        </view>

        <view wx:if="{{loadingMore}}" class="list-footer">
          <t-loading theme="circular" size="32rpx" text="加载更多索赔中..." vertical />
        </view>

        <view wx:elif="{{!hasMore && claims.length > 0}}" class="list-footer list-footer-end">
          <text>没有更多索赔记录了</text>
        </view>
      </view>
    </block>

    <block wx:elif="{{sectionTab === 'appeals'}}">
      <view wx:if="{{loading && !appeals.length}}" class="state-block state-block-compact">
        <t-loading theme="circular" size="40rpx" text="刷新申诉中..." vertical />
      </view>

      <view wx:elif="{{!loading && appeals.length === 0}}" class="empty-wrap">
        <t-empty description="暂无申诉记录" />
      </view>

      <view wx:else class="claims-list">
        <view wx:for="{{appeals}}" wx:key="id" class="claim-card" data-claim-id="{{item.claimId}}" bindtap="onViewAppealClaim">
          <view class="card-header">
            <view class="left">
              <text class="order-no">{{item.claimTypeLabel}} · {{item.orderNo}}</text>
            </view>
            <t-tag size="small" theme="{{item.statusTheme}}" variant="dark">{{item.statusLabel}}</t-tag>
          </view>

          <view class="row">
            <text class="label">关联索赔单</text>
            <text class="value">#{{item.claimId}}</text>
          </view>
          <view class="row">
            <text class="label">提交时间</text>
            <text class="value">{{item.createdAtLabel}}</text>
          </view>

        </view>
      </view>
    </block>
  </block>
</view>