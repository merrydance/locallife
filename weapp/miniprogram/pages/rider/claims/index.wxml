<custom-navbar title="索赔与申诉" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <view wx:if="{{errorMessage && !loading}}" class="state-shell">
    <t-empty icon="error-circle" description="{{errorMessage}}" />
    <t-button theme="primary" block shape="round" bindtap="onRetry">重新加载</t-button>
  </view>

  <block wx:else>
    <view class="form-card">
      <view class="section-title">发起申诉</view>
      <t-cell title="关联索赔单" arrow hover note="{{form.claimLabel || '请选择索赔单'}}" bindtap="onPickClaim" />
      <t-textarea 
        placeholder="请写明对索赔结果的异议原因，平台会据此复核。" 
        value="{{form.description}}" 
        bindchange="onDescChange"
        maxlength="300"
        indicator
      />
      <t-button theme="primary" block shape="round" loading="{{submitting}}" disabled="{{!form.claimId || !form.description}}" bindtap="onSubmit">提交申诉</t-button>
      <view class="form-hint">异常报备请前往异常报备页；本页仅处理索赔、追偿和申诉。</view>
    </view>

    <view class="history-section">
      <t-tabs value="{{activeTab}}" bind:change="switchTab">
        <t-tab-panel label="索赔记录" value="claims"></t-tab-panel>
        <t-tab-panel label="我的申诉" value="appeals"></t-tab-panel>
      </t-tabs>

      <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" class="loading" />

      <view wx:if="{{!loading && activeTab === 'claims'}}" class="claims-list">
        <view wx:if="{{claims.length === 0}}" class="empty">
          <t-empty description="暂无索赔记录" />
        </view>

        <view wx:else>
          <view wx:for="{{claims}}" wx:key="id" class="claim-card">
            <view class="card-header">
              <text class="claim-type">{{item.typeLabel}}</text>
              <t-tag theme="{{item.status === 'pending' ? 'warning' : item.status === 'approved' || item.status === 'compensated' ? 'success' : 'danger'}}" size="small">{{item.statusLabel}}</t-tag>
            </view>
            <text class="claim-order">关联订单 {{item.orderNo}}</text>
            <text class="claim-desc">{{item.description}}</text>
            <text class="claim-time">{{item.createdAt}}</text>

            <view wx:if="{{item.appealStatusLabel}}" class="claim-recovery">
              <view class="recovery-row">
                <text class="recovery-label">申诉状态</text>
                <text class="recovery-value">{{item.appealStatusLabel}}</text>
              </view>
            </view>

            <view wx:if="{{item.recoveryStatus}}" class="claim-recovery">
              <view class="recovery-row">
                <text class="recovery-label">追偿状态</text>
                <text class="recovery-value">{{item.recoveryStatusLabel}}</text>
              </view>
              <t-button
                wx:if="{{item.recoveryStatus === 'pending' || item.recoveryStatus === 'overdue'}}"
                theme="primary"
                size="small"
                loading="{{recoveryPaying[item.id]}}"
                data-claim-id="{{item.id}}"
                bindtap="onPayRecovery"
                shape="round"
              >支付追偿</t-button>
            </view>

            <view class="card-actions">
              <t-button
                theme="default"
                variant="outline"
                size="small"
                shape="round"
                loading="{{decisionLoading[item.id]}}"
                data-claim-id="{{item.id}}"
                bindtap="onViewDecision"
              >查看判定依据</t-button>
              <t-button
                wx:if="{{!item.appealId}}"
                theme="primary"
                variant="outline"
                size="small"
                shape="round"
                data-claim-id="{{item.id}}"
                bindtap="onPrepareAppeal"
              >发起申诉</t-button>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{!loading && activeTab === 'appeals'}}" class="claims-list">
        <view wx:if="{{appeals.length === 0}}" class="empty">
          <t-empty description="暂无申诉记录" />
        </view>

        <view wx:else>
          <view wx:for="{{appeals}}" wx:key="id" class="claim-card">
            <view class="card-header">
              <text class="claim-type">申诉单 #{{item.id}}</text>
              <t-tag theme="{{item.status === 'pending' ? 'warning' : item.status === 'approved' || item.status === 'compensated' ? 'success' : 'danger'}}" size="small">{{item.statusLabel}}</t-tag>
            </view>
            <text class="claim-order">关联索赔单 #{{item.claimId}}</text>
            <text class="claim-desc">{{item.reason}}</text>
            <text class="claim-time">{{item.createdAt}}</text>
            <view wx:if="{{item.reviewNotes}}" class="claim-recovery">
              <view class="recovery-row">
                <text class="recovery-label">处理说明</text>
                <text class="recovery-value">{{item.reviewNotes}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
