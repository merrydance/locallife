.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding: 0;
  box-sizing: border-box;
}

.state-block,
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
}

.state-block {
  padding: 140rpx var(--spacer-md);
}

.state-block-compact {
  padding: 80rpx var(--spacer-md);
}

.sync-state {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  margin-bottom: var(--spacer-sm);
  padding: var(--spacer-sm);
  border-radius: var(--radius-md);
  background: var(--td-warning-color-1);
  color: var(--td-text-color-primary);
}

.sync-state__text {
  flex: 1;
  min-width: 0;
  font-size: var(--font-size-xs);
  line-height: 1.5;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.summary-card {
  border-radius: var(--radius-md);
  padding: var(--spacer-sm);
  color: var(--td-text-color-primary);
  border: 1rpx solid var(--td-border-level-1-color);
}

.accent-total {
  background: var(--td-bg-color-secondarycontainer);
}

.accent-pending {
  background: var(--td-warning-color-1);
}

.accent-appealed {
  background: var(--td-bg-color-secondarycontainer);
}

.accent-closed {
  background: var(--td-success-color-1);
}

.summary-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.summary-value {
  display: block;
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-title);
  font-weight: 700;
}

.claims-tabs {
  margin-bottom: var(--spacer-xs);
  border-radius: 0;
  overflow: visible;
  background: transparent;
}

.sub-tabs {
  margin-bottom: var(--spacer-sm);
}

.empty-wrap {
  margin-top: 120rpx;
}

.claims-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.list-footer {
  display: flex;
  justify-content: center;
  padding: var(--spacer-md) 0 var(--spacer-lg);
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-xs);
}

.list-footer-end {
  opacity: 0.92;
}

.claim-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  border: 1rpx solid var(--td-border-level-1-color);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--spacer-sm);
  gap: var(--spacer-sm);
}

.card-header .left {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--spacer-xs);
}

.order-no {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.status-strip {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-xs);
  margin-bottom: var(--spacer-sm);
}

.row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin: var(--spacer-xs) 0;
}

.label {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  white-space: nowrap;
}

.value {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-primary);
  text-align: right;
  line-height: 1.5;
}

.claims-list {
  padding-bottom: var(--spacer-sm);
}
