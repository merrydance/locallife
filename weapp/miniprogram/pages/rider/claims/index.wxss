.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding: 24rpx;
}

.state-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: 120rpx 40rpx;
}

.form-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: #333;
  margin-bottom: var(--spacer-md);
}

.form-hint {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-xs);
  color: #999;
  line-height: 1.6;
}

.history-section {
  margin-top: var(--spacer-lg);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.empty {
  padding: 60rpx 0;
}

.claim-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-sm);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--spacer-sm);
  margin-bottom: 12rpx;
}

.claim-type {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: #333;
}

.claim-order {
  font-size: var(--font-size-xs);
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.claim-desc {
  font-size: var(--font-size-sm);
  color: #666;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.claim-time {
  font-size: var(--font-size-xs);
  color: #999;
}

.claim-recovery {
  margin-top: var(--spacer-sm);
  padding: var(--spacer-sm);
  background: #f8fafc;
  border-radius: var(--radius-md);
}

.recovery-row {
  display: flex;
  justify-content: space-between;
  gap: var(--spacer-sm);
  font-size: var(--font-size-xs);
  color: #666;
  line-height: 1.6;
}

.recovery-label {
  color: #999;
}

.recovery-value {
  flex: 1;
  text-align: right;
  color: #333;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: var(--spacer-sm);
}
