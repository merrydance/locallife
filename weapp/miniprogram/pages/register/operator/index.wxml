<custom-navbar title="运营商入驻" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 140rpx;">
  <view class="steps-container" wx:if="{{currentStep > 0 && currentStep < 4}}">
    <t-steps current="{{currentStep - 1}}">
      <t-step-item title="选择区域" />
      <t-step-item title="资质上传" />
      <t-step-item title="提交申请" />
    </t-steps>
  </view>

  <view class="form-content">
    <view class="step-view animate-fade-in" wx:if="{{currentStep === 0}}">
      <view class="hero-card">
        <view class="partner-badge">CITY PARTNER</view>
        <view class="hero-title">成为 LocalLife 城市合伙人</view>
        <view class="hero-subtitle">共享数字化本地生活万亿蓝海市场</view>
        
        <view class="feature-list">
          <view class="feature-item">
            <view class="feature-icon"><t-icon name="location-setting" size="48rpx" color="var(--td-brand-color)" /></view>
            <view class="feature-info">
              <text class="feature-title">区域独占经营</text>
              <text class="feature-desc">一区一商，锁定行政区域经营权</text>
            </view>
          </view>
          <view class="feature-item">
            <view class="feature-icon"><t-icon name="chart-bubble" size="48rpx" color="var(--td-brand-color)" /></view>
            <view class="feature-info">
              <text class="feature-title">高比例分佣</text>
              <text class="feature-desc">区域内所有商家流水均可获得收益分成</text>
            </view>
          </view>
          <view class="feature-item">
            <view class="feature-icon"><t-icon name="view-module" size="48rpx" color="var(--td-brand-color)" /></view>
            <view class="feature-info">
              <text class="feature-title">全套系统赋能</text>
              <text class="feature-desc">提供成熟的商家/骑手管理与营销工具</text>
            </view>
          </view>
        </view>
      </view>

      <view class="operation-flow">
        <view class="flow-title">入驻标准流程</view>
        <view class="flow-steps">
          <view class="flow-node">选择区域</view>
          <view class="flow-line"></view>
          <view class="flow-node">上传资质</view>
          <view class="flow-line"></view>
          <view class="flow-node">总部面试</view>
          <view class="flow-line"></view>
          <view class="flow-node">正式签约</view>
        </view>
      </view>
    </view>

    <view class="step-view animate-fade-in" wx:if="{{currentStep === 1}}">
      <view class="section-title">申请区域</view>
      <view class="card-group">
        <t-cell title="目标运营区" arrow hover bindtap="onOpenRegionPopup">
          <view slot="note" class="cell-value {{formData.regionName ? '' : 'placeholder'}}">
            {{formData.regionName || '点击选择省市县'}}
          </view>
        </t-cell>
      </view>

      <view class="section-title">运营商基本信息</view>
      <view class="card-group">
        <t-input 
          label="运营商名称" 
          placeholder="可选，留空将自动使用个人姓名" 
          value="{{formData.name}}" 
          bindchange="onInput" 
          data-field="name" 
        />
        <t-input 
          label="联系人姓名" 
          maxlength="{{20}}"
          placeholder="负责人真实姓名" 
          value="{{formData.contactName}}" 
          bindchange="onInput" 
          data-field="contactName" 
        />
        <view class="field-block {{phoneError ? 'field-block-error' : ''}}">
          <t-input 
            label="联系人电话" 
            type="number" 
            placeholder="请输入负责人手机号" 
            value="{{formData.contactPhone}}" 
            bindchange="onInput" 
            data-field="contactPhone" 
          />
        </view>
        <view class="field-error-text" wx:if="{{phoneError}}">{{phoneError}}</view>
      </view>

      <view class="section-title">合伙方案</view>
      <view class="card-group">
        <t-cell title="申请合同期限">
           <t-stepper 
             value="{{formData.years}}" 
             min="{{1}}" 
             max="{{10}}" 
             theme="gray" 
             bind:change="onYearsChange" 
             slot="note" 
           />
           <text slot="note" class="unit-text">年</text>
        </t-cell>
      </view>
    </view>

    <view class="step-view animate-fade-in" wx:if="{{currentStep === 2}}">
      <view class="section-title">资质上传（仅需身份证）</view>
      <view class="upload-section">
        <view class="label-row">
          <text class="label required">法人身份证正反面</text>
        </view>
        <view class="upload-stack">
          <document-uploader 
            type="id-front" 
            title="法人身份证人像面" 
            value="{{idFront.url}}" 
            rawUrl="{{idFront.rawUrl}}"
            feedbackState="{{uploadFeedback.idFront.state}}"
            feedbackTitle="{{uploadFeedback.idFront.title}}"
            feedbackDescription="{{uploadFeedback.idFront.description}}"
            bind:change="onIdFrontUpload"
            bind:remove="onIdFrontRemove" 
          />
          <view class="upload-spacer"></view>
          <document-uploader 
            type="id-back" 
            title="法人身份证国徽面" 
            value="{{idBack.url}}" 
            rawUrl="{{idBack.rawUrl}}"
            feedbackState="{{uploadFeedback.idBack.state}}"
            feedbackTitle="{{uploadFeedback.idBack.title}}"
            feedbackDescription="{{uploadFeedback.idBack.description}}"
            bind:change="onIdBackUpload"
            bind:remove="onIdBackRemove" 
          />
        </view>
      </view>
    </view>

    <view class="step-view animate-fade-in" wx:if="{{currentStep === 3}}">
      <view class="ocr-status-banner" wx:if="{{ocrDisplayState.idCard === 'processing'}}">
        系统仍在核验身份证图片，本页不再展示字段级占位，避免把进度提示和确认信息混在一起。
      </view>
      <view class="final-check">
        <t-icon name="check-circle-filled" size="120rpx" color="var(--td-brand-color)" />
        <view class="check-title">确认以上信息真实有效</view>
        <view class="check-desc">提交后将进入总部人工审核，预计 2 个工作日内会有专人联系面试</view>
      </view>

      <view class="summary-list">
        <t-cell title="申请区域" note="{{formData.regionName}}" />
        <t-cell title="运营商" note="{{formData.name}}" />
        <t-cell title="负责人" note="{{formData.contactName}}" />
        <t-cell title="手机号" note="{{formData.contactPhone}}" />
      </view>
    </view>

    <view class="step-view center" wx:if="{{currentStep === 4}}">
       <view class="result-status">
         <t-icon name="time-filled" size="160rpx" color="#FF9800" />
         <view class="status-text">申请已提交，审核中</view>
         <view class="status-hint">我们的合伙人经理将在 24 小时内致电与您进行初选沟通，请保持电话畅通。</view>
       </view>
      <t-button theme="primary" ghost block bindtap="onBackHome">返回个人中心</t-button>
    </view>

  </view>
  <view class="bottom-action animate-slide-up" wx:if="{{currentStep < 4}}">
    <view class="consent-row" wx:if="{{currentStep === 0 || currentStep === 3}}">
      <t-checkbox-group bindchange="onConsentChange">
        <label class="consent-label">
          <t-checkbox value="agree" checked="{{consentChecked}}"></t-checkbox>
          <text>我已阅读并同意</text>
        </label>
      </t-checkbox-group>
      <view class="consent-links">
        <text class="consent-link" data-type="USER_AGREEMENT" data-title="用户服务协议" catchtap="onViewAgreement">《用户服务协议》</text>
        <text>和</text>
        <text class="consent-link" data-type="PRIVACY_POLICY" data-title="隐私政策" catchtap="onViewAgreement">《隐私政策》</text>
      </view>
    </view>

    <block wx:if="{{currentStep === 0}}">
      <t-button block theme="primary" bindtap="onNext">立即申请区域合伙人</t-button>
    </block>
    <block wx:else>
      <view class="btn-group">
        <t-button bindtap="onPrev">上一步</t-button>
        <t-button theme="primary" bindtap="onNextOrSubmit" loading="{{isSubmitting}}">
          {{currentStep === 3 ? '确认提交申请' : '下一步'}}
        </t-button>
      </view>
    </block>
  </view>
</view>

<t-popup visible="{{consentPopupVisible}}" placement="bottom" bind:visible-change="closeConsentPopup">
  <view class="consent-popup">
    <view class="consent-popup-title">入驻协议确认</view>
    <view class="consent-popup-desc">继续入驻前，请阅读并同意以下协议：</view>
    <view class="consent-popup-links">
      <text class="consent-link" data-type="USER_AGREEMENT" data-title="用户服务协议" catchtap="onViewAgreement">《用户服务协议》</text>
      <text class="consent-link" data-type="PRIVACY_POLICY" data-title="隐私政策" catchtap="onViewAgreement">《隐私政策》</text>
    </view>
    <t-button block theme="primary" bindtap="onConfirmConsent">我已阅读并同意，继续</t-button>
    <t-button block variant="text" bindtap="closeConsentPopup">暂不继续</t-button>
  </view>
</t-popup>
<t-picker
  visible="{{regionPopupVisible}}"
  value="{{regionPickerValue}}"
  title="选择运营区域"
  cancelBtn="取消"
  confirmBtn="确认"
  auto-close="{{false}}"
  visible-item-count="{{7}}"
  item-height="{{64}}"
  popup-props="{{regionPickerPopupProps}}"
  bind:pick="onRegionPickerPick"
  bind:confirm="onRegionPickerConfirm"
  bind:cancel="onCloseRegionPopup"
>
  <t-picker-item options="{{provinceOptions}}" />
  <t-picker-item options="{{cityOptions}}" />
  <t-picker-item options="{{regionOptions}}" />
  <view slot="footer" class="picker-safe-area"></view>
</t-picker>
