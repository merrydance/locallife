<custom-navbar title="商家入驻" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 80rpx;">
  <view class="hero-section">
    <view class="hero-title">开启您的数字化餐厅之路</view>
    <view class="hero-subtitle">选择适合您的入驻方式，享受全方位技术赋能</view>
  </view>

  <view class="entry-list animate-fade-in">
    <view class="entry-card" bindtap="onSelectStore" hover-class="card-hover">
      <view class="entry-icon store">
        <t-image src="/assets/icons/store.svg" width="64rpx" height="64rpx" />
      </view>
      <view class="entry-info">
        <text class="entry-title">单店入驻</text>
        <text class="entry-desc">适用于独立经营的餐饮店。快速开店，低门槛，自主管理核心业务。</text>
      </view>
      <t-icon name="chevron-right" size="48rpx" color="#DDD" />
    </view>

    <view class="entry-card" bindtap="onSelectGroup" hover-class="card-hover">
      <view class="entry-icon group">
        <t-image src="/assets/icons/brand.svg" width="64rpx" height="64rpx" />
      </view>
      <view class="entry-info">
        <text class="entry-title">集团 / 品牌入驻</text>
        <text class="entry-desc">适用于品牌总部或商圈。统一管理多家门店，共享会员、营销与财务体系。</text>
      </view>
      <t-icon name="chevron-right" size="48rpx" color="#DDD" />
    </view>
  </view>

  <view wx:if="{{localOperatorPhone}}" class="operator-assist animate-slide-up" bindtap="onCallOperator" hover-class="operator-assist--hover">
    <text class="operator-assist__text">联系运营商上门协助入驻</text>
    <t-icon name="call" size="56rpx" color="var(--td-brand-color)" />
  </view>

  <view wx:else class="operator-assist operator-assist--disabled animate-slide-up">
    <text class="operator-assist__text">本地暂无运营商</text>
    <t-icon name="call" size="56rpx" color="var(--td-text-color-placeholder)" />
  </view>

  <view class="footer-action animate-slide-up">
    <view class="join-entry" bindtap="onJoinGroup">
      <text class="tip">已有店铺？</text>
      <text class="link">点击申请关联集团/品牌</text>
      <t-icon name="link" size="32rpx" color="var(--td-brand-color)" />
    </view>
  </view>
</view>
