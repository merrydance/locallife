.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  box-sizing: border-box;
}

.hero-section {
  padding: 80rpx 40rpx;
  text-align: center;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 24rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.entry-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--spacer-lg);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  border: 4rpx solid transparent;
}

.card-hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
  border-color: var(--td-brand-color-light);
}

.entry-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacer-lg);
  flex-shrink: 0;
}

.entry-icon.store { background: #FFF5F3; }
.entry-icon.group { background: #EBF2FF; }

.entry-info {
  flex: 1;
}

.entry-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 12rpx;
}

.entry-desc {
  display: block;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  line-height: 1.5;
}

.footer-action {
  margin-top: 48rpx;
  display: flex;
  justify-content: center;
}

.operator-contact {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.operator-assist {
  min-height: 112rpx;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-sizing: border-box;
}

.operator-assist--hover {
  background: var(--td-bg-color-secondarycontainer);
}

.operator-assist--disabled {
  box-shadow: none;
}

.operator-assist__text {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: var(--td-text-color-primary);
  flex: 1;
  min-width: 0;
}

.join-entry {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 40rpx;
  background: #FFFFFF;
  border-radius: var(--radius-round);
  box-shadow: var(--shadow-sm);
}

.join-entry .tip {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

.join-entry .link {
  font-size: 26rpx;
  color: var(--td-brand-color);
  font-weight: 500;
}

.animate-fade-in {
  animation: fadeIn 0.6s ease-out both;
}

.animate-slide-up {
  animation: slideUp 0.6s ease-out 0.2s both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}
