.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  display: flex;
  align-items: center;
}

.redirect-card {
  width: 100%;
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-xl);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--spacer-sm);
  box-shadow: var(--shadow-sm);
}

.redirect-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(0, 82, 217, 0.14);
  border-top-color: #0052d9;
  animation: redirect-spin 0.9s linear infinite;
}

.redirect-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.redirect-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

@keyframes redirect-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.skeleton-dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-top: 8rpx;
}

.skeleton-line {
  height: 32rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
}

.w-40 { width: 40%; }
.w-60 { width: 60%; }
.w-80 { width: 80%; }

.skeleton-animate {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

/* Error State */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  gap: 32rpx;
}

.empty-container {
  padding-top: 100rpx;
  text-align: center;
}
