<custom-navbar title="堂食点餐" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: 120rpx;">
  
  <!-- 1. 错误状态 -->
  <view wx:if="{{isError}}" class="error-container">
    <t-empty icon="info-circle" description="{{errorMsg}}" />
    <t-button theme="primary" variant="outline" size="medium" bindtap="onRetry" shape="round">重新加载</t-button>
  </view>

  <!-- 2. 骨架屏 (App Shell + Skeleton) -->
  <view wx:elif="{{loading}}" class="skeleton-container">
    <!-- Header -->
    <view class="skeleton-header skeleton-animate"></view>
    <!-- Body -->
    <view class="skeleton-body">
      <!-- Sidebar -->
      <view class="skeleton-sidebar">
         <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="skeleton-tab skeleton-animate"></view>
      </view>
      <!-- List -->
      <view class="skeleton-content">
         <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="skeleton-dish-item">
            <view class="skeleton-dish-img skeleton-animate"></view>
            <view class="skeleton-dish-info">
               <view class="skeleton-line w-60 skeleton-animate"></view>
               <view class="skeleton-line w-40 skeleton-animate"></view>
               <view class="skeleton-line w-40 skeleton-animate" style="margin-top: 20rpx;"></view>
            </view>
         </view>
      </view>
    </view>
  </view>

  <!-- 3. 正常内容 -->
  <view wx:elif="{{session}}" class="content animate-fade-in">
    <!-- 桌台信息 -->
    <view class="table-info">
      <view class="info-row">
        <text class="label">餐厅:</text>
        <text class="value">{{session.merchant_name}}</text>
      </view>
      <view class="info-row">
        <text class="label">桌台:</text>
        <text class="value">{{session.table_name}}</text>
      </view>
      <t-button class="call-btn" size="small" icon="service" bindtap="onCallWaiter" shape="round">呼叫服务员</t-button>
    </view>

    <!-- 菜品列表 -->
    <view class="dishes-container">
      <!-- 左侧分类 -->
      <scroll-view class="category-sidebar" scroll-y>
        <view 
          wx:for="{{categories}}" 
          wx:key="id"
          class="category-item {{activeCategoryId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onCategoryChange"
        >
          {{item.name}}
        </view>
      </scroll-view>

      <!-- 右侧菜品 -->
      <scroll-view class="dishes-list" scroll-y>
        <view wx:for="{{dishes}}" wx:key="id" wx:if="{{item.category_id === activeCategoryId}}" class="dish-item">
          <t-image class="dish-image" src="{{item.image_url}}" mode="aspectFill" lazy />
          <view class="dish-info">
            <text class="dish-name">{{item.name}}</text>
            <text class="dish-desc">{{item.description}}</text>
            <view class="dish-meta">
              <text class="rating">⭐{{item.rating}}</text>
              <text class="price">¥{{item.priceDisplay}}</text>
            </view>
          </view>
          <t-button 
            wx:if="{{item.hasCustomizations}}"
            class="spec-btn"
            size="small" 
            theme="primary"
            variant="outline"
            shape="round"
            data-id="{{item.id}}"
            bindtap="onShowDishDetail"
          >选规格</t-button>
          <t-button 
            wx:else
            class="add-btn" 
            size="small" 
            icon="add" 
            shape="circle" 
            theme="primary"
            data-id="{{item.id}}"
            bindtap="onAddCart"
          />
        </view>
      </scroll-view>
    </view>
  </view>
</view>

<!-- 购物车栏 -->
<view wx:if="{{!loading && session && cartCount > 0}}" class="cart-bar">
  <view class="cart-info">
    <text class="cart-count">🛒 {{cartCount}}件</text>
    <text class="cart-price">¥{{cartPriceDisplay}}</text>
  </view>
  <t-button class="submit-btn" theme="primary" bindtap="onSubmitOrder" shape="round">下单</t-button>
</view>
