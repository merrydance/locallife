/* 外卖首页 */
@import '../../styles/customer.wxss';

/* Skyline 滚动容器 */
.page-scroll {
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

/* ========== 搜索区域 ========== */
.search-section {
  padding: 0 var(--spacer-md) var(--spacer-md);
  background: var(--td-bg-color-page);
  position: sticky;
  top: 0;
  z-index: var(--z-index-sticky);
}

/* ========== 内容区域 ==========*/
.content-section {
  display: flex;
  flex-direction: column;
  padding: var(--spacer-sm) var(--spacer-md) var(--spacer-lg); /* 上16, 左右24, 下32 */
  gap: var(--spacer-sm);
}

/* ========== 发现页增强样式 ========== */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-md);
  padding: 0 8rpx;
}

.special-offers-section {
  margin-bottom: var(--spacer-lg);
}

.offers-scroll {
  width: 100%;
}

.offers-list {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--spacer-md);
  padding: 4rpx; /* for shadow clipping */
  padding-bottom: var(--spacer-sm);
}

.offer-item {
  width: 540rpx;
  flex-shrink: 0;
}

.feed-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  padding: var(--spacer-lg) 0;
}

.no-more {
  text-align: center;
  padding: var(--spacer-lg) 0;
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-xs);
}

.empty-entry {
  padding: 40rpx 0 20rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 16rpx 48rpx 0;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

/* ========== 位置引导提示 ========== */
.location-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacer-xl);
  text-align: center;
}

.location-guide-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacer-lg);
}

.location-guide-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.location-guide-desc {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  margin-bottom: var(--spacer-xl);
  line-height: 1.6;
}

.location-guide-buttons {
  display: flex;
  gap: var(--spacer-md);
}

.location-guide-buttons .t-button {
  min-width: 180rpx;
}

/* ========== 菜系品类网格 ========== */
.cuisine-grid-section {
  background: transparent;
  padding: 0 var(--spacer-md) var(--spacer-sm);
  margin-bottom: var(--spacer-xs);
}

.cuisine-grid {
  --td-grid-bg-color: transparent;
  --td-grid-item-padding: 16rpx 8rpx;
}

.cuisine-grid-item {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.cuisine-grid-item--active {
  background: linear-gradient(180deg, rgba(255, 250, 240, 0.98) 0%, rgba(255, 243, 220, 0.98) 100%);
  box-shadow: 0 14rpx 28rpx rgba(180, 95, 0, 0.12);
}

.cuisine-grid-item-content {
  min-height: 120rpx;
}

.cuisine-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.35);
}

.cuisine-icon-wrap--active {
  transform: translateY(-2rpx);
}

.cuisine-icon-text {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 1rpx;
}

.cuisine-grid-item-text {
  font-size: 22rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
  text-align: center;
}

.cuisine-grid-item-text--active {
  color: #7a3a00;
}
