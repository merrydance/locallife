/* 外卖首页 */
@import '../../styles/customer.wxss';

/* Skyline 滚动容器 */
.page-scroll {
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

/* ========== 搜索区域 ========== */
.search-section {
  padding: 0 var(--spacer-md) var(--spacer-sm);
  background: var(--td-bg-color-page);
  position: sticky;
  top: 0;
  z-index: var(--z-index-sticky);
}

/* ========== 内容区域 ==========*/
.content-section {
  display: flex;
  flex-direction: column;
  padding: var(--spacer-xs) var(--spacer-md) var(--spacer-lg);
  gap: var(--spacer-sm);
}

/* ========== 发现页增强样式 ========== */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-md);
  padding: 0 8rpx;
}

.special-offers-section {
  margin-bottom: var(--spacer-lg);
}

.offers-scroll {
  width: 100%;
}

.offers-list {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--spacer-md);
  padding: 4rpx; /* for shadow clipping */
  padding-bottom: var(--spacer-sm);
}

.offer-item {
  width: 540rpx;
  flex-shrink: 0;
}

.feed-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  padding: var(--spacer-lg) 0;
}

.no-more {
  text-align: center;
  padding: var(--spacer-lg) 0;
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-xs);
}

.empty-entry {
  padding: 40rpx 0 20rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 16rpx 48rpx 0;
}

.provider-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding-top: 24rpx;
  color: var(--td-brand-color);
  font-size: var(--font-size-sm);
}

.provider-entry-divider {
  color: var(--td-text-color-placeholder);
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

/* ========== 位置引导提示 ========== */
.location-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacer-xl);
  text-align: center;
}

.location-guide-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacer-lg);
}

.location-guide-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.location-guide-desc {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  margin-bottom: var(--spacer-xl);
  line-height: 1.6;
}

.location-guide-buttons {
  display: flex;
  gap: var(--spacer-md);
}

/* weapp-gate allow-tdesign-internal-class: 定位引导区按钮需要最小宽度以避免弱网文案抖动，待切成包装按钮类后移除 */
.location-guide-buttons .t-button {
  min-width: 180rpx;
}

/* ========== 菜系品类网格 ========== */
.cuisine-grid-section {
  padding: 0 var(--spacer-md) var(--spacer-xs);
  margin-bottom: 0;
}

.cuisine-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: 8rpx 0 4rpx;
  overflow: hidden;
}

.cuisine-grid {
  --td-grid-bg-color: transparent;
  --td-grid-item-padding: 6rpx;
  --td-grid-item-text-padding-top: 0rpx;
  --td-grid-item-horizontal-text-padding-left: 0rpx;
}

.cuisine-grid-item {
  background: transparent;
}

.cuisine-grid-item--active {
  background: transparent;
}

.cuisine-grid-item-content {
  min-height: 72rpx;
  padding-bottom: 6rpx !important;
}

.cuisine-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #f4f4f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.cuisine-icon-wrap--active {
  background: #fff3d6;
}

.cuisine-icon-text {
  font-size: 36rpx;
  line-height: 1;
}

.cuisine-grid-item-text {
  font-size: 20rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
  text-align: center;
  margin-top: 4rpx;
}

.cuisine-grid-item-text--active {
  color: #7a3a00;
  font-weight: 600;
}
