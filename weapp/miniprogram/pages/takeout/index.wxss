/* 外卖首页 */
@import '../../styles/customer.wxss';

/* Skyline 滚动容器 */
.page-scroll {
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

/* ========== 搜索区域 ========== */
.search-section {
  padding: var(--spacer-md) var(--spacer-md);
  background: var(--td-bg-color-container);
  position: sticky;
  top: 0;
  z-index: var(--z-index-sticky);
}

/* ========== Tabs区域 ========== */
.tabs-section {
  background: var(--td-bg-color-container);
  margin-bottom: var(--spacer-sm);
  box-shadow: var(--shadow-sm); /* 轻微阴影区分内容 */
  z-index: var(--z-index-sticky);
}

/* ========== 分类导航 ========== */
.category-section {
  background: var(--td-bg-color-container);
  margin-bottom: var(--spacer-sm);
  padding-bottom: var(--spacer-xs);
}

/* ========== 内容区域 ========== */
.content-section {
  display: flex;
  flex-direction: column;
  padding: var(--spacer-sm) var(--spacer-md) var(--spacer-lg); /* 上16, 左右24, 下32 */
  gap: var(--spacer-sm);
}

/* ========== 发现页增强样式 ========== */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-md);
  padding: 0 8rpx;
}

.special-offers-section {
  margin-bottom: var(--spacer-lg);
}

.offers-scroll {
  width: 100%;
}

.offers-list {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--spacer-md);
  padding: 4rpx; /* for shadow clipping */
  padding-bottom: var(--spacer-sm);
}

.offer-item {
  width: 540rpx;
  flex-shrink: 0;
}

.nearby-merchants-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.package-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.package-list-item {
  width: 100%;
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  padding: var(--spacer-lg) 0;
}

.no-more {
  text-align: center;
  padding: var(--spacer-lg) 0;
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-xs);
}

.empty-entry {
  padding: 40rpx 0 20rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 16rpx 48rpx 0;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

/* ========== 位置引导提示 ========== */
.location-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacer-xl);
  text-align: center;
}

.location-guide-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacer-lg);
}

.location-guide-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.location-guide-desc {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  margin-bottom: var(--spacer-xl);
  line-height: 1.6;
}

.location-guide-buttons {
  display: flex;
  gap: var(--spacer-md);
}

.location-guide-buttons .t-button {
  min-width: 180rpx;
}

/* ========== 菜系品类网格 ========== */
.cuisine-grid-section {
  background: var(--td-bg-color-container);
  padding: 24rpx 16rpx 20rpx;
  margin-bottom: var(--spacer-sm);
}

.cuisine-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx 8rpx;
}

.cuisine-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.cuisine-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cuisine-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.cuisine-name {
  font-size: 24rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
  text-align: center;
}
