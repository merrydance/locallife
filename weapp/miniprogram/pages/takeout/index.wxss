/* 外卖首页 */
@import '../../styles/customer.wxss';

/* Skyline 滚动容器 */
.page-scroll {
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

/* ========== 搜索区域 ========== */
.search-section {
  padding: var(--spacer-md) var(--spacer-md);
  background: var(--td-bg-color-container);
  position: sticky;
  top: 0;
  z-index: var(--z-index-sticky);
}

/* ========== Tabs区域 ========== */
.tabs-section {
  background: var(--td-bg-color-container);
  margin-bottom: var(--spacer-sm);
  box-shadow: var(--shadow-sm); /* 轻微阴影区分内容 */
  z-index: var(--z-index-sticky);
}

/* ========== 分类导航 ========== */
.category-section {
  background: var(--td-bg-color-container);
  margin-bottom: var(--spacer-sm);
  padding-bottom: var(--spacer-xs);
}

/* ========== 内容区域 ========== */
.content-section {
  display: flex;
  flex-direction: column;
  padding: var(--spacer-sm) var(--spacer-md) var(--spacer-lg); /* 上16, 左右24, 下32 */
  gap: var(--spacer-sm);
}

/* ========== 发现页增强样式 ========== */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-md);
  padding: 0 8rpx;
}

.special-offers-section {
  margin-bottom: var(--spacer-lg);
}

.offers-scroll {
  width: 100%;
}

.offers-list {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--spacer-md);
  padding: 4rpx; /* for shadow clipping */
  padding-bottom: var(--spacer-sm);
}

.offer-item {
  width: 540rpx;
  flex-shrink: 0;
}

.nearby-merchants-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.package-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.package-list-item {
  width: 100%;
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  padding: var(--spacer-lg) 0;
}

.no-more {
  text-align: center;
  padding: var(--spacer-lg) 0;
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-xs);
}

.empty-entry {
  padding: 40rpx 0 20rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 16rpx 48rpx 0;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

/* ========== 位置引导提示 ========== */
.location-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacer-xl);
  text-align: center;
}

.location-guide-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacer-lg);
}

.location-guide-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.location-guide-desc {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  margin-bottom: var(--spacer-xl);
  line-height: 1.6;
}

.location-guide-buttons {
  display: flex;
  gap: var(--spacer-md);
}

.location-guide-buttons .t-button {
  min-width: 180rpx;
}

/* ========== Banner 轮播 ========== */
.banner-swiper {
  width: 100%;
  height: 240rpx;
  display: block;
}

.banner-item {
  width: 100%;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.banner-inner {
  flex: 1;
  z-index: 1;
}

.banner-tag {
  font-size: 20rpx;
  color: var(--td-text-color-anti);
  background: rgba(255,255,255,0.25);
  margin-bottom: 12rpx;
  backdrop-filter: blur(4rpx);
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--td-text-color-anti);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.banner-deco {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.9;
  flex-shrink: 0;
}

/* ========== 快捷入口网格 ========== */
.quick-entry-grid {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  background: var(--td-bg-color-container);
  padding: 24rpx 16rpx 16rpx;
  margin-bottom: var(--spacer-sm);
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.entry-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-icon {
  width: 52rpx;
  height: 52rpx;
}

.entry-label {
  font-size: 24rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}
