.skeleton-shimmer {
  background: linear-gradient(90deg, var(--td-bg-color-secondarycontainer) 25%, var(--td-bg-color-page) 37%, var(--td-bg-color-secondarycontainer) 63%);
  background-size: 400% 100%;
  animation: shimmer 1.4s ease infinite;
}

@keyframes shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

.header-skeleton {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.header-overlay.hidden {
  opacity: 0;
}

.category-item-skeleton {
  height: 40rpx;
  margin: 30rpx 20rpx;
  border-radius: 4rpx;
}

.room-skeleton {
  height: 420rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius-md);
}

.error-container {
  padding-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头图 - 高度及覆盖层优化 */
.header-section {
  position: fixed;
  left: 0;
  right: 0;
  height: 320rpx;
  background-color: var(--td-bg-color-secondarycontainer);
  background-size: cover;
  background-position: center;
  z-index: 10;
  overflow: hidden;
  transition: height var(--transition-base), top var(--transition-base);
}

/* 背景图：t-image 完全覆盖 header-section */
.header-bg-image {
  position: absolute !important;
  top: 0;
  left: 0;
  width: 100% !important;
  height: 100% !important;
  z-index: 0;
}

.header-section.collapsed {
  height: 100rpx;
}

.header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacer-md);
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 100%);
  color: var(--td-text-color-anti);
  transition: padding var(--transition-base);
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  box-sizing: border-box;
}

.header-section.collapsed .header-overlay {
  padding: 0 var(--spacer-md);
  justify-content: center;
}

.restaurant-title-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  margin-bottom: var(--spacer-xs);
  transition: all var(--transition-base);
}

.header-section.collapsed .restaurant-title-row {
  margin-bottom: 0;
}

.restaurant-name {
  font-size: var(--font-size-title);
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.header-section.collapsed .restaurant-name {
  font-size: var(--font-size-base);
}

.text-ellipsis {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 80%;
}

.name-arrow {
  color: rgba(255,255,255,0.7);
}

.restaurant-meta {
  font-size: var(--font-size-xs);
  margin-bottom: var(--spacer-xs);
  opacity: 0.9;
  transition: opacity var(--transition-base);
}

.restaurant-service {
  display: flex;
  gap: var(--spacer-sm);
  font-size: var(--font-size-xxs);
  margin-bottom: var(--spacer-sm);
  transition: opacity var(--transition-base);
}

.service-count, .delivery-time {
  background: rgba(0,0,0,0.3);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  backdrop-filter: blur(4px);
}

.service-count {
  color: var(--td-warning-color);
}

.delivery-time {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  white-space: nowrap;
}

.restaurant-tags {
  display: flex;
  gap: var(--spacer-xs);
  transition: opacity var(--transition-base);
}

.share-btn-reset {
  padding: 0;
  margin: 0;
  line-height: normal;
  background: none;
  border: none;
  overflow: visible;
}

.share-btn-reset::after {
  border: none;
}

.header-share-row {
  margin-top: var(--spacer-xs);
}

.header-share-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--radius-round);
  backdrop-filter: blur(4px);
}

.header-share-text {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.9);
}

/* Tab切换 - 设计系统适配 */
.tabs-section {
  position: fixed;
  left: 0;
  right: 0;
  background: var(--td-bg-color-container);
  z-index: 10;
  box-shadow: var(--shadow-sm);
  transition: top var(--transition-base);
}

/* 内容区域 - 布局优化 */
.content-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: var(--td-bg-color-page);
  overflow: hidden;
  transition: bottom var(--transition-base), top var(--transition-base); /* 平滑切换 */
}

.content-area.no-cart {
  bottom: env(safe-area-inset-bottom);
}

/* 菜品点单布局 */
.dishes-tab {
  height: 100%;
  display: flex;
  background: var(--td-bg-color-container);
}

.dishes-container {
  display: flex;
  flex: 1;
  height: 100%;
}

.category-sidebar {
  width: 160rpx;
  background: var(--td-bg-color-page);
  flex-shrink: 0;
}

.category-item {
  padding: var(--spacer-md) var(--spacer-sm);
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  position: relative;
  transition: all var(--transition-base);
}

.category-item.active {
  background: var(--td-bg-color-container);
  color: var(--td-brand-color);
  font-weight: bold;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 30%;
  height: 40%;
  width: 6rpx;
  background: var(--td-brand-color);
  border-radius: 0 4rpx 4rpx 0;
}

.dishes-list {
  flex: 1;
  padding: var(--spacer-sm) var(--spacer-md);
  box-sizing: border-box;
}

.dish-item {
  display: flex;
  gap: var(--spacer-md);
  padding: var(--spacer-md) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.dish-tags {
  display: flex;
  gap: var(--spacer-xs);
  margin: 4rpx 0;
}

.dish-meta {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.dish-price-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-xs);
}

.dish-price {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-brand-color);
}

.dish-original-price {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
}

/* 操作按钮 */
.action-area {
  align-self: flex-end;
  flex-shrink: 0;
}

/* 套餐列表 */
.combos-tab {
  height: 100%;
  padding: var(--spacer-sm);
  box-sizing: border-box;
}

.combo-item {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacer-md);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  gap: var(--spacer-md);
}

.combo-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

/* 套餐组合图 - Grid系统重构 */
.combo-image-grid {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--td-bg-color-page);
  display: grid;
  gap: 2rpx;
  flex-shrink: 0;
}

/* 1张图 */
.grid-count-1 {
  grid-template-columns: 1fr;
  grid-template-rows: 1fr;
}

/* 2张图：并排 */
.grid-count-2 {
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: 1fr;
}

/* 3张图：上1下2 */
.grid-count-3 {
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
}
.grid-count-3 .grid-img:first-child {
  grid-column: span 2;
}

/* 4张及以上：四宫格 */
.grid-count-4 {
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
}

.grid-img {
  width: 100% !important;
  height: 100% !important;
  display: block;
}


.combo-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0; /* 防止溢出 */
}

.combo-name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.combo-desc {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  line-height: 1.4;
  margin: 8rpx 0;
}

.combo-price-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

/* 此时 t-button 已移至 .action-area，无需在此设置 */

.combo-price {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-brand-color);
}

.combo-discount {
  background: var(--td-brand-color-light);
  color: var(--td-brand-color);
  font-size: var(--font-size-xxs);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-xs);
}

/* 包间列表 */
.rooms-tab {
  height: 100%;
  padding: var(--spacer-sm);
  box-sizing: border-box;
}

.room-item {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacer-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.room-image {
  width: 100%;
  height: 300rpx;
}

.room-info {
  padding: var(--spacer-md);
}

.room-name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-xs);
}

.room-meta {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  margin-top: var(--spacer-sm);
}

.room-price {
  font-size: var(--font-size-title);
  color: var(--td-brand-color);
  font-weight: bold;
}

/* 底部占位 */
.empty-placeholder {
  height: var(--spacer-xl);
}
