@import '../../../styles/customer.wxss';
@import '../../../styles/takeout-restaurant-detail-sections.wxss';

.skeleton-shimmer {
  background: linear-gradient(90deg, var(--td-bg-color-secondarycontainer) 25%, var(--td-bg-color-page) 37%, var(--td-bg-color-secondarycontainer) 63%);
  background-size: 400% 100%;
  animation: shimmer 1.4s ease infinite;
}

@keyframes shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

.header-skeleton {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.header-overlay.hidden {
  opacity: 0;
}

.category-item-skeleton {
  height: 40rpx;
  margin: 30rpx 20rpx;
  border-radius: 4rpx;
}

.room-skeleton {
  height: 420rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius-md);
}

.error-container {
  padding-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Tab切换 - 设计系统适配 */
.tabs-section {
  position: fixed;
  left: 0;
  right: 0;
  background: var(--td-bg-color-container);
  z-index: 10;
  box-shadow: var(--shadow-sm);
  transition: top var(--transition-base);
}

/* 内容区域 - 布局优化 */
.content-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: var(--td-bg-color-page);
  overflow: hidden;
  transition: bottom var(--transition-base), top var(--transition-base);
}

.content-area.no-cart {
  bottom: env(safe-area-inset-bottom);
}

/* 菜品点单布局 */
.dishes-tab {
  height: 100%;
  display: flex;
  background: var(--td-bg-color-container);
}

.dishes-container {
  display: flex;
  flex: 1;
  height: 100%;
}

.category-sidebar {
  width: 160rpx;
  background: var(--td-bg-color-page);
  flex-shrink: 0;
}

.category-item {
  padding: var(--spacer-md) var(--spacer-sm);
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  position: relative;
  transition: all var(--transition-base);
}

.category-item.active {
  background: var(--td-bg-color-container);
  color: var(--td-brand-color);
  font-weight: bold;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 30%;
  height: 40%;
  width: 6rpx;
  background: var(--td-brand-color);
  border-radius: 0 4rpx 4rpx 0;
}

.dishes-list {
  flex: 1;
  padding: var(--spacer-sm) var(--spacer-md);
  box-sizing: border-box;
}

.dish-item {
  display: flex;
  gap: var(--spacer-md);
  padding: var(--spacer-md) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.dish-tags {
  display: flex;
  gap: var(--spacer-xs);
  margin: 4rpx 0;
}

.dish-meta {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.dish-price-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-xs);
}

.dish-price {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-brand-color);
}

.dish-original-price {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
}
