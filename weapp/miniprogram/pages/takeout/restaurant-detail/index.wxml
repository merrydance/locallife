<custom-navbar title="{{restaurant.name || '餐厅详情'}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<!-- 餐厅头图及基本信息 -->
<view class="header-section {{headerCollapsed ? 'collapsed' : ''}}" style="top: {{navBarHeight}}px; background-image: url('{{restaurant.cover_image || restaurant.logo_url || '/assets/happy.jpg'}}')">
  <view class="header-overlay">
    <view class="restaurant-title-row" bindtap="onMerchantInfoTap">
      <view class="restaurant-name {{headerCollapsed ? 'text-ellipsis' : ''}}">{{restaurant.name}}</view>
      <t-icon name="chevron-right" size="40rpx" class="name-arrow" />
    </view>
    <view class="restaurant-meta" bindtap="onMerchantInfoTap" wx:if="{{!headerCollapsed}}">
      <view style="display: flex; align-items: center; gap: 8rpx;">
        <t-icon name="location" size="28rpx" />
        <text>{{restaurant.address}}</text>
      </view>
    </view>
    <view class="restaurant-service" wx:if="{{!headerCollapsed}}">
      <view class="service-count">
        <text>本月服务 {{restaurant.monthly_sales || 0}} 单</text>
      </view>
      <view class="delivery-time">
        <t-icon name="time" size="24rpx" style="margin-right: 4rpx;" />
        <text>约 {{restaurant.avg_prep_minutes || 15}} 分钟出餐</text>
      </view>
    </view>
    <view class="restaurant-tags" wx:if="{{restaurant.tags.length > 0 && !headerCollapsed}}">
      <t-tag 
        wx:for="{{restaurant.tags}}" 
        wx:key="*this" 
        size="extra-small" 
        variant="light" 
        theme="primary"
        style="border-radius: var(--radius-xs);"
      >{{item}}</t-tag>
    </view>
  </view>
</view>

<!-- Tab 导航 -->
<view class="tabs-section {{headerCollapsed ? 'collapsed' : ''}}" style="top: calc({{navBarHeight}}px + {{headerCollapsed ? '100rpx' : '320rpx'}});">
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" list-style="border-bottom: none;">
    <t-tab-panel label="菜品" value="dishes" />
    <t-tab-panel label="套餐" value="combos" />
    <t-tab-panel label="包间" value="rooms" />
  </t-tabs>
</view>

<view wx:if="{{loading}}" class="loading-wrapper" style="margin-top: calc({{navBarHeight}}px + 400rpx);">
  <t-loading theme="circular" size="48rpx" text="正在加载..." />
</view>

<!-- 核心内容区域 -->
<view wx:if="{{!loading && restaurant}}" class="content-area {{headerCollapsed ? 'collapsed' : ''}} {{activeTab === 'rooms' ? 'no-cart' : ''}}" style="top: calc({{navBarHeight}}px + {{headerCollapsed ? '100rpx' : '320rpx'}} + 96rpx);">
  
  <!-- 菜品列表 (点单模式) -->
  <view wx:if="{{activeTab === 'dishes'}}" class="dishes-tab">
    <view class="dishes-container">
      <!-- 左侧全部分类 -->
      <scroll-view class="category-sidebar" scroll-y enhanced show-scrollbar="{{false}}">
        <view 
          wx:for="{{categories}}" 
          wx:key="id"
          class="category-item {{activeCategoryId == item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onCategoryChange"
        >
          <text>{{item.name}}</text>
        </view>
        <view style="height: 100rpx;"></view>
      </scroll-view>

      <!-- 右侧商品列表 -->
      <scroll-view class="dishes-list" scroll-y enhanced show-scrollbar="{{false}}" bindscroll="onScroll">
        <view wx:for="{{filteredDishes}}" wx:key="id" class="dish-item" bindtap="onDishTap" data-id="{{item.id}}">
          <t-image class="dish-image" src="{{item.image_url}}" mode="aspectFill" lazy />
          <view class="dish-info">
            <view>
              <view class="dish-name">{{item.name}}</view>
              <view class="dish-tags" wx:if="{{item.tags.length > 0}}">
                <t-tag 
                  wx:for="{{item.tags}}" 
                  wx:for-item="tag" 
                  wx:key="*this" 
                  size="extra-small" 
                  variant="light-outline" 
                  theme="primary"
                >{{tag}}</t-tag>
              </view>
              <view class="dish-meta">月售 {{item.monthly_sales || 0}}</view>
            </view>
            <view class="dish-price-row">
              <text class="dish-price">¥{{item.priceDisplay}}</text>
              <text wx:if="{{item.originalPriceDisplay}}" class="dish-original-price">¥{{item.originalPriceDisplay}}</text>
            </view>
          </view>
          <view class="action-area" catchtap="stopPropagation">
            <t-button 
              wx:if="{{item.hasCustomizations}}"
              size="extra-small" 
              theme="primary"
              variant="outline"
              shape="round"
              data-id="{{item.id}}"
              catchtap="onDishTap"
            >规格</t-button>
            <t-button 
              wx:else
              icon="add" 
              shape="circle" 
              theme="primary"
              size="small"
              data-id="{{item.id}}"
              catchtap="onAddCart"
            />
          </view>
        </view>
        <view wx:if="{{filteredDishes.length === 0}}" class="empty-category">
          <t-empty icon="info-circle" description="该分类暂无商品" />
        </view>
        <view style="height: 120rpx;"></view>
      </scroll-view>
    </view>
  </view>

  <!-- 精选套餐 -->
  <scroll-view wx:if="{{activeTab === 'combos'}}" class="combos-tab" scroll-y bindscroll="onScroll">
    <block wx:if="{{combos.length > 0}}">
      <view wx:for="{{combos}}" wx:key="id" class="combo-item" data-id="{{item.id}}" bindtap="onComboTap">
        <!-- 套餐多图组合展示 -->
        <view class="combo-image-grid grid-count-{{item.dish_images.length > 4 ? 4 : item.dish_images.length}}" wx:if="{{item.dish_images && item.dish_images.length > 0}}">
          <t-image 
            wx:for="{{item.dish_images}}" 
            wx:for-item="img" 
            wx:for-index="imgIdx"
            wx:if="{{imgIdx < 4}}"
            wx:key="*this"
            class="grid-img" 
            src="{{img}}" 
            mode="aspectFill" 
            lazy 
          />
        </view>
        <t-image wx:else class="combo-image" src="{{item.image_url}}" mode="aspectFill" lazy />

        <view class="combo-info">
          <view>
            <view class="combo-name">{{item.name}}</view>
            <view class="combo-desc">{{item.description}}</view>
          </view>
          <view class="combo-price-row">
            <text class="combo-price">¥{{item.comboPriceDisplay}}</text>
            <view class="combo-discount">省 ¥{{item.savingsDisplay}}</view>
            <t-button 
              icon="add" 
              shape="circle" 
              theme="primary"
              size="small"
              style="margin-left: auto;"
              data-id="{{item.id}}"
              catchtap="onAddComboCart"
            />
          </view>
        </view>
      </view>
    </block>
    <t-empty wx:else icon="info-circle" description="暂无精选套餐" />
    <view class="empty-placeholder"></view>
  </scroll-view>

  <!-- 豪华包间 -->
  <scroll-view wx:if="{{activeTab === 'rooms'}}" class="rooms-tab" scroll-y bindscroll="onScroll">
    <block wx:if="{{rooms.length > 0}}">
      <view wx:for="{{rooms}}" wx:key="id" class="room-item" data-id="{{item.id}}" bindtap="onRoomTap">
        <t-image class="room-image" src="{{item.primary_image || '/assets/placeholder-room.jpg'}}" mode="aspectFill" lazy />
        <view class="room-info">
          <view class="room-name">{{item.name}}</view>
          <view class="dish-tags" wx:if="{{item.tags.length > 0}}">
            <t-tag wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" size="extra-small" variant="light-outline" theme="primary">{{tag}}</t-tag>
          </view>
          <view class="room-meta">
            <text>可容纳 {{item.capacity}} 人</text>
            <text class="room-price">¥{{item.minimum_spend / 100}} 起</text>
          </view>
        </view>
      </view>
    </block>
    <t-empty wx:else icon="info-circle" description="暂无可用包间" />
    <view class="empty-placeholder"></view>
  </scroll-view>

</view>

<!-- 购物车浮层 - 仅在点单(菜品/套餐)时显示 -->
<cart-bar 
  wx:if="{{!loading && restaurant && activeTab !== 'rooms'}}"
  totalCount="{{cartCount}}"
  totalPrice="{{cartPrice}}"
  alwaysShow="{{true}}"
  dockBottom="{{true}}"
  bind:checkout="onCheckout"
  bind:toggle="onCartTap"
/>
