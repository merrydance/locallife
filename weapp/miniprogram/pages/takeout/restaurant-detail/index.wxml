<custom-navbar title="{{restaurant.name || '餐厅详情'}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-shell-anchor" style="padding-top: calc({{navBarHeight}}px + var(--spacer-sm)); height: 0; overflow: hidden;"></view>

<!-- 1. 餐厅头图 (App Shell) -->
<view
  class="header-section {{headerCollapsed ? 'collapsed' : ''}}"
  style="top: calc({{navBarHeight}}px + var(--spacer-sm));"
  capture-bind:touchstart="onMenuTouchStart"
  capture-bind:touchmove="onMenuTouchMove"
>
  <!-- 背景图：使用 t-image 支持 lazy 和 fallback -->
  <t-image
    class="header-bg-image"
    src="{{restaurant.cover_image || restaurant.logo_url || ''}}"
    mode="aspectFill"
    lazy
    use-error-placeholder
    error-placeholder-src="/assets/icons/dish.svg"
  />
  <!-- 骨架屏占位 -->
  <view wx:if="{{loading && !restaurant}}" class="header-skeleton skeleton-shimmer"></view>
  
  <view class="header-overlay {{loading && !restaurant ? 'hidden' : ''}}">
    <view class="restaurant-title-row">
      <view class="restaurant-title-main" bindtap="onMerchantInfoTap">
        <view class="restaurant-name {{headerCollapsed ? 'text-ellipsis' : ''}}">{{restaurant.name || '正在加载...'}}</view>
        <t-icon name="chevron-right" size="40rpx" class="name-arrow" />
      </view>
      <button class="share-btn-reset header-share-btn" open-type="share" catchtap="stopPropagation">
        <t-icon name="share" size="28rpx" color="rgba(255,255,255,0.85)" />
        <text class="header-share-text">分享</text>
      </button>
    </view>
    <view class="restaurant-meta" bindtap="onMerchantInfoTap" wx:if="{{!headerCollapsed}}">
      <view style="display: flex; align-items: center; gap: 8rpx;">
        <t-icon name="location" size="28rpx" />
        <text>{{restaurant.address || '正在获取地址...'}}</text>
      </view>
    </view>
    <view class="restaurant-service" wx:if="{{!headerCollapsed}}">
      <view class="service-count">
        <text>本月服务 {{restaurant.monthly_sales || 0}} 单</text>
      </view>
      <view class="delivery-time">
        <t-icon name="time" size="24rpx" style="margin-right: 4rpx;" />
        <text>约 {{restaurant.avg_prep_minutes || 15}} 分钟出餐</text>
      </view>
    </view>
    <view wx:if="{{restaurant.is_ordering_suspended && !headerCollapsed}}" class="suspension-chip">暂停接单</view>
    <view wx:if="{{restaurant.displayTags.length > 0 && !headerCollapsed}}" class="restaurant-tags">
      <t-tag wx:for="{{restaurant.displayTags}}" wx:key="*this" size="small" variant="dark" theme="default" shape="round">{{item}}</t-tag>
    </view>
  </view>
</view>
<!-- header-section closing handled below -->

<!-- 2. Tab 导航 (App Shell) -->
<view
  class="tabs-section {{headerCollapsed ? 'collapsed' : ''}}"
  style="top: calc({{navBarHeight}}px + var(--spacer-sm) + {{headerCollapsed ? '100rpx' : '320rpx'}});"
  capture-bind:touchstart="onMenuTouchStart"
  capture-bind:touchmove="onMenuTouchMove"
>
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" list-style="border-bottom: none;">
    <t-tab-panel label="菜品" value="dishes" />
    <t-tab-panel label="套餐" value="combos" />
    <t-tab-panel label="包间" value="rooms" />
  </t-tabs>
</view>

<!-- 3. 内容区域 (App Shell with Skeletons) -->
<view
  class="content-area {{headerCollapsed ? 'collapsed' : ''}} {{activeTab === 'rooms' ? 'no-cart' : ''}}"
  style="top: calc({{navBarHeight}}px + var(--spacer-sm) + {{headerCollapsed ? '100rpx' : '320rpx'}} + 96rpx);"
  capture-bind:touchstart="onMenuTouchStart"
  capture-bind:touchmove="onMenuTouchMove"
>
  
  <!-- 错误状态 -->
  <view wx:if="{{isError}}" class="error-container">
    <t-empty icon="info-circle" description="{{errorMsg}}" />
    <t-button theme="primary" size="small" bindtap="loadRestaurantDetail" style="margin-top: 24rpx;" shape="round">重试</t-button>
  </view>

  <block wx:else>
    <view wx:if="{{restaurant && restaurant.biz_status === 'CLOSED' && !restaurant.is_ordering_suspended}}" class="store-closed-banner">
      <view class="store-closed-banner-title">商家休息中，暂不可下单</view>
    </view>

    <view wx:if="{{restaurant && restaurant.is_ordering_suspended}}" class="suspension-banner">
      <view class="suspension-banner-title">当前暂停接单</view>
      <view class="suspension-banner-desc">该商户暂时无法下外卖单或预订包间，恢复后会自动恢复可下单状态。</view>
    </view>

    <merchant-coupon-strip coupons="{{coupons}}" claiming-coupon-id="{{claimingCouponId}}" bind:claim="onClaimCoupon" />

    <!-- 菜品列表 Tab -->
    <view wx:if="{{activeTab === 'dishes'}}" class="dishes-tab">
      <view class="dishes-container">
      <!-- 左侧分类 (Shell + Loading) -->
      <scroll-view class="category-sidebar" scroll-y enhanced show-scrollbar="{{false}}">
        <block wx:if="{{loading && categories.length === 0}}">
          <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="category-item-skeleton skeleton-shimmer"></view>
        </block>
        <block wx:else>
          <view 
            wx:for="{{categories}}" 
            wx:key="id"
            class="category-item {{activeCategoryId == item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="onCategoryChange"
          >
            <text>{{item.name}}</text>
          </view>
        </block>
        <view style="height: 100rpx;"></view>
      </scroll-view>

      <!-- 右侧商品列表 (Shell + Loading) -->
      <scroll-view class="dishes-list" scroll-y enhanced show-scrollbar="{{false}}" bindtouchstart="onMenuTouchStart" bindtouchmove="onMenuTouchMove" bindscroll="onScroll">
        <block wx:if="{{loading && filteredDishes.length === 0}}">
          <dish-skeleton wx:for="{{[1,2,3,4,5]}}" wx:key="*this" />
        </block>
        <block wx:elif="{{filteredDishes.length > 0}}">
          <view wx:for="{{filteredDishes}}" wx:key="id" class="dish-item" bindtap="onDishTap" data-id="{{item.id}}">
            <t-image class="dish-image" src="{{item.image_url}}" mode="aspectFill" lazy />
            <view class="dish-info">
              <view>
                <view class="dish-name">{{item.name}}</view>
                <view class="dish-tags" wx:if="{{item.tags.length > 0}}">
                  <t-tag 
                    wx:for="{{item.tags}}" 
                    wx:for-item="tag" 
                    wx:key="*this" 
                    size="extra-small" 
                    variant="dark" 
                    theme="primary"
                  >{{tag}}</t-tag>
                </view>
                <view class="dish-meta">月售 {{item.monthly_sales || 0}}</view>
              </view>
              <view class="dish-price-row">
                <text class="dish-price">¥{{item.priceDisplay}}</text>
                <text wx:if="{{item.originalPriceDisplay}}" class="dish-original-price">¥{{item.originalPriceDisplay}}</text>
              </view>
            </view>
            <view class="action-area" catchtap="stopPropagation">
              <view wx:if="{{restaurant && restaurant.is_ordering_suspended}}" class="disabled-action">已暂停</view>
              <view wx:elif="{{restaurant && restaurant.biz_status === 'CLOSED'}}" class="disabled-action">未营业</view>
              <t-button 
                wx:elif="{{item.hasCustomizations}}"
                size="extra-small" 
                theme="primary"
                shape="round"
                data-id="{{item.id}}"
                catchtap="onDishTap"
              >规格</t-button>
              <t-button 
                wx:else
                icon="add" 
                shape="circle" 
                theme="primary"
                size="small"
                data-id="{{item.id}}"
                catchtap="onAddCart"
              />
            </view>
          </view>
        </block>
        <view wx:elif="{{!loading}}" class="empty-category">
          <t-empty icon="info-circle" description="该分类暂无商品" />
        </view>
        <view style="height: 120rpx;"></view>
      </scroll-view>
      </view>
    </view>

    <!-- 精选套餐 Tab -->
    <scroll-view wx:elif="{{activeTab === 'combos'}}" class="combos-tab" scroll-y bindtouchstart="onMenuTouchStart" bindtouchmove="onMenuTouchMove" bindscroll="onScroll">
      <block wx:if="{{loading && combos.length === 0}}">
        <dish-skeleton wx:for="{{[1,2,3]}}" wx:key="*this" />
      </block>
      <block wx:elif="{{combos.length > 0}}">
        <view wx:for="{{combos}}" wx:key="id" class="combo-item" data-id="{{item.id}}" bindtap="onComboTap">
          <view class="combo-image-grid grid-count-{{item.dish_images.length > 4 ? 4 : item.dish_images.length}}" wx:if="{{item.dish_images && item.dish_images.length > 0}}">
            <t-image 
              wx:for="{{item.dish_images}}" 
              wx:for-item="img" 
              wx:for-index="imgIdx"
              wx:if="{{imgIdx < 4}}"
              wx:key="*this"
              class="grid-img" 
              src="{{img}}" 
              mode="aspectFill" 
              lazy 
            />
          </view>
          <t-image wx:else class="combo-image" src="{{item.image_url}}" mode="aspectFill" lazy />

          <view class="combo-info">
            <view>
              <view class="combo-name">{{item.name}}</view>
              <view class="combo-desc">{{item.description}}</view>
            </view>
            <view class="combo-price-row">
              <text class="combo-price">¥{{item.comboPriceDisplay}}</text>
              <view class="combo-discount">省 ¥{{item.savingsDisplay}}</view>
            </view>
          </view>

          <view class="action-area" catchtap="stopPropagation">
            <view wx:if="{{restaurant && restaurant.is_ordering_suspended}}" class="disabled-action">已暂停</view>
            <view wx:elif="{{restaurant && restaurant.biz_status === 'CLOSED'}}" class="disabled-action">未营业</view>
            <t-button 
              wx:else
              icon="add" 
              shape="circle" 
              theme="primary"
              size="small"
              data-id="{{item.id}}"
              catchtap="onAddComboCart"
            />
          </view>
        </view>
      </block>
      <t-empty wx:elif="{{!loading}}" icon="info-circle" description="暂无精选套餐" />
      <view class="empty-placeholder"></view>
    </scroll-view>

    <!-- 豪华包间 Tab -->
    <scroll-view wx:elif="{{activeTab === 'rooms'}}" class="rooms-tab" scroll-y bindtouchstart="onMenuTouchStart" bindtouchmove="onMenuTouchMove" bindscroll="onScroll">
      <block wx:if="{{loading && rooms.length === 0}}">
        <view wx:for="{{[1,2]}}" wx:key="*this" class="room-skeleton skeleton-shimmer"></view>
      </block>
      <block wx:elif="{{rooms.length > 0}}">
        <view wx:for="{{rooms}}" wx:key="id" class="room-item" data-id="{{item.id}}" bindtap="onRoomTap">
          <t-image class="room-image" src="{{item.primary_image}}" mode="aspectFill" lazy use-error-placeholder error-placeholder-src="/assets/icons/dish.svg" />
          <view class="room-info">
            <view class="room-name">{{item.name}}</view>
            <view class="dish-tags" wx:if="{{item.tags.length > 0}}">
              <t-tag wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" size="extra-small" variant="dark" theme="primary">{{tag}}</t-tag>
            </view>
            <view class="room-meta">
              <text>可容纳 {{item.capacity}} 人</text>
              <text class="room-price">¥{{item.minimumSpendDisplay}} 起</text>
            </view>
          </view>
        </view>
      </block>
      <t-empty wx:elif="{{!loading}}" icon="info-circle" description="暂无可用包间" />
      <view class="empty-placeholder"></view>
    </scroll-view>
  </block>

</view>

<!-- 4. 购物车栏 (App Shell) -->
<cart-bar 
  wx:if="{{!isError && activeTab !== 'rooms'}}"
  totalCount="{{cartCount}}"
  totalPrice="{{cartPrice}}"
  alwaysShow="{{true}}"
  dockBottom="{{true}}"
  bind:checkout="onCheckout"
  bind:toggle="onCartTap"
/>
