<custom-navbar title="购物车" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 140rpx;"
>
  <!-- 骨架屏加载状态 (App Shell + Skeleton) -->
  <view wx:if="{{loading && merchantGroups.length === 0}}" class="cart-skeleton">
    <view wx:for="{{[1,2]}}" wx:key="*this" class="merchant-skeleton-group card">
      <view class="skeleton-header skeleton-shimmer"></view>
      <list-skeleton wx:for="{{[1,2]}}" wx:key="*this" showAvatar="{{true}}" />
      <view class="skeleton-footer skeleton-shimmer"></view>
    </view>
  </view>

  <!-- 购物车列表（按商户分组） -->
  <view wx:elif="{{merchantGroups.length > 0}}" class="cart-groups">
    <view wx:for="{{merchantGroups || []}}" wx:key="cartId" class="merchant-group">
      <!-- 商户头部 -->
      <view class="merchant-header {{item.errorStatus ? 'disabled' : ''}}">
        <view class="merchant-info" bindtap="{{item.errorStatus ? '' : 'onToggleMerchant'}}" data-cart-id="{{item.cartId}}">
          <t-checkbox 
            value="{{item.cartId}}" 
            checked="{{item.selected}}"
            disabled="{{!!item.errorStatus}}"
            borderless
            t-class="custom-checkbox"
            t-class-icon="custom-checkbox-icon"
          />
          <image wx:if="{{item.merchantLogo}}" class="merchant-logo" src="{{item.merchantLogo}}" mode="aspectFill" />
          <text class="merchant-name">{{item.merchantName}}</text>
          
          <!-- 错误提示标签 -->
          <t-tag wx:if="{{item.errorStatus}}" theme="danger" variant="dark" size="small" style="margin-left: 12rpx; flex-shrink: 0; max-width: 240rpx;">
            <view style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{item.errorStatus}}</view>
          </t-tag>
        </view>
        <text class="clear-btn" bindtap="onClearMerchant" data-merchant-id="{{item.merchantId}}">清空本店</text>
      </view>

      <!-- 商品列表 -->
      <view class="cart-items">
        <view wx:for="{{item.items || []}}" wx:for-item="cartItem" wx:key="id" class="cart-item {{!cartItem.isAvailable ? 'unavailable' : ''}}">
          <!-- 组合图系统 -->
          <view wx:if="{{cartItem.dishImages && cartItem.dishImages.length > 0}}" class="combo-image-grid grid-count-{{cartItem.dishImages.length > 4 ? 4 : cartItem.dishImages.length}}">
            <t-image 
              wx:for="{{cartItem.dishImages}}" 
              wx:for-item="img" 
              wx:for-index="imgIdx"
              wx:if="{{imgIdx < 4}}"
              wx:key="*this"
              class="grid-img" 
              src="{{img}}" 
              mode="aspectFill" 
              lazy 
            />
          </view>
          <t-image wx:else class="item-image" src="{{cartItem.imageUrl}}" mode="aspectFill" lazy />
          
          <view class="item-info">
            <text class="item-name">{{cartItem.name}}</text>
            <t-tag wx:if="{{cartItem.specDisplay}}" variant="dark" theme="primary" size="small" class="item-specs-tag">{{cartItem.specDisplay}}</t-tag>
            <view class="item-price-row">
              <text class="item-price">{{cartItem.priceDisplay}}</text>
              <!-- 数量操作 -->
              <view class="item-actions">
                <view class="quantity-btn decrease" bindtap="onDecrease" data-item-id="{{cartItem.id}}">
                  <t-icon name="remove" size="24rpx" />
                </view>
                <text class="quantity">{{cartItem.quantity}}</text>
                <view class="quantity-btn increase" bindtap="onIncrease" data-item-id="{{cartItem.id}}">
                  <t-icon name="add" size="24rpx" />
                </view>
              </view>
            </view>
            <view wx:if="{{!cartItem.isAvailable}}" class="unavailable-actions" style="display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx;">
              <text class="item-status">已下架</text>
              <t-button
                size="extra-small"
                variant="text"
                theme="danger"
                loading="{{removingUnavailableItemIds[cartItem.id]}}"
                disabled="{{removingUnavailableItemIds[cartItem.id]}}"
                bindtap="onRemoveUnavailable"
                data-item-id="{{cartItem.id}}"
                data-cart-id="{{item.cartId}}"
                shape="round"
              >
                移除
              </t-button>
            </view>
          </view>
        </view>
      </view>

      <!-- 商户小计 -->
      <view class="merchant-footer">
        <view class="fee-row">
          <text class="fee-label">商品小计</text>
          <text class="fee-value">{{item.subtotalDisplay}}</text>
        </view>
        <view class="fee-row">
          <text class="fee-label">代取费</text>
          <text class="fee-value">{{item.deliveryFeeDisplay}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-container">
    <t-empty 
      icon="cart"
      description="购物车是空的"
    >
      <t-button theme="primary" size="large" bindtap="onBackToTakeout" shape="round">去逛逛</t-button>
    </t-empty>
  </view>
</view>

<!-- 底部结算栏 -->
<view wx:if="{{merchantGroups.length > 0}}" class="checkout-bar">
  <view class="total-info">
    <view class="total-row">
      <text class="total-label">已选 {{selectedCartIds.length}} 家商户</text>
    </view>
    <view class="total-row">
      <text class="total-label">合计:</text>
      <text class="total-price">{{checkoutTotalDisplay}}</text>
    </view>
    <view class="total-row" wx:if="{{singleMerchantCheckoutNotice}}">
      <text class="total-label checkout-warning">{{singleMerchantCheckoutNotice}}</text>
    </view>
  </view>
  <t-button 
    class="checkout-btn" 
    theme="primary" 
    size="large" 
    disabled="{{selectedCartIds.length === 0 || !!singleMerchantCheckoutNotice}}"
    bindtap="onCheckout"
    t-class="checkout-btn-inner"
   shape="round">
    去下单
  </t-button>
</view>
