/* Pages/takeout/cart/index.wxss */
.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  padding: 0 var(--spacer-md);
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

/* 空状态容器 */
.empty-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: calc(100vh - 200rpx);
}

/* 商户分组 */
.cart-groups {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding-top: var(--spacer-md);
  padding-bottom: 40rpx;
}

.merchant-group {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

/* 商户头部 */
.merchant-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacer-sm) var(--spacer-md) var(--spacer-sm) 12rpx;
  border-bottom: 1rpx solid var(--td-component-stroke);
}

.merchant-info {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

/* Checkbox */
.custom-checkbox {
  margin-right: 0 !important;
  padding: 0 !important;
  flex-shrink: 0;
}

.custom-checkbox-icon {
  margin-right: 0 !important;
}

.merchant-logo {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-sm);
  background-color: var(--td-bg-color-secondarycontainer);
}

.merchant-name {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.clear-btn {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-placeholder);
  padding: var(--spacer-xs) var(--spacer-sm);
}

/* 商品列表 */
.cart-items {
  padding: 0 var(--spacer-md);
}

.cart-item {
  display: flex;
  align-items: flex-start; /* 顶部对齐 */
  gap: var(--spacer-sm);
  padding: var(--spacer-md) 0;
  border-bottom: 1rpx solid var(--td-component-stroke);
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-item.unavailable {
  opacity: 0.5;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  background-color: var(--td-bg-color-secondarycontainer);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 140rpx; /* 撑开高度与图片一致 */
}

.item-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.item-specs-tag {
  align-self: flex-start; /* 宽度自适应 */
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.item-price-row {
  display: flex;
  align-items: flex-end; /* 底部对齐 */
  justify-content: space-between;
  margin-top: auto; /* 推到底部 */
}

.item-price {
  font-size: var(--font-size-base);
  color: var(--td-brand-color);
  font-weight: 600;
}

.item-status {
  font-size: var(--font-size-xs);
  color: var(--td-error-color);
  background: var(--td-error-color-light, #fff2f0);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-xs);
  margin-top: 8rpx;
  align-self: flex-start;
}

/* 数量操作 */
.item-actions {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.quantity-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: opacity var(--transition-base);
}

.quantity-btn:active {
  opacity: 0.6;
}

.quantity-btn.increase {
  background-color: var(--td-brand-color);
  color: #fff;
}

.quantity-btn.decrease {
  color: var(--td-text-color-primary);
  border: 2rpx solid var(--td-component-stroke);
  background-color: var(--td-bg-color-container);
}

.quantity {
  min-width: 48rpx;
  text-align: center;
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

/* 套餐组合图 - Grid系统 */
.combo-image-grid {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--td-bg-color-secondarycontainer);
  display: grid;
  gap: 1rpx;
  flex-shrink: 0;
}

.grid-count-1 { grid-template-columns: 1fr; grid-template-rows: 1fr; }
.grid-count-2 { grid-template-columns: repeat(2, 1fr); grid-template-rows: 1fr; }
.grid-count-3 { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); }
.grid-count-3 .grid-img:first-child { grid-column: span 2; }
.grid-count-4 { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); }

.grid-img {
  width: 100% !important;
  height: 100% !important;
  display: block;
}


/* 商户小计 */
.merchant-footer {
  padding: var(--spacer-sm) var(--spacer-md);
  background: var(--td-bg-color-secondarycontainer);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.fee-value {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
  font-weight: 500;
}

/* 底部结算栏 */
.checkout-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-top); /* 需确认 app.wxss 是否有，如无用 0 -4rpx ... */
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.total-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.total-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-xs);
}

.total-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.total-price {
  font-size: 36rpx;
  color: var(--td-brand-color);
  font-weight: 700;
}

.checkout-btn {
  flex-shrink: 0;
}

/* TDesign t-button 内部样式 */
.checkout-btn-inner {
  margin: 0 !important;
  padding-left: 48rpx !important;
  padding-right: 48rpx !important;
  font-weight: 600 !important;
}
