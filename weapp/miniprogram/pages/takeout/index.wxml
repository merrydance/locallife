<custom-navbar title="外卖" location="{{address}}" bind:locationchange="onLocationChange" />

<template name="provider-onboarding-empty">
  <t-empty description="附近暂无可代取商户" />
  <view class="empty-actions">
    <t-button theme="primary" size="large" block bind:tap="onRefresh" shape="round">重新加载</t-button>
    <t-button size="large" block bind:tap="onManualLocation" shape="round">切换位置</t-button>
  </view>
  <view class="provider-entry">
    <text bindtap="onMerchantRegister">我是商家</text>
    <text class="provider-entry-divider">/</text>
    <text bindtap="onOperatorRegister">合作入驻</text>
  </view>
</template>

<!-- Skyline 需要用 scroll-view 实现页面滚动和下拉刷新 -->
<scroll-view 
  scroll-y 
  class="page-scroll" 
  style="height: {{scrollViewHeight}}px; padding-top: calc({{navBarHeight}}px + var(--spacer-sm)); box-sizing: border-box; padding-bottom: env(safe-area-inset-bottom);"
  bindscrolltolower="onReachBottom"
  lower-threshold="200"
  refresher-enabled="{{true}}"
  refresher-triggered="{{refresherTriggered}}"
  bindrefresherrefresh="onRefresh"
  enhanced="{{true}}"
  show-scrollbar="{{false}}"
>
  <!-- 搜索框 (App Shell) -->
  <view class="search-section" bindtap="onSearchTap">
    <t-search 
      model:value="{{searchKeyword}}"
      placeholder="搜索菜品、商家"
      disabled="{{true}}"
    />
  </view>

  <!-- 菜系品类网格（动态，按区域） -->
  <view wx:if="{{cuisineCategories.length > 1}}" class="cuisine-grid-section">
    <view class="cuisine-card">
      <t-grid column="{{6}}" gutter="{{0}}" border="{{false}}" t-class="cuisine-grid">
        <t-grid-item
          wx:for="{{cuisineCategories}}"
          wx:key="id"
          bind:click="onCategoryTap"
          data-id="{{item.id}}"
          text="{{item.name}}"
          image="slot"
          t-class="{{item.selected ? 'cuisine-grid-item cuisine-grid-item--active' : 'cuisine-grid-item'}}"
          t-class-content="cuisine-grid-item-content"
          t-class-text="{{item.selected ? 'cuisine-grid-item-text cuisine-grid-item-text--active' : 'cuisine-grid-item-text'}}"
        >
          <view slot="image" class="cuisine-icon-wrap {{item.selected ? 'cuisine-icon-wrap--active' : ''}}">
            <text class="cuisine-icon-text">{{item.iconText}}</text>
          </view>
        </t-grid-item>
      </t-grid>
    </view>
  </view>

  <!-- 内容区域 (统一 Feed) -->
  <view class="content-section">
    <!-- 0. 位置引导提示 (Persistent state) -->
    <view wx:if="{{needLocation}}" class="location-guide">
      <view class="location-guide-icon">📍</view>
      <view class="location-guide-title">需要您的位置信息</view>
      <view class="location-guide-desc">本地生活服务依赖于您的位置，请先完成定位</view>
      <view class="location-guide-buttons">
        <t-button theme="primary" size="small" bind:tap="onRetryLocation" shape="round">重新定位</t-button>
        <t-button size="small" bind:tap="onManualLocation" shape="round">手动选择</t-button>
      </view>
    </view>

    <!-- 1. 错误状态 (Four States - Error) -->
    <view wx:elif="{{isError}}" class="error-container">
      <t-empty icon="info-circle" description="{{errorMsg}}" />
      <t-button theme="primary" size="small" bindtap="loadData" block style="margin: 0 40rpx;" shape="round">重试</t-button>
    </view>

    <block wx:else>
      <!-- 商户 Feed 列表 -->
      <view class="feed-section">

        <block wx:if="{{loading && merchantFeed.length === 0}}">
          <list-skeleton wx:for="{{[1,2,3,4,5]}}" wx:key="*this" showAvatar="{{true}}" />
        </block>

        <block wx:elif="{{merchantFeed.length > 0}}">
          <merchant-feed-card
            wx:for="{{merchantFeed}}"
            wx:key="id"
            merchant="{{item}}"
            bind:dishadd="onDishAddFromFeed"
            bind:merchanttap="onMerchantTapFromFeed"
          />
          <view wx:if="{{!hasMore}}" class="no-more">没有更多了</view>
        </block>

        <view wx:elif="{{!loading}}" class="empty-entry">
          <block wx:if="{{!hasServiceProviders}}">
            <template is="provider-onboarding-empty" />
          </block>
          <t-empty wx:else description="附近暂无商家" />
        </view>

        <view wx:if="{{loading && merchantFeed.length > 0}}" class="loading-wrapper">
          <t-loading theme="circular" size="40rpx" text="加载中..." />
        </view>

      </view>
    </block>
  </view>
  
  <!-- 底部安全区占位 (购物车显示时) -->
  <view wx:if="{{cartTotalCount > 0}}" style="height: 120rpx;"></view>
</scroll-view>

<!-- 购物车栏 (App Shell - Persistent Action) -->
<cart-bar 
  wx:if="{{cartTotalCount > 0}}"
  totalCount="{{cartTotalCount}}"
  totalPrice="{{cartTotalPrice}}"
  bind:checkout="onCheckout"
  bind:toggle="onCheckout"
/>
