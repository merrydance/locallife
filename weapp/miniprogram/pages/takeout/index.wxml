<custom-navbar title="外卖" location="{{address}}" bind:locationchange="onLocationChange" />

<template name="provider-onboarding-empty">
  <t-empty description="附近暂无商户服务，你可以成为第一个 🏪" />
  <view class="empty-actions">
    <t-button theme="primary" size="large" block bind:tap="onMerchantRegister" shape="round">商户入驻</t-button>
    <t-button variant="outline" size="large" block bind:tap="onOperatorRegister" shape="round">运营商入驻</t-button>
  </view>
</template>

<!-- Skyline 需要用 scroll-view 实现页面滚动和下拉刷新 -->
<scroll-view 
  scroll-y 
  class="page-scroll" 
  style="height: {{scrollViewHeight}}px; margin-top: {{navBarHeight}}px;"
  bindscrolltolower="onReachBottom"
  lower-threshold="200"
  refresher-enabled="{{true}}"
  refresher-triggered="{{refresherTriggered}}"
  bindrefresherrefresh="onRefresh"
  enhanced="{{true}}"
  show-scrollbar="{{false}}"
>
  <!-- 搜索框 (App Shell) -->
  <view class="search-section" bindtap="onSearchTap">
    <t-search 
      model:value="{{searchKeyword}}"
      placeholder="搜索菜品、商家"
      disabled="{{true}}"
    />
  </view>

  <!-- Banner 轮播 -->
  <swiper
    class="banner-swiper"
    autoplay="{{true}}"
    interval="{{3500}}"
    circular="{{true}}"
    indicator-dots="{{true}}"
    indicator-color="rgba(255,255,255,0.5)"
    indicator-active-color="#fff"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}">
      <view class="banner-item" style="background: {{item.bg}}">
        <view class="banner-inner">
          <t-tag wx:if="{{item.tag}}" size="small" variant="light" theme="default" shape="round" class="banner-tag">{{item.tag}}</t-tag>
          <view class="banner-title">{{item.title}}</view>
          <view class="banner-subtitle">{{item.subtitle}}</view>
        </view>
        <image class="banner-deco" src="{{item.icon}}" mode="aspectFit" />
      </view>
    </swiper-item>
  </swiper>

  <!-- 4宫格快捷入口 -->
  <view class="quick-entry-grid">
    <view
      class="entry-item"
      wx:for="{{quickEntries}}"
      wx:key="id"
      bindtap="onQuickEntryTap"
      data-url="{{item.url}}"
    >
      <view class="entry-icon-wrap" style="background: {{item.bg}}">
        <image class="entry-icon" src="{{item.icon}}" mode="aspectFit" />
      </view>
      <text class="entry-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 三标签切换 -->
  <view class="tabs-section">
    <t-tabs value="{{activeTab}}" bind:change="onTabChange">
      <t-tab-panel value="dishes" label="菜品" />
      <t-tab-panel value="packages" label="套餐" />
      <t-tab-panel value="restaurants" label="餐厅" />
    </t-tabs>
  </view>

  <!-- 内容区域 (发现型排版) -->
  <view class="content-section">
    <!-- 0. 位置引导提示 (Persistent state) -->
    <view wx:if="{{needLocation}}" class="location-guide">
      <view class="location-guide-icon">📍</view>
      <view class="location-guide-title">需要您的位置信息</view>
      <view class="location-guide-desc">本地生活服务依赖于您的位置，请先完成定位</view>
      <view class="location-guide-buttons">
        <t-button theme="primary" size="small" bind:tap="onRetryLocation" shape="round">重新定位</t-button>
        <t-button variant="outline" size="small" bind:tap="onManualLocation" shape="round">手动选择</t-button>
      </view>
    </view>

    <!-- 1. 错误状态 (Four States - Error) -->
    <view wx:elif="{{isError}}" class="error-container">
      <t-empty icon="info-circle" description="{{errorMsg}}" />
      <t-button theme="primary" variant="outline" size="small" bindtap="loadData" block style="margin: 0 40rpx;" shape="round">重试</t-button>
    </view>

    <block wx:else>
      <!-- 菜品列表 -->
      <view wx:if="{{activeTab === 'dishes'}}" class="nearby-merchants-section">
        <view class="section-title">推荐菜品</view>

        <block wx:if="{{loading && dishes.length === 0}}">
          <list-skeleton wx:for="{{[1,2,3,4,5]}}" wx:key="*this" showAvatar="{{true}}" />
        </block>

        <block wx:elif="{{dishes.length > 0}}">
          <dish-card
            wx:for="{{dishes}}"
            wx:key="id"
            dish="{{item}}"
            bind:add="onAddCart"
          />
          <view wx:if="{{!hasMore}}" class="no-more">没有更多了</view>
        </block>

        <view wx:elif="{{!loading}}" class="empty-entry">
          <block wx:if="{{!hasServiceProviders}}">
            <template is="provider-onboarding-empty" />
          </block>
          <t-empty wx:else description="暂未找到菜品" />
        </view>

        <view wx:if="{{loading && dishes.length > 0}}" class="loading-wrapper">
          <t-loading theme="circular" size="40rpx" text="加载中..." />
        </view>
      </view>

      <!-- 套餐列表 -->
      <view wx:elif="{{activeTab === 'packages'}}" class="nearby-merchants-section">
        <view class="section-title">精选套餐</view>

        <block wx:if="{{loading && packages.length === 0}}">
          <list-skeleton wx:for="{{[1,2,3,4,5]}}" wx:key="*this" showAvatar="{{true}}" />
        </block>

        <block wx:elif="{{packages.length > 0}}">
          <view class="package-list">
            <package-card
              wx:for="{{packages}}"
              wx:key="id"
              package="{{item}}"
              class="package-list-item"
              data-id="{{item.id}}"
              data-merchant-id="{{item.merchantId}}"
              bind:click="onPackageTap"
              bind:add="onAddComboToCart"
            />
          </view>
          <view wx:if="{{!hasMore}}" class="no-more">没有更多了</view>
        </block>

        <view wx:elif="{{!loading}}" class="empty-entry">
          <block wx:if="{{!hasServiceProviders}}">
            <template is="provider-onboarding-empty" />
          </block>
          <t-empty wx:else description="暂未找到套餐" />
        </view>

        <view wx:if="{{loading && packages.length > 0}}" class="loading-wrapper">
          <t-loading theme="circular" size="40rpx" text="加载中..." />
        </view>
      </view>

      <!-- 商户列表 -->
      <view wx:else class="nearby-merchants-section">
        <view class="section-title">附近商家</view>

        <block wx:if="{{loading && restaurants.length === 0}}">
          <list-skeleton wx:for="{{[1,2,3,4,5]}}" wx:key="*this" showAvatar="{{true}}" />
        </block>

        <block wx:elif="{{restaurants.length > 0}}">
          <restaurant-card
            wx:for="{{restaurants}}"
            wx:key="id"
            restaurant="{{item}}"
          />
          <view wx:if="{{!hasMore}}" class="no-more">没有更多了</view>
        </block>

        <view wx:elif="{{!loading}}" class="empty-entry">
          <template is="provider-onboarding-empty" />
        </view>

        <view wx:if="{{loading && restaurants.length > 0}}" class="loading-wrapper">
          <t-loading theme="circular" size="40rpx" text="加载中..." />
        </view>
      </view>
    </block>
  </view>
  
  <!-- 底部安全区占位 (购物车显示时) -->
  <view wx:if="{{cartTotalCount > 0}}" style="height: 120rpx;"></view>
</scroll-view>

<!-- 购物车栏 (App Shell - Persistent Action) -->
<cart-bar 
  wx:if="{{cartTotalCount > 0}}"
  totalCount="{{cartTotalCount}}"
  totalPrice="{{cartTotalPrice}}"
  bind:checkout="onCheckout"
  bind:toggle="onCheckout"
/>
