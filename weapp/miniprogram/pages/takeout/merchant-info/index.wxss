.page {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

.content {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 骨架屏布局 */
.skeleton-content {
  background: var(--td-bg-color-page);
  min-height: 100vh;
}

.skeleton-hero {
  height: 380rpx;
  background: var(--td-bg-color-secondarycontainer);
  margin-bottom: 24rpx;
}

.skeleton-line {
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 4rpx;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-state {
  display: none;
}

.hero {
  position: relative;
  height: 380rpx;
  background-size: cover;
  background-position: center;
  border-radius: 0;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.65), rgba(0,0,0,0.15));
  color: var(--td-text-color-anti);
}

.hero-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.hero-static-tag {
  margin: 0;
}

.info-section {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.info-desc {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--td-border-level-1-color);
  font-size: 26rpx;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--td-text-color-secondary);
}

.info-value {
  color: var(--td-text-color-primary);
}

.info-value.open {
  color: var(--td-success-color);
}

.info-value.closed {
  color: var(--td-error-color);
}

.info-value.call {
  color: var(--td-brand-color);
}

.hours-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  align-items: flex-end;
}

.hour-line {
  display: flex;
  gap: 12rpx;
  color: var(--td-text-color-primary);
}

.hour-line.closed {
  color: var(--td-text-color-placeholder);
}

.promotion-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.promo-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--td-text-color-primary);
}

.license-images {
  display: flex;
  gap: 20rpx;
}

.license-item {
  width: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.license-image {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.license-name {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.no-license {
  font-size: 26rpx;
  color: var(--td-text-color-placeholder);
}
