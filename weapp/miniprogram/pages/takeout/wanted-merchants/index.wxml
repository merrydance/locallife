<custom-navbar title="想吃榜" showBack="{{true}}" />

<view class="wanted-page" style="padding-top: calc({{navBarHeight}}px + var(--spacer-sm));">
  <view class="wanted-header">
    <view class="wanted-title-row">
      <text class="wanted-title">你想吃谁家外卖？</text>
      <t-tag wx:if="{{regionName}}" theme="primary" variant="light">{{regionName}}</t-tag>
    </view>
    <text class="wanted-subtitle">告诉我们，平台优先邀请他入驻</text>
  </view>

  <view class="submit-panel">
    <t-search
      model:value="{{inputName}}"
      placeholder="店名、档口名、品牌名"
      disabled="{{submitting}}"
      bind:change="onInputChange"
      bind:submit="onSubmitManual"
      bind:clear="onClearInput"
    />
    <view class="submit-actions">
      <t-button theme="primary" size="small" shape="round" loading="{{submitting}}" bindtap="onSubmitManual">提交店名</t-button>
      <t-button size="small" shape="round" bindtap="onPickFromMap">
        <t-icon name="location" size="28rpx" />
        <text>地图选择</text>
      </t-button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <t-loading theme="circular" size="40rpx" text="加载榜单..." />
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <t-empty description="{{errorMessage || '榜单加载失败'}}" />
    <t-button theme="primary" size="small" shape="round" bindtap="onRetry">重试</t-button>
  </view>

  <view wx:else class="leaderboard-section">
    <view class="leaderboard-meta">
      <text>上榜商户 {{total}} 家</text>
      <t-button size="extra-small" variant="text" bindtap="onRefresh" loading="{{refreshing}}">
        <t-icon name="refresh" size="26rpx" />
      </t-button>
    </view>

    <scroll-view
      scroll-y
      class="leaderboard-scroll"
      scroll-into-view="{{scrollIntoView}}"
      scroll-with-animation="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view wx:if="{{items.length === 0}}" class="empty-list">
        <t-empty description="还没有店上榜" />
      </view>

      <view
        wx:for="{{items}}"
        wx:key="id"
        id="wanted-{{item.id}}"
        class="rank-row {{item.highlight ? 'rank-row--highlight' : ''}}"
      >
        <view class="{{item.rankClass}}">{{item.rankLabel}}</view>
        <view class="rank-main">
          <view class="rank-name-row">
            <text class="rank-name">{{item.name}}</text>
            <text class="rank-count">{{item.want_count}} 人想吃</text>
          </view>
          <text wx:if="{{item.address}}" class="rank-address">{{item.address}}</text>
        </view>
        <view class="vote-wrap">
          <text wx:if="{{item.plusAnimating}}" class="plus-fly">+1</text>
          <t-button
            theme="{{item.has_voted ? 'default' : 'primary'}}"
            size="small"
            shape="round"
            loading="{{item.voting}}"
            disabled="{{item.voting}}"
            data-id="{{item.id}}"
            bindtap="onVote"
          >{{item.has_voted ? '已+1' : '+1'}}</t-button>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
