<custom-navbar title="想吃榜" showBack="{{true}}" />

<view class="wanted-page page-shell page-shell--with-nav page-shell--bottom-safe" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view class="poster-section">
    <view class="poster-kicker">
      <view class="poster-line"></view>
      <text>LOCAL LIFE RANKING</text>
      <view class="poster-line"></view>
    </view>
    <text class="poster-title">想吃榜</text>
    <text class="poster-subtitle">你想吃谁家外卖？</text>
    <view class="poster-meta-row">
      <view class="poster-meta-pill">
        <t-icon name="location" size="24rpx" />
        <text>{{regionName || '当前区县'}}</text>
      </view>
      <view class="poster-meta-pill">
        <t-icon name="hotspot-wave" size="24rpx" />
        <text>{{total}} 家上榜</text>
      </view>
    </view>
  </view>

  <view class="submit-panel">
    <view class="submit-title-row">
      <text class="submit-title">告诉我们，优先邀请他入驻</text>
      <t-tag wx:if="{{regionName}}" theme="primary" variant="light">{{regionName}}</t-tag>
    </view>
    <view class="pick-row">
      <view class="name-input-wrap">
        <t-input
          value="{{inputName}}"
          placeholder="店名、档口名、品牌名"
          disabled="{{submitting}}"
          clearable
          confirm-type="done"
          borderless
          bind:change="onInputChange"
          bind:enter="onSubmitManual"
          bind:clear="onClearInput"
          t-class="name-input"
          t-class-input="name-input-control"
        />
      </view>
      <view class="map-pick {{submitting ? 'map-pick--disabled' : ''}}" bindtap="onPickFromMap">
        <t-icon name="map-location" size="30rpx" class="map-pick-icon" />
        <text>去地图选店</text>
      </view>
    </view>
    <t-button
      theme="primary"
      size="large"
      shape="round"
      block
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bindtap="onSubmitManual"
      t-class="submit-button"
    >提交</t-button>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <t-loading theme="circular" size="40rpx" text="加载榜单..." />
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <t-empty description="{{errorMessage || '榜单加载失败'}}" />
    <t-button theme="primary" size="small" shape="round" bindtap="onRetry">重试</t-button>
  </view>

  <view wx:else class="leaderboard-section">
    <view class="leaderboard-meta">
      <view class="leaderboard-title-block">
        <text class="leaderboard-title">本区热想榜</text>
        <text class="leaderboard-subtitle">上榜商户 {{total}} 家</text>
      </view>
    </view>

    <scroll-view
      scroll-y
      class="leaderboard-scroll"
      scroll-into-view="{{scrollIntoView}}"
      scroll-with-animation="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view wx:if="{{items.length === 0}}" class="empty-list">
        <t-empty description="还没有店上榜" />
      </view>

      <view
        wx:for="{{items}}"
        wx:key="id"
        id="wanted-{{item.id}}"
        class="rank-row {{item.highlight ? 'rank-row--highlight' : ''}}"
      >
        <view class="{{item.rankClass}}">
          <text class="rank-badge-caption">{{item.rankCaption}}</text>
          <text class="rank-badge-number">{{item.rankLabel}}</text>
        </view>
        <view class="rank-main">
          <view wx:if="{{item.rank <= 5}}" class="rank-hotline">
            <t-icon name="hotspot-wave" size="24rpx" />
            <text>{{item.want_count}} 人想吃</text>
          </view>
          <view class="rank-name-row">
            <text class="rank-name">{{item.name}}</text>
          </view>
          <text wx:if="{{item.address}}" class="rank-address">{{item.address}}</text>
        </view>
        <view class="vote-wrap">
          <text wx:if="{{item.plusAnimating}}" class="plus-fly">+1</text>
          <t-button
            theme="{{item.has_voted ? 'default' : 'primary'}}"
            size="small"
            shape="round"
            loading="{{item.voting}}"
            disabled="{{item.voting}}"
            data-id="{{item.id}}"
            bindtap="onVote"
          >{{item.has_voted ? '已+1' : '+1'}}</t-button>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
