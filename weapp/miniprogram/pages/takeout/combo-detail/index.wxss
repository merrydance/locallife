.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  display: flex;
  flex-direction: column;
}

/* 骨架屏布局 */
.skeleton-content {
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

.skeleton-header-image {
  width: 100%;
  height: 560rpx;
  background: var(--td-bg-color-secondarycontainer);
}

.skeleton-scroll {
  padding: 0 24rpx;
}

.skeleton-line {
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 4rpx;
}

.action-bar-skeleton {
  display: flex;
  width: 100%;
  justify-content: space-between;
  align-items: center;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-container {
  display: none;
}

/* 头部主图 / 拼图 */
.header-image {
  position: relative;
  width: 100%;
  height: 560rpx;
  background-color: var(--td-bg-color-secondarycontainer);
  overflow: hidden;
}

.combo-image-grid {
  display: grid;
  width: 100%;
  height: 100%;
  gap: 2rpx;
}

.grid-count-1 { grid-template-columns: 1fr; }
.grid-count-2 { grid-template-columns: 1fr 1fr; }
.grid-count-3 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
.grid-count-3 .grid-img:first-child { grid-row: span 2; }
.grid-count-4 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }

.grid-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.1));
}

/* 内容区域 */
.content-scroll {
  flex: 1;
  position: relative;
  z-index: 1;
}

.content-card {
  padding: 0 24rpx 180rpx;
}

.basic-info {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-lg);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacer-sm);
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  line-height: 1.4;
  flex: 1;
  margin-right: 24rpx;
}

.share-btn-reset {
  padding: 0;
  margin: 0;
  line-height: normal;
  background: none;
  border: none;
  overflow: visible;
}

.share-btn-reset::after {
  border: none;
}

.share-icon-box {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--td-brand-color-light);
  border-radius: var(--radius-round);
}

.stats-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacer-md);
}

.sales {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.delivery-info {
  margin-left: 24rpx;
  display: flex;
  align-items: center;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.delivery-info .divider {
  margin: 0 12rpx;
  color: var(--td-border-level-1-color);
}

.price-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: var(--spacer-md);
}

.price-box {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 32rpx;
  color: var(--td-brand-color);
  font-weight: 600;
}

.price {
  font-size: 48rpx;
  color: var(--td-brand-color);
  font-weight: 700;
  margin-left: 4rpx;
}

.original-price {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
  margin-left: 16rpx;
}

.savings-tag {
  margin-left: 16rpx;
  margin-bottom: 8rpx;
}

/* 规格选择 */
.spec-section {
  margin-bottom: var(--spacer-lg);
  padding-top: var(--spacer-sm);
  border-top: 2rpx solid var(--td-border-level-1-color);
}

.spec-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-tag {
  border-radius: 8rpx;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
}

.spec-tag.selected {
  font-weight: 500;
}

.description {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

.desc-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

/* 区块卡片 */
.section-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-lg);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-lg);
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.dish-count {
  font-size: var(--font-size-xs);
  font-weight: normal;
  color: var(--td-text-color-placeholder);
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-lg);
}

.dish-item {
  display: flex;
  align-items: center;
}

.dish-img {
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  margin-left: 20rpx;
  margin-right: 12rpx;
}

.dish-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dish-name {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-primary);
}

.dish-qty {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.dish-price-row {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

/* 备注 */
.remark-section {
  padding-bottom: var(--spacer-md);
}

.remark-textarea {
  --td-textarea-background-color: var(--td-bg-color-secondarycontainer);
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.quick-remarks {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-remark-tag {
  border-radius: 4rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  background: var(--td-bg-color-secondarycontainer);
  border: none !important;
}

.merchant-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.merchant-info {
  display: flex;
  align-items: center;
}

.merchant-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 500;
  margin-left: 16rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--td-bg-color-container);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-md);
  z-index: 100;
}

.quantity-control {
  margin-right: 24rpx;
}

.btn-group {
  display: flex;
  flex: 1;
  gap: 16rpx;
}

.add-cart-btn {
  flex: 1;
  --td-button-light-color: var(--td-brand-color);
  --td-button-light-bg-color: var(--td-brand-color-light);
}

.buy-now-btn {
  flex: 1;
}

.resting-bar {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 16rpx;
  align-items: center;
}

.resting-text {
  font-size: 26rpx;
  color: var(--td-text-color-placeholder);
  font-weight: 500;
}

.safe-bottom {
  height: 40rpx;
}
