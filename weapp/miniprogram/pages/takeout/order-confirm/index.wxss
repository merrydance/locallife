.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

/* 卡片通用样式 */
.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin: var(--spacer-sm) var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

/* 收货地址 */
.address-section {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  gap: var(--spacer-md);
  margin-bottom: var(--spacer-xs);
}

.address-name {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.address-phone {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
}

.address-detail {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-placeholder);
  display: block;
}

.address-empty {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--td-text-color-placeholder);
}

.address-arrow {
  color: var(--td-text-color-placeholder);
}

/* 商家卡片 */
.merchant-card {
  padding: var(--spacer-md);
}

.merchant-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-md);
}

.merchant-name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.merchant-count {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-secondary);
  background: var(--td-bg-color-secondarycontainer);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-round);
}

/* 子模块通用 */
.module-section {
  margin-top: var(--spacer-md);
}

.section-title {
  font-size: var(--font-size-sm);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

/* 配送时间 */
.eta-row {
  padding: var(--spacer-sm);
  background: var(--td-brand-color-light);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.eta-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.eta-values {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-xs);
}

.eta-window {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-brand-color);
}

.eta-note {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

/* 商品清单 */
.item-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.item-row:last-child {
  border-bottom: none;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  display: block;
  margin-bottom: 4rpx;
}

.item-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.item-spec-tag {
  font-size: 20rpx;
  color: var(--td-text-color-placeholder);
  background: var(--td-bg-color-secondarycontainer);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.item-quantity {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  margin-right: var(--spacer-md);
}

.item-price {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

/* 备注 */
.remark-input {
  width: 100%;
  padding: var(--spacer-sm);
  background: var(--td-bg-color-secondarycontainer);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-base);
  box-sizing: border-box;
}

/* 费用明细 */
.cost-row {
  display: flex;
  justify-content: space-between;
  padding: var(--spacer-xs) 0;
}

.cost-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.cost-value {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
}

.cost-row.total {
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
  margin-top: var(--spacer-sm);
  padding-top: var(--spacer-sm);
}

.cost-row.total .cost-label {
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.cost-row.total .cost-value {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-brand-color);
}

/* 汇总页面底部样式 */
.cost-section.summary {
  margin-bottom: var(--spacer-xl);
}

/* 底部操作栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md);
  padding-right: var(--spacer-sm); /* 减少右侧间距，使按钮更贴右 */
  /* 适配各种屏幕的安全区域间距 */
  padding-bottom: calc(var(--spacer-sm) + env(safe-area-inset-bottom));
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-md);
  z-index: var(--z-index-fixed);
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.submit-info {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.submit-label {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.submit-price {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-brand-color);
  margin-left: var(--spacer-xs);
}

.submit-btn {
  width: 260rpx; /* 适当收窄，比例更和谐 */
}

/* 套餐组合图 - Grid系统 */
.combo-image-grid {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--td-bg-color-secondarycontainer);
  display: grid;
  gap: 1rpx;
  flex-shrink: 0;
}

.grid-count-1 { grid-template-columns: 1fr; grid-template-rows: 1fr; }
.grid-count-2 { grid-template-columns: repeat(2, 1fr); grid-template-rows: 1fr; }
.grid-count-3 { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); }
.grid-count-3 .grid-img:first-child { grid-column: span 2; }
.grid-count-4 { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); }

.grid-img {
  width: 100% !important;
  height: 100% !important;
  display: block;
}
