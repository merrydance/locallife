@import '../../../styles/customer.wxss';
@import "../../../styles/takeout-order-confirm-sections.wxss";

.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

/* 骨架屏布局 */
.skeleton-content {
  padding-top: var(--spacer-sm);
}

.address-skeleton {
  height: 140rpx;
  background: var(--td-bg-color-secondarycontainer);
  border-radius: var(--radius-md);
}

.merchant-skeleton {
  min-height: 400rpx;
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
}

.error-shell {
  display: flex;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.skeleton-line {
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 4rpx;
}

/* 卡片通用样式 */
.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin: var(--spacer-sm) 0;
  box-shadow: var(--shadow-sm);
}

.split-checkout-notice {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  color: var(--td-text-color-primary);
  background: var(--td-warning-color-1, #fff4e5);
  border: 1rpx solid var(--td-warning-color-3, #ffd8a6);
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

/* 收货地址 */
.address-section {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  gap: var(--spacer-md);
  margin-bottom: var(--spacer-xs);
}

.address-name {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.address-phone {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
}

.address-detail {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-placeholder);
  display: block;
}

.address-empty {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--td-text-color-placeholder);
}

.address-arrow {
  color: var(--td-text-color-placeholder);
}

/* 商家卡片 */
.merchant-card {
  padding: var(--spacer-md);
}

.merchant-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-md);
}

.merchant-name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.merchant-count {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-secondary);
  background: var(--td-bg-color-secondarycontainer);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-round);
}

/* 子模块通用 */
.module-section {
  margin-top: var(--spacer-md);
}

.section-title {
  font-size: var(--font-size-sm);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.payment-section {
  padding: var(--spacer-sm) 0;
}

.payment-method-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  min-height: 72rpx;
}

.payment-method-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
}

/* 代取时间 */
.eta-row {
  padding: var(--spacer-sm);
  background: var(--td-brand-color-light);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.eta-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.eta-values {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-xs);
}

.eta-window {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-brand-color);
}

.eta-note {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

/* 商品清单 */
.item-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.item-row:last-child {
  border-bottom: none;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  display: block;
  margin-bottom: 4rpx;
}

.item-specs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-xs);
}

.item-quantity {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  margin-right: var(--spacer-md);
}

.item-price {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

/* 备注 */
.remark-input {
  width: 100%;
  padding: var(--spacer-sm);
  background: var(--td-bg-color-secondarycontainer);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-base);
  box-sizing: border-box;
}

/* 费用明细 */
.cost-row {
  display: flex;
  justify-content: space-between;
  padding: var(--spacer-xs) 0;
}

.cost-label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.cost-value {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary);
}

.cost-row.total {
  margin-top: var(--spacer-sm);
  padding-top: var(--spacer-sm);
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.cost-row.total .cost-label {
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.cost-divider {
  height: 1rpx;
  background-color: var(--td-bg-color-secondarycontainer);
  margin: var(--spacer-sm) 0;
}

.total-row-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-label {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.total-price-group {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-xs);
}

.old-price {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
}

.new-price {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-brand-color);
}

.status-red {
  color: var(--td-error-color) !important;
}

.cost-row.total .cost-value {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-brand-color);
}

/* 汇总页面底部样式 */
