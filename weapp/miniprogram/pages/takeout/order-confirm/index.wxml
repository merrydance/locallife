<custom-navbar title="确认订单" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 200rpx;"
>
  <!-- 1. 骨架屏状态 (App Shell + Skeleton) -->
  <view wx:if="{{initLoading}}" class="skeleton-content">
    <view class="address-skeleton card skeleton-shimmer"></view>
    <view wx:for="{{[1]}}" wx:key="*this" class="merchant-skeleton card">
      <view class="skeleton-line skeleton-shimmer" style="width: 40%; height: 40rpx; margin-bottom: 30rpx;"></view>
      <view class="skeleton-line skeleton-shimmer" style="width: 100%; height: 160rpx; margin-bottom: 20rpx;"></view>
      <view class="skeleton-line skeleton-shimmer" style="width: 100%; height: 160rpx;"></view>
    </view>
  </view>

  <view wx:elif="{{loadError}}" class="error-shell card">
    <t-empty icon="error-circle" description="{{loadError}}">
      <t-button slot="action" theme="primary" size="small" bindtap="onRetryLoad" shape="round">重试</t-button>
    </t-empty>
  </view>

  <!-- 2. 正常内容 -->
  <block wx:else>
    <view wx:if="{{singleMerchantCheckoutNotice}}" class="split-checkout-notice card">
      <t-icon name="info-circle" size="32rpx" color="var(--td-warning-color)" />
      <text>{{singleMerchantCheckoutNotice}}</text>
    </view>

    <!-- 收货地址 -->
    <view wx:if="{{requiresAddress}}" class="address-section card" bindtap="onSelectAddress">
      <view wx:if="{{address && address.id}}" class="address-content">
      <view class="address-header">
        <text class="address-name">{{address.contact_name}}</text>
        <text class="address-phone">{{address.contact_phone}}</text>
        <t-tag wx:if="{{address.is_default}}" size="small" theme="primary" variant="dark">默认</t-tag>
      </view>
      <text class="address-detail">{{address.detail_address}}</text>
    </view>
    <view wx:else class="address-empty">
      <t-icon name="location" size="48rpx" color="var(--td-text-color-placeholder)" />
      <text class="empty-text">请选择收货地址</text>
    </view>
    <t-icon name="chevron-right" size="40rpx" class="address-arrow" />
  </view>
  <view wx:else class="address-section card self-pickup-section">
    <t-icon name="shop" size="40rpx" color="var(--td-brand-color)" />
    <view class="address-content">
      <view class="address-header">
        <text class="address-name">到店自取</text>
      </view>
      <text class="address-detail">下单后请到商户门店取餐。</text>
    </view>
  </view>

  <!-- 商户列表 -->
  <block wx:for="{{carts || []}}" wx:key="merchantId">
    <view class="merchant-card card">
      <view class="merchant-header">
        <view class="merchant-info" style="display: flex; align-items: center; gap: 8rpx;">
          <t-icon name="shop" size="32rpx" color="var(--td-text-color-primary)" />
          <text class="merchant-name">{{item.merchantName}}</text>
        </view>
        <text class="merchant-count">共 {{item.totalCount}} 件</text>
      </view>

      <!-- 代取时间 -->
      <view class="module-section" wx:if="{{item.orderType !== 'takeaway'}}">
        <view class="section-title">预计送达时间</view>
        <view class="eta-row" wx:if="{{item.deliveryEtaDisplay}}">
          <t-icon name="time" size="32rpx" color="var(--td-brand-color)" />
          <view class="eta-values">
            <text class="eta-window">{{item.deliveryEtaDisplay}}</text>
            <text class="eta-note" wx:if="{{item.deliveryEtaMinutes}}">约 {{item.deliveryEtaMinutes}} 分钟</text>
          </view>
        </view>
        <view class="eta-row" wx:elif="{{!(address && address.id)}}">
          <text class="eta-label">请选择代取地址</text>
        </view>
        <view class="eta-row" wx:else>
          <text class="eta-label">正在计算送达时间...</text>
        </view>
      </view>
      <view class="module-section" wx:else>
        <view class="section-title">取餐方式</view>
        <view class="eta-row">
          <t-icon name="shop" size="32rpx" color="var(--td-brand-color)" />
          <text class="eta-label">到店自取，商户备餐完成后凭取餐码取餐</text>
        </view>
      </view>

      <!-- 商品列表 -->
      <view class="module-section">
        <view class="section-title">商品清单</view>
        <view class="items-list">
          <block wx:for="{{item.items || []}}" wx:key="id" wx:for-item="cartItem">
            <view class="item-row">
              <!-- 组合图系统 -->
              <view wx:if="{{cartItem.dishImages && cartItem.dishImages.length > 0}}" class="combo-image-grid grid-count-{{(cartItem.dishImages && cartItem.dishImages.length > 4) ? 4 : (cartItem.dishImages ? cartItem.dishImages.length : 0)}}">
                <t-image 
                  wx:for="{{cartItem.dishImages || []}}" 
                  wx:for-item="img" 
                  wx:for-index="imgIdx"
                  wx:if="{{imgIdx < 4}}"
                  wx:key="*this"
                  class="grid-img" 
                  src="{{img}}" 
                  mode="aspectFill" 
                  lazy 
                />
              </view>
              <t-image wx:else class="item-image" src="{{cartItem.imageUrl}}" mode="aspectFill" lazy />
              <view class="item-info">
                <text class="item-name">{{cartItem.name}}</text>
                <view class="item-specs" wx:if="{{cartItem.specText}}">
                  <t-tag size="extra-small" variant="dark" theme="default" shape="round">{{cartItem.specText}}</t-tag>
                </view>
              </view>
              <text class="item-quantity">×{{cartItem.quantity}}</text>
              <text class="item-price">¥{{cartItem.priceDisplay}}</text>
            </view>
          </block>
        </view>
      </view>

      <!-- 备注 -->
      <view class="module-section">
        <remark-input
          value="{{remarks[item.merchantId] || ''}}"
          placeholder="给商家留言"
          data-merchant-id="{{item.merchantId}}"
          bind:change="onRemarkInput"
        />
      </view>

      <!-- 费用明细 -->
      <view class="module-section">
        <view class="cost-row">
          <text class="cost-label">商品金额</text>
          <text class="cost-value">¥{{item.subtotalDisplay}}</text>
        </view>
        <view class="cost-row" wx:for="{{item.ladderPromotions || []}}" wx:key="name" wx:for-item="ladder">
          <text class="cost-label" wx:if="{{ladder.currentHit}}">{{ladder.name}}（已满{{ladder.thresholdDisplay}}）</text>
          <text class="cost-label" wx:else>{{ladder.name}}（还差¥{{ladder.missingNeedDisplay}}）</text>
          <text class="cost-value" wx:if="{{ladder.currentHit}}">可减¥{{ladder.discountDisplay}}</text>
          <text class="cost-value" wx:else>可减¥{{ladder.discountDisplay}}</text>
        </view>
        <view class="cost-row" wx:for="{{item.appliedPromotions || []}}" wx:key="title" wx:for-item="promo" wx:if="{{promo.type === 'merchant' || promo.type === 'voucher'}}">
          <text class="cost-label status-red">{{promo.title}}</text>
          <text class="cost-value status-red">-¥{{promo.amountDisplay}}</text>
        </view>
        <view class="cost-row" wx:for="{{item.voucherTrials || []}}" wx:key="voucherName" wx:for-item="trial">
          <text class="cost-label">券试算：{{trial.voucherName}}（减¥{{trial.amountDisplay}}）</text>
          <text class="cost-value">试算后¥{{trial.trialPayableDisplay}}</text>
        </view>
        <view class="cost-row">
          <text class="cost-label">{{item.deliveryFeeLabel}}</text>
          <text class="cost-value">{{item.deliveryFeeDisplay}}</text>
        </view>
        <view class="cost-row" wx:for="{{item.appliedPromotions || []}}" wx:key="title" wx:for-item="promo" wx:if="{{promo.type === 'delivery'}}">
          <text class="cost-label status-red">{{promo.title}}</text>
          <text class="cost-value status-red">-¥{{promo.amountDisplay}}</text>
        </view>
        <view class="cost-divider"></view>
        <view class="cost-row total-row-main">
          <text class="total-label">小计</text>
          <view class="total-price-group">
            <text class="old-price" wx:if="{{item.hasDiscount}}">¥{{item.originalTotalDisplay}}</text>
            <text class="new-price">¥{{item.orderTotalDisplay}}</text>
          </view>
        </view>
        <view class="cost-row" wx:if="{{item.paymentHint}}">
          <text class="cost-label">支付提示</text>
          <text class="cost-value">{{item.paymentHint}}</text>
        </view>
        <view wx:if="{{item.feeBreakdownView && item.feeBreakdownView.available}}" class="profit-sharing-section">
          <view class="profit-sharing-title">分账明细</view>
          <view
            wx:for="{{item.feeBreakdownView.settlement_groups}}"
            wx:key="key"
            wx:for-item="group"
            wx:if="{{group.visible}}"
            class="profit-sharing-group profit-sharing-group--{{group.tone}}"
          >
            <view class="profit-sharing-group-header">
              <text class="profit-sharing-group-title">{{group.title}}</text>
              <text class="profit-sharing-group-total">{{group.total_text}}</text>
            </view>
            <view
              wx:for="{{group.rows}}"
              wx:key="key"
              wx:for-item="row"
              wx:if="{{row.visible}}"
              class="profit-sharing-row profit-sharing-row--{{row.tone}}"
            >
              <text class="profit-sharing-label">{{row.label}}</text>
              <text class="profit-sharing-value">{{row.value_text}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 支付方式 -->
      <view class="module-section payment-section" wx:if="{{carts.length === 1}}">
        <view class="section-title">支付方式</view>
        <payment-methods
          selected="{{selectedPaymentMethod}}"
          methods="{{paymentMethods}}"
          balanceInsufficient="{{balanceInsufficient}}"
          bind:change="onPaymentMethodChange"
        />
      </view>

      <!-- 商户优惠活动 -->
      <view class="module-section">
        <merchant-promos 
          merchantId="{{item.merchantId}}"
          membershipId="{{membershipIds[item.merchantId]}}"
          currentBalance="{{memberBalances[item.merchantId]}}"
          orderTotal="{{item.orderTotal}}"
          bind:recharged="onRecharged"
          bind:voucherClaimed="onVoucherClaimed"
        />
      </view>
    </view>
  </block>

  <!-- 汇总 -->
  <view class="cost-section summary card">
    <view class="section-title">费用合计</view>
    <view wx:if="{{pricingError}}" class="pricing-error-box">
      <text class="pricing-error-text">{{pricingError}}</text>
      <t-button size="small" theme="primary" variant="outline" shape="round" bindtap="onRetryPricing">重新计算</t-button>
    </view>
    <view class="cost-row">
      <text class="cost-label">商品总额</text>
      <text class="cost-value">¥{{summarySubtotalDisplay}}</text>
    </view>
    <view class="cost-row">
      <text class="cost-label">{{summaryDeliveryLabel}}</text>
      <text class="cost-value">{{summaryDeliveryDisplay}}</text>
    </view>
    <view class="cost-row total">
      <text class="cost-label">实付款</text>
      <text class="cost-value">¥{{orderTotalDisplay}}</text>
    </view>
    </view>
  </block>
</view>

<!-- 底部提交栏 -->
<view class="submit-bar">
  <view class="submit-info">
    <text class="submit-label">合计</text>
    <text class="submit-price">¥{{orderTotalDisplay}}</text>
  </view>
  <t-button 
    class="submit-btn" 
    theme="primary" 
    shape="round"
    size="large"
    loading="{{loading}}"
    disabled="{{loading || !!loadError || !!pricingError || !!singleMerchantCheckoutNotice || (requiresAddress && !(address && address.id)) || !(carts && carts.length)}}"
    bindtap="onSubmitOrder"
  >
    去支付
  </t-button>
  <t-toast id="t-toast" />
</view>
