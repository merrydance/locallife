.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

/* 骨架屏布局 */
.skeleton-content {
  padding-bottom: 200rpx;
}

.skeleton-swiper {
  width: 100%;
  height: 600rpx;
  background: #f0f0f0;
}

.skeleton-text {
  background: #f0f0f0;
  border-radius: 4rpx;
}

.detail-content {
  padding-bottom: 40rpx;
}

/* 图片轮播 */
.swiper-container {
  position: relative;
  width: 100%;
  height: 600rpx;
}

.image-swiper {
  width: 100%;
  height: 100%;
  background: var(--td-bg-color-secondarycontainer);
}

.dish-image {
  width: 100%;
  height: 100%;
}

.image-indicator {
  position: absolute;
  bottom: var(--spacer-md);
  right: var(--spacer-md);
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  z-index: 10;
}

/* 卡片通用样式 */
.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin: var(--spacer-sm) var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

/* 基本信息 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.shop-dish-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  line-height: 48rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-sm);
  margin-top: 8rpx;
}

.price {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--td-brand-color);
}

.original-price {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
}

.tags-row {
  display: flex;
  gap: var(--spacer-xs);
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  margin-top: 8rpx;
}

.separator {
  color: var(--td-text-color-placeholder);
  margin: 0 4rpx;
}

/* 规格选择 */
.spec-group {
  margin-bottom: var(--spacer-md);
}

.spec-group:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: 20rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.spec-tag {
  transition: all 0.2s;
}

/* 详情描述 */
.description {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

/* 商家信息 */
.shop-section-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.shop-info {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.shop-name {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  font-weight: 500;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + var(--safe-area-bottom));
  background: var(--td-bg-color-container);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 1000;
}

.bottom-bar-skeleton {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.quantity {
  font-size: 32rpx;
  color: var(--td-text-color-primary);
  min-width: 44rpx;
  text-align: center;
  font-weight: 600;
}

.btn-group {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.cart-btn {
  flex: 1;
}

.buy-btn {
  flex: 1;
}
