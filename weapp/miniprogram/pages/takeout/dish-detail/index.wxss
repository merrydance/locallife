.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 200rpx 0;
}

.detail-content {
  padding-bottom: var(--spacer-xl);
}

/* 图片轮播 */
.swiper-container {
  position: relative;
  width: 100%;
  height: 600rpx;
}

.image-swiper {
  width: 100%;
  height: 100%;
  background: var(--td-bg-color-container);
}

.dish-image {
  width: 100%;
  height: 100%;
}

.image-indicator {
  position: absolute;
  bottom: var(--spacer-md);
  right: var(--spacer-md);
  background: rgba(0, 0, 0, 0.6);
  color: var(--td-text-color-anti);
  padding: var(--spacer-xxs) var(--spacer-sm);
  border-radius: var(--radius-round);
  font-size: var(--font-size-xs);
  z-index: 10;
}

/* 卡片通用样式 */
.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin: var(--spacer-sm) var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

/* 基本信息 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.shop-dish-name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-sm);
}

.price {
  font-size: var(--font-size-title);
  font-weight: bold;
  color: var(--td-brand-color);
}

.original-price {
  font-size: var(--font-size-base);
  color: var(--td-text-color-placeholder);
  text-decoration: line-through;
}

.tags-row {
  display: flex;
  gap: var(--spacer-xs);
  flex-wrap: wrap;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.delivery-row {
  display: flex;
  align-items: center;
  gap: var(--spacer-md);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.delivery-row .delivery-time {
  color: var(--td-brand-color);
}

/* 规格选择 */
.spec-group {
  margin-bottom: var(--spacer-md);
}

.spec-group:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
}

.spec-tag {
  transition: var(--transition-base);
}

/* 详情描述 */
.description {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

/* 商家信息 */
.shop-section-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.shop-info {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
}

.shop-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.shop-arrow {
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-title);
}

/* 评价部分 */
.review-item {
  padding: var(--spacer-md) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.review-item:first-child {
  padding-top: 0;
}

.review-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.review-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacer-xs);
}

.reviewer-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 500;
}

.review-date {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.review-rating {
  margin-bottom: var(--spacer-xs);
}

.star {
  font-size: var(--font-size-xs);
  color: var(--td-warning-color);
}

.review-content {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  line-height: 1.6;
  display: block;
  margin-bottom: var(--spacer-sm);
}

.review-images {
  display: flex;
  gap: var(--spacer-sm);
  overflow-x: auto;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md);
  padding-bottom: calc(var(--spacer-sm) + var(--safe-area-bottom));
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-md);
  z-index: var(--z-index-fixed);
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: var(--spacer-sm);
  margin-right: var(--spacer-sm);
}

.quantity {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  min-width: 40rpx;
  text-align: center;
  font-weight: bold;
}

.cart-btn {
  flex: 1;
}

.buy-btn {
  flex: 1;
}
