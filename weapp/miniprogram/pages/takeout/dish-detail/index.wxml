<custom-navbar title="{{dish.name || '菜品详情'}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: 200rpx;">
  
  <!-- 1. 错误状态 -->
  <view wx:if="{{isError}}" class="error-container">
    <t-empty icon="info-circle" description="{{errorMsg}}" />
    <t-button theme="primary" size="small" bindtap="loadDishDetail" style="margin-top: 24rpx;" shape="round">重新加载</t-button>
  </view>

  <!-- 2. 骨架屏状态 (App Shell with Skeleton) -->
  <view wx:elif="{{loading && !dish}}" class="skeleton-content">
    <view class="skeleton-swiper skeleton-shimmer"></view>
    <view class="card skeleton-info">
      <view class="skeleton-text skeleton-shimmer" style="width: 60%; height: 48rpx;"></view>
      <view class="skeleton-text skeleton-shimmer" style="width: 30%; height: 36rpx;"></view>
      <view class="skeleton-text skeleton-shimmer" style="width: 45%; height: 28rpx;"></view>
    </view>
    <view class="card skeleton-specs">
      <view class="skeleton-text skeleton-shimmer" style="width: 25%; height: 32rpx; margin-bottom: 24rpx;"></view>
      <view style="display: flex; gap: 20rpx;">
        <view class="skeleton-btn skeleton-shimmer" style="width: 120rpx; height: 60rpx; border-radius: 30rpx;"></view>
        <view class="skeleton-btn skeleton-shimmer" style="width: 120rpx; height: 60rpx; border-radius: 30rpx;"></view>
      </view>
    </view>
    <view class="card skeleton-desc">
      <view class="skeleton-text skeleton-shimmer" style="width: 25%; height: 32rpx; margin-bottom: 20rpx;"></view>
      <view class="skeleton-text skeleton-shimmer" style="width: 90%; height: 24rpx; margin-bottom: 12rpx;"></view>
      <view class="skeleton-text skeleton-shimmer" style="width: 80%; height: 24rpx;"></view>
    </view>
  </view>

  <!-- 3. 正常数据展示 -->
  <view wx:elif="{{dish}}" class="detail-content">
    <!-- 图片轮播 -->
    <view class="swiper-container">
      <swiper class="image-swiper" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff" bindchange="onImageChange">
        <swiper-item wx:for="{{dish.images}}" wx:key="*this">
          <t-image class="dish-image" src="{{item}}" mode="aspectFill" lazy />
        </swiper-item>
      </swiper>
      <view class="image-indicator">{{currentImageIndex + 1}} / {{dish.images.length}}</view>
    </view>

    <!-- 基本信息 -->
    <view class="info-section card">
      <view class="shop-dish-name">{{dish.name}}</view>
      <view class="price-row">
        <text class="price">¥{{dish.priceDisplay}}</text>
        <text wx:if="{{dish.originalPriceDisplay && dish.originalPriceDisplay !== dish.priceDisplay}}" class="original-price">¥{{dish.originalPriceDisplay}}</text>
      </view>
      <view class="tags-row" wx:if="{{dish.tags.length > 0 || dish.is_premade}}">
        <t-tag wx:if="{{dish.is_premade}}" theme="danger" variant="dark" size="small">预订款</t-tag>
        <t-tag wx:for="{{dish.tags}}" wx:key="*this" theme="primary" variant="dark" size="small">{{item}}</t-tag>
      </view>
      <view class="meta-row">
        <text class="sales">月销 {{dish.month_sales}}</text>
        <text class="separator" wx:if="{{dish.distance_km_display}}">|</text>
        <text class="distance" wx:if="{{dish.distance_km_display}}">距离 {{dish.distance_km_display}}</text>
      </view>
    </view>

    <!-- 规格选择 -->
    <view class="spec-section card" wx:if="{{dish.spec_groups && dish.spec_groups.length > 0}}">
      <view class="spec-group" wx:for="{{dish.spec_groups}}" wx:for-item="group" wx:key="id">
        <view class="section-title">{{group.name}}</view>
        <view class="spec-options">
          <t-tag 
            wx:for="{{group.specs}}" 
            wx:for-item="spec" 
            wx:key="id"
            class="spec-tag"
            variant="{{selectedSpecs[group.id] === spec.id ? 'dark' : 'light-outline'}}"
            theme="primary"
            size="medium"
            data-group-id="{{group.id}}"
            data-spec-id="{{spec.id}}"
            bind:tap="onSpecTap"
          >
            {{spec.name}} <text wx:if="{{spec.priceDiffDisplay}}" style="margin-left: 4rpx;">+¥{{spec.priceDiffDisplay}}</text>
          </t-tag>
        </view>
      </view>
    </view>

    <!-- 菜品详情 -->
    <view class="description-section card" wx:if="{{dish.description}}">
      <view class="section-title">菜品详情</view>
      <text class="description">{{dish.description}}</text>
    </view>

    <!-- 商家信息 -->
    <view class="shop-section card" bindtap="onShopTap">
      <view class="shop-section-content">
        <view class="shop-info">
          <t-icon name="shop" size="32rpx" color="var(--td-text-color-secondary)" />
          <text class="shop-name">{{dish.shop_name}}</text>
        </view>
        <t-icon name="chevron-right" size="40rpx" color="var(--td-text-color-placeholder)" />
      </view>
    </view>
  </view>
</view>

<!-- 底部操作栏 (App Shell) -->
<view wx:if="{{!isError}}" class="bottom-bar">
  <block wx:if="{{!loading && dish}}">
    <view class="quantity-control">
      <t-button 
        size="small" 
        icon="remove" 
        shape="circle"
        theme="primary"
        data-type="minus" 
        bindtap="onQuantityChange" 
      />
      <text class="quantity">{{quantity}}</text>
      <t-button 
        size="small" 
        icon="add" 
        shape="circle" 
        theme="primary" 
        data-type="plus" 
        bindtap="onQuantityChange" 
      />
    </view>
    <view class="btn-group">
      <t-button class="cart-btn" theme="primary" shape="round" bindtap="onAddToCart">加入购物车</t-button>
      <t-button class="buy-btn" theme="primary" shape="round" bindtap="onBuyNow">立即购买</t-button>
    </view>
  </block>
  <view wx:else class="bottom-bar-skeleton">
    <view class="skeleton-rect skeleton-shimmer" style="width: 180rpx; height: 60rpx; border-radius: 30rpx;"></view>
    <view class="skeleton-rect skeleton-shimmer" style="width: 400rpx; height: 80rpx; border-radius: 40rpx;"></view>
  </view>
</view>
