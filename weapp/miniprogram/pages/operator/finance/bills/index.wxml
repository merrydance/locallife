<custom-navbar title="佣金账单" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: var(--spacer-lg);">
  <view wx:if="{{initialLoading}}" class="page-content">
    <t-loading theme="circular" size="40rpx" text="加载佣金账单中..." vertical />
  </view>

  <view wx:elif="{{initialError}}" class="page-content">
    <t-empty icon="error-circle" description="{{initialErrorMessage || '佣金账单加载失败，请重试'}}" />
    <t-button theme="primary" bind:tap="onRetry">重试</t-button>
  </view>

  <view wx:else class="page-content">
    <t-cell-group>
      <t-cell title="区间佣金" note="{{summary.totalCommissionText}}" />
      <t-cell title="区域 GMV" note="{{summary.totalGmvText}}" />
      <t-cell title="区域订单" note="{{summary.totalOrdersText}}" />
      <t-cell title="账单区间" note="{{summary.rangeLabel}}" arrow bind:tap="onOpenRangePicker" />
    </t-cell-group>

    <view class="quick-range-row">
      <t-button
        wx:for="{{quickRanges}}"
        wx:key="id"
        size="small"
        theme="{{item.active ? 'primary' : 'default'}}"
        variant="{{item.active ? 'base' : 'outline'}}"
        data-range="{{item.id}}"
        disabled="{{loadingBills}}"
        bind:tap="onUseQuickRange"
      >{{item.label}}</t-button>
    </view>

    <t-cell-group wx:if="{{refreshErrorMessage}}">
      <t-cell title="账单同步失败" note="{{refreshErrorMessage}}">
        <view slot="right-icon">
          <t-button size="extra-small" theme="primary" variant="text" loading="{{loadingBills}}" bind:tap="onRetry">重试</t-button>
        </view>
      </t-cell>
    </t-cell-group>

    <t-empty wx:if="{{!rows.length}}" icon="info-circle" description="当前区间暂无佣金账单" />
    <t-cell-group wx:else>
      <t-cell
        wx:for="{{rows}}"
        wx:key="id"
        title="{{item.date}}"
        description="GMV {{item.totalGmvText}} · 订单 {{item.orderCountText}}"
        note="{{item.commissionText}}"
      >
        <view slot="right-icon">
          <t-tag theme="primary" size="small">{{item.commissionRateText}}</t-tag>
        </view>
      </t-cell>
    </t-cell-group>

    <t-button wx:if="{{hasMore}}" theme="default" loading="{{loadingBills}}" bind:tap="onLoadMore">加载更多</t-button>
  </view>

  <t-calendar
    title="选择账单区间"
    type="range"
    visible="{{rangePickerVisible}}"
    value="{{rangePickerValue}}"
    minDate="{{rangePickerMinDate}}"
    maxDate="{{rangePickerMaxDate}}"
    confirmBtn="确定"
    bind:confirm="onConfirmRangePicker"
    bind:close="onCancelRangePicker"
  />
</view>
