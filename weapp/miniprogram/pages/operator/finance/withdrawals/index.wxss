.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.withdrawal-scroll {
  flex: 1;
  min-height: 0;
  height: 100%;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: var(--spacer-sm) 0 var(--spacer-lg);
}

.no-more-text {
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-xs);
}
