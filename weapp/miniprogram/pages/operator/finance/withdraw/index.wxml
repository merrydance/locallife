<custom-navbar title="财务概览" show-back="{{true}}" bind:navheight="onNavHeight" />

<view class="page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <scroll-view
    class="content"
    scroll-y
    refresher-enabled
    bindrefresherrefresh="onPullDownRefresh"
  >
    <view class="card summary-card">
      <view class="card-title">收入概览</view>

      <view wx:if="{{loadingOverview}}" class="skeleton-wrap">
        <view class="skeleton-line skeleton-lg skeleton-shimmer"></view>
        <view class="skeleton-row">
          <view class="skeleton-line skeleton-sm skeleton-shimmer"></view>
          <view class="skeleton-line skeleton-sm skeleton-shimmer"></view>
        </view>
      </view>

      <view wx:elif="{{loadError}}" class="state-wrap">
        <t-empty icon="info-circle" description="{{loadError}}">
          <t-button slot="action" theme="primary" bindtap="onRetryLoad">重试</t-button>
        </t-empty>
      </view>

      <view wx:else>
        <view class="balance-label">累计收入（元）</view>
        <view class="balance-value">¥{{formatFen(totalIncomeFen)}}</view>
        <view class="metrics-row">
          <view class="metric-item">
            <text class="metric-label">本月收入</text>
            <text class="metric-value">¥{{formatFen(currentMonthIncomeFen)}}</text>
          </view>
          <view class="metric-divider"></view>
          <view class="metric-item">
            <text class="metric-label">分成比例</text>
            <text class="metric-value">{{formatShareRatio(operatorShareRatio)}}</text>
          </view>
        </view>
        <view class="metrics-row metrics-row--secondary">
          <view class="metric-item">
            <text class="metric-label">本月 GMV</text>
            <text class="metric-value">¥{{formatFen(currentMonthGmvFen)}}</text>
          </view>
          <view class="metric-divider"></view>
          <view class="metric-item">
            <text class="metric-label">本月订单</text>
            <text class="metric-value">{{currentMonthOrders}}</text>
          </view>
        </view>
        <view class="share-ratio">本月平台佣金：¥{{formatFen(currentMonthCommissionFen)}}</view>
      </view>
    </view>

    <view class="card summary-card">
      <view class="card-title">近期佣金明细</view>

      <view wx:if="{{commissionLoading}}" class="skeleton-wrap">
        <view class="skeleton-line skeleton-input skeleton-shimmer"></view>
        <view class="skeleton-line skeleton-input skeleton-shimmer"></view>
      </view>

      <view wx:elif="{{commissionError}}" class="state-wrap">
        <t-empty icon="info-circle" description="{{commissionError}}">
          <t-button slot="action" theme="primary" bindtap="onRetryLoad">重试</t-button>
        </t-empty>
      </view>

      <view wx:elif="{{commissionRows.length === 0}}" class="state-wrap">
        <t-empty description="暂无佣金明细" />
      </view>

      <view wx:else class="commission-list">
        <view wx:for="{{commissionRows}}" wx:key="date" class="commission-item">
          <view class="commission-header">
            <text class="commission-date">{{item.date}}</text>
            <text class="commission-value">¥{{formatFen(item.total_commission_fen)}}</text>
          </view>
          <view class="commission-meta">
            <text>订单 {{item.order_count}}</text>
            <text>GMV ¥{{formatFen(item.total_gmv_fen)}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="safe-bottom"></view>
  </scroll-view>
</view>
