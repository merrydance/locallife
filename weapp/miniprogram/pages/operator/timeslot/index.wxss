.page-container {
  height: 100vh;
  background: var(--td-bg-color-page);
  overflow: hidden;
}

.rules-content {
  height: 100%;
}

.content-inner {
  padding: var(--spacer-md);
}

.welcome-header {
  margin-bottom: var(--spacer-md);
}

.title {
  font-size: var(--font-size-heading);
  color: var(--td-text-color-primary);
  font-weight: 600;
  margin-bottom: var(--spacer-xxs);
}

.subtitle {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.section-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.notice-card {
  background: rgba(0, 82, 217, 0.06);
}

.notice-title {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
  margin-bottom: var(--spacer-xxs);
}

.notice-text {
  font-size: var(--font-size-xs);
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.status-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.skeleton-item {
  height: 88rpx;
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-secondarycontainer);
  margin-bottom: var(--spacer-sm);
}

.skeleton-item:last-child {
  margin-bottom: 0;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-sm);
}

.summary-title {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.rules-list {
  margin-top: var(--spacer-sm);
}

.rule-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: flex-start;
}

.rule-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  background: var(--td-bg-color-secondarycontainer);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacer-sm);
  flex-shrink: 0;
}

.rule-info {
  flex: 1;
}

.rule-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-xs);
}

.name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  font-weight: 600;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-xs);
}

.meta-label {
  min-width: 120rpx;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.meta-value {
  flex: 1;
  text-align: right;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-primary);
}

.actions {
  margin-top: var(--spacer-xs);
  display: flex;
  justify-content: flex-end;
}

.days-select {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-xxs);
}

.day-tag {
  width: 76rpx;
  height: 60rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--td-component-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  background: var(--td-bg-color-container);
}

.day-tag.active {
  color: var(--td-brand-color);
  border-color: var(--td-brand-color);
  background: var(--td-bg-color-secondarycontainer);
}

.dialog-content {
  padding: var(--spacer-xs) 0;
}

.form-item-col {
  margin-top: var(--spacer-sm);
}

.label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
  margin-bottom: var(--spacer-xs);
}
