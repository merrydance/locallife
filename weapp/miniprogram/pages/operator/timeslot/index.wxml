<custom-navbar title="时段系数配置" show-back="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <scroll-view scroll-y class="rules-content">
    <view class="content-inner">
      <view class="welcome-header">
        <view class="title">时段系数配置</view>
        <view class="subtitle">当前区域：{{selectedRegionName || '未命名区域'}}，保存后立即生效。已有时段如需调整，请删除后重建。</view>
      </view>

      <view class="section-card">
        <view class="meta-row">
          <text class="meta-label">配置区域</text>
          <text class="meta-value">{{selectedRegionName || '未命名区域'}}</text>
        </view>
      </view>

      <view wx:if="{{initialLoading}}" class="section-card">
        <view wx:for="{{3}}" wx:key="index" class="skeleton-item"></view>
      </view>

      <view wx:elif="{{error}}" class="section-card status-wrap">
        <t-empty icon="error-circle" description="{{error}}">
          <t-button slot="action" theme="primary" bind:tap="onRetry">重试</t-button>
        </t-empty>
      </view>

      <view wx:else>
        <view class="title-row">
          <text class="summary-title">时段系数列表</text>
          <t-button size="small" theme="primary" bind:tap="onAddPeak">新增时段</t-button>
        </view>

        <view class="rules-list" wx:if="{{peakConfigs.length > 0}}">
          <view class="rule-card" wx:for="{{peakConfigs}}" wx:key="id">
            <view class="rule-icon">
              <t-icon name="time" size="48rpx" color="var(--td-brand-color)" />
            </view>

            <view class="rule-info">
              <view class="rule-top">
                <text class="name">{{item.start_time}} - {{item.end_time}}</text>
                <t-tag theme="success" variant="dark" size="small">生效中</t-tag>
              </view>

              <view class="meta-row">
                <text class="meta-label">生效日期</text>
                <text class="meta-value">周{{item.daysText}}</text>
              </view>
              <view class="meta-row">
                <text class="meta-label">时段系数</text>
                <text class="meta-value">{{item.coefficient}}x</text>
              </view>

              <view class="actions">
                <t-button
                  theme="danger"
                  size="small"
                  icon="delete"
                  bind:tap="onDeletePeak"
                  data-id="{{item.id}}"
                >删除</t-button>
              </view>
            </view>
          </view>
        </view>

        <view wx:else class="section-card status-wrap">
          <t-empty description="该区域暂无时段系数配置" />
        </view>
      </view>
    </view>
  </scroll-view>

  <t-dialog
    visible="{{showPeakModal}}"
    title="新增时段系数"
    confirm-btn="{{ { content: '保存配置', theme: 'primary', loading: saving } }}"
    cancel-btn="取消"
    bind:confirm="onSavePeak"
    bind:cancel="onClosePeakModal"
  >
    <view slot="content" class="dialog-content">
      <t-cell title="开始时间" note="{{peakForm.startTime}}" arrow bind:tap="showPeakStartTimePicker" />
      <t-cell title="结束时间" note="{{peakForm.endTime}}" arrow bind:tap="showPeakEndTimePicker" />

      <t-input
        label="时段系数"
        placeholder="1.50"
        suffix="x"
        type="digit"
        value="{{peakForm.coefficient}}"
        data-field="coefficient"
        bind:change="onPeakFormChange"
      />

      <view class="form-item-col">
        <text class="label">生效日期</text>
        <t-checkbox-group value="{{peakForm.days}}" bind:change="onDaysChange">
          <view class="days-select">
            <t-checkbox
              wx:for="{{daysOptions}}"
              wx:key="value"
              value="{{item.value}}"
              label="{{item.label}}"
            />
          </view>
        </t-checkbox-group>
      </view>
    </view>
  </t-dialog>

  <t-date-time-picker
    title="选择开始时间"
    visible="{{peakStartTimePickerVisible}}"
    mode="time"
    format="HH:mm"
    defaultValue="{{peakForm.startTime}}"
    bind:confirm="onPeakStartTimeConfirm"
    bind:cancel="hidePeakStartTimePicker"
  />

  <t-date-time-picker
    title="选择结束时间"
    visible="{{peakEndTimePickerVisible}}"
    mode="time"
    format="HH:mm"
    defaultValue="{{peakForm.endTime}}"
    bind:confirm="onPeakEndTimeConfirm"
    bind:cancel="hidePeakEndTimePicker"
  />
</view>
