.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.content {
  padding: 0;
}

.region-list {
  padding-bottom: calc(var(--spacer-xl) + env(safe-area-inset-bottom));
}

.empty-container,
.error-container {
  padding-top: var(--spacer-xl);
}

.list-skeleton-item {
  margin-bottom: var(--spacer-sm);
}
