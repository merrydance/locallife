<custom-navbar title="区域配置中心" showBack="{{true}}" bind:navheight="onNavHeight" />
<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <view class="content">
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <card-skeleton />
        <view style="height: 20rpx;"></view>
        <card-skeleton />
      </view>

      <view wx:else class="animate-fade-in">
        <view class="hero-card">
          <view class="hero-title">区域配置中心</view>
          <view class="hero-subtitle">当前区域：{{regionName || ('ID: ' + regionId)}}</view>
          <view class="hero-desc">这里仅承载配置摘要与分流。基础配送费和峰时时段分别在独立页面维护，避免多页重复改同一份规则。</view>
        </view>

        <view class="section-card">
          <view class="section-header">
            <view>
              <view class="section-title">基础配送费</view>
              <view class="section-subtitle">基础计费、超距规则、货值费率统一在这里维护</view>
            </view>
            <t-button size="small" theme="primary" shape="round" bind:tap="onOpenDeliveryFee">去配置</t-button>
          </view>

          <view class="summary-grid">
            <view class="summary-item">
              <text class="summary-label">基础配送费</text>
              <text class="summary-value">{{feeSummary.baseFee}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">基础距离</text>
              <text class="summary-value">{{feeSummary.baseDistance}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">超距每公里</text>
              <text class="summary-value">{{feeSummary.extraFeePerKm}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">货值费率</text>
              <text class="summary-value">{{feeSummary.valueRatio}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">最低运费</text>
              <text class="summary-value">{{feeSummary.minFee}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">最高运费</text>
              <text class="summary-value">{{feeSummary.maxFee}}</text>
            </view>
          </view>

          <view class="status-line">{{feeSummary.statusText}}</view>
        </view>

        <view class="section-card">
          <view class="section-header">
            <view>
              <view class="section-title">峰时时段</view>
              <view class="section-subtitle">时段系数单独维护，和基础配送费分离</view>
            </view>
            <t-button size="small" theme="primary" shape="round" bind:tap="onOpenTimeslot">去管理</t-button>
          </view>

          <view class="summary-grid summary-grid--double">
            <view class="summary-item">
              <text class="summary-label">配置数量</text>
              <text class="summary-value">{{peakSummary.count}} 条</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">覆盖日期</text>
              <text class="summary-value">{{peakSummary.daysText}}</text>
            </view>
          </view>

          <view class="status-note">{{peakSummary.note}}</view>
        </view>

        <view class="section-card boundary-card">
          <view class="section-title">职责边界</view>
          <view class="boundary-item">
            <t-icon name="money" size="32rpx" color="#0052D9" />
            <text>基础配送费页面只处理基础费、超距规则、货值费率和费用边界。</text>
          </view>
          <view class="boundary-item">
            <t-icon name="time" size="32rpx" color="#ED7B2F" />
            <text>峰时时段页面只处理新增、删除和冲突校验，不再与基础配送费重复编辑。</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
