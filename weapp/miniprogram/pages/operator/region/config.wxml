<custom-navbar title="区域配送配置" showBack="{{true}}" bind:navheight="onNavHeight" />
<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <view class="content">

    <!-- Error State -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Skeleton State -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <card-skeleton />
        <view style="height: 20rpx;"></view>
        <card-skeleton />
      </view>

      <!-- Content State -->
      <view wx:else class="animate-fade-in">
        <view class="section">
          <view class="section-title">基础配送配置</view>
          <t-cell-group theme="card">
              <t-input label="基础配送费" placeholder="请输入金额" suffix="元" type="digit" value="{{baseFeeInput}}" data-field="baseFeeInput" bind:change="onInputChange" align="right" />
              <t-input label="基础距离" placeholder="请输入距离" suffix="米" type="number" value="{{baseDistanceInput}}" data-field="baseDistanceInput" bind:change="onInputChange" align="right" />
              <t-input label="超距加价" placeholder="请输入金额" suffix="元/km" type="digit" value="{{extraFeeInput}}" data-field="extraFeeInput" bind:change="onInputChange" align="right" />
                <t-input label="货值费率" placeholder="请输入比例" suffix="%" type="digit" value="{{valueRatioInput}}" data-field="valueRatioInput" bind:change="onInputChange" align="right" />
                <t-input label="最低运费" placeholder="请输入金额" suffix="元" type="digit" value="{{minFeeInput}}" data-field="minFeeInput" bind:change="onInputChange" align="right" />
                <t-input label="最高运费" placeholder="留空表示不限" suffix="元" type="digit" value="{{maxFeeInput}}" data-field="maxFeeInput" bind:change="onInputChange" align="right" />
          </t-cell-group>
          
          <view class="btn-wrapper">
              <t-button theme="primary" block bind:tap="onSaveFeeConfig" shape="round">保存基础配置</t-button>
          </view>
        </view>

        <view class="section">
          <view class="section-header">
              <view class="section-title">特殊/峰时配置</view>
              <t-button size="small" bind:tap="onAddPeak" shape="round">添加</t-button>
          </view>
          
          <view class="peak-list">
              <block wx:for="{{peakConfigs}}" wx:key="id">
                  <view class="peak-item-wrapper">
                  <t-cell title="{{item.start_time}} - {{item.end_time}}" description="周{{tools.formatDays(item.days_of_week)}} | 系数 {{item.coefficient}}x">
                  <view slot="right-icon" bind:tap="onDeletePeak" data-id="{{item.id}}">
                    <t-icon name="delete" size="48rpx" color="#d9001b" />
                  </view>
                      </t-cell>
                  </view>
              </block>
              <t-empty wx:if="{{peakConfigs.length === 0}}" icon="info-circle-filled" description="暂无特殊时段配置" />
          </view>
        </view>
      </view>
    </block>
  </view>
  
  <!-- Modal -->
  <t-popup visible="{{showPeakModal}}" placement="bottom" bind:visible-change="onClosePeakModal">
      <view class="popup-content">
          <view class="popup-header">
              <view class="popup-title">添加高峰时段</view>
              <t-icon name="close" size="48rpx" bind:tap="onClosePeakModal" />
          </view>
          <view class="popup-body">
              <picker mode="time" value="{{peakForm.startTime}}" data-field="startTime" bindchange="onPeakFormChange">
                <t-cell title="开始时间" note="{{peakForm.startTime}}" arrow />
              </picker>
              <picker mode="time" value="{{peakForm.endTime}}" data-field="endTime" bindchange="onPeakFormChange">
                <t-cell title="结束时间" note="{{peakForm.endTime}}" arrow />
              </picker>
              
              <t-input label="时段系数" placeholder="1.50" suffix="x" type="digit" value="{{peakForm.coefficient}}" data-field="coefficient" bind:change="onPeakFormChange"/>
              
              <view class="form-item-col">
                  <text class="label">生效日期</text>
                  <view class="days-select">
                    <view 
                        wx:for="{{daysOptions}}" 
                        wx:key="value" 
                        class="day-tag {{tools.includes(peakForm.days, item.value) ? 'active' : ''}}"
                        bindtap="onDayToggle"
                        data-day="{{item.value}}"
                    >
                        {{item.label}}
                    </view>
                  </view>
              </view>
          </view>
          <view class="popup-footer">
              <t-button theme="primary" block bind:tap="onSavePeak" shape="round">确定</t-button>
          </view>
      </view>
  </t-popup>
</view>

<wxs module="tools">
module.exports = {
  formatDays: function(days) {
    if (!days) return '';
    var map = ['日','一','二','三','四','五','六'];
    return days.map(function(d){ return map[d] }).join('、');
  },
  includes: function(arr, val) {
      if (!arr) return false;
      return arr.indexOf(val) > -1;
  }
}
</wxs>
