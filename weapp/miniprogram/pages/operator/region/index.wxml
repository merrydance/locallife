<custom-navbar title="{{pageTitle}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <view class="content">
    <!-- 错误状态 -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Loading (Skeleton) -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <view class="list-skeleton-item" wx:for="{{5}}" wx:key="index">
          <card-skeleton />
        </view>
      </view>

      <view wx:else class="animate-fade-in">
        <!-- 头部说明 -->
        <view class="header-section">
          <view class="title">{{pageTitle}}</view>
          <view class="subtitle">{{subtitle}}</view>
        </view>

        <!-- 区域列表 -->
        <view class="region-list" wx:if="{{regions.length > 0}}">
          <t-cell-group theme="card">
            <t-cell
              wx:for="{{regions}}"
              wx:key="id"
              title="{{item.name}}"
              description="{{target === 'rules' ? '点击进入该区县规则配置' : (item.level + '级区域 | 代码: ' + item.code)}}"
              hover
              arrow
              bind:click="onRegionClick"
              data-id="{{item.id}}"
              data-name="{{item.name}}"
            >
              <view slot="note" class="status-tag {{item.status}}" wx:if="{{target !== 'rules'}}">
                  <t-tag variant="light" theme="{{item.status === 'active' ? 'primary' : 'default'}}">{{item.status === 'active' ? '运营中' : '已停用'}}</t-tag>
              </view>
            </t-cell>
          </t-cell-group>
          
          <!-- 加载更多 -->
          <view class="load-more" wx:if="{{hasMore || loadingMore}}">
            <t-loading theme="circular" size="40rpx" text="加载中..." wx:if="{{loadingMore}}" />
            <text class="no-more" wx:elif="{{!hasMore && regions.length > 0}}">没有更多区域了</text>
          </view>
        </view>

        <!-- 空状态 -->
        <view wx:else class="empty-container">
          <t-empty icon="info-circle" description="暂无负责区域" />
        </view>
      </view>
    </block>
  </view>

  <!-- 浮动操作按钮 -->
  <t-fab icon="add" bind:click="onAddRegion" aria-label="添加区域" wx:if="{{!initialLoading && !error && target !== 'rules'}}"></t-fab>
</view>

