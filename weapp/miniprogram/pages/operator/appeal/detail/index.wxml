<custom-navbar title="申诉详情" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <!-- 错误状态 -->
  <view wx:if="{{error && !initialLoading}}" class="error-container">
    <t-empty icon="info-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
    </t-empty>
  </view>

  <block wx:else>
    <!-- Loading (Skeleton) -->
    <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
      <card-skeleton t-class="detail-skeleton" />
      <card-skeleton t-class="input-skeleton" />
    </view>

    <view wx:elif="{{appeal}}" class="animate-fade-in">
      <view class="card">
        <view class="section-title">申诉信息</view>
        <view class="row">
          <text class="label">申诉类型</text>
          <text class="value">{{appeal.reason || '未指定'}}</text>
        </view>
        <view class="row">
          <text class="label">申诉状态</text>
          <t-tag theme="{{appeal.status === 'pending' ? 'warning' : ((appeal.status === 'approved' || appeal.status === 'compensated') ? 'success' : 'danger')}}" size="small" variant="dark">
            {{appeal.status_label}}
          </t-tag>
        </view>
        <view class="row">
          <text class="label">申请时间</text>
          <text class="value">{{appeal.created_at}}</text>
        </view>
        <view class="row">
          <text class="label">关联单号</text>
          <text class="value">{{appeal.related_order_view ? appeal.related_order_view.order_no : (appeal.claim_id || '无')}}</text>
        </view>
        <view class="row">
          <text class="label">诉求金额</text>
          <text class="value">{{appeal.claim_amount_display}}</text>
        </view>
        <view class="row" wx:if="{{appeal.compensation_amount}}">
          <text class="label">已赔付金额</text>
          <text class="value">{{appeal.compensation_amount_display}}</text>
        </view>
        <view class="divider"></view>
        <view class="row-vertical">
          <text class="label">申诉说明</text>
          <text class="value content">{{appeal.reason || '无详细说明'}}</text>
        </view>
      </view>

      <view class="card" wx:if="{{appeal.claim_description || appeal.claim_type}}">
        <view class="section-title">索赔信息</view>
        <view class="row" wx:if="{{appeal.claim_type}}"><text class="label">索赔类型</text><text class="value">{{appeal.claim_type}}</text></view>
        <view class="row" wx:if="{{appeal.claim_status}}"><text class="label">索赔状态</text><text class="value">{{appeal.claim_status}}</text></view>
        <view class="row" wx:if="{{appeal.claim_approved_amount}}"><text class="label">已核金额</text><text class="value">{{appeal.approved_amount_display}}</text></view>
        <view class="row-vertical" wx:if="{{appeal.claim_description}}">
          <text class="label">索赔说明</text>
          <text class="value content">{{appeal.claim_description}}</text>
        </view>
      </view>

      <view class="card" wx:if="{{appeal.related_order_view}}">
        <view class="section-title">关联订单</view>
        <view class="row"><text class="label">订单号</text><text class="value">{{appeal.related_order_view.order_no}}</text></view>
        <view class="row"><text class="label">商户</text><text class="value">{{appeal.related_order_view.merchant_name}}</text></view>
        <view class="row"><text class="label">骑手</text><text class="value">{{appeal.related_order_view.rider_name}}</text></view>
        <view class="row"><text class="label">订单金额</text><text class="value">{{appeal.related_order_view.order_amount_display}}</text></view>
        <view class="row"><text class="label">订单状态</text><text class="value">{{appeal.related_order_view.status}}</text></view>
      </view>

      <view class="card" wx:if="{{appeal.evidence_files_view.length > 0}}">
        <view class="section-title">证据材料</view>
        <view class="images-grid">
          <image wx:for="{{appeal.evidence_files_view}}" wx:key="*this" class="img" src="{{item}}" mode="aspectFill" bindtap="onPreviewEvidence" data-url="{{item}}" />
        </view>
      </view>

      <view class="card" wx:if="{{appeal.timeline_view.length > 0}}">
        <view class="section-title">处理时间线</view>
        <view class="timeline-list">
          <view wx:for="{{appeal.timeline_view}}" wx:key="timestamp" class="timeline-item">
            <view class="timeline-dot"></view>
            <view class="timeline-content">
              <view class="timeline-header">
                <text class="timeline-title">{{item.title}}</text>
                <text class="timeline-time">{{item.timestamp}}</text>
              </view>
              <text class="timeline-operator">{{item.operator}}</text>
              <text wx:if="{{item.notes}}" class="timeline-notes">{{item.notes}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="card" wx:if="{{recovery}}">
        <view class="section-title">追偿单</view>
        <view class="row">
          <text class="label">追偿状态</text>
          <text class="value">{{recovery.status}}</text>
        </view>
        <view class="row">
          <text class="label">追偿金额</text>
          <text class="value">{{recovery.recovery_amount}}分</text>
        </view>
        <view class="row">
          <text class="label">到期时间</text>
          <text class="value">{{recovery.due_at}}</text>
        </view>
        <t-button
          wx:if="{{recovery.status === 'pending' || recovery.status === 'overdue'}}"
          theme="primary"
          block
          loading="{{recoverySubmitting}}"
          bindtap="onWaiveRecovery"
         shape="round">核销追偿</t-button>
      </view>

      <view class="card input-card" wx:if="{{appeal.status === 'pending'}}">
        <view class="section-title">审核处理</view>
        <t-input
          label="补偿金额(元)"
          type="digit"
          value="{{compensationAmount}}"
          placeholder="通过时必填，不填则使用索赔金额"
          bind:change="onCompensationInput"
        />
        <t-textarea 
          label="审核备注" 
          placeholder="请输入处理说明（必填，至少5个字符）" 
          value="{{replyContent}}" 
          bind:change="onInput" 
          bordered 
          maxlength="200" 
          indicator
        />
      </view>
      
      <view class="footer-actions" wx:if="{{appeal.status === 'pending'}}">
        <t-button theme="danger" block bind:tap="onReject" loading="{{submitting}}" shape="round">驳回申诉</t-button>
        <t-button theme="primary" block bind:tap="onApprove" loading="{{submitting}}" shape="round">审核通过</t-button>
      </view>
    </view>
  </block>

  <t-dialog
    visible="{{showRejectDialog}}"
    title="确认驳回"
    content="确认要驳回此申诉吗？驳回后不可撤销。"
    confirm-btn="确认驳回"
    cancel-btn="取消"
    bind:confirm="onRejectConfirm"
    bind:cancel="onRejectCancel"
  />
</view>
