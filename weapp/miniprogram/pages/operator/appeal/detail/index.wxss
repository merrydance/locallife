.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-left: var(--spacer-md);
  padding-right: var(--spacer-md);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #0052d9;
  line-height: 1;
}

.row {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-vertical {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
}

.row-vertical .label {
  margin-bottom: 12rpx;
}

.label {
  color: #999;
  font-size: 28rpx;
}

.value {
  color: #333;
  font-size: 28rpx;
  text-align: right;
}

.value.content {
  text-align: left;
  line-height: 1.6;
  color: #444;
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 12rpx;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 32rpx 0;
}

.images-section {
  margin-top: 32rpx;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.img {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
}

.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.footer-actions t-button {
  flex: 1;
}

.timeline-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0052d9;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.timeline-content {
  flex: 1;
  border-left: 1rpx solid #e7e7e7;
  padding-left: 20rpx;
  padding-bottom: 8rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.timeline-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.timeline-time,
.timeline-operator,
.timeline-notes {
  font-size: 24rpx;
  color: #666;
}

.timeline-notes {
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.skeleton-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-skeleton {
  height: 600rpx;
}

.input-skeleton {
  height: 300rpx;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
