<custom-navbar title="申诉处理" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <t-tabs value="{{status}}" bind:change="onTabChange" t-class="sticky-tabs">
    <t-tab-panel label="待处理" value="pending" />
    <t-tab-panel label="已处理" value="processed" />
  </t-tabs>

  <view class="content">
    <!-- 错误状态 -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Loading (Skeleton) -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <list-skeleton row="5" />
      </view>

      <view wx:else class="animate-fade-in">
        <view class="list" wx:if="{{appeals.length > 0}}">
          <view class="card" wx:for="{{appeals}}" wx:key="id" bind:tap="onDetail" data-id="{{item.id}}">
            <view class="card-header">
              <text class="type">{{item.reason || '申诉内容'}}</text>
              <text class="time">{{item.created_at}}</text>
            </view>
            <view class="card-footer">
              <text class="user">用户ID: {{item.user_id}}</text>
              <t-tag theme="{{item.status === 'pending' ? 'warning' : 'success'}}" size="small" variant="light-outline">
                {{item.status === 'pending' ? '待处理' : '已完成'}}
              </t-tag>
            </view>
          </view>
        </view>
        
        <t-empty wx:else icon="info-circle" description="暂无申诉数据" />
      </view>
    </block>
  </view>
</view>
