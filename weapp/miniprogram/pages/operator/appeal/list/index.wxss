.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  padding-bottom: env(safe-area-inset-bottom);
}

.sticky-tabs {
  position: sticky;
  top: 0;
  z-index: 100;
}

.content {
  padding: 0;
}

.list {
  padding: var(--spacer-md);
}

.card {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md); /* Standard card padding is spacer-md (24rpx), was 32rpx. If 32rpx intended, use spacer-lg. Sticking to standard md. */
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm, 0 4rpx 12rpx rgba(0,0,0,0.05));
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacer-sm);
}

.type {
  font-size: 30rpx; /* Custom size/heading */
  font-weight: 600;
  color: var(--td-text-color-primary, #333);
  flex: 1;
  margin-right: var(--spacer-sm);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.time {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder, #999);
  white-space: nowrap;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--spacer-sm);
}

.card-meta {
  display: flex;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-bottom: var(--spacer-sm);
}

.meta-text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary, #666);
}

.user {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder, #999);
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.skeleton-container {
  padding: var(--spacer-md);
}

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-bottom: var(--spacer-md);
}

.load-text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder, #999);
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
