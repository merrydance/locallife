.page-container {
  min-height: 100vh;
  background: #F6F6F6;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.automation-list {
  padding: 24rpx;
}

.automation-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

@media (min-width: 1024rpx) {
  .automation-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1440rpx) {
  .automation-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.auto-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.auto-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  display: block;
}

.detail-box {
  background: #F9F9F9;
  padding: 16rpx;
  border-radius: 8rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 24rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #999;
  width: 120rpx;
}

.value {
  color: #333;
  font-family: monospace;
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.skeleton-container {
  padding: 24rpx;
}

.automation-skeleton-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

@media (min-width: 1024rpx) {
  .automation-skeleton-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1440rpx) {
  .automation-skeleton-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.auto-skeleton-item {
  height: 320rpx;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
