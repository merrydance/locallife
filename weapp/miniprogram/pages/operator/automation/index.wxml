<custom-navbar title="自动化配置" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container {{isLargeScreen ? 'large-screen' : ''}}" style="padding-top: {{navBarHeight}}px;">
  <view class="content">
    <!-- 错误状态 -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Loading (Skeleton) -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <view class="automation-skeleton-grid">
          <card-skeleton wx:for="{{4}}" wx:key="index" t-class="auto-skeleton-item" />
        </view>
      </view>

      <view wx:else class="animate-fade-in">
        <view class="automation-list" wx:if="{{automations.length > 0}}">
          <view class="automation-grid">
            <view wx:for="{{automations}}" wx:key="id" class="auto-card">
              <view class="card-header">
                <text class="auto-name">{{item.name}}</text>
                <t-switch 
                  value="{{item.status === 'ACTIVE'}}" 
                  bind:change="onToggleStatus" 
                  data-id="{{item.id}}" 
                  t-class="switch-btn"
                />
              </view>
              
              <text class="desc">{{item.desc}}</text>
              
              <view class="detail-box">
                <view class="detail-row">
                  <text class="label">触发条件:</text>
                  <text class="value">{{item.trigger}}</text>
                </view>
                <view class="detail-row">
                  <text class="label">判断逻辑:</text>
                  <text class="value">{{item.condition}}</text>
                </view>
                <view class="detail-row">
                  <text class="label">执行动作:</text>
                  <text class="value">{{item.action}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        
        <t-empty wx:else icon="info-circle" description="暂无自动化配置" />
      </view>
    </block>
  </view>
</view>
