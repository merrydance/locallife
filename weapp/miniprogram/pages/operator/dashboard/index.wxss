@import "../../../styles/responsive.wxss";

.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.content {
  padding: var(--spacer-md);
}

.stats-grid {
  margin-bottom: var(--spacer-md);
}

.stat-card {
  background-color: var(--td-bg-color-container);
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  box-shadow: var(--shadow-sm, 0 4rpx 12rpx rgba(0,0,0,0.05));
}

.stat-card .label {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary, #666);
}

.stat-card .value {
  font-size: 40rpx; /* Not in tokens exactly, keeping for emphasis */
  font-weight: bold;
  color: var(--td-text-color-primary, #333);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary, #333);
  margin-bottom: var(--spacer-md);
}

.todo-section, .shortcuts-section {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm, 0 4rpx 12rpx rgba(0,0,0,0.05));
}

.approval-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-md) 0;
  border-bottom: 1rpx solid var(--td-border-color, #F0F0F0);
}

.approval-item:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
}

.tag {
  width: fit-content;
}

.item-name {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary, #333);
  font-weight: 500;
}

.item-time {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder, #999);
}

.item-actions {
  display: flex;
  gap: var(--spacer-sm);
}

.shortcuts-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacer-md);
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-md) 0;
}

.shortcut-item text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-primary, #333);
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.skeleton-container {
  padding: var(--spacer-md);
}

.stats-skeleton {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.stat-skeleton-item {
  height: 160rpx;
}

.section-skeleton {
  margin-bottom: var(--spacer-md);
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
