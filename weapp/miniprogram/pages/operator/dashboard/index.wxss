/* Pages/operator/dashboard/index.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  padding: 0 32rpx 64rpx;
  box-sizing: border-box;
}

/* 1. Finance Card (The "Wow" Header) */
.finance-section {
  padding: 24rpx 0;
}

.finance-card {
  background: linear-gradient(135deg, #FF6B58 0%, #FF8D7F 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  color: #FFFFFF;
  box-shadow: 0 16rpx 32rpx rgba(255, 107, 88, 0.3);
  position: relative;
  overflow: hidden;
}

.finance-card::after {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 100rpx;
}

.finance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.balance-title {
  font-size: var(--font-size-sm);
  opacity: 0.9;
}

.withdraw-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 32rpx;
  border-radius: 99rpx;
  font-size: var(--font-size-sm);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(4px);
}

.balance-value {
  font-size: 72rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  font-family: 'DIN Alternate', sans-serif;
}

.income-row {
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  border-radius: 20rpx;
}

.income-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.income-label {
  font-size: var(--font-size-xxs);
  opacity: 0.8;
  margin-bottom: 4rpx;
}

.income-value {
  font-size: var(--font-size-base);
  font-weight: 600;
}

.divider-v {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 32rpx;
}

/* 2. Section Styles */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-top: 32rpx;
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: #333;
  display: flex;
  align-items: center;
}

.badge-custom {
  margin-left: 12rpx;
}

/* 3. Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-item {
  background: var(--td-bg-color-container);
  padding: 32rpx;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.stat-label {
  font-size: var(--font-size-sm);
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  font-family: 'DIN Alternate', sans-serif;
}

/* 4. Todo List */
.approval-list {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.approval-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.approval-item:last-child {
  border-bottom: none;
}

.item-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.type-MERCHANT { background: #0052D9; }
.type-RIDER { background: #ED7B2F; }
.type-APPEAL { background: #E34D59; }

.item-content {
  flex: 1;
}

.item-name {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.item-time {
  font-size: var(--font-size-xxs);
  color: #999;
}

/* 5. Menu Grid */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  background: var(--td-bg-color-container);
  padding: 32rpx;
  border-radius: var(--radius-md);
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.menu-icon-bg {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.menu-item text {
  font-size: var(--font-size-xs);
  color: #666;
}

.color-info { background: rgba(0, 82, 217, 0.1); color: #0052D9; }
.color-warning { background: rgba(237, 123, 47, 0.1); color: #ED7B2F; }
.color-error { background: rgba(227, 77, 89, 0.1); color: #E34D59; }
.color-danger { background: rgba(255, 107, 88, 0.1); color: #FF6B58; }
.color-success { background: rgba(0, 168, 112, 0.1); color: #00A870; }
.color-default { background: rgba(0, 0, 0, 0.05); color: #666; }

/* 6. Rankings */
.ranking-section {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  margin-top: 32rpx;
  padding: 32rpx;
}

.ranking-tabs {
  margin-bottom: 0 !important;
}

.ranking-label {
  font-size: var(--font-size-xxs);
  color: #999;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.ranking-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  color: #999;
  margin-right: 24rpx;
}

.top-1 { color: #FFD700; font-size: 36rpx; }
.top-2 { color: #C0C0C0; font-size: 34rpx; }
.top-3 { color: #CD7F32; font-size: 32rpx; }

.rank-main {
  flex: 1;
}

.rank-name {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: #333;
}

.rank-sub {
  font-size: var(--font-size-xxs);
  color: #999;
}

.rank-val {
  font-weight: bold;
  color: var(--td-brand-color);
  font-family: 'DIN Alternate', sans-serif;
}

/* Animations */
.animate-fade-in {
  animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
