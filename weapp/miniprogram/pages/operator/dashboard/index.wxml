<custom-navbar title="运营中心" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <!-- Loading (Skeleton) -->
  <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
    <view class="skeleton-header-card"></view>
    <view class="stats-skeleton">
      <card-skeleton wx:for="{{4}}" wx:key="index" t-class="stat-skeleton-item" />
    </view>
    <list-skeleton row="3" t-class="section-skeleton" />
  </view>

  <view wx:elif="{{error}}" class="content animate-fade-in">
      <view class="error-container">
        <t-empty icon="info-circle" description="{{error}}">
          <t-button wx:if="{{errorCanRetry}}" slot="action" theme="primary" bindtap="onRetry">重新加载</t-button>
        </t-empty>
      </view>
  </view>

  <view wx:else class="content animate-fade-in">
      
      <!-- 1. 收入概览 -->
      <view class="finance-section">
        <view class="finance-card">
          <view class="finance-header">
            <view class="balance-title">收入概览</view>
            <view wx:if="{{regions.length > 1}}" class="region-pill" bind:tap="onOpenRegionPicker">
              <t-icon name="map" size="26rpx" color="rgba(255,255,255,0.85)" />
              <text class="region-pill-name">{{regions[selectedRegionIdx].name}}</text>
              <t-icon name="chevron-down" size="22rpx" color="rgba(255,255,255,0.85)" />
            </view>
            <view wx:elif="{{regions.length === 1}}" class="region-pill region-pill--static">
              <t-icon name="map" size="26rpx" color="rgba(255,255,255,0.8)" />
              <text class="region-pill-name">{{regions[0].name}}</text>
            </view>
          </view>
          <view class="balance-value">{{finance.total_income_display}}</view>
          <view class="income-row">
            <view class="income-item">
              <text class="income-label">今日收入</text>
              <text class="income-value">+{{stats.today_income_display}}</text>
            </view>
            <view class="divider-v"></view>
            <view class="income-item">
              <text class="income-label">本月收入</text>
              <text class="income-value">{{finance.current_month_income_display}}</text>
            </view>
          </view>
          <view class="finance-actions">
            <navigator url="/pages/operator/finance/withdraw/index" class="finance-link-pill">查看财务概览</navigator>
          </view>
        </view>
      </view>

      <!-- 2. 数据维度切换与核心指标 -->
      <view class="data-section">
        <view class="section-header">
          <view class="section-title">运营概览</view>
          <navigator url="/pages/operator/analytics/index" class="section-link">查看分析</navigator>
          <t-tabs t-class="dimension-tabs" value="{{timeDimension}}" bindchange="onTimeDimensionChange" theme="tag" space-evenly="{{false}}">
            <t-tab-panel label="今日" value="day" />
            <t-tab-panel label="近7天" value="week" />
            <t-tab-panel label="近30天" value="month" />
          </t-tabs>
        </view>

        <view class="stats-grid">
          <view class="stat-item">
            <text class="stat-label">GMV (元)</text>
            <text class="stat-value">{{timeDimension === 'day' ? stats.today_gmv_display : stats.total_gmv_display}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">订单量 (单)</text>
            <text class="stat-value">{{timeDimension === 'day' ? stats.today_orders : stats.total_orders}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">活跃商户</text>
            <text class="stat-value">{{stats.active_merchants}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">活跃骑手</text>
            <text class="stat-value">{{stats.active_riders}}</text>
          </view>
        </view>
      </view>

      <!-- 3. 待办事项 (Critical Actions) -->
      <view class="todo-section" wx:if="{{pending_count > 0}}">
        <view class="section-header">
          <view class="section-title">待办审批 {{pending_count}}</view>
          <view class="view-all" bindtap="onPendingViewAll">查看全部</view>
        </view>
        <view class="approval-list">
          <view wx:for="{{pending_approvals}}" wx:key="id" class="approval-item" bindtap="onPendingTap" data-id="{{item.id}}" data-type="{{item.type}}">
            <view class="item-icon-box type-{{item.type}}">
              <t-icon name="{{item.type === 'MERCHANT' ? 'shop' : 'user-circle'}}" size="32rpx" color="#fff" />
            </view>
            <view class="item-content">
              <view class="item-name">{{item.name}}</view>
              <view class="item-time">申请时间: {{item.time}}</view>
            </view>
            <t-icon name="chevron-right" size="32rpx" color="#BBBBBB" />
          </view>
        </view>
      </view>

      <view class="notification-section">
        <view class="section-header">
          <view class="section-title">待接单提醒</view>
          <view class="view-all" bindtap="onOpenNotifications">查看全部</view>
        </view>
        <view class="notification-card" bindtap="onOpenNotifications">
          <view class="notification-card__head">
            <view class="notification-card__badge">未读 {{notificationSummary.unreadCount}}</view>
            <text wx:if="{{notificationSummary.latestCreatedAt}}" class="notification-card__time">{{notificationSummary.latestCreatedAt}}</text>
          </view>
          <view class="notification-card__title">{{notificationSummary.latestTitle}}</view>
          <view class="notification-card__summary">{{notificationSummary.latestSummary}}</view>
        </view>
      </view>

      <!-- 4. 快捷功能矩阵 (Premium Icons) -->
      <view class="menu-section">
        <view class="section-header">
          <view class="section-title">业务管理</view>
        </view>
        <view class="menu-grid">
          <navigator url="/pages/operator/analytics/index" class="menu-item">
            <view class="menu-icon-bg color-primary">
              <t-icon name="chart-bar" size="48rpx" />
            </view>
            <text>数据分析</text>
          </navigator>
          <navigator url="/pages/operator/merchants/index?region_id={{selectedRegionId}}" class="menu-item">
            <view class="menu-icon-bg color-info">
              <t-icon name="shop" size="48rpx" />
            </view>
            <text>商户管理</text>
          </navigator>
          <navigator url="/pages/operator/riders/index?region_id={{selectedRegionId}}" class="menu-item">
            <view class="menu-icon-bg color-warning">
              <t-icon name="user-circle" size="48rpx" />
            </view>
            <text>骑手管理</text>
          </navigator>
          <navigator url="/pages/operator/region/index" class="menu-item">
            <view class="menu-icon-bg color-error">
              <t-icon name="location" size="48rpx" />
            </view>
            <text>区域配置</text>
          </navigator>
          <navigator url="/pages/operator/safety/report/index" class="menu-item">
            <view class="menu-icon-bg color-danger">
              <t-icon name="error-circle" size="48rpx" />
            </view>
            <text>食安熔断</text>
          </navigator>
          <navigator url="/pages/operator/finance/withdraw/index" class="menu-item">
            <view class="menu-icon-bg color-success">
              <t-icon name="chart-bar" size="48rpx" />
            </view>
            <text>财务概览</text>
          </navigator>
          <navigator url="/pages/operator/notifications/index" class="menu-item">
            <view class="menu-icon-bg color-warning">
              <t-icon name="notification" size="48rpx" />
            </view>
            <text>待接单提醒</text>
          </navigator>
          <navigator url="/pages/operator/rules/index?region_id={{selectedRegionId}}&region_name={{regions[selectedRegionIdx].name}}" class="menu-item">
            <view class="menu-icon-bg color-default">
              <t-icon name="setting" size="48rpx" />
            </view>
            <text>规则配置</text>
          </navigator>
          <navigator url="/pages/operator/region-expansion/index" class="menu-item">
            <view class="menu-icon-bg color-primary">
              <t-icon name="location" size="48rpx" />
            </view>
            <text>申请更多区域</text>
          </navigator>
        </view>
      </view>
      
      <!-- 5. 榜单统计 (Comparison) -->
      <view class="ranking-section">
        <view class="section-header">
          <t-tabs value="{{rankingType}}" bindchange="onRankingTypeChange" theme="tag" t-class="ranking-tabs">
            <t-tab-panel label="商家榜" value="merchant" />
            <t-tab-panel label="骑手榜" value="rider" />
          </t-tabs>
          <view class="ranking-label">{{timeDimension === 'day' ? '今日' : (timeDimension === 'week' ? '本周' : '本月')}}排行</view>
        </view>

        <!-- Merchant Rankings -->
        <view wx:if="{{rankingType === 'merchant'}}" class="ranking-list">
          <t-empty wx:if="{{merchantRankings.length === 0}}" description="暂无排行数据" />
          <view wx:for="{{merchantRankings}}" wx:key="merchant_id" class="ranking-item">
            <view class="rank-num {{index < 3 ? 'top-' + (index + 1) : ''}}">{{index + 1}}</view>
            <view class="rank-main">
              <view class="rank-name">{{item.merchant_name}}</view>
              <view class="rank-sub">订单 {{item.order_count}} | 佣金 ¥{{item.total_commission / 100}}</view>
            </view>
            <view class="rank-val">¥{{item.total_sales / 100}}</view>
          </view>
        </view>

        <!-- Rider Rankings -->
        <view wx:if="{{rankingType === 'rider'}}" class="ranking-list">
          <t-empty wx:if="{{riderRankings.length === 0}}" description="暂无排行数据" />
          <view wx:for="{{riderRankings}}" wx:key="rider_id" class="ranking-item">
            <view class="rank-num {{index < 3 ? 'top-' + (index + 1) : ''}}">{{index + 1}}</view>
            <view class="rank-main">
              <view class="rank-name">{{item.rider_name}}</view>
              <view class="rank-sub">配送 {{item.delivery_count}}单 | 准时率 {{item.completion_rate}}%</view>
            </view>
            <view class="rank-val">¥{{item.total_earnings / 100}}</view>
          </view>
        </view>
      </view>

      <view class="safe-bottom"></view>
  </view>

  <t-picker
    visible="{{regionPickerVisible}}"
    value="{{[selectedRegionValue]}}"
    title="选择区域"
    cancelBtn="取消"
    confirmBtn="确认"
    bind:confirm="onRegionConfirm"
    bind:cancel="onCloseRegionPicker"
  >
    <t-picker-item options="{{regionPickerOptions}}" />
  </t-picker>
</view>
