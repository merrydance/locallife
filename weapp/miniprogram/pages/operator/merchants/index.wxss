.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.merchants-list {
  padding: var(--spacer-md);
}

.merchants-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--spacer-md);
}

@media (min-width: 1024rpx) {
  .merchants-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1440rpx) {
  .merchants-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.merchant-card {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm, 0 4rpx 12rpx rgba(0,0,0,0.05));
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-sm);
  padding-bottom: var(--spacer-sm);
  border-bottom: 1rpx solid var(--td-border-color, #F0F0F0);
}

.merchant-name {
  font-size: 30rpx; /* Keeping custom size or use --font-size-heading (32) */
  font-weight: bold;
  color: var(--td-text-color-primary, #333);
}

.card-body {
  margin-bottom: var(--spacer-sm);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: var(--spacer-xs) 0;
  font-size: var(--font-size-sm);
}

.label {
  color: var(--td-text-color-secondary, #666);
}

.value {
  color: var(--td-text-color-primary, #333);
  font-weight: 500;
}

.rating {
  color: var(--td-warning-color, #FF9C00);
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--spacer-sm);
  padding-top: var(--spacer-sm);
  border-top: 1rpx solid var(--td-border-color, #F0F0F0);
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.skeleton-container {
  padding: var(--spacer-md);
}

.merchants-skeleton-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--spacer-md);
}

@media (min-width: 1024rpx) {
  .merchants-skeleton-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1440rpx) {
  .merchants-skeleton-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.merchant-skeleton-item {
  height: 380rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
