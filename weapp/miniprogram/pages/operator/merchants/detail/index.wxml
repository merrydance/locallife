<custom-navbar title="商户详情" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page" style="padding-top: {{navBarHeight}}px;">
  <view wx:if="{{loading}}" class="card">
    <card-skeleton t-class="skeleton" />
  </view>

  <view wx:elif="{{error}}" class="card center">
    <t-empty icon="error-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bind:tap="onRetry" shape="round">重试</t-button>
    </t-empty>
  </view>

  <view wx:elif="{{!detail}}" class="card center">
    <t-empty description="未找到商户信息" />
  </view>

  <view wx:else class="card">
    <view class="title-row">
      <text class="title">{{detail.name}}</text>
      <t-tag theme="{{detail.status === 'approved' ? 'success' : (detail.status === 'pending' ? 'warning' : 'danger')}}" variant="dark">
        {{detail.status}}
      </t-tag>
    </view>

    <view class="row"><text class="label">联系电话</text><text class="value">{{detail.phone}}</text></view>
    <view class="row"><text class="label">地址</text><text class="value">{{detail.address}}</text></view>
    <view class="row"><text class="label">店主用户ID</text><text class="value">{{detail.owner_user_id}}</text></view>
    <view class="row"><text class="label">区域ID</text><text class="value">{{detail.region_id}}</text></view>
    <view class="row"><text class="label">营业状态</text><text class="value">{{detail.is_open ? '营业中' : '休息中'}}</text></view>
    <view class="row"><text class="label">经纬度</text><text class="value">{{detail.latitude}}, {{detail.longitude}}</text></view>
    <view class="row"><text class="label">创建时间</text><text class="value">{{detail.created_at}}</text></view>
    <view class="row"><text class="label">更新时间</text><text class="value">{{detail.updated_at}}</text></view>
  </view>
</view>
