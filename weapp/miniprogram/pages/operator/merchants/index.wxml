<custom-navbar title="商户管理" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container {{isLargeScreen ? 'large-screen' : ''}}" style="padding-top: {{navBarHeight}}px;">
  <view class="content">
    <!-- 错误状态 -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Loading (Skeleton) -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <view class="merchants-skeleton-grid">
          <card-skeleton wx:for="{{6}}" wx:key="index" t-class="merchant-skeleton-item" />
        </view>
      </view>

      <view wx:else class="animate-fade-in">
        <view wx:if="{{merchants.length === 0}}" class="empty-state">
          <t-empty icon="shop" description="暂无商户配置" />
        </view>

        <view wx:else class="merchants-grid">
          <view wx:for="{{merchants}}" wx:key="id" class="merchant-card">
            <view class="card-header">
              <text class="merchant-name">{{item.name}}</text>
              <t-tag theme="{{item.status === 'approved' ? 'success' : (item.status === 'pending' ? 'warning' : 'danger')}}" size="small" variant="light-outline">
                {{item.status === 'approved' ? '已通过' : (item.status === 'pending' ? '待审核' : item.status)}}
              </t-tag>
            </view>

            <view class="card-body">
              <view class="info-row">
                <text class="label">店主用户ID:</text>
                <text class="value">{{item.owner_user_id}}</text>
              </view>
              <view class="info-row">
                <text class="label">联系电话:</text>
                <text class="value">{{item.phone}}</text>
              </view>
              <view class="info-row">
                <text class="label">区域ID:</text>
                <text class="value">{{item.region_id}}</text>
              </view>
              <view class="info-row">
                <text class="label">营业状态:</text>
                <text class="value">{{item.is_open ? '营业中' : '休息中'}}</text>
              </view>
            </view>

            <view class="card-actions">
              <t-button size="small" theme="default" variant="outline" data-id="{{item.id}}" bindtap="onViewDetail">查看详情</t-button>
            </view>
          </view>
        </view>
        
        <view wx:if="{{loading && !initialLoading}}" class="load-more">
          <t-loading theme="dots" size="40rpx" />
        </view>
      </view>
    </block>
  </view>
</view>
