.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.content {
  padding: 24rpx;
}

.section {
  background: #fff;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  border-bottom: 1rpx solid #f0f0f0;
}

.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.skeleton-container {
  display: flex;
  flex-direction: column;
}

.footer-btn-wrapper {
  margin-top: 48rpx;
  padding: 0 8rpx;
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
