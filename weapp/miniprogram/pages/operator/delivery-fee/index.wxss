.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: 0;
}

.content {
  padding: 0;
}

.section {
  margin-bottom: 24rpx;
  padding-bottom: 0;
  border-radius: 0;
  overflow: visible;
}

.section-title {
  padding: 0;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  border-bottom: 0;
  margin-bottom: 16rpx;
}

.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.skeleton-container {
  display: flex;
  flex-direction: column;
}

.footer-btn-wrapper {
  margin-top: 48rpx;
  padding: 0;
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
