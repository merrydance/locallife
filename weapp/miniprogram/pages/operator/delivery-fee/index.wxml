<custom-navbar title="配送费规则配置" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view class="content">
    
    <!-- Error State -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" bindtap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Skeleton State -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <card-skeleton />
        <view style="height: 20rpx;"></view>
        <card-skeleton />
      </view>

      <!-- Content State -->
      <view wx:else class="animate-fade-in">
        <view class="section">
          <view class="section-title">基础计费</view>
          <t-cell-group theme="card">
            <t-input label="基础配送费" suffix="元" type="digit" value="{{config.base_fee}}" bind:change="onInput" data-field="base_fee" align="right" />
            <t-input label="基础距离" suffix="米" type="number" value="{{config.base_distance}}" bind:change="onInput" data-field="base_distance" align="right" />
          </t-cell-group>
        </view>

        <view class="section">
          <view class="section-title">距离与货值规则</view>
          <t-cell-group theme="card">
            <t-input label="超距加价" suffix="元/公里" type="digit" value="{{config.extra_fee_per_km}}" bind:change="onInput" data-field="extra_fee_per_km" align="right" />
            <t-input label="货值费率" suffix="倍率" type="digit" value="{{config.value_ratio}}" bind:change="onInput" data-field="value_ratio" align="right" />
          </t-cell-group>
        </view>

        <view class="section">
          <view class="section-title">费用边界</view>
          <t-cell-group theme="card">
            <t-input label="最低运费" suffix="元" type="digit" value="{{config.min_fee}}" bind:change="onInput" data-field="min_fee" align="right" />
            <t-input label="最高运费" suffix="元" type="digit" placeholder="留空表示不限" value="{{config.max_fee}}" bind:change="onInput" data-field="max_fee" align="right" />
            <t-cell title="启用状态">
                <t-switch slot="note" value="{{config.is_active}}" bind:change="onActiveChange" />
            </t-cell>
          </t-cell-group>
        </view>

        <view class="footer-btn-wrapper">
          <t-button theme="primary" size="large" block bind:tap="onSave">保存配置</t-button>
        </view>
      </view>
    </block>
  </view>
</view>

