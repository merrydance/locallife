<custom-navbar title="配送费规则配置" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <view class="content">
    
    <!-- Error State -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Skeleton State -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <card-skeleton />
        <view style="height: 20rpx;"></view>
        <card-skeleton />
      </view>

      <!-- Content State -->
      <view wx:else class="animate-fade-in">
        <view class="section">
          <view class="section-title">基础计费</view>
          <t-cell-group theme="card">
            <t-input label="基础配送费" suffix="元" type="digit" value="{{config.base_fee}}" bind:change="onInput" data-field="base_fee" align="right" />
            <t-input label="基础距离" suffix="米" type="number" value="{{config.base_distance}}" bind:change="onInput" data-field="base_distance" align="right" />
          </t-cell-group>
        </view>

        <view class="section">
          <view class="section-title">距离加价</view>
          <t-cell-group theme="card">
            <t-input label="超距离加价" suffix="元" type="digit" value="{{config.extra_distance_fee}}" bind:change="onInput" data-field="extra_distance_fee" align="right" />
            <t-input label="加价单位距离" suffix="米" type="number" value="{{config.extra_distance_unit}}" bind:change="onInput" data-field="extra_distance_unit" align="right" />
          </t-cell-group>
        </view>

        <view class="section">
          <view class="section-title">夜间加价</view>
          <t-cell-group theme="card">
            <t-input label="夜间附加费" suffix="元" type="digit" value="{{config.night_surcharge}}" bind:change="onInput" data-field="night_surcharge" align="right" />
            <t-cell title="夜间时段">
                <view class="time-range" slot="note">
                    <picker mode="time" value="{{config.night_start}}" bindchange="onTimeChange" data-field="night_start">
                        <view class="time-picker">{{config.night_start || '00:00'}}</view>
                    </picker>
                    <text class="separator">-</text>
                    <picker mode="time" value="{{config.night_end}}" bindchange="onTimeChange" data-field="night_end">
                        <view class="time-picker">{{config.night_end || '00:00'}}</view>
                    </picker>
                </view>
            </t-cell>
          </t-cell-group>
        </view>

        <view class="footer-btn-wrapper">
          <t-button theme="primary" size="large" block bind:tap="onSave">保存配置</t-button>
        </view>
      </view>
    </block>
  </view>
</view>

