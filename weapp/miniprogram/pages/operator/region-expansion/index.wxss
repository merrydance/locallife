.page-container {
  padding: 0;
  background: var(--td-bg-color-page);
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-sm);
  padding: 0 4rpx;
}

/* 申请列表 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.error-wrap {
  padding: 24rpx 0;
}

.empty-hint {
  color: var(--td-text-color-placeholder);
  font-size: 26rpx;
  text-align: center;
  padding: 40rpx 0;
}

.reject-reason {
  font-size: 24rpx;
  color: var(--td-error-color);
  margin-top: 4rpx;
}

/* 申请入口 */
.apply-entry {
  padding: 8rpx 0;
}

/* 表单卡片 */
.form-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.field-label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  margin: 24rpx 0 12rpx;
}

.field-label:first-child {
  margin-top: 0;
}

/* 城市选择器 */
.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.picker-display .placeholder {
  color: var(--td-text-color-placeholder);
}

.picker-arrow {
  color: var(--td-text-color-placeholder);
  font-size: 32rpx;
}

/* 区域搜索 */
.region-search {
  margin-bottom: 16rpx;
  background: var(--td-bg-color-secondarycontainer);
  border-radius: 12rpx;
}

/* 区域列表 */
.region-list {
  max-height: 480rpx;
  overflow-y: auto;
  border-radius: 12rpx;
  border: 1rpx solid var(--td-border-level-1-color);
}

.region-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
  position: relative;
  transition: background 0.15s;
}

.region-item:last-child {
  border-bottom: none;
}

.region-item.selected {
  background: var(--td-bg-color-secondarycontainer);
}

.region-item-name {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
  flex: 1;
}

.region-item-sub {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
  margin-left: 16rpx;
}

.region-check {
  font-size: 28rpx;
  color: var(--td-brand-color);
  margin-left: 16rpx;
}

.region-empty {
  text-align: center;
  color: var(--td-text-color-placeholder);
  font-size: 26rpx;
  padding: 40rpx 0;
}

/* 已选区域提示 */
.selected-region-tip {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--td-text-color-primary);
  background: var(--td-bg-color-secondarycontainer);
  border: 1rpx solid var(--td-component-border);
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
}

/* 操作按钮 */
.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.form-actions t-button {
  flex: 1;
}

