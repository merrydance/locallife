<custom-navbar title="微信支付开户" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page page-shell page-shell--with-nav"
  style="--page-shell-nav-height: {{navBarHeight}}px"
>
  <view class="content">
    <view wx:if="{{error}}" class="error-banner">{{error}}</view>

    <view class="card">
      <view class="card-title">提交开户信息</view>
      <view wx:if="{{loading}}" class="status-item">加载中...</view>
      <block wx:else>
        <view wx:if="{{statusView.guideText}}" class="guide-text">{{statusView.guideText}}</view>
        <view wx:if="{{statusView.showRejectReason}}" class="result-note result-note--warning">{{statusView.rejectReason}}</view>

        <view wx:if="{{statusView.canSubmitOpenInfo}}">
          <applyment-bank-form apiBasePath="/v1/operator/applyment" initialDraft="{{bindBankDraft}}" defaultAccountType="ACCOUNT_TYPE_PRIVATE" preloadCatalogs="{{statusView.canSubmitOpenInfo}}" submitLabel="提交微信支付开户" submitting="{{submitting}}" bind:submit="onSubmit" bind:cancel="onCancelForm" bind:draftchange="onBindDraftChange" />
        </view>

        <view wx:else class="result-note result-note--{{statusView.guideTheme}}">{{statusView.guideText}}</view>
        <view wx:if="{{statusView.applymentId !== '-'}}" class="status-item">申请单号：{{statusView.applymentId}}</view>
        <view wx:if="{{statusView.signURL}}" class="sign-url">{{statusView.signURL}}</view>
        <view wx:if="{{!statusView.canSubmitOpenInfo}}" class="action-row">
          <t-button wx:if="{{statusView.signURL}}" theme="primary" shape="round" bindtap="onOpenSignUrl">复制签约链接</t-button>
          <t-button theme="default" variant="outline" shape="round" loading="{{refreshingStatus}}" bindtap="onRefreshStatus">刷新状态</t-button>
        </view>
      </block>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>
