<custom-navbar title="开户结果" showBack="{{false}}" bind:navheight="onNavHeight" />

<view class="page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{loading}}" class="state-block">
    <t-loading theme="circular" size="40rpx" text="加载开户结果中..." vertical />
  </view>

  <view wx:elif="{{error}}" class="state-block">
    <t-empty description="{{error}}" />
    <t-button theme="primary" shape="round" bindtap="onRetry">重新加载</t-button>
  </view>

  <view wx:else class="content">
    <view class="result-card">
      <t-icon name="check-circle-filled" size="120rpx" color="var(--td-success-color-6)" />
      <view class="result-title">{{completed ? '微信支付开户已完成' : '开户尚未完成'}}</view>
      <view class="result-message">{{completed ? (statusDesc || '当前已完成开户，可正常经营与提现。') : '当前开户流程还未走完，返回进件页继续处理即可。'}}</view>

      <view wx:if="{{completed && subMchId}}" class="info-block">
        <view class="info-label">微信二级商户号</view>
        <view class="info-value">{{subMchId}}</view>
      </view>

      <view wx:if="{{completed && applymentId}}" class="info-block">
        <view class="info-label">申请单号</view>
        <view class="info-value">{{applymentId}}</view>
      </view>
    </view>

    <view class="action-group">
      <t-button wx:if="{{completed}}" theme="primary" block shape="round" size="large" bindtap="onBackToDashboard">返回运营台</t-button>
      <t-button wx:else theme="primary" block shape="round" size="large" bindtap="onBackToApplyment">返回进件页</t-button>
      <t-button theme="default" block shape="round" size="large" bindtap="onBackToApplyment">查看进件页</t-button>
    </view>
  </view>
</view>