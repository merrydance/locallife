.page {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.state-block {
  min-height: calc(100vh - var(--page-shell-nav-height, 88px) - var(--spacer-sm));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacer-md);
  padding: var(--spacer-lg);
  box-sizing: border-box;
}

.content {
  min-height: calc(100vh - var(--page-shell-nav-height, 88px) - var(--spacer-sm));
  box-sizing: border-box;
  padding: var(--spacer-lg) var(--spacer-md) calc(var(--safe-area-bottom) + var(--spacer-lg));
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: var(--spacer-lg);
}

.result-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: var(--spacer-xl) var(--spacer-lg);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-sm);
}

.result-title {
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.result-message {
  font-size: var(--font-size-sm);
  line-height: 1.7;
  color: var(--td-text-color-secondary);
  text-align: center;
}

.info-block {
  width: 100%;
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  box-sizing: border-box;
  background: var(--td-success-color-1);
}

.info-label {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--td-text-color-secondary);
  margin-bottom: var(--spacer-xs);
}

.info-value {
  font-size: 30rpx;
  line-height: 1.5;
  color: var(--td-text-color-primary);
  font-weight: 600;
  word-break: break-all;
}

.action-group {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}