<custom-navbar title="运营规则配置" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <!-- 左侧/顶部 分类控制 -->
  <view class="sidebar-tabs">
    <view 
      wx:for="{{categories}}" 
      wx:key="value" 
      class="side-tab {{activeCategory === item.value ? 'active' : ''}}"
      bindtap="switchCategory"
      data-val="{{item.value}}"
    >
      <t-icon name="{{item.icon}}" size="40rpx" />
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 主体内容区 -->
  <scroll-view scroll-y class="rules-content" refresher-enabled bindrefresherrefresh="loadRules" refresher-triggered="{{loading}}">
    <view class="content-inner">
      <view class="welcome-header">
        <view class="title">规则策略中心</view>
        <view class="subtitle">运费相关参数与系数由运营商管理，平台结算参数仅可查看。</view>
      </view>

      <view class="region-picker">
        <t-cell title="当前配置区域" note="{{selectedRegionName || ('ID: ' + selectedRegionId)}}" />
      </view>

      <view class="rules-list animate-fade-in">
        <block wx:if="{{categorizedRules[activeCategory].length > 0}}">
          <view 
            class="rule-card" 
            wx:for="{{categorizedRules[activeCategory]}}" 
            wx:key="id"
          >
            <view class="rule-icon">
              <t-icon name="{{item.icon}}" size="48rpx" color="#0052D9" />
            </view>
            <view class="rule-info">
              <view class="rule-top">
                <view class="rule-top-main">
                  <text class="name">{{item.name}}</text>
                </view>
                <view wx:if="{{item.editable}}" class="edit-btn" bindtap="onEditRule" data-id="{{item.id}}">
                  <t-icon name="edit" size="32rpx" />
                  <text wx:if="{{item.action === 'navigate_peak'}}">管理</text>
                  <text wx:else>修改</text>
                </view>
                <view wx:else class="readonly-badge">平台维护</view>
              </view>
              <view class="value-row" wx:if="{{item.action !== 'navigate_peak'}}">
                <view class="current-badge">当前值</view>
                <text class="num">{{item.value}}</text>
                <text class="unit">{{item.unit}}</text>
              </view>
              <text class="desc">{{item.desc}}</text>
            </view>
          </view>
        </block>
        <view class="empty-box" wx:elif="{{!initialLoading}}">
           <t-empty icon="info-circle" description="该分类下暂无规则" />
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 统一编辑弹窗 -->
  <t-dialog
    visible="{{showEdit}}"
    title="修改规则属性"
    confirm-btn="{{ { content: '保存修改', theme: 'primary' } }}"
    cancel-btn="取消"
    bind:confirm="confirmEdit"
    bind:cancel="onCloseEdit"
  >
    <view slot="content" class="dialog-content">
      <view class="edit-target">
        <text class="target-name">{{editingRule.name}}</text>
        <text class="target-desc">{{editingRule.desc}}</text>
      </view>
      <view class="input-section">
        <t-input
          value="{{newValue}}"
          placeholder="请输入新的规则数值"
          label="规则数值"
          suffix="{{editingRule.unit}}"
          align="right"
          bind:input="onValueChange"
        />
      </view>
      <view class="warning-tip">
        <t-icon name="error-circle" size="28rpx" />
        <text>警告：修改运费参数后将立即生效，请谨慎操作。</text>
      </view>
    </view>
  </t-dialog>
</view>
