<custom-navbar title="规则配置" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container {{isLargeScreen ? 'large-screen' : ''}}" style="padding-top: {{navBarHeight}}px;">
  <view class="content">
    <!-- 错误状态 -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Loading (Skeleton) -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <view class="rules-skeleton-grid">
          <card-skeleton wx:for="{{3}}" wx:key="index" t-class="rule-skeleton-item" />
        </view>
      </view>

      <view wx:else class="animate-fade-in">
        <view class="rules-list" wx:if="{{rules.length > 0}}">
          <view class="rules-grid">
            <view wx:for="{{rules}}" wx:key="id" class="rule-card">
              <view class="card-header">
                <text class="rule-name">{{item.name}}</text>
                <t-button size="small" theme="primary" variant="text" data-id="{{item.id}}" bindtap="onEditRule">修改</t-button>
              </view>
              
              <view class="card-body">
                <view class="value-row">
                  <text class="value">{{item.value}}</text>
                  <text class="unit">{{item.unit}}</text>
                </view>
                <text class="desc">{{item.desc}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <t-empty wx:else icon="info-circle" description="暂无规则配置" />
      </view>
    </block>
  </view>
</view>
