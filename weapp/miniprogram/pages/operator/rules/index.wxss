.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.rules-list {
  padding: var(--spacer-md);
}

.rules-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--spacer-md);
}

@media (min-width: 1024rpx) {
  .rules-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1440rpx) {
  .rules-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.rule-card {
  background-color: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm, 0 4rpx 12rpx rgba(0,0,0,0.05));
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-sm);
  padding-bottom: var(--spacer-sm);
  border-bottom: 1rpx solid var(--td-border-color, #F0F0F0);
}

.rule-name {
  font-size: 30rpx; /* Custom size close to heading */
  font-weight: bold;
  color: var(--td-text-color-primary, #333);
}

.value-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-xs);
  margin-bottom: var(--spacer-sm);
}

.value {
  font-size: var(--font-size-display, 48rpx);
  font-weight: bold;
  color: var(--td-brand-color, #0052D9); /* Using brand color instead of specific blue if appropriate, otherwise primary */
}

.unit {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary, #666);
}

.desc {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-placeholder, #999);
  line-height: 1.4;
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.skeleton-container {
  padding: var(--spacer-md);
}

.rules-skeleton-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--spacer-md);
}

@media (min-width: 1024rpx) {
  .rules-skeleton-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1440rpx) {
  .rules-skeleton-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.rule-skeleton-item {
  height: 240rpx;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
