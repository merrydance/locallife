.page-container {
  display: flex;
  height: 100vh;
  background-color: #f6f6f6;
  overflow: hidden;
}

/* 侧边栏 */
.sidebar-tabs {
  width: 170rpx;
  background-color: #fff;
  border-right: 1rpx solid #eee;
  display: flex;
  flex-direction: column;
  padding-top: 20rpx;
}

.side-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  color: #666;
  position: relative;
  transition: all 0.3s ease;
}

.side-tab t-icon {
  margin-bottom: 8rpx;
}

.side-tab text {
  font-size: 24rpx;
}

.side-tab.active {
  color: var(--td-brand-color);
  background-color: #fff;
}

.side-tab.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 40rpx;
  background-color: var(--td-brand-color);
  border-radius: 0 4rpx 4rpx 0;
}

/* 主内容区 */
.rules-content {
  flex: 1;
  height: 100%;
}

.content-inner {
  padding: 30rpx;
}

.welcome-header {
  margin-bottom: 40rpx;
}

.welcome-header .title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.welcome-header .subtitle {
  font-size: 24rpx;
  color: #999;
}

.region-picker {
  margin-bottom: 24rpx;
}

/* 规则卡片 */
.rule-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.rule-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #f0f7ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.rule-info {
  flex: 1;
}

.rule-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.rule-top-main {
  display: flex;
  align-items: center;
  min-width: 0;
}

.rule-top .name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
  min-width: 0;
}

.current-badge {
  font-size: 20rpx;
  color: #0052D9;
  background-color: rgba(0, 82, 217, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.value-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 10rpx;
}

.value-row .num {
  font-size: 44rpx;
  font-family: 'DIN Alternate', sans-serif;
  font-weight: bold;
  color: #0052D9;
}

.value-row .unit {
  font-size: 24rpx;
  color: #999;
}

.rule-info .desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
  display: block;
}

.edit-btn {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 24rpx;
  background: #f6f6f6;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.edit-btn text {
  margin-left: 6rpx;
}

.readonly-badge {
  color: #999;
  font-size: 22rpx;
  background: #f3f3f3;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

/* 弹窗样式 */
.dialog-content {
  padding: 20rpx 0;
}

.edit-target {
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.target-name {
  display: block;
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.target-desc {
  font-size: 22rpx;
  color: #999;
}

.warning-tip {
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
  color: #FA5151;
  font-size: 22rpx;
  line-height: 1.4;
}

.warning-tip t-icon {
  margin-right: 8rpx;
  margin-top: 2rpx;
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
