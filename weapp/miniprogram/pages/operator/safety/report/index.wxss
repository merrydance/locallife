.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  padding: 24rpx;
}

.form-card {
  margin-top: 0;
}

.card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.card-header,
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-header {
  margin-bottom: 16rpx;
}

.title {
  font-size: 30rpx;
  color: #111;
  font-weight: 500;
}

.section-title {
  font-size: 30rpx;
  color: #111;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.level-group {
  margin: 20rpx 0;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.card-body {
  margin-bottom: 16rpx;
}

.body-text {
  font-size: 24rpx;
  color: #666;
}

.card-footer {
  font-size: 24rpx;
  color: #666;
}

.load-more {
  padding: 0 24rpx 32rpx;
  display: flex;
  justify-content: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #999;
}

.error-wrap {
  padding: 120rpx 0;
}
