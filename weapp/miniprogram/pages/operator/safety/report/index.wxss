.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}
.card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.card-header,
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-header {
  margin-bottom: 16rpx;
}

.title {
  font-size: 30rpx;
  color: #111;
  font-weight: 500;
}

.card-footer {
  font-size: 24rpx;
  color: #666;
}

.load-more {
  padding: 0 24rpx 32rpx;
}
