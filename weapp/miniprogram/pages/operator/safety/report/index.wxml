<custom-navbar title="食安事件" showBack="{{true}}" bind:navheight="onNavHeight" />
<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <t-tabs value="{{status}}" bind:change="onTabChange" t-class="sticky-tabs">
    <t-tab-panel label="全部" value="" />
    <t-tab-panel label="待处理" value="pending" />
    <t-tab-panel label="已处理" value="resolved" />
    <t-tab-panel label="已驳回" value="rejected" />
  </t-tabs>

  <view class="list" wx:if="{{reports.length > 0}}">
    <view class="card" wx:for="{{reports}}" wx:key="id" bindtap="onDetail" data-id="{{item.id}}">
      <view class="card-header">
        <text class="title">{{item.title}}</text>
        <t-tag theme="{{item.status === 'pending' ? 'warning' : (item.status === 'resolved' ? 'success' : 'danger')}}" variant="light-outline" size="small">
          {{item.status}}
        </t-tag>
      </view>
      <view class="card-footer">
        <text>ID: {{item.id}}</text>
        <text>{{item.created_at}}</text>
      </view>
    </view>
  </view>

  <t-empty wx:else icon="info-circle" description="暂无食安事件" />

  <view class="load-more" wx:if="{{hasMore}}">
    <t-button size="small" variant="outline" bindtap="onLoadMore" loading="{{loading}}">加载更多</t-button>
  </view>
</view>
