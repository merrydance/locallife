<custom-navbar title="食安案件" showBack="{{true}}" bind:navheight="onNavHeight" />
<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px"
>
  <t-tabs value="{{status}}" bind:change="onTabChange" t-class="sticky-tabs">
    <t-tab-panel label="全部" value="" />
    <t-tab-panel label="待调查" value="merchant-suspended" />
    <t-tab-panel label="调查中" value="investigating" />
    <t-tab-panel label="已结案" value="resolved" />
  </t-tabs>

  <view wx:if="{{error && !initialLoading}}" class="error-wrap">
    <t-empty icon="info-circle" description="{{error}}" />
  </view>

  <view wx:elif="{{initialLoading}}" class="list">
    <list-skeleton row="4" />
  </view>

  <scroll-view
    wx:elif="{{cases.length > 0}}"
    scroll-y
    class="safety-scroll"
    scroll-top="{{scrollTop}}"
    bindscrolltolower="onLoadMore"
    lower-threshold="100"
    enable-back-to-top
    refresher-enabled="{{true}}"
    bindrefresherrefresh="onPullDownRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <view class="list">
      <view class="card" wx:for="{{cases}}" wx:key="id" bindtap="onDetail" data-id="{{item.id}}">
        <view class="card-header">
          <text class="title">{{item.primary_product_label}}</text>
          <t-tag theme="{{item.status_theme}}" variant="dark" size="small">
            {{item.status_label}}
          </t-tag>
        </view>
        <view class="card-body">
          <text class="body-text">商户ID：{{item.merchant_id}}</text>
          <text class="body-text">触发原因：{{item.trigger_reason}}</text>
          <text class="body-text">熔断时间：{{item.suspended_at}}</text>
        </view>
        <view class="card-footer">
          <text>案件ID: {{item.id}}</text>
          <text>{{item.created_at}}</text>
        </view>
      </view>

      <view class="load-more">
        <t-loading wx:if="{{loadingMore}}" theme="circular" size="32rpx" />
        <text wx:elif="{{!hasMore}}" class="no-more-text">没有更多案件了</text>
      </view>
    </view>
  </scroll-view>

  <scroll-view
    wx:else
    scroll-y
    class="safety-scroll"
    scroll-top="{{scrollTop}}"
    enable-back-to-top
    refresher-enabled="{{true}}"
    bindrefresherrefresh="onPullDownRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <t-empty icon="info-circle" description="暂无食安案件" />
  </scroll-view>
</view>
