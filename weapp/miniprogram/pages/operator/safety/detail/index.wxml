<custom-navbar title="食安案件详情" showBack="{{true}}" bind:navheight="onNavHeight" />
<view
  class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px"
>
  <view wx:if="{{loading && initialLoading}}">
    <list-skeleton row="6" />
  </view>

  <view wx:elif="{{error}}" class="card center-card">
    <t-empty icon="info-circle" description="{{error}}">
      <t-button slot="action" theme="primary" bindtap="onRetry">重试</t-button>
    </t-empty>
  </view>

  <view wx:elif="{{caseDetail}}">
    <view class="card">
      <view class="header-row">
        <text class="title">{{caseDetail.primary_product_label || caseDetail.primary_product_key || '未识别问题商品'}}</text>
        <t-tag theme="{{caseDetail.status_theme}}" variant="dark">{{caseDetail.status_label}}</t-tag>
      </view>
      <view class="meta">案件ID：{{caseDetail.id}}</view>
      <view class="meta">商户ID：{{caseDetail.merchant_id}}</view>
      <view class="meta">熔断时间：{{caseDetail.suspended_at}}</view>
      <view wx:if="{{caseDetail.resolved_at}}" class="meta">结案时间：{{caseDetail.resolved_at}}</view>
      <view class="desc">{{caseDetail.trigger_reason}}</view>
    </view>

    <view class="card" wx:if="{{caseDetail.is_active}}">
      <view class="section-title">调查报告</view>
      <t-textarea label="调查内容" placeholder="填写现场核查、批次追溯和风险判断" value="{{investigationReport}}" bindchange="onInvestigationReportChange" maxlength="4000" />
      <t-button theme="warning" block bindtap="onSubmitInvestigation" loading="{{investigateSubmitting}}">保存调查报告</t-button>
    </view>

    <view class="card" wx:if="{{caseDetail.is_active}}">
      <view class="section-title">结案处置</view>
      <t-textarea label="商户整改报告" placeholder="填写商户整改完成情况" value="{{merchantRectificationReport}}" bindchange="onMerchantRectificationReportChange" maxlength="4000" />
      <t-textarea label="结案结论" placeholder="填写结案结论与恢复依据" value="{{resolution}}" bindchange="onResolutionChange" maxlength="2000" />
      <t-button theme="primary" block bindtap="onSubmitResolution" loading="{{resolveSubmitting}}">提交结案</t-button>
    </view>

    <view class="card" wx:else>
      <view class="section-title">结案结果</view>
      <view class="meta">当前状态：{{caseDetail.status_label}}</view>
      <view class="desc">调查报告：{{caseDetail.investigation_report || '暂无调查报告'}}</view>
      <view class="desc">整改报告：{{caseDetail.merchant_rectification_report || '暂无整改报告'}}</view>
      <view class="desc">结案结论：{{caseDetail.resolution || '暂无结论'}}</view>
    </view>

    <view class="card">
      <view class="section-title">关联事件</view>
      <view wx:if="{{incidents.length > 0}}">
        <view wx:for="{{incidents}}" wx:key="id" class="card-body">
          <view class="card-header">
            <text class="title">订单 {{item.order_id}}</text>
            <t-tag theme="{{item.status_theme}}" variant="light" size="small">{{item.status_label}}</t-tag>
          </view>
          <view class="body-text">用户ID：{{item.user_id}}</view>
          <view class="body-text">事件类型：{{item.incident_type}}</view>
          <view class="body-text">描述：{{item.description}}</view>
          <view class="card-footer">
            <text>事件ID: {{item.id}}</text>
            <text>{{item.created_at}}</text>
          </view>
        </view>
      </view>
      <t-empty wx:else icon="info-circle" description="暂无关联事件" />
    </view>
  </view>

  <t-empty wx:else icon="info-circle" description="案件不存在或无权限" />
</view>
