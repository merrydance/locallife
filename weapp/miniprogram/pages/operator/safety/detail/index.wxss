.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.center-card {
  display: flex;
  justify-content: center;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
  color: #111;
}

.meta,
.desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 30rpx;
  color: #111;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.readonly-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}
