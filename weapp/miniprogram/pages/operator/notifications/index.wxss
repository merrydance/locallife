.header-tools {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.filter-tabs {
  flex: 1;
}

.content {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.notifications-scroll {
  height: calc(100vh - var(--page-shell-nav-height) - 140rpx);
}

.summary-strip {
  margin-bottom: 20rpx;
  color: #b45309;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.summary-strip text {
  white-space: nowrap;
}

.notification-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notification-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
}

.notification-card.is-unread {
  border: 1px solid rgba(237, 108, 2, 0.16);
  background: linear-gradient(135deg, #fffaf2 0%, #ffffff 100%);
}

.notification-card.is-read {
  opacity: 0.78;
}

.notification-card__head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.notification-card__title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.notification-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #ed6c02;
  flex-shrink: 0;
}

.notification-card__title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.notification-card__time {
  color: #8c8c8c;
  font-size: 24rpx;
  white-space: nowrap;
}

.notification-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.notification-card__region,
.notification-card__wait {
  color: #5f6368;
  font-size: 24rpx;
}

.notification-card__wait {
  color: #b45309;
}

.notification-card__summary {
  color: #454b54;
  font-size: 26rpx;
  line-height: 1.7;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 36rpx;
}

.no-more-text {
  color: #8c8c8c;
  font-size: 24rpx;
}
