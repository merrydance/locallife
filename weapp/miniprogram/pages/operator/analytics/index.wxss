.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.content {
  padding: 0;
}

.toolbar-card {
  background: transparent;
  border-radius: 0;
  padding: 0;
  margin-bottom: 24rpx;
  box-shadow: none;
}

.toolbar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.toolbar-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.region-picker {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: var(--td-brand-color-1);
  color: var(--td-brand-color);
  font-size: 24rpx;
}

.region-picker--static {
  background: #F3F3F3;
  color: #666;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.large-screen .metrics-grid {
  grid-template-columns: repeat(4, 1fr);
}

.metric-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.metric-label {
  font-size: 26rpx;
  color: #666;
}

.metric-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.metric-trend {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  gap: 4rpx;
}

.metric-trend.up { color: #00A870; }
.metric-trend.down { color: #E34D59; }

.table-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.card-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-subtitle {
  font-size: 24rpx;
  color: #999;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.summary-item {
  background: #F8FAFF;
  border-radius: 12rpx;
  padding: 20rpx;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.summary-value {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.ranking-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-weight: bold;
  font-size: 28rpx;
  margin-right: 24rpx;
  border-radius: 8rpx;
  background: #F0F0F0;
  color: #666;
}

.rank-1 { background: #FFD700; color: #fff; }
.rank-2 { background: #C0C0C0; color: #fff; }
.rank-3 { background: #CD7F32; color: #fff; }

.merchant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.merchant-orders {
  font-size: 24rpx;
  color: #999;
}

.merchant-gmv {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.skeleton-container {
  padding: 0;
}

.metrics-skeleton {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.metric-skeleton-item {
  height: 180rpx;
}

.table-skeleton {
  padding: 24rpx;
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
