<custom-navbar title="全局数据分析" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container {{isLargeScreen ? 'large-screen' : ''}}" style="padding-top: {{navBarHeight}}px;">
  <view class="content">
    <!-- 错误状态 -->
    <view wx:if="{{error && !initialLoading}}" class="error-container">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- Loading (Skeleton) -->
      <view wx:if="{{initialLoading}}" class="skeleton-container animate-fade-in">
        <view class="metrics-skeleton">
          <card-skeleton wx:for="{{4}}" wx:key="index" t-class="metric-skeleton-item" />
        </view>
        <card-skeleton t-class="chart-skeleton" />
        <list-skeleton row="5" t-class="table-skeleton" />
      </view>

      <view wx:else class="animate-fade-in">
        <view class="toolbar-card">
          <view class="toolbar-row">
            <text class="toolbar-title">统计范围</text>
            <picker wx:if="{{regions.length > 0}}" mode="selector" range="{{regions}}" range-key="name" value="{{selectedRegionIdx}}" bindchange="onRegionChange">
              <view class="region-picker">{{regions[selectedRegionIdx].name}}</view>
            </picker>
            <view wx:else class="region-picker region-picker--static">全部区域</view>
          </view>

          <t-tabs value="{{timeDimension}}" bindchange="onTimeDimensionChange" theme="tag" space-evenly="{{false}}">
            <t-tab-panel label="今日" value="day" />
            <t-tab-panel label="近7天" value="week" />
            <t-tab-panel label="近30天" value="month" />
          </t-tabs>
        </view>

        <!-- 核心指标 -->
        <view class="metrics-grid">
          <view wx:for="{{metrics}}" wx:key="label" class="metric-card">
            <text class="metric-label">{{item.label}}</text>
            <text class="metric-value">{{item.value}}</text>
            <view class="metric-trend {{item.trend}}">
              <t-icon name="{{item.trend === 'up' ? 'arrow-up' : 'arrow-down'}}" size="24rpx" />
              <text>{{item.change}}</text>
            </view>
          </view>
        </view>

        <view class="table-card">
          <view class="card-header">
            <text class="card-title">区域体检</text>
            <text class="card-subtitle">{{regionSummary.regionName}}</text>
          </view>
          <view class="summary-grid">
            <view class="summary-item">
              <text class="summary-label">活跃商户 / 总商户</text>
              <text class="summary-value">{{regionSummary.merchantText}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">在线骑手 / 活跃骑手</text>
              <text class="summary-value">{{regionSummary.riderText}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">履约完成率</text>
              <text class="summary-value">{{regionSummary.completionRate}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">区域佣金</text>
              <text class="summary-value">{{regionSummary.commission}}</text>
            </view>
          </view>
        </view>

        <view class="table-card">
          <view class="card-header">
            <text class="card-title">运营排行</text>
            <t-tabs value="{{rankingType}}" bindchange="onRankingTypeChange" theme="tag" space-evenly="{{false}}">
              <t-tab-panel label="商户 GMV" value="merchant" />
              <t-tab-panel label="骑手效率" value="rider" />
            </t-tabs>
          </view>

          <view wx:if="{{rankingType === 'merchant'}}" class="ranking-list">
            <view wx:for="{{topMerchants}}" wx:key="rank" class="ranking-item">
              <view class="rank-num rank-{{item.rank}}">{{item.rank}}</view>
              <view class="merchant-info">
                <text class="merchant-name">{{item.name}}</text>
                <text class="merchant-orders">{{item.orders}} 单 | 佣金 ¥{{item.commission}}</text>
              </view>
              <text class="merchant-gmv">¥{{item.gmv}}</text>
            </view>
            <t-empty wx:if="{{topMerchants.length === 0}}" description="暂无商户排行数据" />
          </view>

          <view wx:if="{{rankingType === 'rider'}}" class="ranking-list">
            <view wx:for="{{topRiders}}" wx:key="rank" class="ranking-item">
              <view class="rank-num rank-{{item.rank}}">{{item.rank}}</view>
              <view class="merchant-info">
                <text class="merchant-name">{{item.name}}</text>
                <text class="merchant-orders">配送 {{item.deliveries}} 单 | 完成率 {{item.completionRate}}</text>
              </view>
              <text class="merchant-gmv">¥{{item.earnings}}</text>
            </view>
            <t-empty wx:if="{{topRiders.length === 0}}" description="暂无骑手排行数据" />
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
