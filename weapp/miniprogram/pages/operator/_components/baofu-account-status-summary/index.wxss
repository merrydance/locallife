.account-status-summary {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.status-panel {
  display: flex;
  align-items: flex-start;
  gap: var(--spacer-md);
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
}

.status-panel--success {
  background: var(--td-success-color-light);
}

.status-panel--warning,
.status-panel--primary {
  background: var(--td-warning-color-1);
}

.status-panel--danger {
  background: var(--td-error-color-1);
}

.status-panel__icon {
  display: flex;
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--td-bg-color-container);
  color: var(--td-brand-color);
}

.status-panel--success .status-panel__icon {
  color: var(--td-success-color);
}

.status-panel--warning .status-panel__icon,
.status-panel--primary .status-panel__icon {
  color: var(--td-warning-color);
}

.status-panel--danger .status-panel__icon {
  color: var(--td-error-color);
}

.status-panel__body {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.status-panel__heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacer-xs);
}

.status-panel__title {
  color: var(--td-text-color-primary);
  font-size: var(--font-size-lg);
  font-weight: 600;
  line-height: 1.4;
}

.status-detail__value {
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

.status-detail {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: var(--radius-md);
  background: var(--td-bg-color-container);
}

.status-detail__row {
  display: flex;
  gap: var(--spacer-sm);
  padding: var(--spacer-sm) var(--spacer-md);
  border-top: 1rpx solid var(--td-component-border);
}

.status-detail__row:first-child {
  border-top: 0;
}

.status-detail__row--muted {
  background: var(--td-bg-color-secondarycontainer);
}

.status-detail__label {
  width: 128rpx;
  flex: 0 0 128rpx;
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

.status-detail__value {
  flex: 1;
  min-width: 0;
}
