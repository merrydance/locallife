<custom-navbar title="骑手详情" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page" style="padding-top: {{navBarHeight}}px;">
  <view wx:if="{{loading}}" class="card">
    <card-skeleton t-class="skeleton" />
  </view>

  <view wx:elif="{{error}}" class="card center">
    <t-empty icon="error-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bind:tap="onRetry" shape="round" variant="outline">重试</t-button>
    </t-empty>
  </view>

  <view wx:elif="{{!detail}}" class="card center">
    <t-empty description="未找到骑手信息" />
  </view>

  <view wx:else class="card">
    <view class="title-row">
      <text class="title">{{detail.real_name}}</text>
      <t-tag theme="{{detail.status === 'active' ? 'success' : (detail.status === 'pending' ? 'warning' : 'danger')}}" variant="light-outline">{{detail.status}}</t-tag>
    </view>

    <view class="row"><text class="label">手机号</text><text class="value">{{detail.phone}}</text></view>
    <view class="row"><text class="label">身份证(脱敏)</text><text class="value">{{detail.id_card_no || '-'}}</text></view>
    <view class="row"><text class="label">在线状态</text><text class="value">{{detail.is_online ? '在线' : '离线'}}</text></view>
    <view class="row"><text class="label">区域ID</text><text class="value">{{detail.region_id}}</text></view>
    <view class="row"><text class="label">押金</text><text class="value">¥{{detail.deposit_amount_display}}</text></view>
    <view class="row"><text class="label">冻结押金</text><text class="value">¥{{detail.frozen_deposit_display}}</text></view>
    <view class="row"><text class="label">信用分</text><text class="value">{{detail.credit_score}}</text></view>
    <view class="row"><text class="label">高值单资格</text><text class="value">{{detail.high_value_qualified ? '是' : '否'}}</text></view>
    <view class="row"><text class="label">累计订单</text><text class="value">{{detail.total_orders}}</text></view>
    <view class="row"><text class="label">累计收入</text><text class="value">¥{{detail.total_earnings_display}}</text></view>
    <view class="row"><text class="label">定位更新时间</text><text class="value">{{detail.location_updated_at || '-'}}</text></view>
    <view class="row"><text class="label">创建时间</text><text class="value">{{detail.created_at}}</text></view>
  </view>
</view>
