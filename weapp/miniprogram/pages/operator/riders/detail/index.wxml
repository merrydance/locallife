<custom-navbar title="骑手详情" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter"
  style="--page-shell-nav-height: {{navBarHeight}}px"
>
  <view wx:if="{{loading}}" class="card">
    <card-skeleton t-class="skeleton" />
  </view>

  <view wx:elif="{{error}}" class="card center">
    <t-empty icon="error-circle" description="{{error}}">
      <t-button slot="action" theme="primary" bind:tap="onRetry">重试</t-button>
    </t-empty>
  </view>

  <view wx:elif="{{!detail}}" class="card center">
    <t-empty description="未找到骑手信息" />
  </view>

  <block wx:else>
    <!-- 骑手基本资料 -->
    <view class="card">
      <view class="rider-header">
        <view class="avatar">
          <text class="avatar-text">{{detail.real_name[0]}}</text>
        </view>
        <view class="header-info">
          <text class="rider-name">{{detail.real_name}}</text>
          <view class="tag-row">
            <t-tag theme="{{detail.status_theme}}" variant="dark" size="small">{{detail.status_label}}</t-tag>
            <t-tag theme="{{detail.online_status_theme}}" variant="light" size="small">{{detail.online_status_label}}</t-tag>
          </view>
        </view>
      </view>

      <view class="section-title">基本资料</view>
      <view class="row"><text class="label">手机号</text><text class="value">{{detail.phone}}</text></view>
      <view class="row"><text class="label">身份证(脱敏)</text><text class="value">{{detail.id_card_no || '-'}}</text></view>
      <view class="row"><text class="label">所属区域</text><text class="value">{{detail.region_name}}</text></view>
      <view class="row"><text class="label">信用分</text><text class="value">{{detail.credit_score}}</text></view>
      <view class="row"><text class="label">骑手评分</text><text class="value">{{detail.rating_display}}</text></view>
      <view class="row"><text class="label">车辆类型</text><text class="value">{{detail.vehicle_type_display}}</text></view>
      <view class="row"><text class="label">紧急联系人</text><text class="value">{{detail.emergency_contact}}</text></view>
      <view class="row"><text class="label">紧急联系电话</text><text class="value">{{detail.emergency_phone}}</text></view>
      <view class="row"><text class="label">押金</text><text class="value">¥{{detail.deposit_amount_display}}</text></view>
      <view class="row"><text class="label">冻结押金</text><text class="value">¥{{detail.frozen_deposit_display}}</text></view>
      <view class="row"><text class="label">入驻时间</text><text class="value">{{detail.created_at}}</text></view>
      <view class="row"><text class="label">定位更新</text><text class="value">{{detail.location_updated_at || '-'}}</text></view>
    </view>

    <!-- 配送统计 -->
    <view class="card">
      <view class="section-header">
        <text class="section-title">配送统计</text>
        <t-tag wx:if="{{stats}}" variant="outline" size="small">近30天</t-tag>
      </view>

      <!-- 历史汇总 -->
      <view class="stat-grid">
        <view class="stat-item">
          <text class="stat-value">{{detail.total_orders}}</text>
          <text class="stat-label">累计订单</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">¥{{detail.total_earnings_display}}</text>
          <text class="stat-label">累计收入</text>
        </view>
      </view>

      <view wx:if="{{statsLoading}}" class="stats-loading">
        <t-loading size="small" />
        <text class="loading-text">加载中...</text>
      </view>

      <block wx:elif="{{stats}}">
        <view class="divider" />
        <view class="sub-title">近30天绩效</view>
        <view class="stat-grid">
          <view class="stat-item">
            <text class="stat-value">{{stats.total_deliveries}}</text>
            <text class="stat-label">配送单数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{stats.completed_deliveries}}</text>
            <text class="stat-label">完成单数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{stats.completion_rate_display}}%</text>
            <text class="stat-label">完成率</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{stats.avg_delivery_min}}分钟</text>
            <text class="stat-label">平均配送时长</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">¥{{stats.period_earnings_display}}</text>
            <text class="stat-label">期间收入</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{stats.delayed_count}}</text>
            <text class="stat-label">超时次数</text>
          </view>
        </view>
      </block>
    </view>
  </block>

</view>
