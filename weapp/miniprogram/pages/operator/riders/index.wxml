<custom-navbar title="骑手档案" showBack="{{true}}" bind:navheight="onNavHeight" />

<view
  class="page page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter {{isLargeScreen ? 'large-screen' : ''}}"
  style="--page-shell-nav-height: {{navBarHeight}}px"
>
  <view class="header-tools">
    <view class="search-bar">
      <t-search
        model:value="{{searchKeyword}}"
        placeholder="搜索骑手姓名、电话"
        bind:change="onSearchChange"
        bind:clear="onSearchClear"
      />
    </view>

    <view class="filter-tabs">
      <t-tabs value="{{statusFilter}}" bind:change="onStatusFilterChange" t-class="tabs-container">
        <t-tab-panel label="全部" value="" />
        <t-tab-panel label="待激活" value="approved" />
        <t-tab-panel label="正常" value="active" />
        <t-tab-panel label="暂停" value="suspended" />
      </t-tabs>
    </view>
  </view>

  <view class="content">
    <view wx:if="{{initialLoading}}" class="card">
      <card-skeleton t-class="skeleton" />
    </view>

    <view wx:elif="{{error}}" class="card center">
      <t-empty icon="error-circle" description="{{error}}">
        <t-button slot="action" theme="primary" bind:tap="onRetry">重试</t-button>
      </t-empty>
    </view>

    <scroll-view
      wx:else
      scroll-y
      class="riders-scroll"
      scroll-top="{{scrollTop}}"
      bindscrolltolower="onLoadMore"
      lower-threshold="100"
      enable-back-to-top
      refresher-enabled="{{true}}"
      bindrefresherrefresh="onPullDownRefresh"
      refresher-triggered="{{refreshing}}"
    >
      <view class="rider-summary">
        <view class="rider-summary__main">
          <text class="rider-summary__title">{{totalLabel}}</text>
          <text class="rider-summary__count">{{total}}</text>
        </view>
        <text class="rider-summary__loaded">已加载 {{riders.length}}/{{total}}</text>
      </view>

      <view wx:if="{{riders.length === 0}}" class="card center">
        <t-empty description="暂无骑手数据" />
      </view>

      <view wx:else class="riders-container">
        <view wx:for="{{riders}}" wx:key="id" class="card rider-card" bind:tap="onTapRider" data-id="{{item.id}}">
          <view class="title-row">
            <view class="title-main">
              <text class="title">{{item.name}}</text>
              <text class="region-text">区域ID {{item.region_id}}</text>
            </view>
            <t-tag theme="{{item.status_theme}}" variant="dark">{{item.status_label}}</t-tag>
          </view>

          <view class="meta-row">
            <view class="meta-item"><text class="label">手机号</text><text class="value">{{item.phone}}</text></view>
            <view class="meta-item"><text class="label">在线状态</text><text class="value">{{item.online_status_label}}</text></view>
          </view>

          <view class="stats-row">
            <view class="stat-item">
              <text class="stat-value">{{item.delivery_count}}</text>
              <text class="stat-label">代取单</text>
            </view>
            <view class="stat-item">
              <text class="stat-value">{{item.total_earnings_display}}</text>
              <text class="stat-label">累计收入</text>
            </view>
          </view>
        </view>

        <view class="loading-wrap">
          <t-loading wx:if="{{loadingMore}}" theme="circular" size="32rpx" />
          <text wx:elif="{{!hasMore && riders.length > 0}}" class="no-more-text">没有更多数据了</text>
        </view>
      </view>
    </scroll-view>
  </view>

</view>
