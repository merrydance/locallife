<custom-navbar title="骑手管理" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page" style="padding-top: {{navBarHeight}}px;">
  <view wx:if="{{initialLoading}}" class="card">
    <card-skeleton t-class="skeleton" />
  </view>

  <view wx:elif="{{error}}" class="card center">
    <t-empty icon="error-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bind:tap="onRetry" shape="round">重试</t-button>
    </t-empty>
  </view>

  <view wx:elif="{{riders.length === 0}}" class="card center">
    <t-empty description="暂无骑手数据" />
  </view>

  <view wx:else>
    <view wx:for="{{riders}}" wx:key="id" class="card rider-card" bind:tap="onTapRider" data-id="{{item.id}}">
      <view class="title-row">
        <text class="title">{{item.real_name}}</text>
        <t-tag theme="{{item.status === 'active' ? 'success' : (item.status === 'pending' ? 'warning' : 'danger')}}" variant="dark">{{item.status}}</t-tag>
      </view>
      <view class="row"><text class="label">手机号</text><text class="value">{{item.phone}}</text></view>
      <view class="row"><text class="label">在线状态</text><text class="value">{{item.is_online ? '在线' : '离线'}}</text></view>
      <view class="row"><text class="label">区域ID</text><text class="value">{{item.region_id}}</text></view>
      <view class="row"><text class="label">累计订单</text><text class="value">{{item.total_orders}}</text></view>
      <view class="row"><text class="label">累计收入</text><text class="value">¥{{item.total_earnings_display}}</text></view>
    </view>

    <view wx:if="{{loading}}" class="loading-wrap">
      <t-loading theme="circular" size="32rpx" />
    </view>
  </view>
</view>
