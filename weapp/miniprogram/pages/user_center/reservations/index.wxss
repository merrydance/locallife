/* Pages User Center Reservations */
.page {
  min-height: 100vh;
  background-color: var(--td-bg-color-page, #f6f6f6);
}

.tabs-wrapper {
  background: var(--td-bg-color-container, #fff);
  position: sticky;
  top: 0;
  z-index: 100;
  padding-bottom: 8rpx;
}

.list-container {
  padding: 24rpx;
}

.empty-state {
  margin-top: 120rpx;
}

/* Reservation Card */
.reservation-card {
  background: var(--td-bg-color-container, #fff);
  border-radius: var(--radius-md, 16rpx);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}

.card-hover {
  transform: scale(0.99);
  background-color: #fafafa;
}

/* Header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.merchant-info {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.merchant-name {
  margin-right: 8rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Body */
.card-body {
  margin-bottom: 20rpx;
}

.info-primary {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.time-display {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  font-family: 'DIN Alternate', sans-serif;
}

.guest-info {
  font-size: 26rpx;
  color: #666;
}

.info-secondary {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.items-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-val {
  color: #333;
  font-weight: bold;
}

/* Footer */
.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 12rpx;
}

.loading-footer {
  padding: 32rpx 0;
  text-align: center;
}

.no-more {
  color: #bbb;
  font-size: 24rpx;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.reservations-skeleton-list {
  padding: 0;
}

.skeleton-item {
  margin-bottom: 24rpx;
}

.load-more-wrap {
  padding: 32rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--td-text-color-placeholder);
}
