@import '../../../styles/customer.wxss';

/* Pages User Center Reservations */
.page {
  min-height: 100vh;
  background-color: var(--td-bg-color-page, #f6f6f6);
}

.tabs-wrapper {
  background: var(--td-bg-color-container, #fff);
  position: sticky;
  top: 0;
  z-index: 100;
  padding-bottom: 8rpx;
}

.empty-state {
  margin-top: 120rpx;
}

/* Reservation Card */
.reservation-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.reservation-card-main {
  border-radius: var(--radius-sm);
  transition: opacity 0.16s ease;
}

.reservation-card-main-hover {
  opacity: 0.72;
}

/* Header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.merchant-info {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.merchant-name {
  margin-right: 8rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Body */
.card-body {
  margin-bottom: 20rpx;
}

.info-primary {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.time-display {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--td-text-color-primary);
  font-family: 'DIN Alternate', sans-serif;
}

.guest-info {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

.info-secondary {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
  margin-top: 8rpx;
}

.items-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-val {
  color: var(--td-text-color-primary);
  font-weight: bold;
}

/* Footer */
.card-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.footer-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 26rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 24rpx !important;
}

.loading-footer {
  padding: 32rpx 0;
  text-align: center;
}

.no-more {
  color: var(--td-text-color-disabled);
  font-size: 24rpx;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.reservations-skeleton-list {
  padding: 0;
}

.skeleton-item {
  margin-bottom: 24rpx;
}

.load-more-wrap {
  padding: 32rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--td-text-color-placeholder);
}
