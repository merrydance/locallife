.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 100rpx 0;
}

.detail-content {
  padding-bottom: var(--spacer-xl);
}

/* 卡片通用样式 */
.card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  margin: var(--spacer-sm) var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

/* 支付状态卡片 */
.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-sm);
  padding: var(--spacer-xl) var(--spacer-md);
}

.status-icon {
  margin-bottom: var(--spacer-xs);
}

.status-text {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-secondary);
}

.amount {
  font-size: var(--font-size-display);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

/* 信息卡片 */
.card-title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
  margin-bottom: var(--spacer-md);
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-sm) 0;
  font-size: var(--font-size-base);
}

.info-row .label {
  color: var(--td-text-color-secondary);
}

.info-row .value {
  color: var(--td-text-color-primary);
  font-weight: 500;
  text-align: right;
  max-width: 65%;
  word-break: break-all;
}

/* 退款记录 */
.refund-item {
  padding: var(--spacer-md) 0;
  border-bottom: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.refund-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.refund-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-xs);
}

.refund-amount {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.refund-status {
  font-size: var(--font-size-xxs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-weight: bold;
}

.refund-status.pending,
.refund-status.processing {
  background: var(--td-warning-color-light);
  color: var(--td-warning-color);
}

.refund-status.success {
  background: var(--td-success-color-light);
  color: var(--td-success-color);
}

.refund-status.failed {
  background: var(--td-error-color-light);
  color: var(--td-error-color);
}

.refund-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.refund-reason {
  flex: 1;
  margin-right: var(--spacer-md);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacer-sm) var(--spacer-md);
  padding-bottom: calc(var(--spacer-sm) + env(safe-area-inset-bottom));
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-md);
  z-index: var(--z-index-fixed);
  border-top: 1rpx solid var(--td-bg-color-secondarycontainer);
}

.empty-view {
  padding-top: 200rpx;
}
