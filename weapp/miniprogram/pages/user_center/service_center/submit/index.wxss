@import '../../../../styles/customer.wxss';

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ========== Result ========== */
.result-container {
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-top: 12rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
}

.result-amount {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 16rpx;
  padding: 24rpx 48rpx;
  background: #f0faf0;
  border-radius: 12rpx;
}

.result-amount-label {
  font-size: 24rpx;
  color: #999;
}

.result-amount-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2e7d32;
}

.result-eta,
.result-warning {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.result-warning {
  color: #ff9800;
}

/* ========== Form ========== */
.form-container {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.type-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.type-badge-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.type-badge-icon.type-foreign-object {
  background: linear-gradient(135deg, #ff9a56, #ff6b00);
}
.type-badge-icon.type-damage {
  background: linear-gradient(135deg, #ff7eb3, #ff4081);
}
.type-badge-icon.type-timeout {
  background: linear-gradient(135deg, #64b5f6, #1976d2);
}

.type-badge-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.amount-hint {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
  margin-left: 8rpx;
}

/* Order selection */
.select-order-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx dashed #ddd;
}

.select-order-text {
  font-size: 28rpx;
  color: #0052D9;
}

.selected-order {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.order-no {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.order-amount {
  font-size: 24rpx;
  color: #999;
}

/* Amount input */
.amount-input-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.amount-prefix {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.amount-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* Submit */
.submit-area {
  margin-top: 16rpx;
}

/* Animation */
.animate-fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
