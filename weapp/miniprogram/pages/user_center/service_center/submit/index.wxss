@import '../../../../styles/customer.wxss';

.page-container {
  min-height: 100vh;
  background: var(--td-bg-color-page);
  padding-bottom: var(--submit-content-bottom-offset, 0rpx);
}

/* ========== Result ========== */
.result-container {
  margin-top: calc(-1 * var(--spacer-sm));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-detail-card {
  width: 100%;
  margin-top: var(--spacer-lg);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.result-detail-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  line-height: 1.6;
}

.result-amount {
  display: flex;
  flex-direction: column;
  padding: var(--spacer-md);
  background: var(--td-success-color-light);
  border-radius: var(--radius-sm);
}

.result-amount-label {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-secondary);
}

.result-amount-value {
  font-size: var(--font-size-display);
  font-weight: 700;
  color: var(--td-success-color);
}

.result-eta,
.result-warning {
  display: flex;
  align-items: center;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.result-warning {
  color: var(--td-warning-color);
}

.result-action {
  margin-top: var(--spacer-lg) !important;
}

.result-actions {
  width: 100%;
  margin-top: var(--spacer-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.result-action-error {
  margin-top: var(--spacer-sm);
  font-size: var(--font-size-sm);
  color: var(--td-error-color);
  text-align: center;
  line-height: 1.5;
}

/* ========== Form ========== */
.form-container {
  margin-top: calc(-1 * var(--spacer-sm));
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.field-group--textarea {
  background: var(--td-bg-color-container);
  box-sizing: border-box;
}

.field-label {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-primary);
  padding: var(--spacer-md) var(--spacer-md) var(--spacer-sm);
}

.claim-textarea {
  --td-textarea-background-color: var(--td-bg-color-container);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-index-fixed);
  padding: var(--spacer-sm) 0 calc(var(--spacer-sm) + var(--safe-area-bottom));
  background: var(--td-bg-color-container);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* ========== Order Picker ========== */
.order-picker {
  max-height: 72vh;
  padding-bottom: var(--popup-bottom-padding-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  box-sizing: border-box;
  overflow: hidden;
}

.order-picker-close {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: var(--spacer-md) var(--spacer-md) var(--spacer-xs);
}

.order-picker-state {
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-picker-list {
  max-height: 54vh;
}

/* Animation */
.animate-fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
