<custom-navbar title="{{pageTitle}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav" style="--page-shell-nav-height: {{navBarHeight}}px; --submit-content-bottom-offset: {{submitResult ? 0 : 112}}rpx;">
  <!-- 提交成功结果 -->
  <view wx:if="{{submitResult}}" class="result-container animate-fade-in">
    <t-result theme="{{resultTheme}}" title="{{resultTitle}}" description="{{resultSummary}}" />

    <view class="result-detail-card">
      <text wx:if="{{submitResult.reason}}" class="result-detail-text">{{submitResult.reason}}</text>
      <view wx:if="{{submitResult.approved_amount}}" class="result-amount">
        <text class="result-amount-label">赔付金额</text>
        <text class="result-amount-value">¥{{approvedAmountDisplay}}</text>
      </view>

      <view wx:if="{{submitResult.payout_eta}}" class="result-eta">
        <text>预计赔付时间：{{submitResult.payout_eta}}</text>
      </view>

      <view wx:if="{{submitResult.warning}}" class="result-warning">
        <text>{{submitResult.warning}}</text>
      </view>
    </view>

    <view wx:if="{{canConfirmContinueResult}}" class="result-actions">
      <t-button theme="primary" block loading="{{resultActionSubmitting}}" disabled="{{resultActionSubmitting}}" bindtap="onConfirmContinueFromResult">
        继续申请赔付
      </t-button>
      <t-button theme="danger" variant="outline" block disabled="{{resultActionSubmitting}}" bindtap="onWithdrawFromResult">
        撤回本次索赔
      </t-button>
      <t-button theme="default" variant="text" block disabled="{{resultActionSubmitting}}" bindtap="onViewClaimDetail">
        查看工单详情
      </t-button>
    </view>

    <t-button wx:else theme="primary" block bindtap="onBackToCenter" t-class="result-action">
      返回客服中心
    </t-button>

    <text wx:if="{{resultActionError}}" class="result-action-error">{{resultActionError}}</text>
  </view>

  <!-- 提交表单 -->
  <view wx:else class="form-container">
    <view class="field-group">
      <t-cell
        wx:if="{{selectedOrder}}"
        title="{{selectedOrder.merchantName}}"
        note="¥{{selectedOrder.amountDisplay}}"
        arrow
        hover
        bindtap="onSelectOrder"
      />
      <t-cell
        wx:else
        title="选择可索赔订单"
        arrow
        hover
        bindtap="onSelectOrder"
      />
    </view>

    <view class="field-group">
      <t-cell title="索赔金额" note="{{selectedOrder ? '¥' + selectedOrder.amountDisplay : '-'}}" />
    </view>

    <view class="field-group field-group--textarea">
      <view class="field-label">问题描述</view>
      <t-textarea
        class="claim-textarea"
        placeholder="请详细描述您遇到的问题（至少5个字）"
        maxlength="{{1000}}"
        value="{{reasonInput}}"
        bind:change="onReasonInput"
        autosize
      />
    </view>
  </view>
</view>

<view wx:if="{{!submitResult}}" class="bottom-bar">
  <t-button
    theme="primary"
    block
    loading="{{submitting}}"
    disabled="{{!canSubmit}}"
    bindtap="onSubmit"
  >提交</t-button>
</view>

<t-popup
  visible="{{orderPickerVisible}}"
  placement="bottom"
  close-on-overlay-click="{{true}}"
  using-custom-navbar="{{true}}"
  bind:visible-change="onOrderPickerVisibleChange"
>
  <view class="order-picker">
    <view class="order-picker-close">
      <t-icon name="close" size="44rpx" bind:click="closeOrderPicker" />
    </view>

    <view wx:if="{{orderCandidatesLoading}}" class="order-picker-state">
      <t-loading theme="circular" size="40rpx" text="正在加载订单" />
    </view>

    <t-empty wx:elif="{{orderCandidatesError}}" icon="info-circle" description="{{orderCandidatesError}}">
      <t-button slot="action" theme="primary" variant="text" bindtap="onRetryClaimOrders">重试</t-button>
    </t-empty>

    <t-empty wx:elif="{{orderCandidates.length === 0}}" icon="order-adjustment" description="暂无可索赔订单" />

    <scroll-view wx:else scroll-y class="order-picker-list">
      <t-cell
        wx:for="{{orderCandidates}}"
        wx:key="id"
        title="{{item.merchantName}}"
        note="¥{{item.amountDisplay}}"
        right-icon="{{item.selected ? 'check-circle-filled' : ''}}"
        hover
        data-id="{{item.id}}"
        bindtap="onChooseOrder"
      />
    </scroll-view>
  </view>
</t-popup>
