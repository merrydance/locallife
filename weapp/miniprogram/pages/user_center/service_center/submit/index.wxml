<custom-navbar title="{{pageTitle}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <!-- 提交成功结果 -->
  <view wx:if="{{submitResult}}" class="result-container animate-fade-in">
    <view class="result-card">
      <t-icon
        name="{{resultIcon}}"
        size="120rpx"
        color="{{resultColor}}"
      />
      <text class="result-title">{{resultTitle}}</text>
      <text class="result-desc">{{submitResult.reason}}</text>

      <view wx:if="{{submitResult.approved_amount}}" class="result-amount">
        <text class="result-amount-label">赔付金额</text>
        <text class="result-amount-value">¥{{approvedAmountDisplay}}</text>
      </view>

      <view wx:if="{{submitResult.refund_eta}}" class="result-eta">
        <t-icon name="time" size="28rpx" color="#666" />
        <text>预计到账：{{submitResult.refund_eta}}</text>
      </view>

      <view wx:if="{{submitResult.warning}}" class="result-warning">
        <t-icon name="error-circle" size="28rpx" color="#ff9800" />
        <text>{{submitResult.warning}}</text>
      </view>
    </view>

    <t-button theme="primary" shape="round" block bindtap="onBackToCenter" style="margin-top: 48rpx;">
      返回客服中心
    </t-button>
  </view>

  <!-- 提交表单 -->
  <view wx:else class="form-container">
    <!-- 问题类型标签 -->
    <view class="type-badge">
      <view class="type-badge-icon {{typeClass}}">
        <t-icon name="{{typeIcon}}" size="36rpx" />
      </view>
      <text class="type-badge-text">{{claimTypeText}}</text>
    </view>

    <!-- 选择关联订单 -->
    <view class="form-card">
      <view class="card-title">关联订单</view>
      <view wx:if="{{selectedOrder}}" class="selected-order" bindtap="onSelectOrder">
        <view class="order-info">
          <text class="order-no">{{selectedOrder.orderNo}}</text>
          <text class="order-amount">¥{{selectedOrder.amountDisplay}}</text>
        </view>
        <t-icon name="chevron-right" size="36rpx" color="#999" />
      </view>
      <view wx:else class="select-order-btn" bindtap="onSelectOrder">
        <t-icon name="add" size="36rpx" color="#0052D9" />
        <text class="select-order-text">选择已完成的订单</text>
      </view>
    </view>

    <!-- 索赔金额 -->
    <view class="form-card">
      <view class="card-title">
        索赔金额
        <text wx:if="{{selectedOrder}}" class="amount-hint">(最高 ¥{{selectedOrder.amountDisplay}})</text>
      </view>
      <view class="amount-input-wrapper">
        <text class="amount-prefix">¥</text>
        <input
          class="amount-input"
          type="digit"
          placeholder="请输入索赔金额"
          value="{{amountInput}}"
          bindinput="onAmountInput"
        />
      </view>
    </view>

    <!-- 问题描述 -->
    <view class="form-card">
      <view class="card-title">问题描述</view>
      <t-textarea
        placeholder="请详细描述您遇到的问题（至少5个字）"
        maxlength="{{1000}}"
        value="{{reasonInput}}"
        bind:change="onReasonInput"
        autosize
        style="--td-textarea-background-color: #f8f8f8; border-radius: 12rpx;"
      />
    </view>

    <!-- 提交按钮 -->
    <view class="submit-area">
      <t-button
        theme="primary"
        shape="round"
        block
        loading="{{submitting}}"
        disabled="{{!canSubmit}}"
        bindtap="onSubmit"
      >
        提交
      </t-button>
    </view>
  </view>
</view>
