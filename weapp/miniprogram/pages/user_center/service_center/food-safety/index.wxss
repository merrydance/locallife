@import '../../../../styles/customer.wxss';

.page-container {
  --page-shell-bottom-offset: var(--spacer-md);
  --page-shell-nav-gap: var(--spacer-xs);
}

.loading-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-lg);
  padding: var(--spacer-xl) 0;
}

.form-container {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
  margin-top: calc(-1 * var(--spacer-sm));
}

.result-container {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.field-group {
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.order-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacer-sm) var(--spacer-md);
}

.order-main {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-xs);
  min-width: 0;
}

.order-title {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.order-subtitle {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.field-label {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
  padding: var(--spacer-sm) var(--spacer-md) var(--spacer-xs);
}

.option-group {
  display: flex;
  flex-direction: column;
}

.food-radio {
  --td-radio-vertical-padding: var(--spacer-xs) var(--spacer-md);
  --td-radio-icon-size: 40rpx;
  --td-radio-label-line-height: 44rpx;
  --td-radio-font: var(--font-size-base) / 44rpx var(--td-font-family, PingFang SC, Microsoft YaHei, Arial Regular);
}

.food-textarea {
  --td-textarea-padding: var(--spacer-xs) var(--spacer-md) var(--spacer-sm);
  --td-textarea-background-color: var(--td-bg-color-container);
}

.form-error {
  font-size: var(--font-size-sm);
  color: var(--td-error-color);
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-sm);
  background: var(--td-bg-color-container);
  box-shadow: var(--shadow-sm);
  padding: var(--spacer-xl) var(--spacer-lg);
}

.result-title {
  font-size: var(--font-size-title);
  font-weight: 700;
  color: var(--td-text-color-primary);
}

.result-desc,
.result-meta {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  text-align: center;
  line-height: 1.6;
}

.result-meta {
  color: var(--td-text-color-placeholder);
}
