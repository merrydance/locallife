@import '../../../styles/customer.wxss';

/* Pages User Center Addresses */
.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
}

.mode-tip {
  margin: var(--spacer-sm) var(--spacer-md) 0;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  color: var(--td-brand-color);
  background: var(--td-brand-color-light);
}

.loading {
  padding: 60rpx;
  text-align: center;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Empty State */
.empty-state {
  padding-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-tip {
  margin-top: 16rpx;
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-sm);
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  margin-top: var(--spacer-xl);
  width: 60%;
}

/* List */
.address-list {
  padding: var(--spacer-md);
}

/* Card */
.address-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  padding: 0 var(--spacer-md);
  margin-bottom: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  overflow: hidden;
}

.card-hover {
  transform: scale(0.99);
  background: var(--td-bg-color-secondarycontainer);
}

.card-main {
  padding: 28rpx 0;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacer-sm);
}

.user-info {
  display: flex;
  align-items: baseline;
  gap: var(--spacer-sm);
}

.name {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
}

.phone {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  font-family: 'DIN Alternate', sans-serif;
}

.address-detail {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  line-height: 1.5;
}

.select-hint {
  margin-top: 10rpx;
  font-size: var(--font-size-sm);
  color: var(--td-brand-color);
}

.region-row {
  margin-bottom: 8rpx;
}

.region-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

/* Actions */
.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.action-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
}

.action-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.action-text.active {
  color: var(--td-brand-color);
}

.action-right {
  display: flex;
  gap: var(--spacer-lg);
}

.btn-icon {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  padding: 10rpx;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--td-bg-color-container);
  padding: var(--spacer-md) var(--spacer-lg) calc(var(--spacer-md) + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: var(--z-index-fixed);
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.wechat-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--spacer-xs);
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  padding: 12rpx 0;
}

.wechat-tip {
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.address-skeleton-list {
  padding: var(--spacer-md);
}

.skeleton-item {
  margin-bottom: var(--spacer-md);
}
