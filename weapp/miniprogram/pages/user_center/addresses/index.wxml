<custom-navbar title="{{isSelectMode ? '选择收货地址' : '地址管理'}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 180rpx;">
  <view wx:if="{{isSelectMode}}" class="mode-tip">请选择用于本次下单的收货地址</view>
  
  <!-- 错误状态 -->
  <view wx:if="{{error && !initialLoading}}" class="error-container">
    <t-empty icon="info-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
    </t-empty>
  </view>

  <block wx:else>
    <!-- Loading State (Skeleton) -->
    <view wx:if="{{initialLoading}}" class="address-skeleton-list">
      <list-skeleton row="5" t-class="skeleton-item" />
    </view>

    <!-- Empty State -->
    <view wx:elif="{{addresses.length === 0}}" class="empty-state animate-fade-in">
      <t-empty image="/assets/icons/empty.svg" description="{{isSelectMode ? '暂无可用收货地址' : '还没有收货地址'}}" />
      <text class="empty-tip">可新建地址，或从微信导入后直接保存</text>
    </view>

    <!-- Address List -->
    <view wx:else class="address-list animate-fade-in">
      <block wx:for="{{addresses}}" wx:key="id">
        <view class="address-card {{isSelectMode ? 'selectable' : ''}}">
          <view
            class="card-main"
            bindtap="onSelectAddress"
            data-id="{{item.id}}"
            hover-class="{{isSelectMode ? 'card-main-hover' : 'none'}}"
          >
            <view class="info-header">
               <view class="user-info">
                 <text class="name">{{item.contact_name}}</text>
                 <text class="phone">{{item.contact_phone}}</text>
               </view>
               <t-tag wx:if="{{item.is_default}}" size="small" variant="dark" theme="primary">默认</t-tag>
            </view>
            
            <view class="region-row" wx:if="{{item.region_name}}">
              <text class="region-text">{{item.region_name}}</text>
            </view>
            <view class="address-detail">
               <text>{{item.detail_address}}</text>
            </view>

            <view wx:if="{{isSelectMode}}" class="select-hint">点击使用该地址</view>
          </view>

          <t-divider dashed />

          <view class="card-actions" catchtap="preventBubble">
            <view class="action-left">
              <t-button
                wx:if="{{!isSelectMode}}"
                size="small"
                variant="text"
                theme="{{item.is_default ? 'primary' : 'default'}}"
                icon="{{item.is_default ? 'check-circle-filled' : 'circle'}}"
                catchtap="onSetDefault"
                data-id="{{item.id}}"
                t-class="action-btn"
              >{{item.is_default ? '默认地址' : '设为默认'}}</t-button>
            </view>

            <view class="action-right">
              <t-button size="small" variant="text" icon="edit" catchtap="onEditAddress" data-id="{{item.id}}" t-class="action-btn">编辑</t-button>
              <t-button size="small" variant="text" theme="danger" icon="delete" catchtap="onDeleteAddress" data-id="{{item.id}}" t-class="action-btn">删除</t-button>
            </view>
          </view>
        </view>
      </block>
    </view>
  </block>
</view>

<!-- Bottom Fixed Bar -->
<view class="bottom-bar">
  <t-button block theme="primary" size="large" shape="round" icon="add" bindtap="onAddAddress">{{isSelectMode ? '新建并使用地址' : '新建收货地址'}}</t-button>
  <t-button block theme="default" variant="outline" size="large" shape="round" icon="logo-wechat" bindtap="onImportWechatAddress">{{isSelectMode ? '微信导入并使用' : '从微信导入'}}</t-button>
</view>
