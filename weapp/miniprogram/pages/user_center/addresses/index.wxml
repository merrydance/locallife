<custom-navbar title="{{isSelectMode ? '选择收货地址' : '地址管理'}}" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: calc(180rpx + env(safe-area-inset-bottom));">
  <view wx:if="{{isSelectMode}}" class="mode-tip">请选择用于本次下单的收货地址</view>
  
  <!-- 错误状态 -->
  <view wx:if="{{error && !initialLoading}}" class="error-container">
    <t-empty icon="info-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round" variant="outline">重试</t-button>
    </t-empty>
  </view>

  <block wx:else>
    <!-- Loading State (Skeleton) -->
    <view wx:if="{{initialLoading}}" class="address-skeleton-list">
      <list-skeleton row="5" t-class="skeleton-item" />
    </view>

    <!-- Empty State -->
    <view wx:elif="{{addresses.length === 0}}" class="empty-state animate-fade-in">
      <t-empty image="/assets/icons/empty.svg" description="{{isSelectMode ? '暂无可用收货地址' : '还没有收货地址'}}" />
      <text class="empty-tip">可新建地址，或从微信导入后补充地图定位</text>
    </view>

    <!-- Address List -->
    <view wx:else class="address-list animate-fade-in">
      <block wx:for="{{addresses}}" wx:key="id">
        <view 
          class="address-card {{isSelectMode ? 'selectable' : ''}}" 
          bindtap="onSelectAddress" 
          data-id="{{item.id}}"
          hover-class="card-hover"
        >
          <view class="card-main">
            <view class="info-header">
               <view class="user-info">
                 <text class="name">{{item.contact_name}}</text>
                 <text class="phone">{{item.contact_phone}}</text>
               </view>
               <t-tag wx:if="{{item.is_default}}" size="small" variant="light" theme="primary">默认</t-tag>
            </view>
            
            <view class="region-row" wx:if="{{item.region_name}}">
              <text class="region-text">{{item.region_name}}</text>
            </view>
            <view class="address-detail">
               <text>{{item.detail_address}}</text>
            </view>

            <view wx:if="{{isSelectMode}}" class="select-hint">点击使用该地址</view>
          </view>

          <t-divider dashed />

          <view class="card-actions" catchtap="preventBubble">
             <!-- Left: Set Default -->
             <view class="action-left" catchtap="onSetDefault" data-id="{{item.id}}" wx:if="{{!isSelectMode}}">
               <t-icon name="{{item.is_default ? 'check-circle-filled' : 'circle'}}" size="36rpx" color="{{item.is_default ? 'var(--td-brand-color)' : '#999'}}" />
               <text class="action-text {{item.is_default ? 'active' : ''}}">{{item.is_default ? '默认地址' : '设为默认'}}</text>
             </view>
             <view class="action-left" wx:else>
                <!-- Selector Placeholder -->
             </view>

             <!-- Right: Edit/Delete -->
             <view class="action-right">
               <view class="btn-icon" catchtap="onEditAddress" data-id="{{item.id}}">
                 <t-icon name="edit" size="32rpx" color="#666" />
                 <text>编辑</text>
               </view>
               <view class="btn-icon" catchtap="onDeleteAddress" data-id="{{item.id}}">
                 <t-icon name="delete" size="32rpx" color="#666" />
                 <text>删除</text>
               </view>
             </view>
          </view>
        </view>
      </block>
    </view>
  </block>
</view>

<!-- Bottom Fixed Bar -->
<view class="bottom-bar">
  <t-button block theme="primary" size="large" shape="round" icon="add" bindtap="onAddAddress">{{isSelectMode ? '新建并使用地址' : '新建收货地址'}}</t-button>
  <view class="wechat-btn" bindtap="onImportWechatAddress">
     <t-icon name="logo-wechat" size="32rpx" color="#07C160" />
     <text>{{isSelectMode ? '微信导入并补定位' : '从微信导入'}}</text>
  </view>
  <text class="wechat-tip">导入后需在编辑页完成地图定位，确保坐标准确</text>
</view>
