@import '../../../../styles/customer.wxss';

/* Pages User Center Addresses Edit */
.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
}

.form-title {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  margin: var(--spacer-lg) 0 var(--spacer-sm) var(--spacer-sm);
}

.form-title--first {
  margin-top: 0;
}

.form-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.default-card {
  margin-top: var(--spacer-lg);
}

.form-hint {
  margin: 16rpx 8rpx 0;
  color: var(--td-text-color-secondary);
  font-size: var(--font-size-sm);
  line-height: 1.5;
}

.form-group {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--spacer-md);
}

.gender-group {
  padding: 0 var(--spacer-lg);
  background: var(--td-bg-color-container);
}

.map-placeholder {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  color: var(--td-text-color-placeholder);
  font-size: var(--font-size-base);
}
.map-placeholder.has-value {
  color: var(--td-text-color-primary);
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--td-bg-color-container);
  padding: var(--spacer-md) var(--spacer-lg) calc(var(--spacer-md) + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: var(--z-index-fixed);
  display: flex;
  gap: var(--spacer-md);
}

.delete-section {
  display: flex;
  justify-content: center;
  margin-top: var(--spacer-lg);
}

/* weapp-gate allow-tdesign-internal-class: 地址编辑页单选组需要横向紧凑排布，待抽成地址偏好选项容器后移除 */
.t-radio-group {
  display: flex;
  gap: var(--spacer-lg);
}

/* weapp-gate allow-tdesign-internal-class: 地址表单暂时依赖内部 label 颜色统一，待迁到显式 label 文本后移除 */
.t-input__label {
  color: var(--td-text-color-primary) !important;
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.form-skeleton {
  padding: 0;
}

.skeleton-item {
  margin-bottom: var(--spacer-md);
}
