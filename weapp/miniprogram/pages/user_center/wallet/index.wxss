@import '../../../styles/customer.wxss';
@import "../../../styles/wallet-skeleton.wxss";

.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  padding: 0 var(--spacer-md) var(--spacer-lg); /* Added horizontal and bottom padding */
  box-sizing: border-box;
}

.balance-card {
  background-color: var(--td-bg-color-page);
  padding: 0 var(--spacer-md);
}

/* 总资产卡片 */
.header-section {
  padding-top: var(--spacer-md);
  margin-bottom: var(--spacer-md);
}

.total-balance-card {
  position: relative;
  height: 320rpx;
  background: linear-gradient(135deg, #FF6B58 0%, #FF8E7F 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacer-lg);
  color: #FFFFFF;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 88, 0.3);
  box-sizing: border-box;
}

.card-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.balance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.balance-header .label {
  font-size: var(--font-size-sm);
  opacity: 0.9;
}

.balance-display {
  display: flex;
  align-items: baseline;
  margin: 16rpx 0;
}

.balance-display .symbol {
  font-size: var(--font-size-title);
  margin-right: 8rpx;
}

.balance-display .amount {
  font-size: var(--font-size-display);
  font-weight: bold;
  letter-spacing: 2rpx;
}

.balance-stats {
  display: flex;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: var(--font-size-xxs);
  opacity: 0.8;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: var(--font-size-base);
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 var(--spacer-md);
}

.card-bg-decoration {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  z-index: 1;
}

.card-bg-decoration::after {
  content: '';
  position: absolute;
  left: -80rpx;
  bottom: -160rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

/* 快捷操作栏 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: var(--td-bg-color-container);
  padding: var(--spacer-md) 0;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacer-md);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md); /* Changed to small round for modern look */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  background: #FFF5F3; /* Light brand background */
  transition: all 0.2s ease;
}

.icon-wrap.withdraw { background: #F5F5F5; }
.icon-wrap.coupon { background: #FFF9F0; }
.icon-wrap.bill { background: #F0FFF4; }

.action-item:active .icon-wrap {
  transform: scale(0.9);
  opacity: 0.8;
}

.action-item text {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-primary);
}

.action-item text.disabled {
  color: var(--td-text-color-placeholder);
}

/* 通用区块样式 */
.section-container {
  margin-top: var(--spacer-md);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacer-sm);
  padding: 0 8rpx;
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.section-more {
  display: flex;
  align-items: center;
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

/* 资产列表 */
.asset-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.asset-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-md);
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.asset-info {
  display: flex;
  align-items: center;
}

.asset-logo {
  border: 4rpx solid #F0F0F0;
  margin-right: var(--spacer-md);
}

.asset-meta {
  display: flex;
  flex-direction: column;
}

.asset-name {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--td-text-color-primary);
}

.asset-date {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
  margin-top: 4rpx;
}

.asset-balance {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.asset-amount {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-brand-color);
  margin-bottom: 8rpx;
}

/* 交易列表 */
.transactions-list {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: 0 var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacer-md) 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.transaction-item:last-child {
  border-bottom: none;
}

.transaction-left {
  display: flex;
  align-items: center;
}

.type-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #F0F7FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacer-md);
  color: #0052D9;
}

.type-icon.REFUND {
  background: #FFF0ED;
  color: #E53935;
}

.transaction-info {
  display: flex;
  flex-direction: column;
}

.transaction-title {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  margin-bottom: 4rpx;
}

.transaction-time {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

.transaction-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.transaction-amount {
  font-size: var(--font-size-heading);
  font-weight: 600;
  margin-bottom: 4rpx;
}

.transaction-amount.positive {
  color: var(--td-success-color);
}

.transaction-amount.negative {
  color: var(--td-text-color-primary);
}

/* 动画 */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 错误与加载容器 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-wrap {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--td-text-color-placeholder);
}
