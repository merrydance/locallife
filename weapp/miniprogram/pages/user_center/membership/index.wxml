<custom-navbar title="我的会员" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: calc(40rpx + env(safe-area-inset-bottom));">
  
  <!-- 错误状态 -->
  <view wx:if="{{error && !initialLoading}}" class="error-container">
    <t-empty icon="info-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
    </t-empty>
  </view>

  <block wx:else>
    <!-- Loading (Skeleton) -->
    <view wx:if="{{initialLoading}}" class="membership-skeleton-list">
      <list-skeleton row="3" t-class="skeleton-item" />
    </view>

    <!-- Content -->
    <view wx:else class="content animate-fade-in">
      
      <!-- Membership Cards List -->
      <view wx:if="{{memberships.length > 0}}" class="card-list">
        <block wx:for="{{memberships}}" wx:key="id">
          <view class="member-card" bindtap="onCardTap" data-id="{{item.id}}">
            <!-- Decorative Background Circles -->
            <view class="card-bg-circle circle-1"></view>
            <view class="card-bg-circle circle-2"></view>

            <!-- Card Header -->
            <view class="card-header">
              <view class="merchant-info">
                <t-image src="{{item.logoUrl}}" mode="aspectFill" width="60rpx" height="60rpx" class="merchant-logo" shape="circle" />
                <text class="merchant-name">{{item.merchantName}}</text>
              </view>
              <view class="vip-badge">
                <t-icon name="diamond" size="24rpx" color="#7A5C26" />
                <text>VIP会员</text>
              </view>
            </view>

            <!-- Card Body: Balance -->
            <view class="card-body">
              <view class="balance-label">账户余额</view>
              <view class="balance-value">
                <text class="symbol">¥</text>
                <text class="amount">{{item.balanceDisplay}}</text>
              </view>
            </view>

            <!-- Card Footer: Stats -->
            <view class="card-footer">
              <view class="stat-item">
                <text class="stat-label">累计充值</text>
                <text class="stat-value">¥{{item.totalRechargedDisplay}}</text>
              </view>
              <view class="stat-divider"></view>
              <view class="stat-item">
                <text class="stat-label">累计消费</text>
                <text class="stat-value">¥{{item.totalConsumedDisplay}}</text>
              </view>
              
              <view class="action-btn {{rechargingMembershipId === item.id ? 'is-loading' : ''}}" catchtap="onRechargeTap" data-item="{{item}}">
                <text>{{rechargingMembershipId === item.id ? '处理中' : '立即充值'}}</text>
                <t-icon name="chevron-right" size="24rpx" color="#fff" />
              </view>
            </view>
          </view>
        </block>
        
        <view class="load-more-wrap" wx:if="{{loading}}">
          <t-loading theme="circular" size="32rpx" text="正在加载..." />
        </view>
      </view>

      <!-- Empty State -->
      <view wx:else class="empty-state">
        <t-empty image="/assets/icons/empty.svg" description="暂无会员卡" />
        <view class="empty-tips">去喜欢的餐厅看看，加入会员享受优惠吧</view>
        <t-button theme="primary" size="medium" shape="round" bindtap="onGoHome" class="empty-btn">去逛逛</t-button>
      </view>

    </view>
  </block>
</view>
