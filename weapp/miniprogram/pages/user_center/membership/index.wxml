<custom-navbar title="会员中心" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px;">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" class="loading" />

  <view wx:if="{{!loading}}" class="content">
    <!-- 会员卡列表 -->
    <view wx:if="{{memberships.length > 0}}" class="membership-list">
      <view class="member-card" wx:for="{{memberships}}" wx:key="id">
        <view class="card-header">
          <text class="merchant-name">{{item.merchantName}}</text>
          <text class="balance">¥{{item.balanceDisplay}}</text>
        </view>
        <view class="card-body">
          <view class="meta-row">
            <text class="meta-label">累计充值</text>
            <text class="meta-value">¥{{item.totalRechargedDisplay}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-label">累计消费</text>
            <text class="meta-value">¥{{item.totalConsumedDisplay}}</text>
          </view>
        </view>
      </view>
    </view>
    <t-empty wx:else description="暂无会员卡" />

    <!-- 会员权益 -->
    <view class="benefits-section">
      <view class="section-title">会员权益</view>
      <view class="benefits-grid">
        <view wx:for="{{benefits}}" wx:key="name" class="benefit-item">
          <view class="benefit-icon">
            <t-icon name="{{item.icon}}" size="48rpx" color="#E34D59" />
          </view>
          <text class="benefit-name">{{item.name}}</text>
          <text class="benefit-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
