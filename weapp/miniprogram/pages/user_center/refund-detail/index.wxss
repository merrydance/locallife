@import '../../../styles/customer.wxss';

.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  padding-left: var(--spacer-md);
  padding-right: var(--spacer-md);
}

.loading-center {
  padding-top: 200rpx;
  display: flex;
  justify-content: center;
}

.detail-content {
  padding: var(--spacer-md) 0;
}

/* 状态卡片 */
.status-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--spacer-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacer-md);
}

.status-content {
  display: flex;
  align-items: center;
}

.status-badge {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--td-brand-color-light);
  color: var(--td-brand-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacer-md);
}

.status-card.success .status-badge { background: var(--td-success-color-light); color: var(--td-success-color); }
.status-card.processing .status-badge { background: var(--td-warning-color-light); color: var(--td-warning-color); }
.status-card.failed .status-badge { background: var(--td-error-color-light); color: var(--td-error-color); }
.status-card.default .status-badge { background: #eef1f6; color: var(--td-text-color-secondary); }

.status-main {
  display: flex;
  flex-direction: column;
}

.status-text {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  margin-bottom: 4rpx;
}

.amount-display {
  display: flex;
  align-items: baseline;
}

.amount-display .symbol {
  font-size: var(--font-size-title);
  font-weight: 600;
  margin-right: 4rpx;
}

.amount-display .amount-val {
  font-size: var(--font-size-display);
  font-weight: bold;
}

/* 区块通用 */
.section-container {
  margin-top: var(--spacer-lg);
}

.section-title {
  font-size: var(--font-size-heading);
  font-weight: 600;
  margin-bottom: var(--spacer-sm);
  padding-left: 8rpx;
}

.refund-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-sm);
}

.refund-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
}

.refund-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.refund-card-amount {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.refund-card-status {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.refund-card-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.refund-reason {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
}

.refund-time {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

/* 进度步骤条 */
.progress-box {
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: var(--spacer-lg);
  box-shadow: var(--shadow-sm);
}

.step-item {
  position: relative;
  display: flex;
  padding-bottom: var(--spacer-lg);
}

.step-item:last-child {
  padding-bottom: 0;
}

.step-line {
  position: absolute;
  left: 15rpx;
  top: 30rpx;
  bottom: -10rpx;
  width: 2rpx;
  font-size: 24rpx;
  color: #9aa4c2;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(18, 30, 63, 0.08);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.label {
  font-size: 28rpx;
  color: #9aa4c2;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #1d2750;
  text-align: right;
  max-width: 65%;
  word-break: break-all;
}

.value.error {
  color: #e34d59;
}

/* 提示卡片 */
.tips-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff9e6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #865900;
}

.empty-center {
  padding-top: 200rpx;
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.detail-skeleton {
  padding: var(--spacer-md) 0;
}

.skeleton-item {
  margin-bottom: var(--spacer-md);
}
