<custom-navbar title="我的评价" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view wx:if="{{initialLoading}}" class="skeleton-wrap">
    <t-skeleton 
      wx:for="{{3}}" 
      wx:key="index"
      rowCol="{{ [ { size: '48rpx', type: 'rect' }, { width: '40%' }, { height: '160rpx', width: '100%' } ] }}" 
      t-class="skeleton-item" 
    />
  </view>

  <block wx:else>
    <view wx:if="{{error}}" class="state-wrap">
      <t-empty icon="info-circle" description="{{error}}" />
      <t-button theme="primary" size="small" shape="round" bindtap="onRetry">重试</t-button>
    </view>

    <view wx:elif="{{reviews.length === 0}}" class="empty-state">
      <t-empty icon="chat" description="还没有评价过订单" />
      <t-button theme="primary" size="small" shape="round" bindtap="onGoHome">去探索美食</t-button>
    </view>

    <scroll-view 
      wx:else
      scroll-y 
      class="review-scroll"
      bindscrolltolower="onReachBottom"
      refresher-enabled
      bindrefresherrefresh="onPullDownRefresh"
      refresher-triggered="{{refreshing}}"
    >
      <view class="list-inner">
        <view
          class="review-card"
          wx:for="{{reviews}}" 
          wx:key="id"
        >
          <view class="card-header" bindtap="onMerchantClick" data-id="{{item.merchantId}}">
            <view class="merchant-main">
              <view class="merchant-copy">
                <view class="shop-title">
                  <text class="name">{{item.merchantName}}</text>
                  <t-icon name="chevron-right" size="32rpx" color="var(--td-text-color-placeholder)" />
                </view>
                <text class="order-label">{{item.orderIdLabel}}</text>
              </view>
            </view>
            <view class="date">{{item.createdAt}}</view>
          </view>

          <view class="card-body">
            <view class="content-text">{{item.content}}</view>
            
            <view class="media-grid" wx:if="{{item.images.length > 0}}">
              <view 
                class="media-item {{item.images.length === 1 ? 'large' : ''}}"
                wx:for="{{item.images}}"
                wx:for-item="img"
                wx:for-index="imageIndex"
                wx:key="*this"
                catchtap="onImagePreview"
                data-review-id="{{item.id}}"
                data-image-index="{{imageIndex}}"
              >
                <t-image class="review-image" src="{{img}}" mode="aspectFill" />
              </view>
            </view>
          </view>

          <view class="reply-box" wx:if="{{item.merchantReply}}">
            <view class="reply-header">
              <text class="label">商家回复</text>
              <text class="reply-date">{{item.repliedAt}}</text>
            </view>
            <view class="reply-content">{{item.merchantReply}}</view>
          </view>

          <view class="card-footer">
            <view class="footer-tabs">
              <view class="footer-tab" data-id="{{item.id}}" bindtap="onEditReview" hover-class="footer-tab--active">
                <t-icon name="edit" size="36rpx" color="var(--td-text-color-primary)" />
                <text>编辑</text>
              </view>
              <view class="footer-tab footer-tab--delete {{item.deleting ? 'footer-tab--disabled' : ''}}" data-id="{{item.id}}" bindtap="onDeleteReview" hover-class="footer-tab--active">
                <t-icon wx:if="{{!item.deleting}}" name="delete" size="36rpx" color="var(--td-error-color)" />
                <t-loading wx:else theme="circular" size="32rpx" />
                <text>删除</text>
              </view>
            </view>
          </view>
        </view>

        <view class="load-more" wx:if="{{loading && !refreshing}}">
          <t-loading theme="circular" size="32rpx" text="正在加载..." />
        </view>
        <view class="no-more" wx:if="{{!hasMore && reviews.length > 0}}">
          已加载全部评价
        </view>
      </view>
    </scroll-view>
  </block>

  <t-dialog
    visible="{{deleteDialogVisible}}"
    title="删除评价"
    using-custom-navbar="{{true}}"
    confirm-btn="{{ { content: '确认删除', theme: 'danger', loading: deleteDialogSubmitting } }}"
    cancel-btn="取消"
    bind:confirm="onConfirmDeleteReview"
    bind:cancel="onCancelDeleteDialog"
    bind:close="onCancelDeleteDialog"
  >
    <view slot="content" class="delete-dialog-content">
      <text>删除后无法恢复，确定删除对“{{deleteDialogMerchantName}}”的这条评价吗？</text>
    </view>
  </t-dialog>

</view>
