.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--td-bg-color-page);
}

.review-scroll {
  flex: 1;
  height: 0;
}

.list-inner {
  padding: 24rpx;
}

/* 评价卡片 */
.review-card {
  background: var(--td-bg-color-container);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.shop-title {
  display: flex;
  align-items: center;
}

.shop-title .name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin: 0 8rpx;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-header .date {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder);
}

/* Gap 2: 标签行 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
  margin-bottom: 18rpx;
}

.card-body .content-text {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  line-height: 1.6;
  margin-bottom: 24rpx;
  word-wrap: break-word;
}

/* 媒体展示 */
.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.media-item {
  width: calc((100% - 24rpx) / 3);
  height: 200rpx;
  background: var(--td-bg-color-component);
  border-radius: 12rpx;
  overflow: hidden;
}

.media-item.large {
  width: 400rpx;
  height: 400rpx;
}

/* 商家回复 */
.reply-box {
  background: var(--td-bg-color-component);
  border-radius: 16rpx;
  padding: 2rpx;
  margin-top: 24rpx;
  position: relative;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx 8rpx;
}

.reply-header .label {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--td-brand-color);
}

.reply-header .reply-date {
  font-size: 22rpx;
  color: var(--td-text-color-disabled);
}

.reply-content {
  padding: 0 20rpx 16rpx;
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  line-height: 1.5;
}

/* 操作栏 */
.card-footer {
  margin-top: 24rpx;
  border-top: 1rpx solid var(--td-border-level-1-color);
  padding-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.visibility-status {
  display: flex;
  align-items: center;
  font-size: 22rpx;
}

.visibility-status text {
  margin-left: 6rpx;
}

.visibility-status.public {
  color: var(--td-success-color);
}

.visibility-status.audit {
  color: var(--td-warning-color);
}

/* 加载更多 */
.load-more {
  padding: 30rpx 0;
  display: flex;
  justify-content: center;
}

.no-more {
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-disabled);
  padding: 40rpx 0;
}

/* 空状态与骨架 */
.empty-state {
  padding-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.skeleton-wrap {
  padding: 24rpx;
}

.skeleton-item {
  margin-bottom: 24rpx;
}

.animate-slide-up {
  opacity: 0;
  animation: slideUp 0.4s ease-out forwards;
}

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
