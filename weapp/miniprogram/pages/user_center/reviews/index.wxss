@import '../../../styles/customer.wxss';

.page-container {
  --page-shell-nav-gap: var(--spacer-xs);
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: var(--td-bg-color-page);
}

.review-scroll {
  flex: 1;
  min-height: 0;
}

.list-inner {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
  padding: 0;
}

.review-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.card-header,
.merchant-main,
.shop-title,
.card-footer,
.footer-actions,
.reply-header {
  display: flex;
  align-items: center;
}

.card-header {
  justify-content: space-between;
  gap: var(--spacer-md);
}

.merchant-main {
  flex: 1;
  min-width: 0;
  gap: var(--spacer-sm);
}

.merchant-logo {
  flex-shrink: 0;
  background: var(--td-bg-color-secondarycontainer);
}

.merchant-copy {
  flex: 1;
  min-width: 0;
}

.shop-title {
  min-width: 0;
}

.shop-title .name {
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.order-label,
.date,
.reply-date,
.no-more {
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
}

.order-label {
  display: block;
  margin-top: var(--spacer-xs);
}

.date {
  flex-shrink: 0;
  white-space: nowrap;
}

.card-body {
  margin-top: var(--spacer-md);
}

.content-text {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
}

.media-item {
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--td-bg-color-secondarycontainer);
}

.media-item.large {
  width: 400rpx;
  height: 400rpx;
}

.reply-box {
  margin-top: var(--spacer-md);
  padding: var(--spacer-sm) var(--spacer-md);
  border-radius: var(--radius-md);
  background: var(--td-bg-color-secondarycontainer);
}

.reply-header {
  justify-content: space-between;
  gap: var(--spacer-sm);
}

.reply-header .label {
  font-size: var(--font-size-xs);
  font-weight: 600;
  color: var(--td-brand-color);
}

.reply-content {
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.card-footer {
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacer-sm);
  margin-top: var(--spacer-md);
  padding-top: var(--spacer-sm);
  border-top: 1rpx solid var(--td-border-level-1-color);
}

.footer-actions {
  flex: 1;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: var(--spacer-xs);
}

.load-more {
  padding: var(--spacer-sm) 0;
  display: flex;
  justify-content: center;
}

.no-more {
  text-align: center;
  padding: var(--spacer-md) 0;
}

.empty-state,
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacer-md);
  padding-top: 160rpx;
}

.skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

.skeleton-item {
  margin-bottom: 0;
}

.delete-dialog-content {
  font-size: var(--font-size-base);
  color: var(--td-text-color-primary);
  line-height: 1.6;
}
