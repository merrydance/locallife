.page {
  min-height: 100vh;
  padding: 0 32rpx 120rpx;
  background: #f5f6fb;
}

/* 商家卡片 */
.merchant-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(29, 39, 71, 0.06);
}

.merchant-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2750;
}

/* 通用section */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d2750;
  margin-bottom: 20rpx;
}

/* 评分选择 */
.rating-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(29, 39, 71, 0.06);
}

.rating-options {
  display: flex;
  justify-content: space-between;
}

.rating-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.rating-item.active {
  background: #e1ebff;
}

.rating-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.rating-label {
  font-size: 22rpx;
  color: #57618c;
}

.rating-item.active .rating-label {
  color: #1d63ff;
  font-weight: 600;
}

/* 评价内容 */
.content-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(29, 39, 71, 0.06);
}

.content-input {
  width: 100%;
  height: 240rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #1d2750;
  background: #f5f6fb;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.content-count {
  text-align: right;
  font-size: 24rpx;
  color: #9aa4c2;
  margin-top: 12rpx;
}

/* 图片上传 */
.images-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(29, 39, 71, 0.06);
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d0d5e8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-image text {
  font-size: 24rpx;
  color: #9aa4c2;
}

.images-tip {
  font-size: 24rpx;
  color: #9aa4c2;
  margin-top: 16rpx;
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.create-skeleton {
  padding: 32rpx 0;
}

.skeleton-item {
  margin-bottom: 24rpx;
}
