.page-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.review-create-wrap {
  padding: 30rpx;
}

/* 商家头部 */
.merchant-header {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.shop-icon {
  width: 90rpx;
  height: 90rpx;
  background: #f0f7ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.shop-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

/* 卡片布局 */
.content-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: baseline;
}

.card-title .subtitle {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
  margin-left: 12rpx;
}

.external-textarea {
  background: #f9f9f9 !important;
  border-radius: 12rpx !important;
  padding: 20rpx !important;
  font-size: 28rpx !important;
  min-height: 200rpx !important;
}

.upload-wrapper {
  margin-top: 10rpx;
}

/* 底部按钮 */
.footer-btn-wrap {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.policy-tip {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 30rpx;
}

/* 动画 */
.animate-slide-up {
  opacity: 0;
  animation: slideUp 0.5s ease-out forwards;
}

@keyframes slideUp {
  from {
    transform: translateY(30rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* ========== Gap 2: 星级评分 ========== */
.rate-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.rate-label {
  font-size: 26rpx;
  color: #FF8C00;
  font-weight: 600;
}

/* ========== Gap 2: 快捷标签 ========== */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-chip.selected {
  background: #fff0e6;
  color: #FF6B00;
  border-color: #FF6B00;
}
