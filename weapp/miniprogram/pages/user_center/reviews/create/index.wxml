<custom-navbar title="发表评价" showBack="{{true}}" />

<view class="page-container" style="padding-top: {{navBarHeight}}px">
  <view class="review-create-wrap">
    
    <!-- 1. 商家概览 -->
    <view class="merchant-header animate-slide-up">
      <view class="shop-icon">
        <t-icon name="shop" size="48rpx" color="#0052D9" />
      </view>
      <view class="shop-info">
        <view class="shop-name">{{merchantName || '餐饮商家'}}</view>
        <view class="order-no">订单号：{{orderNo || '--'}}</view>
      </view>
    </view>

    <!-- 2. 评价内容 -->
    <view class="content-card animate-slide-up" style="animation-delay: 0.1s">
      <view class="card-title">评价内容</view>
      <t-textarea
        t-class="external-textarea"
        placeholder="这一刻的想法...（至少10个字）"
        maxlength="{{maxContentLength}}"
        disableDefaultPadding="{{true}}"
        indicator
        bordered
        value="{{content}}"
        bind:change="onContentChange"
      />
    </view>

    <!-- 3. 媒体上传 -->
    <view class="content-card animate-slide-up" style="animation-delay: 0.2s">
      <view class="card-title">添加图片 <text class="subtitle">(可选，最多9张)</text></view>
      <view class="upload-wrapper">
        <t-upload
          mediaType="{{['image']}}"
          files="{{fileList}}"
          gridConfig="{{ { column: 3 } }}"
          max="{{maxImages}}"
          bind:add="onAddImage"
          bind:remove="onRemoveImage"
          bind:complete="onUploadComplete"
        />
      </view>
    </view>

    <!-- 4. 提交按钮 -->
    <view class="footer-btn-wrap animate-slide-up" style="animation-delay: 0.3s">
      <t-button 
        theme="primary" 
        size="large" 
        block 
        disabled="{{content.length < 10 || submitting}}"
        loading="{{submitting}}"
        bindtap="onSubmit"
      >
        发布评价
      </t-button>
      <view class="policy-tip">发布内容将经过系统安全审核</view>
    </view>

  </view>
</view>

<t-message id="t-message" />
