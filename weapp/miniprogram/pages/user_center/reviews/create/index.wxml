<custom-navbar title="发表评价" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px;">
  <view class="review-create-wrap">
    <view class="merchant-header animate-slide-up">
      <view class="shop-icon">
        <t-icon name="shop" size="48rpx" color="var(--td-brand-color)" />
      </view>
      <view class="shop-info">
        <view class="shop-name">{{merchantName || '餐饮商家'}}</view>
        <view class="order-no">订单号：{{orderNo || '--'}}</view>
      </view>
    </view>

    <view class="content-card animate-slide-up" style="animation-delay: 0.02s">
      <view class="card-title">评价内容</view>
      <t-textarea
        t-class="external-textarea"
        placeholder="至少10个字"
        maxlength="{{maxContentLength}}"
        disableDefaultPadding="{{true}}"
        indicator
        bordered
        value="{{content}}"
        bind:change="onContentChange"
      />
    </view>

    <view class="content-card animate-slide-up" style="animation-delay: 0.05s">
      <view class="card-title">添加图片 <text class="subtitle">(可选，最多9张)</text></view>
      <view class="upload-wrapper">
        <t-upload
          mediaType="{{['image']}}"
          files="{{fileList}}"
          gridConfig="{{ { column: 3, width: 180, height: 180 } }}"
          max="{{maxImages}}"
          bind:add="onAddImage"
          bind:remove="onRemoveImage"
        />
      </view>
    </view>
  </view>
</view>

<view class="bottom-submit-bar animate-slide-up" style="animation-delay: 0.3s">
  <t-button
    theme="primary"
    size="large"
    block
    disabled="{{submitting}}"
    loading="{{submitting}}"
    bindtap="onSubmit"
    shape="round"
  >
    发布评价
  </t-button>
  <view class="policy-tip">发布内容将经过系统安全审核</view>
</view>

<t-message id="t-message" />
