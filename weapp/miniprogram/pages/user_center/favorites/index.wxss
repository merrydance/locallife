@import '../../../styles/customer.wxss';

/* Pages User Center Favorites */
.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page, #f6f6f6);
}

.loading {
  padding: 60rpx;
  text-align: center;
}

.loading-more {
  padding: 24rpx;
  text-align: center;
}

/* List */
.favorite-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacer-md);
}

/* Card */
.favorite-card {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-lg);
  display: flex;
  padding: var(--spacer-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  overflow: hidden;
}

.card-hover {
  transform: scale(0.99);
  background: var(--td-bg-color-secondarycontainer);
}

.card-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  margin-right: var(--spacer-md);
  flex-shrink: 0;
  background-color: var(--td-bg-color-secondarycontainer);
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.header-tags {
  display: flex;
  align-items: center;
  gap: var(--spacer-xs);
  flex-shrink: 0;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.title {
  font-size: var(--font-size-heading);
  font-weight: bold;
  color: var(--td-text-color-primary);
  flex: 1;
  margin-right: var(--spacer-sm);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.status-note {
  margin-top: var(--spacer-xs);
  font-size: var(--font-size-xs);
  color: var(--td-error-color-6);
}

.sub-text {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.remove-btn {
  padding: var(--spacer-xs);
}

.info-row {
  margin-top: var(--spacer-xs);
}

.subtitle {
  font-size: var(--font-size-sm);
  color: var(--td-text-color-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--spacer-sm);
}

.rating-box {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-text {
  font-size: 24rpx;
  color: var(--td-warning-color);
  font-weight: bold;
}

.price {
  font-size: 32rpx;
  color: var(--td-brand-color); /* Often brand color red */
  font-weight: bold;
  font-family: 'DIN Alternate', sans-serif;
}

.date {
  font-size: var(--font-size-xxs);
  color: var(--td-text-color-placeholder);
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  width: 100%;
}

.empty-tips {
  font-size: var(--font-size-base);
  color: var(--td-text-color-secondary);
  margin-top: var(--spacer-md);
  margin-bottom: var(--spacer-xl);
  text-align: center;
}

.empty-btn {
  width: 240rpx;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.favorites-skeleton-list {
  padding: var(--spacer-md);
}

.skeleton-item {
  margin-bottom: var(--spacer-md);
}

.load-more-wrap {
  padding: 32rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--td-text-color-placeholder);
}
