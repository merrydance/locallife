<custom-navbar title="我的收藏" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container page-shell page-shell--with-nav page-shell--bottom-safe page-shell--page-gutter" style="--page-shell-nav-height: {{navBarHeight}}px; --page-shell-bottom-offset: 40rpx;">
  
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" sticky offset-top="{{navBarHeight}}">
    <t-tab-panel label="收藏菜品" value="dish" />
    <t-tab-panel label="收藏餐厅" value="merchant" />
  </t-tabs>

  <!-- 错误状态 -->
  <view wx:if="{{error && !initialLoading}}" class="error-container">
    <t-empty icon="info-circle" description="{{error}}">
      <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
    </t-empty>
  </view>

  <block wx:else>
    <!-- Loading (Skeleton) -->
    <view wx:if="{{initialLoading}}" class="favorites-skeleton-list">
      <list-skeleton row="5" t-class="skeleton-item" />
    </view>

    <!-- Empty State -->
    <view wx:elif="{{favorites.length === 0}}" class="empty-state animate-fade-in">
      <t-empty image="/assets/icons/empty.svg" description="暂无任何收藏" />
      <view class="empty-tips">去发现更多好吃的，收藏起来慢慢享用吧</view>
      <t-button theme="primary" size="medium" shape="round" bindtap="onGoHome" class="empty-btn">去逛逛</t-button>
    </view>

    <!-- List -->
    <view wx:else class="favorites-list animate-fade-in">
      <block wx:for="{{favorites}}" wx:key="id">
         <view class="favorite-card" bindtap="onItemClick" data-item="{{item}}">
            <t-image src="{{item.image}}" mode="aspectFill" width="160rpx" height="160rpx" class="card-img" />
            
            <view class="card-content">
               <view class="card-header">
                  <view class="title">{{item.title}}</view>
                <view class="header-tags">
                  <t-tag wx:if="{{item.isOrderingSuspended}}" size="small" variant="light" theme="danger">暂停接单</t-tag>
                  <t-tag size="small" variant="dark" theme="primary">{{item.typeText}}</t-tag>
                </view>
               </view>

               <view class="card-middle">
                   <view wx:if="{{item.type === 'dish'}}" class="price-row">
                      <text class="symbol">¥</text>
                      <text class="price">{{item.priceDisplay}}</text>
                   </view>
                   <view wx:else class="rating-row">
                      <t-rate value="{{item.rating}}" size="12" disabled count="{{5}}" gap="2" />
                      <text class="rating-text">{{item.rating}}分</text>
                   </view>
                   <view wx:if="{{item.isOrderingSuspended}}" class="status-note">当前商户暂停接单，恢复后可再次下单</view>
                   <view class="sub-text">{{item.subTitle}}</view>
               </view>

               <view class="card-footer">
                  <view class="date">收藏于 {{item.createdAt}}</view>
                  <view class="action-btn" catchtap="onRemoveFavorite" data-item="{{item}}">
                     <t-icon name="heart-filled" size="36rpx" color="#e34d59" />
                  </view>
               </view>
            </view>
         </view>
      </block>

      <view class="load-more-wrap" wx:if="{{loading}}">
        <t-loading theme="circular" size="32rpx" text="正在加载..." />
      </view>
    </view>
  </block>

</view>
