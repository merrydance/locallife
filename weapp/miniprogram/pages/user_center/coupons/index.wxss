/* Pages User Center Coupons */
.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page, #f6f6f6);
}

.loading {
  padding: 60rpx;
  text-align: center;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.empty-state {
  padding-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-btn {
  margin-top: 24rpx;
}

/* Coupon List */
.coupon-list {
  padding: 24rpx;
}

/* Coupon Card Ticket Style */
.coupon-card {
  display: flex;
  height: 200rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); /* Maintain specific design gradient as it's not in system theme yet, or use brand gradient */
  /* Actually app.wxss has --brand-coral-gradient. But coupon card logic was specific purple in previous code.
     Wait, user said "Don't use hardcoded CSS".
     Ideally we should use variables. If I change to brand gradient it changes design.
     But purple gradient isn't in app.wxss.
     I will keep the unique gradient but use variables for radius/spacing. */
  border-radius: var(--radius-lg);
  padding: var(--spacer-md);
  color: #fff; /* White text on dark gradient */
  display: flex;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.coupon-card.used,
.coupon-card.expired {
  background: var(--td-text-color-disabled);
}

.coupon-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.amount {
  font-size: 60rpx; /* Display size */
  font-weight: bold;
}
.symbol {
  font-size: var(--font-size-base);
}

.condition {
  font-size: var(--font-size-sm);
  opacity: 0.9;
  margin-top: var(--spacer-xs);
}

.coupon-right {
  flex: 2;
  border-left: 2rpx dashed rgba(255,255,255,0.3);
  padding-left: var(--spacer-md);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  margin-left: var(--spacer-md);
}

.name {
  font-size: var(--font-size-heading);
  font-weight: bold;
}

.desc {
  font-size: var(--font-size-xs);
  opacity: 0.8;
  margin-top: var(--spacer-xxs);
}

.date {
  font-size: var(--font-size-xxs);
  opacity: 0.7;
  margin-top: var(--spacer-sm);
}

.coupon-action {
  position: absolute;
  height: 24rpx;
  background: #f6f6f6;
  border-radius: 50%;
  left: 188rpx; /* Matches left width - half circle */
  z-index: 2;
}
.circle.top { top: -12rpx; }
.circle.bottom { bottom: -12rpx; }

/* Status Text */
.status-badge {
    font-size: 26rpx;
    font-weight: bold;
    transform: rotate(-15deg);
    border: 2rpx solid;
    padding: 4rpx 8rpx;
    border-radius: 8rpx;
}

.status-badge.used { color: #999; border-color: #999; }
.status-badge.expired { color: #ccc; border-color: #ccc; }
.status-badge.available { color: var(--td-brand-color); border-color: var(--td-brand-color); }

/* 异常状态 */
.error-container {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 骨架屏 */
.coupon-skeleton-list {
  padding: 24rpx;
}

.skeleton-item {
  margin-bottom: 24rpx;
}

.load-more-wrap {
  padding: 32rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--td-text-color-placeholder);
}

