<custom-navbar title="优惠券" showBack="{{true}}" bind:navheight="onNavHeight" />

<view class="page-container" style="padding-top: {{navBarHeight}}px; padding-bottom: calc(120rpx + env(safe-area-inset-bottom));">
  
  <!-- Tabs -->
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" sticky offset-top="{{navBarHeight}}">
    <t-tab-panel label="领券中心" value="AVAILABLE" />
    <t-tab-panel label="我的优惠券" value="MY" />
  </t-tabs>

  <!-- Loading -->
  <t-loading wx:if="{{loading && coupons.length === 0}}" theme="circular" size="40rpx" class="loading" text="加载中..." />

  <!-- Empty State -->
  <view wx:elif="{{coupons.length === 0}}" class="empty-state animate-fade-in">
    <t-empty image="/assets/icons/empty.svg" description="{{activeTab === 'AVAILABLE' ? '暂无可领取的优惠券' : '暂无优惠券'}}" />
    <t-button wx:if="{{activeTab === 'MY'}}" theme="primary" size="medium" shape="round" bindtap="onGoToCenter" class="empty-btn">去领券</t-button>
  </view>

  <!-- Coupon List -->
  <view wx:else class="coupon-list animate-fade-in">
    <block wx:for="{{coupons}}" wx:key="id">
       <view class="coupon-card {{item.statusClass}}">
          <!-- Left: Value -->
          <view class="coupon-left">
             <view class="price-box">
                <text class="symbol">¥</text>
                <text class="amount">{{item.valueDisplay}}</text>
             </view>
             <view class="condition">满{{item.minSpendDisplay}}可用</view>
          </view>

          <!-- Middle: Info -->
          <view class="coupon-middle">
             <view class="title">{{item.title}}</view>
             <view class="merchant">
                <t-icon name="shop" size="24rpx" color="#666" style="margin-right: 4rpx;" />
                <text>{{item.merchantName}}</text>
             </view>
             <view class="date">{{item.timeRange}}</view>
          </view>

          <!-- Right: Action -->
          <view class="coupon-right">
             <!-- Available Tab -->
             <t-button 
               wx:if="{{activeTab === 'AVAILABLE'}}" 
               size="small" 
               theme="{{item.isClaimed ? 'default' : 'primary'}}" 
               variant="{{item.isClaimed ? 'text' : 'base'}}"
               shape="round" 
               disabled="{{item.isClaimed}}" 
               bindtap="onClaim" 
               data-id="{{item.id}}"
             >
               {{item.isClaimed ? '已领取' : '立即领取'}}
             </t-button>

             <!-- My Tab -->
             <view wx:if="{{activeTab === 'MY'}}" class="status-badge {{item.status}}">
                <text>{{item.statusText}}</text>
             </view>
          </view>

          <!-- Decor: Circles -->
          <view class="circle top"></view>
          <view class="circle bottom"></view>
       </view>
    </block>
  </view>

</view>
