<custom-navbar title="我的" showLocation="{{false}}" bind:navheight="onNavHeight" />

<!-- 消息铃铛悬浮按钮 -->
<view
  class="notif-bell-float"
  style="top: calc({{navBarHeight}}px - 56rpx)"
  bindtap="onNotifTap"
>
  <t-icon name="notification" size="44rpx" color="#333" />
  <view wx:if="{{unreadCount > 0}}" class="notif-badge">
    {{unreadCount > 99 ? '99+' : unreadCount}}
  </view>
</view>



<!-- Skyline 需要用 scroll-view 实现页面滚动 -->
<scroll-view 
  scroll-y 
  class="page-scroll" 
  style="height: {{scrollViewHeight}}px; margin-top: {{navBarHeight}}px;"
  enhanced="{{true}}"
  show-scrollbar="{{false}}"
>
  <!-- 内容区域 - 与其他页面一致的结构 -->
  <view class="content-section">
    <!-- 异常状态 -->
    <view wx:if="{{error && !initialLoading}}" class="error-state">
      <t-empty icon="info-circle" description="{{error}}">
        <t-button slot="action" theme="primary" size="small" bindtap="onRetry" shape="round">重试</t-button>
      </t-empty>
    </view>

    <block wx:else>
      <!-- User Profile Card -->
      <view wx:if="{{initialLoading}}" class="user-card skeleton-breath">
        <view class="avatar-skeleton"></view>
        <view class="info-skeleton">
          <view class="line-skeleton title-line"></view>
          <view class="line-skeleton tag-line"></view>
        </view>
      </view>

      <view wx:else class="user-card">
        <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <auth-image wx:if="{{userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          <t-icon wx:else name="user" size="64rpx" color="var(--td-text-color-placeholder)" />
        </button>
        <view class="info-wrapper">
          <view class="nickname-row">
            <input type="nickname" class="nickname-input" placeholder="点击设置昵称" value="{{userInfo.nickName}}" bind:change="onNicknameChange" bind:blur="onNicknameChange" />
            <block wx:for="{{userRoles}}" wx:key="key">
              <t-tag theme="primary" variant="dark" size="small" shape="round" class="role-tag">
                {{item.label}}
              </t-tag>
            </block>
          </view>
        </view>
        <view class="scan-entry" bindtap="onScanToJoin" hover-class="scan-entry--active">
          <t-icon name="scan" size="44rpx" color="var(--td-text-color-primary)" />
        </view>
      </view>

      <!-- Workbenches (for registered roles) -->
      <view wx:if="{{workbenches.length > 0}}" class="card-section">
        <view class="card-title">商家及运营服务</view>
        <view class="card-body">
          <t-cell-group>
            <t-cell 
              wx:for="{{workbenches}}" 
              wx:key="id"
              title="{{item.name}}"
              arrow
              hover
              bind:click="onWorkbenchTap"
              data-path="{{item.path}}"
            >
              <t-image slot="left-icon" src="{{item.icon}}" t-class="workbench-icon" />
            </t-cell>
          </t-cell-group>
        </view>
      </view>

      <!-- Common Functions -->
      <view class="card-section">
        <view class="card-title">我的服务</view>
        <view class="card-body">
          <t-cell-group>
            <t-cell title="外卖订单" left-icon="view-list" arrow hover bind:click="onTakeoutOrders" />
            <t-cell title="我的预订" left-icon="calendar" arrow hover bind:click="onMyReservations" />
            <t-cell title="堂食订单" left-icon="root-list" arrow hover bind:click="onDineInOrders" />
            <t-cell title="地址管理" left-icon="location" arrow hover bind:click="onAddresses" />
            <t-cell title="优惠券" left-icon="coupon" arrow hover bind:click="onCoupons" />
            <t-cell title="收藏夹" left-icon="heart" arrow hover bind:click="onFavorites" />
            <t-cell title="会员中心" left-icon="user-vip" arrow hover bind:click="onMembership" />
            <t-cell title="我的评价" left-icon="chat-bubble" arrow hover bind:click="onMyReviews" />
            <t-cell title="钱包" left-icon="wallet" arrow hover bind:click="onWallet" />
            <t-cell title="联系客服" left-icon="service" arrow hover bind:click="onContact" />
            <t-cell title="协议中心" left-icon="info-circle" arrow hover bind:click="onAgreements" />
          </t-cell-group>
        </view>
      </view>

      <!-- Registration Options -->
      <view class="card-section">
        <view class="card-title">申请入驻</view>
        <view class="card-body">
          <t-cell-group>
            <t-cell 
              wx:for="{{registrationOptions}}" 
              wx:key="id"
              title="{{item.name}}"
              description="{{item.desc}}"
              left-icon="{{item.icon}}"
              arrow
              hover
              bind:click="onRegisterTap"
              data-id="{{item.id}}"
            />
          </t-cell-group>
        </view>
      </view>
    </block>
  </view>
</scroll-view>
