/* 用户中心 - 严格遵循 .github/standards/weapp/DESIGN_SYSTEM.md 规范 */

/* Skyline 滚动容器 */
.page-scroll {
  background: var(--td-bg-color-page);
  box-sizing: border-box;
}

/* 内容区域 */
.content-section {
  display: flex;
  flex-direction: column;
  padding: var(--spacer-sm) var(--spacer-md) calc(var(--spacer-lg) + var(--safe-area-bottom));
}

/* 基础卡片样式 */
.card-base {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* User Profile Card */
.user-card {
  background: var(--td-bg-color-container);
  padding: var(--spacer-md);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacer-md);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  box-shadow: var(--shadow-sm);
}

.avatar-wrapper {
  padding: 0;
  width: 112rpx !important;
  height: 112rpx !important;
  border-radius: var(--radius-round);
  margin: 0 var(--spacer-md) 0 0 !important;
  background-color: var(--td-bg-color-secondarycontainer);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-round);
  display: block;
}

.info-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 1;
  overflow: hidden;
}

.nickname-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
}

.nickname-input {
  font-size: var(--font-size-heading);
  font-weight: 600;
  color: var(--td-text-color-primary);
  text-align: left;
  height: 64rpx;
  min-height: 64rpx;
  width: auto;
  max-width: 300rpx;
  background: transparent;
  padding: 0;
  margin-right: var(--spacer-sm);
}

.role-tag {
  margin-right: 8rpx;
}

.scan-entry {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  background: var(--td-bg-color-container);
  border: 1rpx solid var(--td-border-level-1-color, #eee);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--spacer-sm);
  transition: all var(--transition-base);
}

.scan-entry:active {
  background: var(--td-bg-color-secondarycontainer);
  transform: scale(0.95);
}

/* 卡片区块 */
.card-section {
  margin-bottom: var(--spacer-md);
}

.card-title {
  padding: var(--spacer-sm) 0 var(--spacer-xs);
  font-size: var(--font-size-xs);
  color: var(--td-text-color-placeholder);
  font-weight: 500;
  letter-spacing: 2rpx;
}

.card-body {
  background: var(--td-bg-color-container);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

/* TDesign 覆盖样式 */
.t-grid {
  background-color: transparent !important;
}

.t-cell-group {
  background-color: transparent !important;
}

.workbench-icon {
  width: 44rpx !important;
  height: 44rpx !important;
  margin-right: 12rpx;
}

/* 骨架屏样式 */
.skeleton-breath {
  animation: bg-breath 1.5s infinite ease-in-out;
}

@keyframes bg-breath {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.avatar-skeleton {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-round);
  background: var(--td-bg-color-secondarycontainer);
  margin-right: var(--spacer-md);
}

.info-skeleton {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.line-skeleton {
  background: var(--td-bg-color-secondarycontainer);
  border-radius: var(--radius-xs);
  margin-bottom: var(--spacer-xs);
}

.title-line {
  width: 200rpx;
  height: 48rpx;
}

.tag-line {
  width: 120rpx;
  height: 32rpx;
}

/* 异常状态样式 */
.error-state {
  padding: 80rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* ========== Gap 4: 消息铃铛悬浮 ========== */
.notif-bell-float {
  position: fixed;
  right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notif-badge {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 32rpx;
  height: 32rpx;
  background: #E34D59;
  border-radius: 999rpx;
  border: 3rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #fff;
  padding: 0 6rpx;
  box-sizing: border-box;
}
