ENVIRONMENT=development

# Database (Unix Socket for local development)
DB_SOURCE=postgresql:///sam:John1818.@/locallife?host=/var/run/postgresql&sslmode=disable
MIGRATION_URL=file://db/migration
AUTO_MIGRATE=false

# HTTP Server
HTTP_SERVER_ADDRESS=0.0.0.0:8080

# 上传文件安全访问（签名URL）
# 建议设置为随机长字符串；不设置时将回退使用 TOKEN_SYMMETRIC_KEY
UPLOAD_URL_SIGNING_KEY=
# 签名URL有效期（例如 10m, 1h）
UPLOAD_URL_TTL=10m
# 前端错误上报共享密钥（可选；配置后 /v1/logs/error 需携带 X-Client-Log-Key）
CLIENT_LOG_SHARED_KEY=

# Token Authentication
TOKEN_SYMMETRIC_KEY=12345678901234567890123456789012
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h

# Web 登录扫码会话过期时间
WEB_LOGIN_SESSION_TTL=5m
# Web 登录二维码签名密钥（HMAC，建议随机长字符串）
WEB_LOGIN_QR_SIGNING_KEY=

# Redis (for async tasks like reservation timeout)
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_REQUIRED=false

# WebSocket reliable push rollout
WS_RELIABLE_ENABLED=true
WS_RELIABLE_PERCENT=100

# Rules engine
RULES_ENGINE_ENABLED=false

# Geofence (delivery location events)
GEOFENCE_RADIUS_M=80
GEOFENCE_DWELL_MIN_SECONDS=60
GEOFENCE_DWELL_MIN_SAMPLES=3
GEOFENCE_MIN_ACCURACY_M=80
GEOFENCE_AUTO_ADVANCE_ENABLED=false
GEOFENCE_AUTO_PICKUP_ENABLED=false
GEOFENCE_AUTO_DELIVER_ENABLED=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Web 前端地址（用于二维码/分享）
WEB_BASE_URL=http://localhost:3000

# WeChat Mini Program
WECHAT_MINI_APP_ID=wx1234567890abcdef
WECHAT_MINI_APP_SECRET=your_wechat_mini_app_secret

# WeChat Pay (微信支付 - 直连商户)
# 申请地址: https://pay.weixin.qq.com
WECHAT_PAY_MCH_ID=1234567890
WECHAT_PAY_SERIAL_NUMBER=your_certificate_serial_number
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_API_V3_KEY=your_32_character_apiv3_key_here
WECHAT_PAY_NOTIFY_URL=https://yourdomain.com/v1/webhooks/wechat-pay/notify
WECHAT_PAY_REFUND_NOTIFY_URL=https://yourdomain.com/v1/webhooks/wechat-pay/refund-notify
# 平台证书（已弃用，建议使用公钥）
WECHAT_PAY_PLATFORM_CERTIFICATE_PATH=./certs/wechatpay_platform_certificate.pem
# 平台公钥（推荐方式，从微信支付商户后台获取）
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=./certs/wechatpay_platform_public_key.pem
WECHAT_PAY_PLATFORM_PUBLIC_KEY_ID=PUB_KEY_ID_xxxxxxxxxxxxxx
WECHAT_PAY_HTTP_TIMEOUT=30s

# 数据加密（用于本地存储敏感信息如身份证号、银行卡号）
# 密钥长度必须为 16/24/32 字节（对应 AES-128/192/256）
DATA_ENCRYPTION_KEY=your_32_character_encryption_key

# WeChat Pay Ecommerce (微信支付 - 平台收付通)
# 用于商户入驻和分账，如不需要可留空
# WECHAT_ECOMMERCE_SP_MCHID=your_service_provider_mchid
# WECHAT_ECOMMERCE_SP_APPID=your_service_provider_appid

# QWeather API (和风天气)
QWEATHER_API_KEY=your_qweather_api_key
QWEATHER_API_HOST=https://devapi.qweather.com

# 地图服务
# 固定使用 tencent
LBS_PROVIDER=tencent
# 腾讯地图 WebService Key（运行时必填）
# 申请地址: https://lbs.qq.com
TENCENT_MAP_KEY=your_tencent_map_key
# 以下为历史兼容配置，运行时不再使用
OSM_BASE_URL=
OSM_BASE_URL_BACKUP=
TIANDITU_MAP_KEY=
TIANDITU_BASE_URL=https://api.tianditu.gov.cn

# 配送参数 (Magic Number 消除)
RIDER_AVERAGE_SPEED=15000
DEFAULT_PREPARE_TIME=20

# 分账回退重试策略
PROFIT_SHARING_RETURN_RETRY_INTERVAL=1m
PROFIT_SHARING_RETURN_MAX_RETRIES=10

# 预订取消退款策略（百分比）
RESERVATION_USER_REFUND_PERCENT_BEFORE_DEADLINE=100
RESERVATION_USER_REFUND_PERCENT_AFTER_DEADLINE=0
RESERVATION_MERCHANT_REFUND_PERCENT_BEFORE_DEADLINE=100
RESERVATION_MERCHANT_REFUND_PERCENT_AFTER_DEADLINE=100
