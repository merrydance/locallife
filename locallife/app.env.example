ENVIRONMENT=development

# Database (Unix Socket for local development)
DB_SOURCE=postgresql:///sam:John1818.@/locallife?host=/var/run/postgresql&sslmode=disable
MIGRATION_URL=file://db/migration
AUTO_MIGRATE=false

# HTTP Server
HTTP_SERVER_ADDRESS=0.0.0.0:8080

# 上传文件安全访问（签名URL）
# 建议设置为随机长字符串；不设置时将回退使用 TOKEN_SYMMETRIC_KEY
UPLOAD_URL_SIGNING_KEY=
# 签名URL有效期（例如 10m, 1h）
UPLOAD_URL_TTL=10m

# Token Authentication
TOKEN_SYMMETRIC_KEY=12345678901234567890123456789012
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h

# Web 登录扫码会话过期时间
WEB_LOGIN_SESSION_TTL=5m
# Web 登录二维码签名密钥（HMAC，建议随机长字符串）
WEB_LOGIN_QR_SIGNING_KEY=

# Redis (for async tasks like reservation timeout)
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_REQUIRED=false

# WebSocket reliable push rollout
WS_RELIABLE_ENABLED=true
WS_RELIABLE_PERCENT=100

# Rules engine
RULES_ENGINE_ENABLED=false
CLAIM_FINAL_ADJUDICATOR_ENABLED=false

# Geofence (delivery location events)
GEOFENCE_RADIUS_M=80
GEOFENCE_DWELL_MIN_SECONDS=60
GEOFENCE_DWELL_MIN_SAMPLES=3
GEOFENCE_MIN_ACCURACY_M=80
GEOFENCE_AUTO_ADVANCE_ENABLED=false
GEOFENCE_AUTO_PICKUP_ENABLED=false
GEOFENCE_AUTO_DELIVER_ENABLED=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 文件上传
# 删除文件时使用的本地基础路径，用于将相对路径拼接成绝对路径
# 示例: /var/app/uploads  留空则使用相对路径（不推荐生产使用）
UPLOADS_BASE_DIR=

# 媒体存储配置
# FILE_STORAGE_PROVIDER=local  → 开发环境：后端自身接收文件，存入 ./uploads/dev/，无需任何云服务
# FILE_STORAGE_PROVIDER=oss    → 生产/测试环境：阿里云 OSS 直传，客户端通过 POST Policy 直传，应用服务器不接收图片流
FILE_STORAGE_PROVIDER=local

# 阿里云 OSS（FILE_STORAGE_PROVIDER=oss 时必填，local 模式下留空即可）
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_PUBLIC_BUCKET=your-media-public-bucket
OSS_PRIVATE_BUCKET=your-media-private-bucket
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_REGION=cn-beijing                  # v2 SDK V4 签名必填，与 OSS_ENDPOINT 地域一致

# CDN 公共图访问域名（FILE_STORAGE_PROVIDER=oss 时必填）
# local 模式下此配置无效，公共图片通过 dev-only 的 /dev/uploads/ 路径访问
CDN_PUBLIC_BASE_URL=https://cdn.example.com

# 阿里云 OCR（统一 OCR 主 provider）
# 当前版本生产建议使用“专用 RAM 用户最小权限 AK/SK”。
# STS 配置位已预留，但运行时尚未实现，不应在当前版本开启 ALIYUN_OCR_STS_ENABLED=true。
ALIYUN_OCR_ENABLED=false
ALIYUN_OCR_ENDPOINT=https://ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_OCR_REGION=cn-hangzhou
ALIYUN_OCR_ACCESS_KEY_ID=your_aliyun_ocr_access_key_id
ALIYUN_OCR_ACCESS_KEY_SECRET=your_aliyun_ocr_access_key_secret
ALIYUN_OCR_STS_ENABLED=false
ALIYUN_OCR_ROLE_ARN=
ALIYUN_OCR_ROLE_SESSION_NAME=locallife-ocr
ALIYUN_OCR_ROLE_EXTERNAL_ID=
ALIYUN_OCR_HTTP_TIMEOUT=30s

# 媒体访问与上传参数
PRIVATE_DOWNLOAD_URL_TTL=5m        # 私有图签名URL有效期
MEDIA_MAX_UPLOAD_BYTES=10485760    # 单文件最大字节数（10MB）
MEDIA_DIRECT_UPLOAD_EXPIRE=15m     # 直传凭证有效期（OSS POST Policy 过期时间）

# 图片规格宽度（px），对应 OSS 图片处理样式参数
IMAGE_VARIANT_THUMB_WIDTH=200      # 缩略图，用于列表页、头像
IMAGE_VARIANT_CARD_WIDTH=400       # 卡片图，用于商品卡片、搜索结果
IMAGE_VARIANT_DETAIL_WIDTH=960     # 详情图，用于详情页主图

# 数据库连接池（高并发场景可按需调整）
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m

# Web 前端地址（用于二维码/分享）
WEB_BASE_URL=http://localhost:3000

# 飞鹅云打印（平台统一账号）
FEIEYUN_ENABLED=false
FEIEYUN_API_BASE_URL=https://api.feieyun.cn
FEIEYUN_USER=
FEIEYUN_UKEY=
FEIEYUN_HTTP_TIMEOUT=5s
# 打印结果回调。回调公钥用于验证飞鹅云回调 sign，不是证书/域名验证文件。
FEIEYUN_PRINT_CALLBACK_URL=https://yourdomain.com/v1/webhooks/feieyun/print-result
FEIEYUN_CALLBACK_PUBLIC_KEY_PEM=
FEIEYUN_CALLBACK_PUBLIC_KEY_PATH=

# 云打印多厂商配置基础。默认禁用；后端 provider runtime 接入并完成真实设备验证前不要在生产开启。
YILIANYUN_ENABLED=false
YILIANYUN_API_BASE_URL=https://open-api.10ss.net/v2
YILIANYUN_CUSTOMER_ID=
YILIANYUN_APP_ID=
YILIANYUN_APP_SECRET=
# 开放型应用通过 OAuth 回调 code 或机器码+终端密钥/临时密钥换取每台打印机自己的 token，并由后端加密入库；不要在 env 中配置全局 token。
YILIANYUN_HTTP_TIMEOUT=5s
# 仅 OAuth 授权码跳转流程需要；小程序机器码+终端密钥绑定不需要配置该项。
YILIANYUN_AUTH_CALLBACK_URL=https://yourdomain.com/v1/merchant/devices/yilianyun/auth/callback
YILIANYUN_PRINT_CALLBACK_URL=https://yourdomain.com/v1/webhooks/yilianyun/print-result
YILIANYUN_PRINT_CALLBACK_FRESHNESS_WINDOW=10m
SHANGPENG_ENABLED=false
SHANGPENG_API_BASE_URL=https://open.spyun.net
SHANGPENG_APPID=
SHANGPENG_APPSECRET=
SHANGPENG_HTTP_TIMEOUT=5s
CLOUD_PRINTER_FAIL_ON_PROVIDER_CONFIG_ERROR=false
CLOUD_PRINTER_STATUS_POLL_INTERVAL=1m
CLOUD_PRINTER_STATUS_POLL_BATCH_SIZE=50
CLOUD_PRINTER_STATUS_POLL_INITIAL_DELAY=30s
CLOUD_PRINTER_STATUS_POLL_MAX_AGE=12h

# WeChat Mini Program
WECHAT_MINI_APP_ID=wx1234567890abcdef
WECHAT_MINI_APP_SECRET=your_wechat_mini_app_secret
# 小程序消息推送 token，用于微信异步图审回调验签
WECHAT_MINI_APP_MESSAGE_TOKEN=your_wechat_mini_program_message_token

# WeChat Pay (微信支付 - 直连商户)
# 申请地址: https://pay.weixin.qq.com
WECHAT_PAY_MCH_ID=1234567890
WECHAT_PAY_SERIAL_NUMBER=your_certificate_serial_number
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_API_V3_KEY=your_32_character_apiv3_key_here
WECHAT_PAY_NOTIFY_URL=https://yourdomain.com/v1/webhooks/wechat-pay/notify
WECHAT_PAY_REFUND_NOTIFY_URL=https://yourdomain.com/v1/webhooks/wechat-pay/refund-notify
WECHAT_PAY_MERCHANT_TRANSFER_NOTIFY_URL=https://yourdomain.com/v1/webhooks/wechat-pay/merchant-transfer-notify
# 平台公钥（必填，从微信支付商户后台获取）
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=./certs/wechatpay_platform_public_key.pem
WECHAT_PAY_PLATFORM_PUBLIC_KEY_ID=PUB_KEY_ID_xxxxxxxxxxxxxx
WECHAT_PAY_HTTP_TIMEOUT=30s

# 数据加密（用于本地存储敏感信息如身份证号、银行卡号）
# 密钥长度必须为 16/24/32 字节（对应 AES-128/192/256）
DATA_ENCRYPTION_KEY=your_32_character_encryption_key

# Baofoo BaoCaiTong (宝付/宝财通)
# 主业务支付切到宝付聚合支付时开启；开户/分账/提现能力也复用这组运行时配置。
BAOFU_MAIN_BUSINESS_ENABLED=false
BAOFU_ENVIRONMENT=sandbox
BAOFU_ACCOUNT_GATEWAY_BASE_URL=
BAOFU_AGGREGATE_PAY_BASE_URL=
BAOFU_AGGREGATE_PAY_BACKUP_BASE_URL=
BAOFU_MERCHANT_REPORT_BASE_URL=
BAOFU_COLLECT_MERCHANT_ID=
BAOFU_COLLECT_TERMINAL_ID=
BAOFU_PAYOUT_MERCHANT_ID=
BAOFU_PAYOUT_TERMINAL_ID=
BAOFU_APP_ID=
BAOFU_PRIVATE_KEY_PATH=./certs/baofu_private.pem
BAOFU_PUBLIC_KEY_PATH=./certs/baofu_public.pem
BAOFU_SIGN_SERIAL_NO=
BAOFU_ENCRYPTION_SERIAL_NO=
BAOFU_NOTIFY_BASE_URL=https://yourdomain.com/v1/webhooks/baofu
BAOFU_PAYMENT_NOTIFY_URL=https://yourdomain.com/v1/webhooks/baofu/payment
BAOFU_PROFIT_SHARING_NOTIFY_URL=https://yourdomain.com/v1/webhooks/baofu/share
BAOFU_REFUND_NOTIFY_URL=https://yourdomain.com/v1/webhooks/baofu/refund
BAOFU_HTTP_TIMEOUT=30s
# 骑手/运营商开户前微信直连核验费，单位：分。商户/平台由平台承担同金额宝付开户核验成本。
BAOFU_ACCOUNT_VERIFY_FEE_FEN=200
# 宝财通机构开户公司所属行业，当前统一为“零售B2C”。
BAOFU_BUSINESS_INDUSTRY_ID=9931
# 宝付微信商户报备参数。注意：758-2 是微信报备经营类目，不是宝财通开户行业。
BAOFU_MERCHANT_REPORT_CHANNEL_ID=148717784
BAOFU_MERCHANT_REPORT_CHANNEL_NAME=宝财通收单商户有限公司
BAOFU_MERCHANT_REPORT_BUSINESS=758-2

# QWeather API (和风天气)
QWEATHER_API_KEY=your_qweather_api_key
QWEATHER_API_HOST=https://devapi.qweather.com

# 地图服务
# 固定使用 tencent
LBS_PROVIDER=tencent
# 腾讯地图 WebService Key（运行时必填）
# 申请地址: https://lbs.qq.com
TENCENT_MAP_KEY=your_tencent_map_key
# 以下为历史兼容配置，运行时不再使用
OSM_BASE_URL=
OSM_BASE_URL_BACKUP=
TIANDITU_MAP_KEY=
TIANDITU_BASE_URL=https://api.tianditu.gov.cn

# 代取参数 (Magic Number 消除)
RIDER_AVERAGE_SPEED=15000
DEFAULT_PREPARE_TIME=20

# 分账回退重试策略
PROFIT_SHARING_RETURN_RETRY_INTERVAL=1m
PROFIT_SHARING_RETURN_MAX_RETRIES=10

# 预订取消退款策略（百分比）
RESERVATION_USER_REFUND_PERCENT_BEFORE_DEADLINE=100
RESERVATION_USER_REFUND_PERCENT_AFTER_DEADLINE=0
RESERVATION_MERCHANT_REFUND_PERCENT_BEFORE_DEADLINE=100
RESERVATION_MERCHANT_REFUND_PERCENT_AFTER_DEADLINE=100

# JPush 极光推送（后端调用推送 API）
JPUSH_APP_KEY=your_jpush_app_key
JPUSH_MASTER_SECRET=your_jpush_master_secret
